  // Open VLAN detail tab
  const openVlanTab = async (subnet) => {
    const tab = window.open("", "_blank");
    if (!tab) return;
    tab.document.write(`<html><head><title>Loading VLAN ${subnet.vlan}...</title></head><body style="background:#0f0a1e;color:#e2e8f0;font-family:Arial,sans-serif;padding:30px;text-align:center"><p style="margin-top:80px;font-size:18px;">&#9203; Loading IP addresses for ${subnet.address_cidr}...</p></body></html>`);
    tab.document.close();
    try {
      const d = await fetchIPAMSubnetIPs(subnet.subnet_id);
      const ips = d?.ips || [];
      const sm  = d?.summary || {};
      const si  = d?.subnet_info || subnet;
      const ts  = new Date().toLocaleString();

      const statusColor  = (c) => c===1?"#ef4444":c===2?"#10b981":c===4?"#f59e0b":c===8?"#3b82f6":"#64748b";
      const statusBg     = (c) => c===1?"#ef444418":c===2?"#10b98118":c===4?"#f59e0b18":c===8?"#3b82f618":"#64748b18";
      const statusLabel  = (c) => c===1?"Used":c===2?"Free":c===4?"Reserved":c===8?"Transient":"Unknown";
      const pct = sm.percent_used||0;
      const barClr = pct>=80?"#ef4444":pct>=50?"#f59e0b":"#10b981";

      const rows = ips.map((ip,i) => `
        <tr style="background:${i%2===0?"#1a1035":"#130d28"}">
          <td style="padding:7px 12px;font-family:monospace;font-weight:600;color:#e2e8f0;font-size:13px">${ip.ip}</td>
          <td style="padding:7px 12px">
            <span style="padding:2px 9px;border-radius:5px;font-size:11px;font-weight:700;
              background:${statusBg(ip.status_code)};color:${statusColor(ip.status_code)};border:1px solid ${statusColor(ip.status_code)}44">
              ${statusLabel(ip.status_code)}
            </span>
          </td>
          <td style="padding:7px 12px;font-size:12px;color:#94a3b8">${ip.hostname||"&mdash;"}</td>
          <td style="padding:7px 12px;font-family:monospace;font-size:11px;color:#64748b">${ip.mac||"&mdash;"}</td>
          <td style="padding:7px 12px;font-size:11px;color:#64748b;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${ip.description||""} ${ip.comments||""}">${ (ip.description||ip.comments||"&mdash;").substring(0,60)+(( ip.description||ip.comments||" ").length>60?"...":"") }</td>
          <td style="padding:7px 12px;font-size:11px;color:#475569">${ip.last_sync||"&mdash;"}</td>
        </tr>`).join("");

      const html = `<!DOCTYPE html>
<html><head><meta charset="UTF-8">
<title>IPAM — VLAN ${si.vlan||"?"} | ${si.address_cidr||""}</title>
<style>
  @media print { .no-print{display:none} body{background:#fff!important;color:#000!important} 
    .card{background:#f8f8f8!important;border:1px solid #ddd!important}
    tr{background:#fff!important} td,th{color:#000!important}
    .kpi-val{color:#000!important} .chip{border:1px solid #999!important}
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #0f0a1e; color: #e2e8f0; font-family: 'Segoe UI', Arial, sans-serif; }
  .header { background: linear-gradient(135deg,#12082a,#1e0a3c); padding: 16px 28px;
    border-bottom: 2px solid #7c3aed44; display:flex; align-items:center; gap:18px; }
  .header img { height: 48px; }
  .header-info { flex:1; }
  .header h1 { font-size: 20px; font-weight: 800; color: #e2e8f0; }
  .header p  { font-size: 12px; color: #94a3b8; margin-top: 3px; }
  .content { padding: 20px 28px; }
  .kpis { display: grid; grid-template-columns: repeat(auto-fit,minmax(120px,1fr)); gap:10px; margin-bottom:18px; }
  .kpi  { background:#1a1035; border:1px solid #2d1b69; border-radius:10px; padding:12px 14px; }
  .kpi-label { font-size:10px; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:.5px; }
  .kpi-val   { font-size:22px; font-weight:800; margin-top:4px; }
  .bar-wrap  { background:#1a1035; border:1px solid #2d1b69; border-radius:10px; padding:14px 18px; margin-bottom:18px; }
  .bar-track { background:#0f0a1e; border-radius:4px; height:10px; overflow:hidden; margin-top:6px; }
  .bar-fill  { height:100%; border-radius:4px; transition:width .5s; }
  table { width:100%; border-collapse:collapse; }
  th { padding:9px 12px; text-align:left; font-size:11px; font-weight:700; color:#64748b;
    border-bottom:2px solid #2d1b69; text-transform:uppercase; letter-spacing:.4px; background:#12082a; }
  td { border-bottom:1px solid #2d1b69; vertical-align:middle; }
  .tbl-wrap { background:#130d28; border:1px solid #2d1b69; border-radius:10px; overflow:hidden; }
  .print-btn { background:linear-gradient(135deg,#7c3aed,#06b6d4); color:#fff; border:none;
    padding:10px 22px; border-radius:8px; font-size:14px; font-weight:700; cursor:pointer; }
  .print-btn:hover { opacity:.9; }
  .chip { padding:2px 8px; border-radius:5px; font-size:10px; font-weight:700; }
  .footer { text-align:center; color:#475569; font-size:11px; padding:18px; border-top:1px solid #2d1b69; margin-top:18px; }
</style>
</head><body>
<div class="header">
  <img src="/wings.png" alt="Wipro Wings" onerror="this.style.display='none'">
  <div class="header-info">
    <h1>&#128225; IPAM — VLAN ${si.vlan||"?"} &nbsp; <span style="font-size:15px;font-weight:400;color:#94a3b8">${si.address_cidr||""}</span></h1>
    <p>${si.name||""} &bull; ${si.location||""} &bull; ${si.status||""}</p>
  </div>
  <button class="print-btn no-print" onclick="window.print()">&#128424; Export / Print PDF</button>
</div>

<div class="content">
  <div class="kpis">
    <div class="kpi"><div class="kpi-label">Total IPs</div><div class="kpi-val" style="color:#7c3aed">${sm.total||0}</div></div>
    <div class="kpi"><div class="kpi-label">Used</div><div class="kpi-val" style="color:#ef4444">${sm.used||0}</div></div>
    <div class="kpi"><div class="kpi-label">Free</div><div class="kpi-val" style="color:#10b981">${sm.free||0}</div></div>
    <div class="kpi"><div class="kpi-label">Reserved</div><div class="kpi-val" style="color:#f59e0b">${sm.reserved||0}</div></div>
    <div class="kpi"><div class="kpi-label">Transient</div><div class="kpi-val" style="color:#3b82f6">${sm.transient||0}</div></div>
    <div class="kpi"><div class="kpi-label">% Used</div><div class="kpi-val" style="color:${barClr}">${pct.toFixed(1)}%</div></div>
  </div>

  <div class="bar-wrap">
    <div style="display:flex;justify-content:space-between;font-size:12px;color:#94a3b8">
      <span>IP Utilization</span><span style="font-weight:700;color:${barClr}">${pct.toFixed(1)}% Used</span>
    </div>
    <div class="bar-track"><div class="bar-fill" style="width:${Math.min(pct,100)}%;background:${barClr}"></div></div>
    <div style="display:flex;gap:16px;margin-top:8px;font-size:11px;color:#64748b">
      <span style="color:#ef4444">&bull; Used: ${sm.used||0}</span>
      <span style="color:#10b981">&bull; Free: ${sm.free||0}</span>
      <span style="color:#f59e0b">&bull; Reserved: ${sm.reserved||0}</span>
      <span style="color:#3b82f6">&bull; Transient: ${sm.transient||0}</span>
    </div>
  </div>

  <div class="tbl-wrap">
    <table>
      <thead><tr>
        <th>IP Address</th><th>Status</th><th>Hostname / DNS</th>
        <th>MAC Address</th><th>Description</th><th>Last Sync</th>
      </tr></thead>
      <tbody>${rows||"<tr><td colspan=6 style='padding:24px;text-align:center;color:#475569'>No IP data</td></tr>"}</tbody>
    </table>
  </div>

  <div class="footer">
    ${si.name||si.address_cidr||""} &nbsp;|&nbsp; SolarWinds IPAM &nbsp;|&nbsp; Wipro Confidential &nbsp;|&nbsp; ${ts}
  </div>
</div>
</body></html>`;

      tab.document.open();
      tab.document.write(html);
      tab.document.close();
    } catch(e) {
      tab.document.open();
      tab.document.write(`<html><body style="background:#0f0a1e;color:#ef4444;padding:40px;font-family:Arial">
        <h2>Error loading IPAM data</h2><p>${e.message}</p></body></html>`);
      tab.document.close();
    }
  };

  if (loading) return (
    <div style={{display:"flex",alignItems:"center",justifyContent:"center",height:200,color:p.textMute,flexDirection:"column",gap:12}}>
      <div style={{width:32,height:32,border:`3px solid ${p.accent}`,borderTopColor:"transparent",borderRadius:"50%",animation:"spin 1s linear infinite"}}/>
      <span>Loading IPAM data…</span>
    </div>
  );

  const subnets  = data?.subnets  || [];
  const summary  = data?.summary  || {};
  const cachedAt = data?.cached_at ? new Date(data.cached_at * 1000).toLocaleTimeString() : "—";

        {canManage && (
          <button onClick={()=>{ setSubnetForm({vlan:"",address_cidr:"",name:"",location:"",comments:"",status:"Up"}); setAddModal(true); setEditEntry(null); }}
            style={{padding:"7px 14px",borderRadius:8,border:"none",background:"linear-gradient(135deg,#10b981,#059669)",color:"#fff",fontWeight:600,fontSize:13,cursor:"pointer"}}>
            + Add Subnet
          </button>
        )}
  const qL = q.toLowerCase();
  const filtered = subnets.filter(s => {
    const matchQ = !qL || [s.vlan, s.address_cidr, s.name, s.location, s.comments]
      .some(x => (x||"").toLowerCase().includes(qL));
    const matchS = statusF === "all" || (s.status||"").toLowerCase() === statusF;
    return matchQ && matchS;
  });

  const sorted = [...filtered].sort((a, b) => {
    let av = a[sortKey] ?? "", bv = b[sortKey] ?? "";
    if (typeof av === "string") av = av.toLowerCase();
    if (typeof bv === "string") bv = bv.toLowerCase();
    if (av < bv) return sortDir === "asc" ? -1 :  1;
    if (av > bv) return sortDir === "asc" ?  1 : -1;
    return 0;
  });

  const toggleSort = (key) => {
    if (sortKey === key) setSortDir(d => d === "asc" ? "desc" : "asc");
    else { setSortKey(key); setSortDir("asc"); }
  };
  const sortIcon = (key) => sortKey !== key ? " ⇅" : sortDir === "asc" ? " ↑" : " ↓";
  const barColor = (pct) => pct >= 80 ? "#ef4444" : pct >= 50 ? "#f59e0b" : "#10b981";

  const thS = (key) => ({
    padding:"8px 10px", textAlign:"left", fontWeight:600, fontSize:11,
    color:p.textMute, borderBottom:`1px solid ${p.border}`,
    cursor:"pointer", whiteSpace:"nowrap", userSelect:"none",
    background: sortKey===key ? `${p.accent}22` : "transparent",
  });
  const tdS = { padding:"7px 10px", fontSize:13, borderBottom:`1px solid ${p.border}`, verticalAlign:"middle" };

  return (
    <div style={{padding:"0 0 32px"}}>
      {/* Header */}
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:16,flexWrap:"wrap",gap:8}}>
        <div>
          <div style={{fontWeight:700,fontSize:20,color:p.text}}>📡 IPAM — IP Address Management</div>
          <div style={{fontSize:12,color:p.textMute,marginTop:2}}>SolarWinds IPAM · {subnets.length} subnets · last updated {cachedAt}</div>
          {(error||data?.error) && <div style={{fontSize:12,color:"#f59e0b",marginTop:3}}>⚠️ {error||data?.error}</div>}
        </div>
        {canManage && (
          <button onClick={()=>{ setSubnetForm({vlan:"",address_cidr:"",name:"",location:"",comments:"",status:"Up"}); setAddModal(true); setEditEntry(null); }}
            style={{padding:"7px 14px",borderRadius:8,border:"none",background:"linear-gradient(135deg,#10b981,#059669)",color:"#fff",fontWeight:600,fontSize:13,cursor:"pointer"}}>
            + Add Subnet
          </button>
        )}
        {canRefresh && (
          <button onClick={handleRefresh} disabled={refreshing}
                {canManage&&<th style={{padding:"8px 10px",fontSize:11,color:p.textMute,borderBottom:`1px solid ${p.border}`}}>ACTIONS</th>}
            style={{padding:"7px 14px",borderRadius:8,border:"none",
              background:refreshing?p.border:`linear-gradient(135deg,${p.accent},${p.cyan})`,
              color:refreshing?p.textMute:"#fff",fontWeight:600,fontSize:13,cursor:refreshing?"not-allowed":"pointer"}}>
            {refreshing ? "⏳ Refreshing…" : "🔄 Refresh"}
          </button>
        )}
      </div>

      {/* KPI Cards */}
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(140px,1fr))",gap:12,marginBottom:20}}>
        {[
          {label:"Total Subnets", value:summary.total_subnets||0,                          icon:"📡", color:p.accent},
          {label:"Total IPs",     value:(summary.total_ips||0).toLocaleString(),            icon:"🔢", color:p.cyan},
          {label:"Used IPs",      value:(summary.used_ips||0).toLocaleString(),             icon:"🔴", color:"#ef4444"},
          {label:"Available IPs", value:(summary.available_ips||0).toLocaleString(),        icon:"🟢", color:"#10b981"},
          {label:"Reserved",      value:(summary.reserved_ips||0).toLocaleString(),         icon:"🔒", color:"#f59e0b"},
          {label:"Overall Used",  value:`${summary.percent_used||0}%`,                      icon:"📊", color:barColor(summary.percent_used||0)},
        ].map(k=>(
          <div key={k.label} style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:10,padding:"12px 14px",display:"flex",flexDirection:"column",gap:4}}>
            <div style={{fontSize:11,color:p.textMute,fontWeight:600,letterSpacing:".4px",textTransform:"uppercase"}}>{k.icon} {k.label}</div>
            <div style={{fontSize:22,fontWeight:800,color:k.color}}>{k.value}</div>
          </div>
        ))}
      </div>

      {/* Filters */}
      <div style={{display:"flex",gap:8,marginBottom:14,flexWrap:"wrap",alignItems:"center"}}>
        <input value={q} onChange={e=>setQ(e.target.value)} placeholder="🔍 Search VLAN, subnet, name, location…"
          style={{flex:1,minWidth:240,padding:"7px 11px",borderRadius:8,border:`1px solid ${p.border}`,
            background:p.panel,color:p.text,fontSize:13,outline:"none"}}/>
        <select value={statusF} onChange={e=>setStatusF(e.target.value)}
          style={{padding:"7px 11px",borderRadius:8,border:`1px solid ${p.border}`,background:p.panel,color:p.text,fontSize:13}}>
          <option value="all">All Status</option>
          <option value="up">Up</option>
          <option value="down">Down</option>
        </select>
        <span style={{fontSize:12,color:p.textMute,whiteSpace:"nowrap"}}>{sorted.length} of {subnets.length} subnets</span>
      </div>

      {/* Table */}
      <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,overflow:"hidden"}}>
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse"}}>
            <thead>
              <tr style={{background:p.bg}}>
                <th style={thS("vlan")}          onClick={()=>toggleSort("vlan")}>VLAN{sortIcon("vlan")}</th>
                <th style={thS("address_cidr")}  onClick={()=>toggleSort("address_cidr")}>Subnet / CIDR{sortIcon("address_cidr")}</th>
                <th style={thS("name")}           onClick={()=>toggleSort("name")}>Name{sortIcon("name")}</th>
                <th style={thS("location")}       onClick={()=>toggleSort("location")}>Location{sortIcon("location")}</th>
                <th style
                    {canManage&&<td style={{...tdS,whiteSpace:"nowrap"}}>
                      {s.is_manual?(
                        <div style={{display:"flex",gap:5}}>
                          <button onClick={()=>{ setEditEntry(s); setSubnetForm({vlan:s.vlan||"",address_cidr:s.address_cidr||"",name:s.name||"",location:s.location||"",comments:s.comments||"",status:s.status||"Up"}); setAddModal(true); }}
                            style={{padding:"2px 8px",borderRadius:5,fontSize:11,fontWeight:600,background:`${p.accent}15`,border:`1px solid ${p.accent}40`,color:p.accent,cursor:"pointer"}}>✏️ Edit</button>
                          <button onClick={()=>handleDeleteSubnet(s)}
                            style={{padding:"2px 8px",borderRadius:5,fontSize:11,fontWeight:600,background:"#ef444415",border:"1px solid #ef444440",color:"#ef4444",cursor:"pointer"}}>🗑 Del</button>
                        </div>
                      ):(
                        <span style={{fontSize:10,color:p.textMute}}>SolarWinds</span>
                      )}
                    </td>}={{...thS("total"),   textAlign:"right"}} onClick={()=>toggleSort("total")}>Total{sortIcon("total")}</th>
                <th style={{...thS("used"),    textAlign:"right"}} onClick={()=>toggleSort("used")}>Used{sortIcon("used")}</th>
                <th style={{...thS("available"),textAlign:"right"}} onClick={()=>toggleSort("available")}>Free{sortIcon("available")}</th>
                <th style={{...thS("reserved"),textAlign:"right"}} onClick={()=>toggleSort("reserved")}>Reserved{sortIcon("reserved")}</th>
                <th style={{...thS("percent_used"),minWidth:140}}  onClick={()=>toggleSort("percent_used")}>% Used{sortIcon("percent_used")}</th>
                <th style={thS("status")}         onClick={()=>toggleSort("status")}>Status{sortIcon("status")}</th>
              </tr>
            </thead>
            <tbody>
              {sorted.length===0 && (
                <tr><td colSpan={10} style={{...tdS,textAlign:"center",color:p.textMute,padding:"32px"}}>No subnets match the filter</td></tr>
              )}
              {sorted.map((s,i)=>{
                const pct = s.percent_used||0;
                const bc  = barColor(pct);
                return (
                  <tr key={s.subnet_id}
                    style={{background:i%2===0?"transparent":p.bg+"88",transition:"background .15s"}}
                    onMouseEnter={e=>e.currentTarget.style.background=p.accent+"18"}
                    onMouseLeave={e=>e.currentTarget.style.background=i%2===0?"transparent":p.bg+"88"}>
                    <td style={tdS}>
                      <span
                        onClick={s.vlan ? ()=>openVlanTab(s) : undefined}
                        title={s.vlan ? `Click to view all IPs in ${s.address_cidr}` : undefined}
                        style={{padding:"2px 7px",borderRadius:5,background:`${p.cyan}22`,color:p.cyan,fontWeight:700,fontSize:12,fontFamily:"monospace",
                          cursor:s.vlan?"pointer":"default",
                          textDecoration:s.vlan?"underline":"none",
                          textUnderlineOffset:3}}>
                        {s.vlan||"—"}
                      </span>
                    </td>
                    <td style={{...tdS,fontFamily:"monospace",fontWeight:600,color:p.text}}>{s.address_cidr||"—"}</td>
                    <td style={{...tdS,color:p.textMute,maxWidth:200}}>
                      <span title={s.comments||s.description||""} style={{display:"block",overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>
                        {s.name||"—"}
                      </span>
                    </td>
                    <td style={{...tdS,color:p.textMute,whiteSpace:"nowrap"}}>{s.location||"—"}</td>
                    <td style={{...tdS,textAlign:"right",fontWeight:600}}>{(s.total||0).toLocaleString()}</td>
                    <td style={{...tdS,textAlign:"right",color:"#ef4444",fontWeight:600}}>{(s.used||0).toLocaleString()}</td>
                    <td style={{...tdS,textAlign:"right",color:"#10b981",fontWeight:700}}>{(s.available||0).toLocaleString()}</td>
                    <td style={{...tdS,textAlign:"right",color:"#f59e0b"}}>{(s.reserved||0).toLocaleString()}</td>
                    <td style={tdS}>
                      <div style={{display:"flex",alignItems:"center",gap:6}}>
                        <div style={{flex:1,height:8,borderRadius:4,background:p.border,overflow:"hidden",minWidth:70}}>
                          <div style={{width:`${Math.min(pct,100)}%`,height:"100%",borderRadius:4,background:bc,transition:"width .4s"}}/>
                        </div>
                        <span style={{fontSize:12,fontWeight:700,color:bc,minWidth:38,textAlign:"right"}}>{pct.toFixed(1)}%</span>
                      </div>
                    </td>
                    <td style={tdS}>
                      <span style={{padding:"2px 8px",borderRadius:5,fontSize:11,fontWeight:600,
                        background:(s.status||"")==="Up"?"#10b98122":"#ef444422",
                        color:(s.status||"")==="Up"?"#10b981":"#ef4444"}}>
                        {s.status||"Unknown"}
                      </span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      {/* Subnet message */}
      {subnetMsg&&<div style={{padding:"10px 14px",borderRadius:8,fontSize:13,fontWeight:500,
        background:subnetMsg.ok?`${p.green}15`:`${p.red}15`,border:`1px solid ${subnetMsg.ok?p.green:p.red}40`,
        color:subnetMsg.ok?p.green:p.red}}>
        {subnetMsg.ok?"✓":"✗"} {subnetMsg.text}
      </div>}

      {/* Add / Edit Subnet Modal */}
      {addModal&&(
        <div className="overlay" onClick={()=>setAddModal(false)}>
          <div className="modal" style={{width:480}} onClick={e=>e.stopPropagation()}>
            <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:16}}>
              <div style={{fontWeight:800,fontSize:16}}>{editEntry?"✏️ Edit Subnet":"➕ Add Manual Subnet"}</div>
              <button className="btn btn-ghost btn-sm" onClick={()=>{ setAddModal(false); setEditEntry(null); }}>✕</button>
            </div>
            <div style={{display:"flex",flexDirection:"column",gap:12}}>
              <div className="g2">
                <div><label>VLAN ID</label>
                  <input value={subnetForm.vlan} onChange={e=>setSubnetForm(f=>({...f,vlan:e.target.value}))} placeholder="e.g. 100"/>
                </div>
                <div><label>Subnet / CIDR *</label>
                  <input value={subnetForm.address_cidr} onChange={e=>setSubnetForm(f=>({...f,address_cidr:e.target.value}))} placeholder="e.g. 10.0.1.0/24"/>
                </div>
              </div>
              <div><label>Name / Description</label>
                <input value={subnetForm.name} onChange={e=>setSubnetForm(f=>({...f,name:e.target.value}))} placeholder="e.g. Management Network"/>
              </div>
              <div className="g2">
                <div><label>Location / Site</label>
                  <input value={subnetForm.location} onChange={e=>setSubnetForm(f=>({...f,location:e.target.value}))} placeholder="e.g. DC1-Row3"/>
                </div>
                <div><label>Status</label>
                  <select value={subnetForm.status} onChange={e=>setSubnetForm(f=>({...f,status:e.target.value}))}><option>Up</option><option>Down</option></select>
                </div>
              </div>
              <div><label>Comments</label>
                <input value={subnetForm.comments} onChange={e=>setSubnetForm(f=>({...f,comments:e.target.value}))} placeholder="Optional notes"/>
              </div>
              {subnetMsg&&!subnetMsg.ok&&<div style={{fontSize:12,color:p.red,fontWeight:600}}>⚠ {subnetMsg.text}</div>}
              <div style={{display:"flex",gap:8,justifyContent:"flex-end",marginTop:4}}>
                <button className="btn btn-ghost btn-sm" onClick={()=>{ setAddModal(false); setEditEntry(null); }}>Cancel</button>
                <button className="btn btn-primary btn-sm" disabled={!subnetForm.address_cidr||subnetBusy}
                  onClick={editEntry?handleEditSubnet:handleAddSubnet}>
                  {subnetBusy?"⏳ Saving…":editEntry?"💾 Save Changes":"➕ Add Subnet"}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── ASSET MANAGEMENT PAGE ────────────────────────────────────────────────────
const _OEM_BADGE = {
  hp:         { label:"HPE",     color:"#0096D6", bg:"#0096D620", logo:"🔵" },
  dell:       { label:"DELL",    color:"#007DB8", bg:"#007DB820", logo:"🔷" },
  cisco:      { label:"CISCO",   color:"#1BA0D7", bg:"#1BA0D720", logo:"🔹" },
  quanta:     { label:"QCT",     color:"#FF6B00", bg:"#FF6B0020", logo:"🟠" },
  supermicro: { label:"SMCI",    color:"#E31837", bg:"#E3183720", logo:"🔴" },
  pure:       { label:"PURE",    color:"#FF6600", bg:"#FF660020", logo:"🟧" },
  rubrik:     { label:"RUBRIK",  color:"#00AF51", bg:"#00AF5120", logo:"🟢" },
  intel:      { label:"INTEL",   color:"#0071C5", bg:"#0071C520", logo:"🔵" },
  nutanix:    { label:"NUTANIX", color:"#024DA1", bg:"#024DA120", logo:"⬛" },
  generic:    { label:"OEM",     color:"#94a3b8", bg:"#94a3b820", logo:"⬜" },
};

function _detectOEM(name, model) {
  const t = `${name||""} ${model||""}`.toLowerCase();
  if (/hp proliant|hp bladesystem|hp synergy|hp enclo|hp 3par|hpe |nimble|alletra|proliant|storeserv|synergy|bladesystem/.test(t)) return "hp";
  if (/dell|poweredge|apex cloud/.test(t)) return "dell";
  if (/cisco|hyperflex|ucs/.test(t)) return "cisco";
  if (/supermicro/.test(t)) return "supermicro";
  if (/quanta/.test(t)) return "quanta";
  if (/pure st/.test(t)) return "pure";
  if (/rubrik/.test(t)) return "rubrik";
  if (/intel/.test(t)) return "intel";
  if (/nutanix/.test(t)) return "nutanix";
  return "generic";
}

function OEMBadge({ name, model }) {
  const oem = _detectOEM(name, model);
  const b   = _OEM_BADGE[oem] || _OEM_BADGE.generic;
  return (
    <span title={`${name||""} ${model||""}`.trim()} style={{
      display:"inline-flex", alignItems:"center", gap:4,
      padding:"2px 7px", borderRadius:5,
      background:b.bg, border:`1px solid ${b.color}44`,
      color:b.color, fontSize:10, fontWeight:800,
      letterSpacing:".5px", whiteSpace:"nowrap",
    }}>
      {b.logo} {b.label}
    </span>
  );
}

function PingDot({ status }) {
  if (status === undefined) return (
    <span title="Not checked" style={{display:"inline-block",width:10,height:10,borderRadius:"50%",background:"#334155",border:"1px solid #475569"}}/>
  );
  return status ? (
    <span title="Reachable" style={{display:"inline-block",width:10,height:10,borderRadius:"50%",
      background:"#10b981",boxShadow:"0 0 6px #10b981",animation:"ping-blink 1.4s ease-in-out infinite"}}/>
  ) : (
    <span title="Unreachable" style={{display:"inline-block",width:10,height:10,borderRadius:"50%",
      background:"#ef4444",border:"1px solid #ef4444"}}/>
  );
}

function AssetManagementPage({ currentUser, p }) {
  const role     = currentUser?.role || "viewer";
  const canEdit  = ["admin","operator"].includes(role);

  const [site,       setSite]       = useState("dc");
  const [data,       setData]       = useState(null);
  const [loading,    setLoading]    = useState(true);
  const [error,      setError]      = useState(null);
  const [selRack,    setSelRack]    = useState("");
  const [pingStatus, setPingStatus] = useState({});
  const [pinging,    setPinging]    = useState(false);
  const [q,          setQ]          = useState("");

  // Modals
  const [actionModal,  setActionModal]  = useState(null); // {asset, action}
  const [credModal,    setCredModal]    = useState(null); // {asset, action, user, pass}
  const [actionResult, setActionResult] = useState(null); // {success, msg}
  const [editModal,    setEditModal]    = useState(null); // asset {} or "new"
  const [editFields,   setEditFields]   = useState({});
  const [deleteConfirm,setDeleteConfirm]= useState(null); // asset

  const load = async (s) => {
    setLoading(true); setError(null); setPingStatus({});
    try {
      const d = await fetchAssetInventory(s||site);
      setData(d);
      const first = (d.sheet_order||[])[0]||"";
      setSelRack(r => r && d.racks[r] ? r : first);
    } catch(e) { setError(e.message); }
    finally { setLoading(false); }
  };
  useEffect(() => { load(site); }, [site]);

  const handlePing = async () => {
    if (!data) return;
    const assets = data.racks[selRack] || [];
    const ips = [...new Set(assets.flatMap(a => [a.mgmt_ip, a.os_ip].filter(x => x && x.trim() && !/none|unknown|na|no mgmt/i.test(x)))
    .map(ip => ip.trim().split(/[\s\/\[]/)[0]).filter(ip => /^\d+\.\d+\.\d+\.\d+$/.test(ip)))];
    if (!ips.length) return;
    setPinging(true);
    try {
      const res = await pingAssets(ips);
      setPingStatus(prev => ({...prev, ...(res.results||{})}));
    } catch(e) { setError(e.message); }
    finally { setPinging(false); }
  };

  // ── Export current rack as PDF in a new tab ──────────────────────────────
  const openRackPDF = () => {
    const assets = data?.racks?.[selRack] || [];
    const ts = new Date().toLocaleString();
    const esc = s => String(s||'—').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/`/g,'&#96;').replace(/\$\{/g,'&#36;{');
    const oem = k => (_OEM_BADGE[_detectOEM(k.asset_name,k.model)]||_OEM_BADGE.generic);
    const statusColor = (a) => {
      const mi = (a.mgmt_ip||'').trim().split(/[\s\/\[]/)[0];
      const oi = (a.os_ip||'').trim().split(/[\s\/\[]/)[0];
      const mr = pingStatus[mi]; const or_ = pingStatus[oi];
      if (mr===true||or_===true) return ['#10b981','Power On'];
      if (mr===false&&or_===false) return ['#ef4444','Not Reachable'];
      const ps = a.power_state||'';
      if (/on|powered.?on/i.test(ps)) return ['#10b981', ps];
      if (/off|faulty/i.test(ps)) return ['#ef4444', ps];
      return ['#f59e0b', ps||'—'];
    };
    const rows = assets.map((a,i) => {
      const b = oem(a); const [sc,sl] = statusColor(a);
      return `<tr style="background:${i%2===0?'#1a1035':'#130d28'}">
        <td style="padding:6px 10px;font-size:11px;font-family:monospace;color:#a78bfa">${esc(a.position)}</td>
        <td style="padding:6px 10px">
          <span style="padding:1px 7px;border-radius:4px;font-size:10px;font-weight:800;background:${b.bg};color:${b.color};border:1px solid ${b.color}44">${b.logo} ${b.label}</span>
        </td>
        <td style="padding:6px 10px;font-weight:600;color:#e2e8f0;font-size:12px">${esc(a.asset_name)}</td>
        <td style="padding:6px 10px;color:#94a3b8;font-size:11px">${esc(a.model)}</td>
        <td style="padding:6px 10px;font-family:monospace;color:#64748b;font-size:10px">${esc(a.serial)}</td>
        <td style="padding:6px 10px;font-family:monospace;color:#06b6d4;font-size:11px">${esc((a.mgmt_ip||'').split(/[\s\n]/)[0])}</td>
        <td style="padding:6px 10px;color:#94a3b8;font-size:11px">${esc(a.os_hypervisor)}</td>
        <td style="padding:6px 10px;font-family:monospace;color:#a78bfa;font-size:11px">${esc((a.os_ip||'').split(/[\s\n]/)[0])}</td>
        <td style="padding:6px 10px">
          <span style="padding:1px 7px;border-radius:4px;font-size:10px;font-weight:700;background:${sc}22;color:${sc}">${esc(sl)}</span>
        </td>
        <td style="padding:6px 10px;color:#64748b;font-size:11px;max-width:120px">${esc(String(a.owner||'').substring(0,30))}</td>
        <td style="padding:6px 10px;color:#64748b;font-size:11px;max-width:200px">${esc(String(a.remarks||'').substring(0,60))}</td>
      </tr>`;
    }).join('');
    const html = `<!DOCTYPE html><html><head><meta charset="UTF-8">
<title>Asset Report — ${selRack} | ${site.toUpperCase()}</title>
<style>
  @media print{.no-print{display:none!important}body{background:#fff!important;color:#000!important}table{color:#000!important}td,th{color:#000!important;border-color:#ddd!important}tr{background:#fff!important}.chip{border:1px solid #999!important}}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:#0f0a1e;color:#e2e8f0;font-family:'Segoe UI',Arial,sans-serif}
  .hdr{background:linear-gradient(135deg,#12082a,#1e0a3c);padding:16px 28px;border-bottom:2px solid #7c3aed44;display:flex;align-items:center;gap:18px}
  .hdr img{height:48px}.hdr h1{font-size:18px;font-weight:800;color:#e2e8f0}.hdr p{font-size:12px;color:#94a3b8;margin-top:3px}
  table{width:100%;border-collapse:collapse}
  th{padding:8px 10px;text-align:left;font-size:10px;font-weight:700;color:#64748b;border-bottom:2px solid #2d1b69;text-transform:uppercase;letter-spacing:.4px;background:#12082a}
  td{border-bottom:1px solid #2d1b6944;vertical-align:middle}
  .wrap{padding:18px 28px}.tbl{background:#130d28;border:1px solid #2d1b69;border-radius:10px;overflow:hidden}
  .kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:10px;margin-bottom:16px}
  .kpi{background:#1a1035;border:1px solid #2d1b69;border-radius:8px;padding:10px;text-align:center}
  .kv{font-size:22px;font-weight:800;color:#a78bfa}.kl{font-size:10px;color:#64748b;text-transform:uppercase;margin-top:2px}
  .pbtn{background:linear-gradient(135deg,#7c3aed,#06b6d4);color:#fff;border:none;padding:10px 22px;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer}
  .footer{text-align:center;color:#475569;font-size:11px;padding:14px;border-top:1px solid #2d1b69;margin-top:16px}
</style></head><body>
<div class="hdr">
  <img src="/wings.png" onerror="this.style.display='none'" alt="Wipro">
  <div style="flex:1">
    <h1>🗃️ Asset Report — ${selRack}</h1>
    <p>${site.toUpperCase()} Inventory &bull; ${assets.length} assets &bull; Generated: ${ts}</p>
  </div>
  <button class="pbtn no-print" onclick="window.print()">🖨️ Export / Print PDF</button>
</div>
<div class="wrap">
  <div class="kpis">
    <div class="kpi"><div class="kv">${assets.length}</div><div class="kl">Total Assets</div></div>
    <div class="kpi"><div class="kv" style="color:#10b981">${assets.filter(a=>{const mi=(a.mgmt_ip||'').trim().split(/[\s\/\[]/)[0];const oi=(a.os_ip||'').trim().split(/[\s\/\[]/)[0];return pingStatus[mi]===true||pingStatus[oi]===true;}).length}</div><div class="kl">Reachable</div></div>
    <div class="kpi"><div class="kv" style="color:#ef4444">${assets.filter(a=>{const mi=(a.mgmt_ip||'').trim().split(/[\s\/\[]/)[0];const oi=(a.os_ip||'').trim().split(/[\s\/\[]/)[0];return pingStatus[mi]===false&&pingStatus[oi]===false;}).length}</div><div class="kl">Not Reachable</div></div>
    <div class="kpi"><div class="kv" style="color:#f59e0b">${assets.filter(a=>!pingStatus[(a.mgmt_ip||'').trim().split(/[\s\/\[]/)[0]]&&!pingStatus[(a.os_ip||'').trim().split(/[\s\/\[]/)[0]]).length}</div><div class="kl">Not Checked</div></div>
  </div>
  <div class="tbl"><table>
    <thead><tr><th>Pos</th><th>OEM</th><th>Asset Name</th><th>Model</th><th>Serial</th><th>Mgmt IP</th><th>OS / Hypervisor</th><th>OS IP</th><th>Power State</th><th>Owner</th><th>Remarks</th></tr></thead>
    <tbody>${rows||'<tr><td colspan=11 style="padding:24px;text-align:center;color:#475569">No assets</td></tr>'}</tbody>
  </table></div>
  <div class="footer">${selRack} &bull; ${site.toUpperCase()} &bull; Wipro Confidential &bull; ${ts}</div>
</div></body></html>`;
    const tab = window.open('','_blank'); if(tab){tab.document.write(html);tab.document.close();}
  };

  // ── Open OEM-wide view in new tab ─────────────────────────────────────────
  const openOEMTab = (oemKey) => {
    if (!data) return;
    const b = _OEM_BADGE[oemKey] || _OEM_BADGE.generic;
    const ts = new Date().toLocaleString();
    // Escape HTML entities + backticks/template-literal chars so document.write is safe
    const esc = s => String(s||'—').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/`/g,'&#96;').replace(/\$\{/g,'&#36;{');
    // Collect all assets of this OEM across all racks
    const byRack = {};
    for (const rack of (data.sheet_order||[])) {
      const matched = (data.racks[rack]||[]).filter(a => _detectOEM(a.asset_name,a.model)===oemKey);
      if (matched.length) byRack[rack] = matched;
    }
    const total = Object.values(byRack).reduce((s,arr)=>s+arr.length,0);
    const html = `<!DOCTYPE html><html><head><meta charset="UTF-8">
<title>${b.label} Assets — All Racks | ${site.toUpperCase()}</title>
<style>
  @media print{.no-print{display:none!important}body{background:#fff!important;color:#000!important}td,th{color:#000!important;border-color:#ddd!important}tr{background:#fff!important}}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:#0f0a1e;color:#e2e8f0;font-family:'Segoe UI',Arial,sans-serif}
  .hdr{background:linear-gradient(135deg,#12082a,#1e0a3c);padding:16px 28px;border-bottom:2px solid ${b.color}44;display:flex;align-items:center;gap:18px}
  .hdr img{height:48px}
  table{width:100%;border-collapse:collapse}
  th{padding:8px 10px;text-align:left;font-size:10px;font-weight:700;color:#64748b;border-bottom:2px solid #2d1b69;text-transform:uppercase;letter-spacing:.4px;background:#12082a}
  td{border-bottom:1px solid #2d1b6944;vertical-align:middle}
  .wrap{padding:18px 28px}
  .pbtn{background:linear-gradient(135deg,#7c3aed,#06b6d4);color:#fff;border:none;padding:10px 22px;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer}
  .footer{text-align:center;color:#475569;font-size:11px;padding:14px;border-top:1px solid #2d1b69;margin-top:8px}
  .kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:20px}
  .kpi{background:#1a1035;border:1px solid #2d1b69;border-radius:8px;padding:10px;text-align:center}
  .kv{font-size:24px;font-weight:800}.kl{font-size:10px;color:#64748b;text-transform:uppercase;margin-top:2px}
</style></head><body>
<div class="hdr">
  <img src="/wings.png" onerror="this.style.display='none'" alt="Wipro">
  <div style="flex:1">
    <div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:4px">
      <span style="padding:3px 12px;border-radius:6px;font-size:14px;font-weight:800;background:${b.bg};color:${b.color};border:1px solid ${b.color}66">${b.logo} ${b.label}</span>
      <span style="font-size:18px;font-weight:800;color:#e2e8f0">Assets — All Racks</span>
    </div>
    <div style="font-size:12px;color:#94a3b8">${site.toUpperCase()} Inventory &bull; ${total} assets across ${Object.keys(byRack).length} racks &bull; ${ts}</div>
  </div>
  <button class="pbtn no-print" onclick="window.print()">🖨️ Export / Print PDF</button>
</div>
<div class="wrap">
  <div class="kpis">
    <div class="kpi"><div class="kv" style="color:${b.color}">${total}</div><div class="kl">Total Assets</div></div>
    <div class="kpi"><div class="kv" style="color:#a78bfa">${Object.keys(byRack).length}</div><div class="kl">Racks</div></div>
    ${Object.entries(byRack).map(([r,arr])=>`<div class="kpi"><div class="kv" style="color:#06b6d4;font-size:16px">${arr.length}</div><div class="kl">${r}</div></div>`).join('')}
  </div>
  <table style="width:100%;border-collapse:collapse;border:1px solid #2d1b69;border-radius:8px;margin-bottom:8px">
    <thead><tr><th>Rack</th><th>Pos</th><th>Asset Name</th><th>Model</th><th>Serial</th><th>Mgmt IP</th><th>OS / Hypervisor</th><th>OS IP</th><th>Power State</th><th>Owner</th><th>Remarks</th></tr></thead>
    <tbody>${Object.entries(byRack).flatMap(([rack,assets])=>assets.map((a,i)=>{const ps=a.power_state||''; const pc=/on|powered.?on/i.test(ps)?'#10b981':/off|faulty/i.test(ps)?'#ef4444':'#f59e0b'; return `
      <tr style="background:${i%2===0?'#1a1035':'#130d28'}">
        <td style="padding:6px 10px;font-size:11px;font-weight:700;color:#a78bfa;font-family:monospace">${esc(rack)}</td>
        <td style="padding:6px 10px;font-size:11px;font-family:monospace;color:#06b6d4">${esc(a.position)}</td>
        <td style="padding:6px 10px;font-weight:600;color:#e2e8f0;font-size:12px">${esc(a.asset_name)}</td>
        <td style="padding:6px 10px;color:#94a3b8;font-size:11px">${esc(a.model)}</td>
        <td style="padding:6px 10px;font-family:monospace;color:#64748b;font-size:10px">${esc(a.serial)}</td>
        <td style="padding:6px 10px;font-family:monospace;color:#06b6d4;font-size:11px">${esc((a.mgmt_ip||'').split(/[\s\n]/)[0])}</td>
        <td style="padding:6px 10px;color:#94a3b8;font-size:11px">${esc(a.os_hypervisor)}</td>
        <td style="padding:6px 10px;font-family:monospace;color:#a78bfa;font-size:11px">${esc((a.os_ip||'').split(/[\s\n]/)[0])}</td>
        <td style="padding:6px 10px;color:${pc};font-size:11px;font-weight:600">${esc(ps)||'—'}</td>
        <td style="padding:6px 10px;color:#64748b;font-size:11px">${esc(String(a.owner||'').substring(0,30))}</td>
        <td style="padding:6px 10px;color:#64748b;font-size:11px">${esc(String(a.remarks||'').substring(0,60))}</td>
      </tr>`;})).join('')}
    </tbody>
  </table>
  <div class="footer">${b.label} Assets &bull; ${site.toUpperCase()} &bull; Wipro Confidential &bull; ${ts}</div>
</div></body></html>`;
    const tab = window.open('','_blank'); if(tab){tab.document.write(html);tab.document.close();}
  };

  // ── DC / DR Rack Topology in a new tab ──────────────────────────────────────
  const openTopology = (siteKey, siteData) => {
    if (!siteData) return;
    const siteName  = siteKey.toUpperCase();
    const ts = new Date().toLocaleString();
    const esc = s => String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    const oemCfg = {
      hp:         {color:'#0096D6', label:'HPE',     logo:'HPE'},
      dell:       {color:'#007DB8', label:'DELL',    logo:'DELL'},
      cisco:      {color:'#1BA0D7', label:'CISCO',   logo:'CSCO'},
      quanta:     {color:'#FF6B00', label:'QCT',     logo:'QCT'},
      supermicro: {color:'#E31837', label:'SMCI',    logo:'SMCI'},
      pure:       {color:'#FF6600', label:'PURE',    logo:'PURE'},
      rubrik:     {color:'#00AF51', label:'RUBRIK',  logo:'RBK'},
      intel:      {color:'#0071C5', label:'INTEL',   logo:'INTL'},
      nutanix:    {color:'#024DA1', label:'NUTANIX', logo:'NTIX'},
      generic:    {color:'#64748b', label:'OEM',     logo:'OEM'},
    };
    const getOEM = (name,model) => {
      const t=`${name||''} ${model||''}`.toLowerCase();
      if(/hp proliant|hpe |nimble|alletra|proliant|storeserv|synergy|bladesystem/.test(t)) return 'hp';
      if(/dell|poweredge/.test(t)) return 'dell';
      if(/cisco|hyperflex|ucs/.test(t)) return 'cisco';
      if(/supermicro/.test(t)) return 'supermicro';
      if(/quanta/.test(t)) return 'quanta';
      if(/pure st/.test(t)) return 'pure';
      if(/rubrik/.test(t)) return 'rubrik';
      if(/intel/.test(t)) return 'intel';
      if(/nutanix/.test(t)) return 'nutanix';
      return 'generic';
    };
    const allRacks = siteData.sheet_order || [];
    const allAssets = allRacks.flatMap(r => (siteData.racks[r]||[]).map(a => ({...a,_rack:r})));
    const totalAssets = allAssets.length;
    const on  = allAssets.filter(a=>/on|powered.?on/i.test(a.power_state||'')).length;
    const off = allAssets.filter(a=>/off|faulty/i.test(a.power_state||'')).length;
    // OEM counts for legend
    const oemCounts = {};
    allAssets.forEach(a=>{ const k=getOEM(a.asset_name,a.model); oemCounts[k]=(oemCounts[k]||0)+1; });
    // Build rack columns HTML
    const rackCols = allRacks.map(rk => {
      const rassets = (siteData.racks[rk]||[]);
      const rOn  = rassets.filter(a=>/on|powered.?on/i.test(a.power_state||'')).length;
      const rOff = rassets.filter(a=>/off|faulty/i.test(a.power_state||'')).length;
      const rows = rassets.map(a => {
        const oem = getOEM(a.asset_name,a.model);
        const c   = oemCfg[oem]||oemCfg.generic;
        const ps  = (a.power_state||'').toLowerCase();
        const psColor = /on|powered.?on/.test(ps)?'#10b981':/off|faulty/.test(ps)?'#ef4444':'#94a3b8';
        const psLabel = /on|powered.?on/.test(ps)?'ON':/off|faulty/.test(ps)?'OFF':'—';
        return `<div class="asset-row" style="border-left:3px solid ${c.color};background:${c.color}10">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:6px">
            <span style="font-size:9px;font-weight:800;color:${c.color};min-width:30px;letter-spacing:.3px">${esc(c.logo)}</span>
            <span style="flex:1;font-size:11px;font-weight:600;color:#e2e8f0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${esc(a.asset_name)}">${esc(a.asset_name)||'—'}</span>
            <span style="font-size:9px;font-weight:700;color:${psColor};flex-shrink:0">${psLabel}</span>
          </div>
          <div style="font-size:9px;color:#64748b;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin-top:2px">${esc(a.model||'')} ${a.position?`· Pos ${esc(a.position)}`:''}</div>
          ${(a.mgmt_ip&&!/none|unknown|na|no mgmt/i.test(a.mgmt_ip))?`<div style="font-size:8.5px;color:#38bdf8;font-family:monospace;margin-top:1px">${esc(a.mgmt_ip)}</div>`:''}
        </div>`;
      }).join('');
      return `<div class="rack-col">
        <div class="rack-hdr">
          <div style="font-weight:800;font-size:12px;color:#e2e8f0">${esc(rk)}</div>
          <div style="display:flex;gap:6px;margin-top:4px">
            <span style="font-size:10px;color:#10b981">✦ ${rOn} on</span>
            <span style="font-size:10px;color:#ef4444">✦ ${rOff} off</span>
            <span style="font-size:10px;color:#64748b">${rassets.length} total</span>
          </div>
        </div>
        <div class="rack-body">${rows||'<div style="padding:12px;text-align:center;color:#475569;font-size:11px">Empty rack</div>'}</div>
        <div class="rack-ftr">${rassets.length} assets</div>
      </div>`;
    }).join('');
    // OEM legend
    const oemLegend = Object.entries(oemCounts).sort((a,b)=>b[1]-a[1]).map(([k,cnt])=>{
      const c = oemCfg[k]||oemCfg.generic;
      return `<span class="leg-item" style="border-color:${c.color}55;background:${c.color}15"><span style="color:${c.color};font-weight:800">${esc(c.logo)}</span><span style="color:#cbd5e1">${esc(c.label)}</span><span style="color:#64748b">${cnt}</span></span>`;
    }).join('');
    const html = `<!doctype html><html><head><meta charset="utf-8"/><title>${siteName} Topology — CaaS</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',Arial,sans-serif;background:#0d1117;color:#e2e8f0;padding:20px}
.hdr{background:linear-gradient(135deg,#12082a,#1e1040);border:1px solid #7c3aed44;border-radius:12px;padding:16px 22px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.hdr-left{display:flex;align-items:center;gap:14px}
.hdr-icon{font-size:28px;background:rgba(124,58,237,.2);border-radius:8px;padding:8px 12px}
.hdr h1{font-size:20px;font-weight:800;color:#f1f5f9}
.hdr .sub{font-size:12px;color:#94a3b8;margin-top:2px}
.actions{display:flex;gap:8px;align-items:center}
btn-cls,button{font-family:inherit;padding:8px 18px;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;border:1px solid}
.btn-print{background:#6366f120;border-color:#6366f155;color:#a5b4fc}
.btn-print:hover{background:#6366f130}
.btn-close{background:#ef444415;border-color:#ef444455;color:#fca5a5}
.kpi-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px}
.kpi{flex:1;min-width:110px;background:#161b27;border:1px solid #1e293b;border-radius:10px;padding:14px 16px;text-align:center}
.kpi-v{font-size:26px;font-weight:800;color:#f1f5f9;line-height:1}
.kpi-l{font-size:11px;color:#64748b;margin-top:4px;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.legend{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px;padding:10px 14px;background:#161b27;border-radius:8px;border:1px solid #1e293b;align-items:center}
.legend-lbl{font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.5px;margin-right:4px}
.leg-item{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:6px;font-size:10px;border:1px solid;font-weight:700;letter-spacing:.3px}
.rack-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:14px}
.rack-col{background:#0f1623;border:1px solid #1e293b;border-radius:10px;overflow:hidden;display:flex;flex-direction:column}
.rack-hdr{background:#161b27;padding:12px 14px;border-bottom:1px solid #1e293b}
.rack-body{flex:1;display:flex;flex-direction:column;gap:4px;padding:8px}
.asset-row{padding:6px 8px;border-radius:6px;cursor:default;transition:background .1s}
.asset-row:hover{background:#ffffff0a!important}
.rack-ftr{background:#0c111c;padding:5px 14px;font-size:10px;color:#475569;text-align:center;border-top:1px solid #1e293b}
.section-title{font-size:11px;font-weight:800;color:#7dd3fc;text-transform:uppercase;letter-spacing:1px;padding:0 0 8px;margin:18px 0 10px;border-bottom:1px solid #1e293b;display:flex;align-items:center;gap:8px}
.footer-bar{margin-top:22px;padding:10px 16px;background:#161b27;border-radius:8px;border:1px solid #1e293b;display:flex;justify-content:space-between;align-items:center;font-size:11px;color:#475569;flex-wrap:wrap;gap:6px}
@media print{
  body{background:#fff!important;color:#0f172a!important;padding:12px}
  .actions,.btn-print,.btn-close{display:none!important}
  .hdr{background:#f8fafc!important;border-color:#e2e8f0!important}
  .hdr h1,.hdr .sub{color:#0f172a!important}
  .kpi{background:#f1f5f9!important;border-color:#e2e8f0!important}
  .kpi-v{color:#0f172a!important}
  .rack-col{background:#f8fafc!important;border-color:#e2e8f0!important;page-break-inside:avoid}
  .rack-hdr{background:#f1f5f9!important;border-color:#e2e8f0!important}
  .rack-body{gap:3px!important}
  .legend{background:#f1f5f9!important;border-color:#e2e8f0!important}
  .footer-bar{background:#f1f5f9!important;border-color:#e2e8f0!important}
  .rack-grid{grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px}
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
}
</style></head><body>
<div class="hdr">
  <div class="hdr-left">
    <div class="hdr-icon">${siteKey==='dc'?'🏢':'🔄'}</div>
    <div><h1>${siteName} — Rack Topology</h1><div class="sub">CaaS Asset Management &nbsp;·&nbsp; ${allRacks.length} Racks &nbsp;·&nbsp; ${totalAssets} Assets &nbsp;·&nbsp; Generated ${ts}</div></div>
  </div>
  <div class="actions">
    <button class="btn-print" onclick="window.print()">🖨️ Export PDF</button>
    <button class="btn-close" onclick="window.close()">✕ Close</button>
  </div>
</div>
<div class="kpi-row">
  <div class="kpi"><div class="kpi-v">${allRacks.length}</div><div class="kpi-l">Racks</div></div>
  <div class="kpi"><div class="kpi-v">${totalAssets}</div><div class="kpi-l">Total Assets</div></div>
  <div class="kpi"><div class="kpi-v" style="color:#10b981">${on}</div><div class="kpi-l">Powered On</div></div>
  <div class="kpi"><div class="kpi-v" style="color:#ef4444">${off}</div><div class="kpi-l">Powered Off</div></div>
  <div class="kpi"><div class="kpi-v" style="color:#94a3b8">${totalAssets-on-off}</div><div class="kpi-l">Unknown State</div></div>
</div>
<div class="legend"><span class="legend-lbl">OEM Legend:</span>${oemLegend}<span style="margin-left:auto;display:flex;gap:10px;align-items:center"><span style="display:flex;align-items:center;gap:5px;font-size:10px"><span style="color:#10b981;font-weight:700">●</span> Powered On</span><span style="display:flex;align-items:center;gap:5px;font-size:10px"><span style="color:#ef4444;font-weight:700">●</span> Powered Off</span><span style="display:flex;align-items:center;gap:5px;font-size:10px"><span style="color:#94a3b8;font-weight:700">●</span> Unknown</span></span></div>
<div class="section-title">🗄️ Rack Layout — ${siteName}</div>
<div class="rack-grid">${rackCols}</div>
<div class="footer-bar">
  <span>CaaS Portal &mdash; ${siteName} Topology &mdash; Wipro Infrastructure</span>
  <span>Generated: ${ts}</span>
  <span>Wipro Confidential</span>
</div>
</body></html>`;
    const tab = window.open('','_blank'); if(tab){tab.document.write(html);tab.document.close();}
  };

  const openAction = (asset, action) => {
    setActionResult(null);
    setCredModal({ asset, action, user: "sdxcoe", pass: "Wipro@123" });
  };

  const execAction = async () => {
    if (!credModal) return;
    const { asset, action, user, pass } = credModal;
    setActionResult({ success: null, msg: "⏳ Sending command…" });
    try {
      const r = await assetPowerAction({
        mgmt_ip: asset.mgmt_ip, action,
        username: user, password: pass,
        asset_name: asset.asset_name, model: asset.model,
      });
      setActionResult({ success: r.success, msg: r.message });
    } catch(e) {
      setActionResult({ success: false, msg: e.message });
    }
  };

  const openEdit = (asset) => {
    setEditFields(asset ? {...asset} : {
      rack_number:"", position:"", asset_name:"", serial:"", model:"",
      mgmt_port:"", mgmt_ip:"", data_ports:"", os_hypervisor:"",
      os_ip:"", remarks:"", power_state:"", owner:""
    });
    setEditModal(asset || "new");
  };

  const saveEdit = async () => {
    if (!editModal) return;
    try {
      if (editModal === "new") {
        await addAssetRow(site, selRack, editFields);
      } else {
        await updateAssetRow(site, selRack, editFields);
      }
      setEditModal(null);
      await load(site);
    } catch(e) { setError(e.message); }
  };

  const confirmDelete = async () => {
    if (!deleteConfirm) return;
    try {
      await deleteAssetRow(site, selRack, deleteConfirm._id);
      setDeleteConfirm(null);
      await load(site);
    } catch(e) { setError(e.message); }
  };

  const assets   = data?.racks?.[selRack] || [];
  const filtered = q ? assets.filter(a =>
    [a.asset_name,a.model,a.serial,a.mgmt_ip,a.os_ip,a.remarks,a.owner,a.position]
      .some(v => (v||"").toLowerCase().includes(q.toLowerCase()))) : assets;

  const racks = data?.sheet_order || [];

  const thS  = { padding:"7px 8px", fontSize:10, fontWeight:700, color:p.textMute,
    borderBottom:`1px solid ${p.border}`, background:"#12082a",
    whiteSpace:"nowrap", textTransform:"uppercase", letterSpacing:".4px" };
  const tdS  = { padding:"6px 8px", fontSize:12, borderBottom:`1px solid ${p.border}44`,
    verticalAlign:"middle", color:p.text };

  const EDIT_FIELDS = [
    ["rack_number","Rack Number"],["position","Position"],["asset_name","Asset Name"],
    ["serial","Serial Number"],["model","Model"],["mgmt_port","Mgmt Port"],
    ["mgmt_ip","Mgmt IP"],["os_hypervisor","OS / Hypervisor"],["os_ip","OS IP"],
    ["power_state","Power State"],["remarks","Remarks"],["owner","Owner"],
  ];

  return (
    <div style={{padding:"0 0 40px"}}>
      {/* Header + Site selector */}
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:14,flexWrap:"wrap",gap:8}}>
        <div>
          <div style={{fontWeight:700,fontSize:20,color:p.text}}>🗃️ Asset Management</div>
          <div style={{fontSize:12,color:p.textMute,marginTop:2}}>Physical rack inventory · ping reachability · OEM power control</div>
          {error && <div style={{fontSize:12,color:"#f59e0b",marginTop:3}}>⚠️ {error}</div>}
        </div>
        {/* DC / DR tabs */}
        <div style={{display:"flex",gap:6}}>
          {["dc","dr"].map(s => (
            <div key={s} style={{display:"flex",alignItems:"stretch",gap:0,borderRadius:8,overflow:"hidden",border:`1.5px solid ${site===s?p.accent:p.border}`}}>
              <button onClick={()=>{ setSite(s); setPingStatus({}); }}
                style={{padding:"7px 18px",border:"none",
                  background:site===s?`${p.accent}22`:"transparent",
                  color:site===s?p.accent:p.textMute,
                  fontWeight:700,fontSize:13,cursor:"pointer",textTransform:"uppercase",letterSpacing:1}}>
                {s==="dc"?"🏢 Data Centre":"🔄 Disaster Recovery"}
              </button>
              <div style={{width:1,background:site===s?`${p.accent}55`:p.border}}/>
              <button
                onClick={async()=>{
                  let d = (site===s) ? data : null;
                  if(!d){ try{ d = await fetchAssetInventory(s); }catch(e){ return; } }
                  openTopology(s, d);
                }}
                title={`View ${s.toUpperCase()} Rack Topology in new tab`}
                style={{padding:"7px 11px",border:"none",
                  background:site===s?`${p.accent}15`:"transparent",
                  color:site===s?p.accent:p.textMute,
                  cursor:"pointer",fontSize:12,fontWeight:700,transition:"background .15s"}}
                onMouseEnter={e=>{e.currentTarget.style.background=`${p.accent}30`;}}
                onMouseLeave={e=>{e.currentTarget.style.background=site===s?`${p.accent}15`:"transparent";}}
              >
                🗺️
              </button>
            </div>
          ))}
        </div>
      </div>

      {loading ? (
        <div style={{display:"flex",alignItems:"center",justifyContent:"center",height:200,color:p.textMute,flexDirection:"column",gap:12}}>
          <div style={{width:32,height:32,border:`3px solid ${p.accent}`,borderTopColor:"transparent",borderRadius:"50%",animation:"spin 1s linear infinite"}}/>
          <span>Loading {site.toUpperCase()} inventory…</span>
        </div>
      ) : !data?.sheet_order?.length ? (
        <div style={{textAlign:"center",padding:60,color:p.textMute}}>
          {site==="dr" ? "No DR inventory file found. Upload a DR Excel file to get started." : "No inventory data found."}
        </div>
      ) : (<>
        {/* Rack tabs */}
        <div style={{display:"flex",gap:4,flexWrap:"wrap",marginBottom:12}}>
          {racks.map(r => (
            <button key={r} onClick={()=>{ setSelRack(r); setQ(""); }}
              style={{padding:"5px 13px",borderRadius:6,fontSize:12,fontWeight:600,cursor:"pointer",
                border:`1.5px solid ${selRack===r?p.accent:p.border}`,
                background:selRack===r?`${p.accent}22`:"transparent",
                color:selRack===r?p.accent:p.textMute}}>
              {r.replace("Rack-","R-")} ({(data.racks[r]||[]).length})
            </button>
          ))}
        </div>

        {/* Toolbar */}
        <div style={{display:"flex",gap:8,alignItems:"center",marginBottom:10,flexWrap:"wrap"}}>
          <input value={q} onChange={e=>setQ(e.target.value)}
            placeholder={`Search in ${selRack}…`}
            style={{flex:1,minWidth:180,padding:"6px 12px",borderRadius:7,border:`1px solid ${p.border}`,
              background:p.panel,color:p.text,fontSize:13,outline:"none"}}/>
          <button onClick={handlePing} disabled={pinging}
            style={{padding:"6px 14px",borderRadius:7,border:"none",fontSize:12,fontWeight:700,cursor:pinging?"not-allowed":"pointer",
              background:pinging?p.border:"linear-gradient(135deg,#10b981,#059669)",color:"#fff"}}>
            {pinging ? "⏳ Pinging…" : "📶 Ping All IPs"}
          </button>
          {canEdit && (
            <button onClick={()=>openEdit(null)}
              style={{padding:"6px 14px",borderRadius:7,border:"none",fontSize:12,fontWeight:700,cursor:"pointer",
                background:`linear-gradient(135deg,${p.accent},${p.cyan})`,color:"#fff"}}>
              ＋ Add Row
            </button>
          )}
          <button onClick={openRackPDF}
            style={{padding:"6px 14px",borderRadius:7,border:"none",fontSize:12,fontWeight:700,cursor:"pointer",
              background:"linear-gradient(135deg,#7c3aed,#06b6d4)",color:"#fff"}}>
            🖨️ Export PDF
          </button>
          <span style={{fontSize:11,color:p.textMute}}>{filtered.length} asset{filtered.length!==1?"s":""}</span>
        </div>

        {/* OEM legend — click to open OEM-wide view */}
        <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:10,alignItems:"center"}}>
          <span style={{fontSize:10,color:p.textMute,marginRight:2}}>Click OEM to view all assets:</span>
          {Object.entries(_OEM_BADGE).filter(([k])=>k!=="generic" && Object.values(data?.racks||{}).flat().some(a=>_detectOEM(a.asset_name,a.model)===k)).map(([k,v])=>(
            <span key={k} onClick={()=>openOEMTab(k)}
              title={`View all ${v.label} assets across all racks`}
              style={{display:"inline-flex",alignItems:"center",gap:3,padding:"2px 9px",borderRadius:4,
                background:v.bg,border:`1px solid ${v.color}44`,color:v.color,fontSize:9,fontWeight:800,
                letterSpacing:".5px",cursor:"pointer",transition:"border-color .15s, box-shadow .15s"}}
              onMouseEnter={e=>{e.currentTarget.style.borderColor=v.color;e.currentTarget.style.boxShadow=`0 0 6px ${v.color}66`;}}
              onMouseLeave={e=>{e.currentTarget.style.borderColor=v.color+'44';e.currentTarget.style.boxShadow='none';}}>
              {v.logo} {v.label}
            </span>
          ))}
        </div>

        {/* Ping blink animation */}
        <style>{`@keyframes ping-blink{0%,100%{opacity:1;box-shadow:0 0 4px #10b981}50%{opacity:.4;box-shadow:0 0 10px #10b981}}`}</style>

        {/* Table */}
        <div style={{overflowX:"auto",borderRadius:10,border:`1px solid ${p.border}`,background:p.panel}}>
          <table style={{width:"100%",borderCollapse:"collapse",minWidth:1100}}>
            <thead>
              <tr>
                <th style={thS}>OEM</th>
                <th style={thS}>Pos</th>
                <th style={thS}>Asset Name</th>
                <th style={thS}>Model</th>
                <th style={thS}>Serial</th>
                <th style={thS}>Mgmt IP</th>
                <th style={thS}>OS / Hypervisor</th>
                <th style={thS}>OS IP</th>
                <th style={thS}>Power State</th>
                <th style={thS}>Owner</th>
                <th style={thS}>Remarks</th>
                <th style={{...thS,textAlign:"center"}}>Reach</th>
                {canEdit && <th style={{...thS,textAlign:"center"}}>Actions</th>}
              </tr>
            </thead>
            <tbody>
              {filtered.length === 0 ? (
                <tr><td colSpan={canEdit?13:12} style={{...tdS,textAlign:"center",color:p.textMute,padding:32}}>
                  No assets found{q?` matching "${q}"`:""}
                </td></tr>
              ) : filtered.map((a, i) => {
                const mgmtReach = pingStatus[a.mgmt_ip?.trim().split(/[\s\/\[]/)[0]];
                const osReach   = pingStatus[a.os_ip?.trim().split(/[\s\/\[]/)[0]];
                const rowBg = i%2===0?"transparent":p.bg+"66";
                return (
                  <tr key={a._id||i}
                    style={{background:rowBg,transition:"background .15s"}}
                    onMouseEnter={e=>e.currentTarget.style.background=p.accent+"18"}
                    onMouseLeave={e=>e.currentTarget.style.background=rowBg}>
                    <td onClick={()=>openOEMTab(_detectOEM(a.asset_name,a.model))} title={`View all ${(_OEM_BADGE[_detectOEM(a.asset_name,a.model)]||_OEM_BADGE.generic).label} assets across all racks`} style={{...tdS,cursor:"pointer"}}><OEMBadge name={a.asset_name} model={a.model}/></td>
                    <td style={{...tdS,fontFamily:"monospace",fontSize:11,color:p.cyan,fontWeight:700}}>{a.position||"—"}</td>
                    <td style={{...tdS,fontWeight:600,maxWidth:160}}>
                      <div title={a.asset_name} style={{overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",maxWidth:155}}>{a.asset_name||"—"}</div>
                    </td>
                    <td style={{...tdS,color:p.textMute,fontSize:11}}>{a.model||"—"}</td>
                    <td style={{...tdS,fontFamily:"monospace",fontSize:10,color:p.textMute}}>{a.serial||"—"}</td>
                    <td style={{...tdS}}>
                      {a.mgmt_ip ? (
                        <span style={{fontFamily:"monospace",fontSize:11,color:p.cyan}}>{a.mgmt_ip.split(/[\s\n]/)[0]}</span>
                      ) : <span style={{color:p.textMute,fontSize:11}}>—</span>}
                    </td>
                    <td style={{...tdS,fontSize:11,color:p.textMute,whiteSpace:"nowrap"}}>{a.os_hypervisor||"—"}</td>
                    <td style={{...tdS}}>
                      {a.os_ip ? (
                        <span style={{fontFamily:"monospace",fontSize:11,color:"#a78bfa"}}>{a.os_ip.split(/[\s\n]/)[0]}</span>
                      ) : <span style={{color:p.textMute,fontSize:11}}>—</span>}
                    </td>
                    <td style={tdS}>
                      {(()=>{
                        const pingChecked = mgmtReach !== undefined || osReach !== undefined;
                        const reachable   = mgmtReach === true || osReach === true;
                        if (pingChecked && reachable) return (
                          <span style={{padding:"1px 7px",borderRadius:4,fontSize:10,fontWeight:700,
                            background:"#10b98122",color:"#10b981",
                            display:"inline-flex",alignItems:"center",gap:4}}>
                            <span style={{width:7,height:7,borderRadius:"50%",background:"#10b981",
                              boxShadow:"0 0 5px #10b981",display:"inline-block",
                              animation:"ping-blink 1.4s ease-in-out infinite"}}/>
                            Power On
                          </span>
                        );
                        if (pingChecked && !reachable) return (
                          <span style={{padding:"1px 7px",borderRadius:4,fontSize:10,fontWeight:700,
                            background:"#ef444422",color:"#ef4444",
                            display:"inline-flex",alignItems:"center",gap:4}}>
                            <span style={{width:7,height:7,borderRadius:"50%",background:"#ef4444",display:"inline-block"}}/>
                            Not Reachable
                          </span>
                        );
                        // Not yet pinged — show raw Excel value
                        if (!a.power_state) return <span style={{color:p.textMute,fontSize:11}}>—</span>;
                        return (
                          <span style={{padding:"1px 7px",borderRadius:4,fontSize:10,fontWeight:700,
                            background:/on|powered.?on/i.test(a.power_state)?"#10b98122":
                                        /off|faulty/i.test(a.power_state)?"#ef444422":"#f59e0b22",
                            color:/on|powered.?on/i.test(a.power_state)?"#10b981":
                                  /off|faulty/i.test(a.power_state)?"#ef4444":"#f59e0b"}}>
                            {a.power_state}
                          </span>
                        );
                      })()}
                    </td>
                    <td style={{...tdS,fontSize:11,color:p.textMute,maxWidth:100}}>
                      <div title={a.owner} style={{overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",maxWidth:95}}>{a.owner||"—"}</div>
                    </td>
                    <td style={{...tdS,fontSize:11,color:p.textMute,maxWidth:180}}>
                      <div title={a.remarks} style={{overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",maxWidth:175}}>{a.remarks||"—"}</div>
                    </td>
                    {/* Reachability */}
                    <td style={{...tdS,textAlign:"center"}}>
                      <div style={{display:"flex",flexDirection:"column",gap:4,alignItems:"center"}}>
                        <div style={{display:"flex",alignItems:"center",gap:4}}>
                          <span style={{fontSize:9,color:p.textMute}}>MGMT</span>
                          <PingDot status={mgmtReach}/>
                        </div>
                        <div style={{display:"flex",alignItems:"center",gap:4}}>
                          <span style={{fontSize:9,color:p.textMute}}>OS</span>
                          <PingDot status={osReach}/>
                        </div>
                      </div>
                    </td>
                    {/* Actions */}
                    {canEdit && (
                      <td style={{...tdS,textAlign:"center",whiteSpace:"nowrap"}}>
                        <div style={{display:"flex",gap:4,justifyContent:"center",flexWrap:"nowrap"}}>
                          <button onClick={()=>openAction(a,"poweron")} title="Power On"
                            style={{padding:"3px 7px",fontSize:10,fontWeight:700,borderRadius:5,border:"none",
                              background:"#10b98122",color:"#10b981",cursor:"pointer"}}>⚡ ON</button>
                          <button onClick={()=>openAction(a,"reboot")} title="Reboot"
                            style={{padding:"3px 7px",fontSize:10,fontWeight:700,borderRadius:5,border:"none",
                              background:"#f59e0b22",color:"#f59e0b",cursor:"pointer"}}>🔄 RBT</button>
                          <button onClick={()=>openAction(a,"shutdown")} title="Shutdown"
                            style={{padding:"3px 7px",fontSize:10,fontWeight:700,borderRadius:5,border:"none",
                              background:"#ef444422",color:"#ef4444",cursor:"pointer"}}>⏹ OFF</button>
                          <button onClick={()=>openEdit(a)} title="Edit row"
                            style={{padding:"3px 7px",fontSize:10,fontWeight:700,borderRadius:5,border:"none",
                              background:`${p.accent}22`,color:p.accent,cursor:"pointer"}}>✏️</button>
                          <button onClick={()=>setDeleteConfirm(a)} title="Delete row"
                            style={{padding:"3px 7px",fontSize:10,fontWeight:700,borderRadius:5,border:"none",
                              background:"#ef444415",color:"#ef4444",cursor:"pointer"}}>🗑</button>
                        </div>
                      </td>
                    )}
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        {/* CREDENTIAL + POWER ACTION MODAL */}
        {credModal && (
          <div style={{position:"fixed",inset:0,background:"#00000099",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center"}}
            onClick={e=>{ if(e.target===e.currentTarget){setCredModal(null);setActionResult(null);} }}>
            <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:14,padding:28,width:400,maxWidth:"95vw"}}>
              <div style={{fontWeight:700,fontSize:16,color:p.text,marginBottom:4}}>
                {credModal.action==="poweron"?"⚡ Power On":credModal.action==="reboot"?"🔄 Reboot":"⏹ Shutdown"}
              </div>
              <div style={{fontSize:12,color:p.textMute,marginBottom:16}}>
                {credModal.asset.asset_name} — {credModal.asset.mgmt_ip || "No Mgmt IP"}
              </div>
              <OEMBadge name={credModal.asset.asset_name} model={credModal.asset.model}/>
              <div style={{marginTop:14,display:"flex",flexDirection:"column",gap:10}}>
                <div>
                  <div style={{fontSize:11,color:p.textMute,marginBottom:4}}>iDRAC / iLO / CIMC Username</div>
                  <input value={credModal.user} onChange={e=>setCredModal(c=>({...c,user:e.target.value}))}
                    style={{width:"100%",padding:"7px 10px",borderRadius:7,border:`1px solid ${p.border}`,
                      background:p.bg,color:p.text,fontSize:13,outline:"none",boxSizing:"border-box"}}/>
                </div>
                <div>
                  <div style={{fontSize:11,color:p.textMute,marginBottom:4}}>Password</div>
                  <input type="password" value={credModal.pass} onChange={e=>setCredModal(c=>({...c,pass:e.target.value}))}
                    style={{width:"100%",padding:"7px 10px",borderRadius:7,border:`1px solid ${p.border}`,
                      background:p.bg,color:p.text,fontSize:13,outline:"none",boxSizing:"border-box"}}/>
                </div>
              </div>
              {actionResult && (
                <div style={{marginTop:12,padding:"8px 12px",borderRadius:7,fontSize:12,fontWeight:600,
                  background: actionResult.success===null?"#f59e0b22":actionResult.success?"#10b98122":"#ef444422",
                  color:       actionResult.success===null?"#f59e0b":actionResult.success?"#10b981":"#ef4444",
                  border:`1px solid ${actionResult.success===null?"#f59e0b44":actionResult.success?"#10b98144":"#ef444444"}`}}>
                  {actionResult.msg}
                </div>
              )}
              <div style={{display:"flex",gap:8,marginTop:16,justifyContent:"flex-end"}}>
                <button onClick={()=>{setCredModal(null);setActionResult(null);}}
                  style={{padding:"7px 16px",borderRadius:7,border:`1px solid ${p.border}`,background:"transparent",color:p.textMute,cursor:"pointer",fontSize:13}}>
                  Cancel
                </button>
                <button onClick={execAction} disabled={actionResult?.success===null}
                  style={{padding:"7px 18px",borderRadius:7,border:"none",fontWeight:700,fontSize:13,cursor:"pointer",
                    background:credModal.action==="shutdown"?"linear-gradient(135deg,#ef4444,#dc2626)":
                               credModal.action==="reboot"?"linear-gradient(135deg,#f59e0b,#d97706)":
                               "linear-gradient(135deg,#10b981,#059669)",color:"#fff"}}>
                  {credModal.action==="poweron"?"⚡ Execute Power On":credModal.action==="reboot"?"🔄 Execute Reboot":"⏹ Execute Shutdown"}
                </button>
              </div>
            </div>
          </div>
        )}

        {/* EDIT / ADD ROW MODAL */}
        {editModal && (
          <div style={{position:"fixed",inset:0,background:"#00000099",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center"}}
            onClick={e=>{ if(e.target===e.currentTarget) setEditModal(null); }}>
            <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:14,padding:28,width:560,maxWidth:"95vw",maxHeight:"85vh",overflowY:"auto"}}>
              <div style={{fontWeight:700,fontSize:16,color:p.text,marginBottom:16}}>
                {editModal==="new" ? "➕ Add New Asset" : `✏️ Edit — ${editModal.asset_name||editModal.position||"Asset"}`}
              </div>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
                {EDIT_FIELDS.map(([key,label])=>(
                  <div key={key}>
                    <div style={{fontSize:11,color:p.textMute,marginBottom:3}}>{label}</div>
                    <input value={editFields[key]||""} onChange={e=>setEditFields(f=>({...f,[key]:e.target.value}))}
                      placeholder={label}
                      style={{width:"100%",padding:"6px 9px",borderRadius:6,border:`1px solid ${p.border}`,
                        background:p.bg,color:p.text,fontSize:12,outline:"none",boxSizing:"border-box"}}/>
                  </div>
                ))}
              </div>
              <div style={{display:"flex",gap:8,marginTop:18,justifyContent:"flex-end"}}>
                <button onClick={()=>setEditModal(null)}
                  style={{padding:"7px 16px",borderRadius:7,border:`1px solid ${p.border}`,background:"transparent",color:p.textMute,cursor:"pointer",fontSize:13}}>
                  Cancel
                </button>
                <button onClick={saveEdit}
                  style={{padding:"7px 18px",borderRadius:7,border:"none",fontWeight:700,fontSize:13,cursor:"pointer",
                    background:`linear-gradient(135deg,${p.accent},${p.cyan})`,color:"#fff"}}>
                  {editModal==="new"?"➕ Add Asset":"💾 Save Changes"}
                </button>
              </div>
            </div>
          </div>
        )}

        {/* DELETE CONFIRM MODAL */}
        {deleteConfirm && (
          <div style={{position:"fixed",inset:0,background:"#00000099",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center"}}
            onClick={e=>{ if(e.target===e.currentTarget) setDeleteConfirm(null); }}>
            <div style={{background:p.panel,border:`1px solid #ef444466`,borderRadius:14,padding:28,width:380,maxWidth:"95vw"}}>
              <div style={{fontWeight:700,fontSize:16,color:"#ef4444",marginBottom:8}}>🗑️ Delete Asset?</div>
              <div style={{fontSize:13,color:p.text,marginBottom:6}}>
                <strong>{deleteConfirm.asset_name||"Asset"}</strong> at position <strong>{deleteConfirm.position}</strong>
              </div>
              <div style={{fontSize:12,color:p.textMute,marginBottom:16}}>This will remove the row from the Excel inventory. This cannot be undone.</div>
              <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
                <button onClick={()=>setDeleteConfirm(null)}
                  style={{padding:"7px 16px",borderRadius:7,border:`1px solid ${p.border}`,background:"transparent",color:p.textMute,cursor:"pointer",fontSize:13}}>
                  Cancel
                </button>
                <button onClick={confirmDelete}
                  style={{padding:"7px 18px",borderRadius:7,border:"none",fontWeight:700,fontSize:13,cursor:"pointer",
                    background:"linear-gradient(135deg,#ef4444,#dc2626)",color:"#fff"}}>
                  Delete Row
                </button>
              </div>
            </div>
          </div>
        )}
      </>)}
    </div>
  );
}

// ─── CAAS LOCAL CHATBOT ───────────────────────────────────────────────────────
function answerQuery(input, {vms,hosts,datastores,snapshots,networks,alerts,vcenters,currentUser}){
  const q=input.toLowerCase().trim();
  const nn=s=>s||"—";

  // Helper: format VM list
  const fmtVMs=(list,limit=10)=>list.slice(0,limit).map(v=>
    `  • ${v.name}  [${v.status==="poweredOn"?"ON":"OFF"}]  CPU:${v.cpu}c  RAM:${v.ram_gb}GB  Host:${nn(v.host)}  IP:${nn(v.ip)}`
  ).join("\n")+(list.length>limit?`\n  … and ${list.length-limit} more`:"");

  // ── powered off VMs
  if(q.match(/power(ed)?\s*off|stopped|off\s*vms?|not\s*running/)){
    const off=vms.filter(v=>v.status==="poweredOff");
    if(!off.length) return "✅ All VMs are currently powered on.";
    return `🔴 ${off.length} powered-off VM${off.length!==1?"s":""}:\n${fmtVMs(off)}`;
  }
  // ── running VMs
  if(q.match(/running|power(ed)?\s*on|on\s*vms?/)){
    const on=vms.filter(v=>v.status==="poweredOn");
    return `✅ ${on.length} VMs powered on out of ${vms.length} total.\n${fmtVMs(on,8)}`;
  }
  // ── suspended VMs
  if(q.match(/suspend/)){
    const s=vms.filter(v=>v.status==="suspended");
    if(!s.length) return "✅ No suspended VMs.";
    return `🟡 ${s.length} suspended VM${s.length!==1?"s":""}:\n${fmtVMs(s)}`;
  }
  // ── high CPU hosts
  if(q.match(/cpu|processor|overload|high\s*usage/)){
    const sorted=hosts.filter(h=>h.status==="connected").map(h=>({...h,cpuUsed:Math.round(100-h.cpu_free_pct)})).sort((a,b)=>b.cpuUsed-a.cpuUsed);
    if(!sorted.length) return "No connected hosts found.";
    return `⚡ ESXi hosts by CPU usage:\n${sorted.map(h=>`  • ${h.name}  ${h.cpuUsed}% used  (${h.cpu_cores} cores)`).join("\n")}`;
  }
  // ── RAM/memory
  if(q.match(/ram|memory|mem\s*free|memory\s*usage/)){
    const sorted=hosts.filter(h=>h.ram_total_gb>0).map(h=>({...h,ramUsedPct:Math.round((h.ram_used_gb/h.ram_total_gb)*100)})).sort((a,b)=>b.ramUsedPct-a.ramUsedPct);
    if(!sorted.length) return "No host memory data available.";
    return `🧠 Hosts by RAM usage:\n${sorted.map(h=>`  • ${h.name}  ${h.ramUsedPct}% used  (${h.ram_used_gb}/${h.ram_total_gb} GB)`).join("\n")}`;
  }
  // ── snapshots
  if(q.match(/snap/)){
    if(!snapshots.length) return "✅ No snapshots found in the environment.";
    const byVM={};
    snapshots.forEach(s=>{byVM[s.vm_name]=(byVM[s.vm_name]||0)+1;});
    const top=Object.entries(byVM).sort((a,b)=>b[1]-a[1]).slice(0,10);
    return `📸 ${snapshots.length} total snapshots across ${Object.keys(byVM).length} VMs:\n${top.map(([n,cnt])=>`  • ${n}: ${cnt} snapshot${cnt!==1?"s":""}`).join("\n")}`;
  }
  // ── datastores / storage
  if(q.match(/datastore|storage|disk\s*space|free\s*space/)){
    const sorted=[...datastores].sort((a,b)=>b.used_pct-a.used_pct);
    const full=sorted.filter(d=>d.used_pct>=80);
    let r=`💾 Datastores (${datastores.length} total):\n${sorted.map(d=>`  • ${d.name}  ${d.used_pct}% used  Free:${d.free_gb}GB/${d.total_gb}GB  ${d.accessible?"OK":"⚠️OFFLINE"}`).join("\n")}`;
    if(full.length) r+=`\n\n⚠️ ${full.length} datastore${full.length!==1?"s":""} above 80% capacity!`;
    return r;
  }
  // ── alerts
  if(q.match(/alert|warning|critical|issue|problem|error/)){
    if(!alerts.length) return "✅ No active alerts.";
    const crit=alerts.filter(a=>a.severity==="error");
    const warn=alerts.filter(a=>a.severity==="warn"||a.severity==="warning");
    let r=`🔔 ${alerts.length} active alert${alerts.length!==1?"s":""}:\n`;
    if(crit.length) r+=`\n🔴 CRITICAL (${crit.length}):\n${crit.map(a=>`  • [${a.type}] ${a.message} — ${nn(a.resource)}`).join("\n")}`;
    if(warn.length) r+=`\n🟡 WARNINGS (${warn.length}):\n${warn.map(a=>`  • [${a.type}] ${a.message} — ${nn(a.resource)}`).join("\n")}`;
    return r;
  }
  // ── disconnected hosts
  if(q.match(/disconnect|not\s*connect|offline|down\s*host/)){
    const bad=hosts.filter(h=>h.status!=="connected");
    if(!bad.length) return "✅ All hosts are connected.";
    return `⚠️ ${bad.length} host${bad.length!==1?"s":""} not connected:\n${bad.map(h=>`  • ${h.name}  Status: ${h.status}  vCenter: ${nn(h.vcenter_name)}`).join("\n")}`;
  }
  // ── hosts list
  if(q.match(/host|esxi|server/)){
    if(!hosts.length) return "No hosts found.";
    return `🖥️ ${hosts.length} ESXi host${hosts.length!==1?"s":""}:\n${hosts.map(h=>`  • ${h.name}  ${h.status}  ${h.cpu_cores} cores  RAM:${h.ram_total_gb}GB  Free:${h.ram_free_gb}GB`).join("\n")}`;
  }
  // ── no IP
  if(q.match(/no\s*ip|without\s*ip|missing\s*ip|ip\s*address/)){
    const noip=vms.filter(v=>!v.ip&&v.status==="poweredOn");
    if(!noip.length) return "✅ All running VMs have IP addresses assigned.";
    return `⚠️ ${noip.length} running VM${noip.length!==1?"s":""} without IP:\n${fmtVMs(noip)}`;
  }
  // ── networks
  if(q.match(/network|port\s*group|vlan/)){
    if(!networks.length) return "No network data available.";
    return `🌐 ${networks.length} network${networks.length!==1?"s":""}:\n${networks.slice(0,15).map(n=>`  • ${n.name}  ${n.type||""}  VMs:${n.vm_count||"?"}`).join("\n")}`;
  }
  // ── vcenters
  if(q.match(/vcenter|vc\s*\d|environment/)){
    return `🏢 vCenters (${vcenters.length}):\n${vcenters.map(v=>`  • ${v.name}  ${v.id}`).join("\n")}\n\nTotal: ${vms.length} VMs · ${hosts.length} hosts · ${datastores.length} datastores`;
  }
  // ── summary / overview
  if(q.match(/summary|overview|status|total|how\s*many|count/)){
    const on=vms.filter(v=>v.status==="poweredOn").length;
    const connH=hosts.filter(h=>h.status==="connected").length;
    const crit=alerts.filter(a=>a.severity==="error").length;
    return `📊 Environment Summary:\n  VMs: ${vms.length} total · ${on} running · ${vms.length-on} off\n  Hosts: ${hosts.length} total · ${connH} connected · ${hosts.length-connH} issues\n  Datastores: ${datastores.length} · Snapshots: ${snapshots.length}\n  Active Alerts: ${alerts.length} (${crit} critical)\n  vCenters: ${vcenters.length}`;
  }
  // ── specific VM search
  const vmMatch=vms.filter(v=>v.name.toLowerCase().includes(q)||nn(v.ip).includes(q));
  if(vmMatch.length>0&&vmMatch.length<=5){
    return `🔍 Found ${vmMatch.length} VM${vmMatch.length!==1?"s":""} matching "${input}":\n${vmMatch.map(v=>`  • ${v.name}\n    Status: ${v.status}  IP: ${nn(v.ip)}\n    CPU: ${v.cpu}c  RAM: ${v.ram_gb}GB  Disk: ${v.disk_gb}GB\n    Host: ${nn(v.host)}  OS: ${nn(v.guest_os)}  Snaps: ${v.snapshot_count||0}`).join("\n\n")}`;
  }
  if(vmMatch.length>5) return `🔍 ${vmMatch.length} VMs match "${input}":\n${fmtVMs(vmMatch,10)}`;

  // ── help
  if(q.match(/help|\?|what\s*can/)){
    return `💡 You can ask me about:\n  • "show powered off VMs"\n  • "which hosts have high CPU?"\n  • "datastores nearly full"\n  • "VMs without IP"\n  • "list all snapshots"\n  • "active alerts"\n  • "environment summary"\n  • "disconnected hosts"\n  • "list networks"\n  • type any VM name to look it up`;
  }

  return `🤔 I didn't understand that. Try asking about:\n  powered off VMs · alerts · datastores · snapshots · hosts · networks\n  or type "help" for a full list of questions I can answer.`;
}

// ─── LOCAL CHATBOT ENGINE ─────────────────────────────────────────────────────
function fmtUptime(sec){
  if(!sec) return "—";
  const d=Math.floor(sec/86400), h=Math.floor((sec%86400)/3600), m=Math.floor((sec%3600)/60);
  return d>0?`${d}d ${h}h`:`${h}h ${m}m`;
}
function fmtToolsStatus(s){
  if(!s) return "—";
  if(s.includes("guestToolsRunning")) return "✅ Running";
  if(s.includes("notRunning")) return "⚠️ Not Running";
  if(s.includes("notInstalled")) return "❌ Not Installed";
  return s.replace("guestTools","");
}
function fmtToolsVer(s){
  if(!s) return "";
  if(s.includes("Current")||s.includes("guestToolsCurrent")) return "✅ Up to date";
  if(s.includes("Old")||s.includes("guestToolsNeedUpgrade")) return "⚠️ Needs upgrade";
  if(s.includes("Unmanaged")) return "ℹ️ Unmanaged";
  return s.replace("guestTools","");
}
function vmDetailCard(v){
  const status = v.status==="poweredOn"?"🟢 Powered On":v.status==="poweredOff"?"🔴 Powered Off":"🟡 "+v.status;
  const ips  = (v.all_ips&&v.all_ips.length)?v.all_ips.join(", "):(v.ip||"—");
  const nets = (v.networks&&v.networks.length)
    ? v.networks.map(n=>"    "+(n.name||"—")+"  MAC:"+(n.mac||"—")+"  "+(n.connected?"✅":"❌")).join("\n")
    : "    —";
  const dss  = (v.datastores&&v.datastores.length)?v.datastores.join(", "):(v.disk_gb?"("+v.disk_gb+"GB used)":"—");
  const snaps= v.snapshot_count||0;
  const note = v.annotation?("\n  Note       : "+v.annotation):"";
  const cpuSock = (v.cpu_cores_per_socket&&v.cpu_cores_per_socket>1)?" ("+v.cpu_cores_per_socket+" cores/socket)":"";
  const diskProv= v.disk_prov_gb?" / "+v.disk_prov_gb+" GB provisioned":"";
  return "╔══════════════════════════════════════\n"+
    "  VM: "+v.name+"\n"+
    "  Status : "+status+"\n"+
    "══════════════════════════════════════\n"+
    "  OS       : "+(v.guest_os||"—")+"\n"+
    "  UUID     : "+(v.uuid||"—")+"\n"+
    "  Folder   : "+(v.folder||"—")+"\n"+
    "══ COMPUTE ════════════════════════════\n"+
    "  CPU      : "+(v.cpu||0)+" vCPUs"+cpuSock+"\n"+
    "  Memory   : "+(v.ram_gb||0)+" GB\n"+
    "  Disk     : "+(v.disk_gb||0)+" GB used"+diskProv+"\n"+
    "══ NETWORK ════════════════════════════\n"+
    "  Primary IP : "+ips+"\n"+
    "  NICs       :\n"+
    nets+"\n"+
    "══ PLATFORM ═══════════════════════════\n"+
    "  ESXi Host  : "+(v.host||"—")+"\n"+
    "  vCenter    : "+(v.vcenter_name||v.vcenter_id||"—")+"\n"+
    "  Datastores : "+dss+"\n"+
    "══ HEALTH ═════════════════════════════\n"+
    "  Uptime       : "+fmtUptime(v.uptime_sec)+"\n"+
    "  Snapshots    : "+(snaps===0?"✅ None":snaps+" snapshot"+(snaps>1?"s":""))+"\n"+
    "  VMware Tools : "+fmtToolsStatus(v.tools_status)+" "+fmtToolsVer(v.tools_version)+note+"\n"+
    "╚══════════════════════════════════════";
}
function localChatEngine({vms, hosts, datastores, snapshots, alerts, vcenters, currentUser}){
  const q = (text) => text.toLowerCase();
  const fmtVM  = v => `• ${v.name}  [${v.status==="poweredOn"?"ON":"OFF"}]  CPU:${v.cpu}  RAM:${v.ram_gb}GB  Disk:${v.disk_gb}GB  Host:${v.host||"—"}  IP:${(v.all_ips&&v.all_ips.length)?v.all_ips.join(","):v.ip||"—"}  vCenter:${v.vcenter_name||"—"}`;
  const fmtH   = h => `• ${h.name}  [${h.status}]  CPU:${Math.round(100-(h.cpu_free_pct||0))}%  RAM:${h.ram_total_gb}GB total / ${h.ram_free_gb}GB free  vCenter:${h.vcenter_name||"—"}`;
  const fmtDS  = d => `• ${d.name}  ${d.used_pct}% used  Free:${d.free_gb}GB / ${d.total_gb}GB  ${d.accessible===false?"⚠️ INACCESSIBLE":"✅"}  vCenter:${d.vcenter_name||"—"}`;
  const fmtSnap= s => `• ${s.vm_name}  snap:"${s.snapshot_name}"  Age:${s.age_days||"?"}d  Size:${s.size_gb||"?"}GB`;
  const fmtAlt = a => `• [${(a.severity||"").toUpperCase()}] ${a.resource}: ${a.message}  vCenter:${a.vcenter_name||"—"}`;

  return function answer(input){
    const t = q(input);
    const has = (...words) => words.every(w => t.includes(w));
    const any  = (...words) => words.some(w => t.includes(w));

    // ── SUMMARY / OVERVIEW ────────────────────────────────────────────────────
    if(any("summary","overview","status","health","how many","count","total")){
      const on  = vms.filter(v=>v.status==="poweredOn").length;
      const off = vms.filter(v=>v.status==="poweredOff").length;
      const sus = vms.filter(v=>v.status==="suspended").length;
      const connHosts = hosts.filter(h=>h.status==="connected").length;
      const critAlerts = alerts.filter(a=>a.severity==="error").length;
      const warnAlerts = alerts.filter(a=>a.severity==="warn"||a.severity==="warning").length;
      const fullDS = datastores.filter(d=>d.used_pct>=90).length;
      return `📊 Infrastructure Summary
━━━━━━━━━━━━━━━━━━━━━━
vCenters : ${vcenters.length}
VMs      : ${vms.length} total  (${on} on · ${off} off${sus?" · "+sus+" suspended":""})
Hosts    : ${hosts.length} total  (${connHosts} connected)
Datastores: ${datastores.length}  (${fullDS} ≥90% full)
Snapshots : ${snapshots.length}
Alerts   : ${critAlerts} critical · ${warnAlerts} warnings
User     : ${currentUser?.username||"—"} (${currentUser?.role||"—"})`;
    }

    // ── POWERED OFF VMs ───────────────────────────────────────────────────────
    if(any("powered off","off vm","shutdown","stopped")){
      const list = vms.filter(v=>v.status==="poweredOff"||v.status==="suspended");
      if(!list.length) return "✅ No powered-off or suspended VMs found.";
      return `🔴 Powered-off / Suspended VMs (${list.length})\n\n`+list.map(fmtVM).join("\n");
    }

    // ── POWERED ON VMs ────────────────────────────────────────────────────────
    if(any("powered on","running vm","online vm")){
      const list = vms.filter(v=>v.status==="poweredOn");
      if(!list.length) return "No powered-on VMs found.";
      return `🟢 Powered-on VMs (${list.length})\n\n`+list.map(fmtVM).join("\n");
    }

    // ── ALL VMs ───────────────────────────────────────────────────────────────
    if(any("all vm","list vm","show vm","every vm")){
      if(!vms.length) return "No VMs found in inventory.";
      return `💻 All VMs (${vms.length})\n\n`+vms.map(fmtVM).join("\n");
    }

    // ── SPECIFIC VM LOOKUP ────────────────────────────────────────────────────
    if(any("vm named","find vm","search vm","show me vm","details of","info about","tell me about")){
      const words = input.trim().split(/\s+/);
      const nameTokens = words.filter(w=>w.length>3&&!["show","find","tell","about","details","named","info","vm"].includes(w.toLowerCase()));
      const matches = vms.filter(v=>nameTokens.some(tok=>v.name.toLowerCase().includes(tok.toLowerCase())));
      if(!matches.length) return `No VMs found matching your search. Try "all vms" for the full list.`;
      return `🔍 VM Details (${matches.length} match${matches.length>1?"es":""})\n\n`+matches.map(fmtVM).join("\n");
    }

    // ── HIGH CPU HOSTS ────────────────────────────────────────────────────────
    if(any("high cpu","cpu usage","cpu load","busy host","cpu utiliz")){
      const threshold = t.includes("90") ? 90 : t.includes("80") ? 80 : 70;
      const list = hosts.filter(h=>(100-(h.cpu_free_pct||0))>=threshold).sort((a,b)=>(b.cpu_free_pct||0)-(a.cpu_free_pct||0));
      if(!list.length) return `✅ No hosts with CPU usage ≥${threshold}%.`;
      return `🔥 High CPU Hosts (≥${threshold}%) — ${list.length} found\n\n`+list.map(fmtH).join("\n");
    }

    // ── HIGH RAM HOSTS ────────────────────────────────────────────────────────
    if(any("high ram","memory usage","ram usage","memory pressure","high memory")){
      const list = hosts.filter(h=>{
        const used = h.ram_total_gb - (h.ram_free_gb||0);
        return h.ram_total_gb>0 && (used/h.ram_total_gb)>=0.8;
      }).sort((a,b)=>((b.ram_total_gb-b.ram_free_gb)/b.ram_total_gb)-((a.ram_total_gb-a.ram_free_gb)/a.ram_total_gb));
      if(!list.length) return "✅ No hosts with RAM usage ≥80%.";
      return `🧠 High Memory Hosts (≥80%) — ${list.length} found\n\n`+list.map(h=>{
        const used=h.ram_total_gb-(h.ram_free_gb||0);
        const pct=Math.round(100*used/h.ram_total_gb);
        return `• ${h.name}  RAM:${pct}% used (${used}GB/${h.ram_total_gb}GB)  vCenter:${h.vcenter_name||"—"}`;
      }).join("\n");
    }

    // ── ALL HOSTS ─────────────────────────────────────────────────────────────
    if(any("all host","list host","show host","every host","esxi","hypervisor")){
      if(!hosts.length) return "No hosts found in inventory.";
      return `🖥️ All ESXi Hosts (${hosts.length})\n\n`+hosts.map(fmtH).join("\n");
    }

    // ── DISCONNECTED HOSTS ────────────────────────────────────────────────────
    if(any("disconnect","not connected","offline host","down host","maintenance")){
      const list = hosts.filter(h=>h.status!=="connected");
      if(!list.length) return "✅ All hosts are connected.";
      return `⚠️ Disconnected / Maintenance Hosts (${list.length})\n\n`+list.map(fmtH).join("\n");
    }

    // ── DATASTORES NEARLY FULL ────────────────────────────────────────────────
    if(any("full datastore","nearly full","datastore","storage","disk space","low space","capacity")){
      const threshold = t.includes("95") ? 95 : t.includes("90") ? 90 : t.includes("80") ? 80 : 75;
      const list = datastores.filter(d=>d.used_pct>=threshold).sort((a,b)=>b.used_pct-a.used_pct);
      if(!list.length) return `✅ No datastores above ${threshold}% capacity.`;
      return `💾 Datastores ≥${threshold}% Full (${list.length})\n\n`+list.map(fmtDS).join("\n");
    }

    // ── ALL DATASTORES ────────────────────────────────────────────────────────
    if(any("all datastore","list datastore","show datastore","every datastore")){
      if(!datastores.length) return "No datastores found.";
      return `💾 All Datastores (${datastores.length})\n\n`+[...datastores].sort((a,b)=>b.used_pct-a.used_pct).map(fmtDS).join("\n");
    }

    // ── INACCESSIBLE DATASTORES ───────────────────────────────────────────────
    if(any("inaccessible","not accessible","unavailable datastore")){
      const list = datastores.filter(d=>d.accessible===false);
      if(!list.length) return "✅ All datastores are accessible.";
      return `🔴 Inaccessible Datastores (${list.length})\n\n`+list.map(fmtDS).join("\n");
    }

    // ── SNAPSHOTS ─────────────────────────────────────────────────────────────
    if(any("snapshot","snap")){
      if(!snapshots.length) return "No snapshots found across any VM.";
      if(any("old","stale","aged","ancient","7 day","14 day","30 day","month","week")){
        const days = t.includes("30")||t.includes("month") ? 30 : t.includes("14") ? 14 : 7;
        const list = snapshots.filter(s=>(s.age_days||0)>=days).sort((a,b)=>(b.age_days||0)-(a.age_days||0));
        if(!list.length) return `✅ No snapshots older than ${days} days.`;
        return `📸 Snapshots Older Than ${days} Days (${list.length})\n\n`+list.map(fmtSnap).join("\n");
      }
      const byVM = {};
      snapshots.forEach(s=>{ byVM[s.vm_name]=(byVM[s.vm_name]||0)+1; });
      const sorted = Object.entries(byVM).sort((a,b)=>b[1]-a[1]).slice(0,20);
      return `📸 Snapshot Summary (${snapshots.length} total across ${Object.keys(byVM).length} VMs)\n\n`
        +sorted.map(([vm,cnt])=>`• ${vm}  —  ${cnt} snapshot${cnt>1?"s":""}`).join("\n")
        +"\n\nTip: Ask 'old snapshots' or 'snapshots older than 30 days' for aged ones.";
    }

    // ── VMs WITHOUT SNAPSHOTS ─────────────────────────────────────────────────
    if(has("no snapshot")||has("without snapshot")){
      const withSnap = new Set(snapshots.map(s=>s.vm_name));
      const list = vms.filter(v=>!withSnap.has(v.name)&&v.status==="poweredOn");
      if(!list.length) return "All running VMs have at least one snapshot.";
      return `📸 Running VMs Without Snapshots (${list.length})\n\n`+list.map(fmtVM).join("\n");
    }

    // ── ALERTS ────────────────────────────────────────────────────────────────
    if(any("alert","alarm","critical","warning","issue","problem","error")){
      if(!alerts.length) return "✅ No active alerts.";
      const crit = alerts.filter(a=>a.severity==="error");
      const warn = alerts.filter(a=>a.severity==="warn"||a.severity==="warning");
      const info = alerts.filter(a=>a.severity==="info");
      let out = `🚨 Active Alerts (${alerts.length} total)\n`;
      if(crit.length) out += `\n🔴 CRITICAL (${crit.length})\n`+crit.map(fmtAlt).join("\n");
      if(warn.length) out += `\n🟡 WARNINGS (${warn.length})\n`+warn.map(fmtAlt).join("\n");
      if(info.length) out += `\n🔵 INFO (${info.length})\n`+info.slice(0,5).map(fmtAlt).join("\n");
      return out;
    }

    // ── VMs WITHOUT IP ────────────────────────────────────────────────────────
    if(has("no ip")||has("without ip")||has("missing ip")||has("no ip address")){
      const list = vms.filter(v=>!v.ip&&v.status==="poweredOn");
      if(!list.length) return "✅ All running VMs have an IP address.";
      return `🌐 Running VMs Without IP (${list.length})\n\n`+list.map(fmtVM).join("\n");
    }

    // ── LARGEST VMs ───────────────────────────────────────────────────────────
    if(any("largest","biggest","most disk","most storage","top vm","heavy vm")){
      const n = t.match(/\d+/)?.[0]||10;
      const list = [...vms].sort((a,b)=>(b.disk_gb||0)-(a.disk_gb||0)).slice(0,n);
      return `💽 Top ${n} VMs by Disk Size\n\n`+list.map(fmtVM).join("\n");
    }

    // ── MOST RAM ──────────────────────────────────────────────────────────────
    if(any("most ram","most memory","largest ram","biggest ram","top ram")){
      const n = t.match(/\d+/)?.[0]||10;
      const list = [...vms].sort((a,b)=>(b.ram_gb||0)-(a.ram_gb||0)).slice(0,n);
      return `🧠 Top ${n} VMs by RAM\n\n`+list.map(fmtVM).join("\n");
    }

    // ── MOST CPU ──────────────────────────────────────────────────────────────
    if(any("most cpu","most core","largest cpu","top cpu")){
      const n = t.match(/\d+/)?.[0]||10;
      const list = [...vms].sort((a,b)=>(b.cpu||0)-(a.cpu||0)).slice(0,n);
      return `⚙️ Top ${n} VMs by CPU Count\n\n`+list.map(fmtVM).join("\n");
    }

    // ── vCENTER SPECIFIC ──────────────────────────────────────────────────────
    if(any("vcenter","vc","rookie","prod","dr","network vc","172.")){
      const vcName = vcenters.find(v=>t.includes(v.name?.toLowerCase())||t.includes(v.id));
      const targetVC = vcName||null;
      if(targetVC){
        const vcVMs   = vms.filter(v=>v.vcenter_id===targetVC.id||v.vcenter_name===targetVC.name);
        const vcHosts = hosts.filter(h=>h.vcenter_id===targetVC.id||h.vcenter_name===targetVC.name);
        const vcDS    = datastores.filter(d=>d.vcenter_id===targetVC.id||d.vcenter_name===targetVC.name);
        return `🏢 vCenter: ${targetVC.name||targetVC.id}\n\nVMs: ${vcVMs.length}  (${vcVMs.filter(v=>v.status==="poweredOn").length} on)\nHosts: ${vcHosts.length}\nDatastores: ${vcDS.length}\n\nHosts:\n`+vcHosts.map(fmtH).join("\n");
      }
      // List all vCenters
      return `🏢 vCenters (${vcenters.length})\n\n`+vcenters.map(v=>{
        const cnt = vms.filter(x=>x.vcenter_id===v.id).length;
        const hcnt= hosts.filter(x=>x.vcenter_id===v.id).length;
        return `• ${v.name||v.id}  —  ${cnt} VMs · ${hcnt} hosts`;
      }).join("\n");
    }

    // ── VM FULL DETAIL CARD ───────────────────────────────────────────────────
    if(any("info","detail","describe","full info")||(any("show","tell","about")&&t.split(" ").length>=3)){
      const words=input.trim().split(/\s+/);
      const skip=new Set(["info","detail","show","tell","about","describe","what","whats","is","me","the","vm","server","machine","full","details","of","for","give","find","search"]);
      const tokens=words.filter(w=>w.length>2&&!skip.has(w.toLowerCase()));
      if(tokens.length){
        const matches=vms.filter(v=>tokens.some(tok=>v.name.toLowerCase().includes(tok.toLowerCase())));
        if(matches.length===1) return vmDetailCard(matches[0]);
        if(matches.length>1&&matches.length<=5) return `Found ${matches.length} VMs:\n\n`+matches.map(fmtVM).join("\n")+"\n\nBe more specific, e.g: info <exact-name>";
        if(matches.length>5) return `Found ${matches.length} VMs — be more specific.\n\nTop results:\n`+matches.slice(0,5).map(fmtVM).join("\n");
      }
    }

    // ── VMware TOOLS ─────────────────────────────────────────────────────────
    if(any("vmware tools","tools status","tools not","tools outdated","tools upgrade","tools installed")){
      const notInstalled=vms.filter(v=>v.status==="poweredOn"&&v.tools_status&&v.tools_status.includes("notInstalled"));
      const needsUpgrade=vms.filter(v=>v.status==="poweredOn"&&v.tools_version&&(v.tools_version.includes("Old")||v.tools_version.includes("NeedUpgrade")));
      const notRunning=vms.filter(v=>v.status==="poweredOn"&&v.tools_status&&!v.tools_status.includes("Running")&&!v.tools_status.includes("notInstalled"));
      if(!notInstalled.length&&!needsUpgrade.length&&!notRunning.length) return "✅ VMware Tools is running and up to date on all powered-on VMs.";
      let out="🔧 VMware Tools Issues\n";
      if(notInstalled.length) out+=`\n❌ NOT INSTALLED (${notInstalled.length})\n`+notInstalled.map(v=>`• ${v.name}  OS:${v.guest_os||"—"}  vCenter:${v.vcenter_name||"—"}`).join("\n");
      if(needsUpgrade.length) out+=`\n⚠️ NEEDS UPGRADE (${needsUpgrade.length})\n`+needsUpgrade.map(v=>`• ${v.name}  vCenter:${v.vcenter_name||"—"}`).join("\n");
      if(notRunning.length)   out+=`\n🛑 NOT RUNNING (${notRunning.length})\n`+notRunning.map(v=>`• ${v.name}  vCenter:${v.vcenter_name||"—"}`).join("\n");
      return out;
    }

    // ── UPTIME ────────────────────────────────────────────────────────────────
    if(any("uptime","longest running","running longest","longest uptime")){
      const list=vms.filter(v=>v.status==="poweredOn"&&(v.uptime_sec||0)>0).sort((a,b)=>(b.uptime_sec||0)-(a.uptime_sec||0)).slice(0,15);
      if(!list.length) return "No uptime data available yet.";
      return `⏱️ VMs by Uptime (longest first)\n\n`+list.map(v=>`• ${v.name}  ${fmtUptime(v.uptime_sec)}  Host:${v.host||"—"}  vCenter:${v.vcenter_name||"—"}`).join("\n");
    }

    // ── RECENTLY STARTED ─────────────────────────────────────────────────────
    if(any("recently started","just started","newly started","started recently","rebooted")){
      const list=vms.filter(v=>v.status==="poweredOn"&&(v.uptime_sec||0)>0&&(v.uptime_sec||0)<7200).sort((a,b)=>(a.uptime_sec||0)-(b.uptime_sec||0));
      if(!list.length) return "No VMs started in the last 2 hours.";
      return `🔄 Recently Started VMs (< 2h uptime)\n\n`+list.map(v=>`• ${v.name}  Uptime:${fmtUptime(v.uptime_sec)}  Host:${v.host||"—"}`).join("\n");
    }

    // ── MULTI-IP / MULTI-NIC ─────────────────────────────────────────────────
    if(any("multi ip","multiple ip","dual nic","multi nic","two ip","multiple nic")){
      const list=vms.filter(v=>(v.all_ips&&v.all_ips.length>1)||(v.networks&&v.networks.length>1));
      if(!list.length) return "No VMs with multiple IPs or NICs found.";
      return `🌐 VMs with Multiple IPs/NICs (${list.length})\n\n`+list.map(v=>`• ${v.name}  IPs:${(v.all_ips||[]).join(", ")||"—"}  NICs:${(v.networks||[]).length}  vCenter:${v.vcenter_name||"—"}`).join("\n");
    }

    // ── WINDOWS VMs ──────────────────────────────────────────────────────────
    if(any("windows vm","windows server","win vm")){
      const list=vms.filter(v=>v.guest_os&&v.guest_os.toLowerCase().includes("windows"));
      if(!list.length) return "No Windows VMs found.";
      return `🪟 Windows VMs (${list.length})\n\n`+list.map(fmtVM).join("\n");
    }

    // ── LINUX VMs ─────────────────────────────────────────────────────────────
    if(any("linux vm","ubuntu","centos","rhel","linux server","red hat")){
      const list=vms.filter(v=>v.guest_os&&(v.guest_os.toLowerCase().includes("linux")||v.guest_os.toLowerCase().includes("ubuntu")||v.guest_os.toLowerCase().includes("centos")||v.guest_os.toLowerCase().includes("red hat")));
      if(!list.length) return "No Linux VMs found.";
      return `🐧 Linux VMs (${list.length})\n\n`+list.map(fmtVM).join("\n");
    }

    // ── VMs WITH ANNOTATIONS ─────────────────────────────────────────────────
    if(any("annotation","note","description","tagged","comment")){
      const list=vms.filter(v=>v.annotation&&v.annotation.length>0);
      if(!list.length) return "No VMs have annotations/notes set.";
      return `📝 VMs with Annotations (${list.length})\n\n`+list.map(v=>`• ${v.name}\n  📌 ${v.annotation}`).join("\n\n");
    }

    // ── HOST DETAIL CARD ──────────────────────────────────────────────────────
    if(any("host info","host detail","esxi info","about host")){
      const words=input.trim().split(/\s+/);
      const skip=new Set(["host","info","detail","show","esxi","about","details","of","for","status"]);
      const tokens=words.filter(w=>w.length>2&&!skip.has(w.toLowerCase()));
      const match=tokens.length?hosts.find(h=>tokens.some(tok=>h.name.toLowerCase().includes(tok.toLowerCase()))):null;
      if(match){
        const hVMs=vms.filter(v=>v.host===match.name);
        const cpuUsed=Math.round(100-(match.cpu_free_pct||0));
        const ramUsed=Number((match.ram_total_gb-(match.ram_free_gb||0)).toFixed(1));
        const ramPct=match.ram_total_gb>0?Math.round(100*ramUsed/match.ram_total_gb):0;
        return "╔══════════════════════════════════════\n"+
          `  HOST: ${match.name}\n`+
          `  Status : ${match.status==="connected"?"🟢 Connected":"🔴 "+match.status}\n`+
          "══════════════════════════════════════\n"+
          `  CPU Model : ${match.cpu_model||"—"}\n`+
          `  CPU Cores : ${match.cpu_cores||"—"}  Used:${cpuUsed}%\n`+
          `  RAM Total : ${match.ram_total_gb} GB\n`+
          `  RAM Used  : ${ramUsed} GB (${ramPct}%)  Free:${match.ram_free_gb} GB\n`+
          `══ VMs on Host (${hVMs.length}) ═══════════════════\n`+
          hVMs.slice(0,10).map(v=>`  • ${v.name}  [${v.status==="poweredOn"?"ON":"OFF"}]  CPU:${v.cpu}  RAM:${v.ram_gb}GB  IP:${v.ip||"—"}`).join("\n")+
          (hVMs.length>10?"\n  … and "+(hVMs.length-10)+" more":"")+
          "\n══ PLATFORM ════════════════════════════\n"+
          `  vCenter : ${match.vcenter_name||match.vcenter_id||"—"}\n`+
          "╚══════════════════════════════════════";
      }
    }

    // ── STORAGE OVERVIEW ─────────────────────────────────────────────────────
    if(any("storage overview","storage summary","total storage","disk overview")){
      const total=datastores.reduce((a,d)=>a+(d.total_gb||0),0);
      const used=datastores.reduce((a,d)=>a+(d.total_gb||0)-(d.free_gb||0),0);
      const free=datastores.reduce((a,d)=>a+(d.free_gb||0),0);
      const pct=total>0?Math.round(100*used/total):0;
      const toTB=v=>v>=1000?(v/1024).toFixed(1)+"TB":Math.round(v)+"GB";
      return `💾 Storage Overview\n━━━━━━━━━━━━━━━━━━━━━━\nTotal    : ${toTB(total)}\nUsed     : ${toTB(used)} (${pct}%)\nFree     : ${toTB(free)}\nDSs      : ${datastores.length}\n🔴 Critical (≥90%): ${datastores.filter(d=>d.used_pct>=90).length}\n🟡 Warning  (≥75%): ${datastores.filter(d=>d.used_pct>=75&&d.used_pct<90).length}\n✅ Healthy          : ${datastores.filter(d=>d.used_pct<75).length}`;
    }

    // ── CAPACITY PLANNING ────────────────────────────────────────────────────
    if(any("capacity","planning","running out","forecast","grow")){
      const critical=datastores.filter(d=>d.used_pct>=90);
      const dsWarn=datastores.filter(d=>d.used_pct>=75&&d.used_pct<90);
      const cpuHeavy=hosts.filter(h=>(100-(h.cpu_free_pct||0))>=80);
      const ramHeavy=hosts.filter(h=>h.ram_total_gb>0&&((h.ram_total_gb-(h.ram_free_gb||0))/h.ram_total_gb)>=0.85);
      const oldSnaps=snapshots.filter(s=>(s.age_days||0)>30).length;
      const offVMs=vms.filter(v=>v.status==="poweredOff").length;
      let out="📈 Capacity Planning Summary\n━━━━━━━━━━━━━━━━━━━━━━\n";
      out+=critical.length?`🔴 STORAGE CRITICAL: ${critical.map(d=>d.name).join(", ")}\n`:"✅ No critical datastores\n";
      out+=dsWarn.length?`🟡 STORAGE WARNING:  ${dsWarn.map(d=>d.name).join(", ")}\n`:"";
      out+=cpuHeavy.length?`🔥 CPU PRESSURE:     ${cpuHeavy.map(h=>h.name).join(", ")}\n`:"✅ CPU healthy\n";
      out+=ramHeavy.length?`🧠 RAM PRESSURE:     ${ramHeavy.map(h=>h.name).join(", ")}\n`:"✅ Memory healthy\n";
      if(oldSnaps>0) out+=`\n💡 ${oldSnaps} snapshots >30d — reclaim storage`;
      if(offVMs>0)   out+=`\n💡 ${offVMs} powered-off VMs using disk — consider cleanup`;
      return out;
    }

    // ── HELP ──────────────────────────────────────────────────────────────────
    if(any("help","what can","commands","examples","how do","what do")){
      return "🤖 CaaS Assistant — Commands\n\n📊 Overview\n  summary · capacity planning · storage overview\n\n💻 VMs\n  all vms · powered off · powered on\n  windows vms · linux vms\n  vms without ip · vms without snapshots\n  top 10 largest · most ram · most cpu\n  multi ip vms · uptime · recently started\n  vmware tools · vms with annotations\n  info <vmname>  ← full VM detail card\n\n🖥️ Hosts\n  all hosts · disconnected hosts\n  high cpu · high memory\n  host info <hostname>  ← full host card\n\n💾 Storage\n  datastores nearly full · all datastores\n  inaccessible · storage overview\n\n📸 Snapshots\n  snapshot summary · old snapshots\n  snapshots older than 30 days\n\n🚨 Alerts\n  active alerts · critical alerts\n\n🏢 vCenters\n  list vcenters\n\nAll live — no internet needed!";
    }

    // ── FALLBACK ──────────────────────────────────────────────────────────────
    return `I didn't understand "${input}".\n\nTry:\n• "summary"  · "info <vmname>"\n• "powered off vms"  · "high cpu hosts"\n• "datastores nearly full"  · "active alerts"\n• "help" for all commands`;
  };
}

function CaaSChatbot({vms,hosts,datastores,snapshots,networks,summary,vcenters,alerts,currentUser,onClose,p}){
  const [msgs,setMsgs]=useState([
    {role:"assistant",content:"👋 Hi! I'm your CaaS Assistant.\n\nI run fully offline using your live dashboard data — no internet required.\n\nAsk me about VMs, hosts, storage, snapshots, alerts, or anything in your infrastructure. Type 'help' to see all commands.",exportHint:null}
  ]);
  const [input,setInput]=useState("");
  const endRef=useRef(null);
  useEffect(()=>{ endRef.current?.scrollIntoView({behavior:"smooth"}); },[msgs]);

  const engine = localChatEngine({vms,hosts,datastores,snapshots,alerts,vcenters,currentUser});

  function send(){
    const text=input.trim();
    if(!text) return;
    setInput("");
    const answer = engine(text);
    const hasData = answer.includes("•");
    setMsgs(m=>[...m,
      {role:"user",content:text,exportHint:null},
      {role:"assistant",content:answer,exportHint:hasData?text:null}
    ]);
  }

  function exportCSV(content){
    const lines=content.split("\n").filter(l=>l.trim().startsWith("•"));
    if(!lines.length){alert("No list data to export.");return;}
    const rows=lines.map(l=>l.replace(/^•\s*/,"").split(/\s{2,}|:\s+/));
    const csv="data:text/csv;charset=utf-8,"+rows.map(r=>r.map(f=>`"${(f||"").trim()}"`).join(",")).join("\n");
    const a=document.createElement("a"); a.href=encodeURI(csv); a.download="caas_export.csv"; a.click();
  }

  function exportTXT(content,hint){
    const blob=new Blob([`CaaS Export: ${hint}\nGenerated: ${new Date().toLocaleString()}\n\n${content}`],{type:"text/plain"});
    const a=document.createElement("a"); a.href=URL.createObjectURL(blob); a.download="caas_export.txt"; a.click();
  }

  function exportPDF(content,hint){
    const _origin=window.location.origin;
    const html=`<!DOCTYPE html><html><head><title>CaaS Export</title>
    <style>
    @page{margin:20mm 14mm 20mm 14mm}
    *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;color-adjust:exact!important}
    body{font-family:monospace;font-size:12px;padding:20px;max-width:900px;margin:auto}
    h2{font-size:16px;color:#1e293b}pre{white-space:pre-wrap;background:#f8fafc;padding:12px;border-radius:6px;border:1px solid #e2e8f0}
    .meta{color:#64748b;font-size:11px;margin-bottom:8px}
    .print-header,.print-footer{display:none}
    @media print{
      .print-header{display:flex!important;position:fixed;top:0;left:0;right:0;height:44px;
        align-items:center;padding:0 8mm;border-bottom:1.5px solid #334155;
        background:#fff;z-index:9999;gap:10px}
      .print-footer{display:flex!important;position:fixed;bottom:0;left:0;right:0;height:28px;
        align-items:center;justify-content:center;
        border-top:1px solid #e2e8f0;background:#fff;
        font-size:10px;color:#64748b;z-index:9999;font-family:Arial,sans-serif;letter-spacing:.3px}
      body{padding-top:54px;padding-bottom:36px}
    }
    </style></head>
    <body>
    <div class="print-header"><img src="${_origin}/wings.png" height="34" style="object-fit:contain" alt="Wipro Wings"/></div>
    <div class="print-footer">CaaS Portal &mdash; Wipro Confidential</div>
    <h2>CaaS Infrastructure Report</h2>
    <div class="meta">Query: ${hint} &nbsp;·&nbsp; Generated: ${new Date().toLocaleString()}</div>
    <pre>${content.replace(/</g,"&lt;")}</pre>
    <script>window.onload=()=>{window.print();window.onafterprint=()=>window.close();}<\/script>
    </body></html>`;
    const w=window.open("","_blank");
    if(w){w.document.write(html);w.document.close();}
  }

  const SUGGESTIONS=["Summary","info <vmname>","Powered off VMs","High CPU hosts","Datastores nearly full","Active alerts","VMware Tools","Uptime","Windows VMs","Linux VMs","Capacity planning","Help"];

  return(
    <div style={{position:"fixed",inset:0,zIndex:999,display:"flex",alignItems:"flex-end",justifyContent:"flex-end",padding:20,pointerEvents:"none"}}>
      <div style={{width:500,height:640,display:"flex",flexDirection:"column",
        background:p.panel,border:`1px solid ${p.border}`,borderRadius:16,
        boxShadow:"0 24px 80px rgba(0,0,0,.6)",animation:"fadeUp .25s ease",pointerEvents:"all",overflow:"hidden"}}>

        {/* Header */}
        <div style={{padding:"12px 16px",borderBottom:`1px solid ${p.border}`,
          background:`linear-gradient(135deg,${p.purple}18,${p.accent}12)`,
          display:"flex",alignItems:"center",gap:10,flexShrink:0}}>
          <div style={{width:34,height:34,borderRadius:10,
            background:`linear-gradient(135deg,${p.purple},${p.accent})`,
            display:"flex",alignItems:"center",justifyContent:"center",fontSize:17}}>🤖</div>
          <div style={{flex:1}}>
            <div style={{fontWeight:700,fontSize:14}}>LaaS Assistant</div>
            <div style={{fontSize:10,color:p.textMute}}>Offline · Live Data · {vms.length} VMs · {hosts.length} hosts · {alerts.filter(a=>a.severity==="error").length} critical</div>
          </div>
          <button className="btn btn-ghost btn-sm" onClick={onClose}>✕</button>
        </div>

        {/* Messages */}
        <div style={{flex:1,overflowY:"auto",padding:"10px 12px",display:"flex",flexDirection:"column",gap:10}}>
          {msgs.map((m,i)=>(
            <div key={i} style={{display:"flex",flexDirection:"column",alignItems:m.role==="user"?"flex-end":"flex-start",gap:4}}>
              <div style={{
                maxWidth:"95%",padding:"9px 12px",
                borderRadius:m.role==="user"?"12px 12px 4px 12px":"12px 12px 12px 4px",
                fontSize:11.5,lineHeight:1.65,
                fontFamily:"'Geist Mono',monospace",
                whiteSpace:"pre-wrap",wordBreak:"break-word",
                background:m.role==="user"?`linear-gradient(135deg,${p.accent},${p.cyan})`:p.panelAlt,
                color:m.role==="user"?"#fff":p.text,
                border:m.role==="user"?"none":`1px solid ${p.border}`,
              }}>
                {m.content}
              </div>
              {m.role==="assistant"&&m.exportHint&&(
                <div style={{display:"flex",gap:5,flexWrap:"wrap",paddingLeft:4}}>
                  <span style={{fontSize:9,color:p.textMute,alignSelf:"center",marginRight:2}}>Export:</span>
                  {[
                    {label:"📄 PDF", fn:()=>exportPDF(m.content,m.exportHint)},
                    {label:"📊 CSV", fn:()=>exportCSV(m.content)},
                    {label:"📋 TXT", fn:()=>exportTXT(m.content,m.exportHint)},
                  ].map(({label,fn})=>(
                    <button key={label} onClick={fn}
                      style={{fontSize:9,padding:"2px 8px",borderRadius:12,cursor:"pointer",
                        fontWeight:600,background:`${p.accent}15`,border:`1px solid ${p.accent}30`,
                        color:p.accent,fontFamily:"inherit",transition:"all .1s"}}
                      onMouseEnter={e=>e.currentTarget.style.background=`${p.accent}30`}
                      onMouseLeave={e=>e.currentTarget.style.background=`${p.accent}15`}>
                      {label}
                    </button>
                  ))}
                </div>
              )}
            </div>
          ))}
          <div ref={endRef}/>
        </div>

        {/* Suggestions */}
        {msgs.length<=1&&(
          <div style={{padding:"0 10px 6px",display:"flex",flexWrap:"wrap",gap:4,flexShrink:0}}>
            {SUGGESTIONS.map((s,i)=>(
              <button key={i} onClick={()=>{ setInput(""); const a=engine(s); const hasData=a.includes("•"); setMsgs(m=>[...m,{role:"user",content:s},{role:"assistant",content:a,exportHint:hasData?s:null}]); }}
                style={{fontSize:10,padding:"3px 8px",borderRadius:20,cursor:"pointer",fontWeight:500,
                  background:`${p.accent}10`,border:`1px solid ${p.accent}28`,color:p.accent,fontFamily:"inherit"}}>
                {s}
              </button>
            ))}
          </div>
        )}

        {/* Input */}
        <div style={{padding:"8px 10px",borderTop:`1px solid ${p.border}`,
          background:p.panelAlt,display:"flex",gap:7,alignItems:"center",flexShrink:0}}>
          <input
            value={input}
            onChange={e=>setInput(e.target.value)}
            onKeyDown={e=>{if(e.key==="Enter"&&!e.shiftKey){e.preventDefault();send();}}}
            placeholder="Ask about your infra… (type 'help' for commands)"
            style={{flex:1,padding:"7px 10px",background:p.panel,border:`1px solid ${p.border}`,
              borderRadius:7,fontSize:12,color:p.text,fontFamily:"inherit",outline:"none"}}
          />
          <button onClick={send} disabled={!input.trim()}
            style={{padding:"7px 14px",borderRadius:7,fontSize:13,fontWeight:700,cursor:"pointer",
              background:input.trim()?`linear-gradient(135deg,${p.purple},${p.accent})`:p.border,
              border:"none",color:input.trim()?"#fff":p.textMute,transition:"all .15s",flexShrink:0}}>
            ↑
          </button>
        </div>
      </div>
    </div>
  );
}

// ─── LOGIN ────────────────────────────────────────────────────────────────────
function Login({onLogin,p}){
  const [u,setU]=useState(""); const [pw,setPw]=useState("");
  const [err,setErr]=useState(""); const [busy,setBusy]=useState(false);
  async function go(){
    if(!u.trim()){setErr("Enter your username.");return;}
    if(!pw){setErr("Enter your password.");return;}
    setBusy(true);setErr("");
    try{
      const user = await login(u.trim(), pw);
      onLogin(user);
    }catch(e){
      setErr(e.message||"Login failed. Check credentials or AD connectivity.");
    }
    setBusy(false);
  }
  return(
    <div className="login-bg">
      <div style={{position:"relative",width:420,animation:"fadeUp .4s ease",zIndex:1}}>
        <div style={{textAlign:"center",marginBottom:28}}>
          <img src="/wings.png" alt="Wipro Wings" style={{width:"100%",maxWidth:260,height:"auto",filter:"drop-shadow(0 4px 24px rgba(0,0,0,.6))",marginBottom:12}}/>
          <div style={{fontSize:17,color:"rgba(255,255,255,.9)",fontWeight:600,letterSpacing:".5px",textShadow:"0 2px 12px rgba(0,0,0,.7)"}}>Lab as a Service Portal</div>
          <div style={{fontSize:12,color:"rgba(255,255,255,.55)",marginTop:4,letterSpacing:".3px"}}>Hybrid-Cloud Infrastructure Engineering Lab</div>
        </div>
        <div className="card" style={{padding:32,background:"rgba(15,8,40,.78)",backdropFilter:"blur(18px)",WebkitBackdropFilter:"blur(18px)",border:"1px solid rgba(255,255,255,.12)",boxShadow:"0 24px 64px rgba(0,0,0,.6)"}}>
          <div style={{fontWeight:700,fontSize:19,marginBottom:22,textAlign:"center",color:"#fff",letterSpacing:".2px"}}>Sign In</div>
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <div>
              <label>Username</label>
              <input value={u} onChange={e=>setU(e.target.value)}
                placeholder="AD username or admin"
                onKeyDown={e=>e.key==="Enter"&&go()} autoFocus/>
              <div style={{fontSize:10,color:p.textMute,marginTop:3}}>Use your Windows AD username (e.g. jsmith)</div>
            </div>
            <div>
              <label>Password</label>
              <input type="password" value={pw} onChange={e=>setPw(e.target.value)}
                placeholder="Password" onKeyDown={e=>e.key==="Enter"&&go()}/>
            </div>
            {err&&<div style={{color:"#fca5a5",fontSize:12,padding:"8px 12px",background:"rgba(239,68,68,.18)",borderRadius:7,border:"1px solid rgba(239,68,68,.35)"}}>⚠️ {err}</div>}
            <button className="btn btn-primary" style={{width:"100%",padding:"11px",fontSize:15,fontWeight:800,justifyContent:"center",marginTop:4,background:"linear-gradient(135deg,#fbbf24,#f97316)",color:"#1a1a1a",border:"none",boxShadow:"0 4px 24px rgba(251,191,36,.55)",letterSpacing:"0.5px"}}
              onClick={go} disabled={busy}>
              {busy?<><span className="spinner" style={{width:16,height:16,borderWidth:2}}/> Authenticating…</> :"Sign In →"}
            </button>
          </div>
          <div style={{marginTop:16,padding:"10px 12px",background:"rgba(255,255,255,.07)",borderRadius:7,border:"1px solid rgba(255,255,255,.12)",fontSize:11,color:"rgba(255,255,255,.5)",textAlign:"center"}}>
            🔐 Authenticates against <strong style={{color:"rgba(255,255,255,.75)"}}>sdxtest.local</strong> Active Directory
          </div>
        </div>
      </div>
    </div>
  );
}



// ─── VM REQUEST FORM ─────────────────────────────────────────────────────────
function VMRequestForm({vcenters, currentUser, ocpData, nutData, onClose, onSubmitted, p, vmwareOnly=false}) {
  const [step,     setStep]    = useState(1);
  const [busy,     setBusy]    = useState(false);
  const [result,   setResult]  = useState(null);
  const [vcRes,     setVcRes]    = useState(null);
  const [templates, setTemplates]= useState([]);
  const [tmplLoad,  setTmplLoad] = useState(false);
  // Step 1 — Basics
  const [vcId,      setVcId]     = useState(vcenters[0]?.id||"");
  const [vmName,    setVmName]   = useState("");
  const [osTemp,    setOsTemp]   = useState("");
  const [customTmpl,setCustomTmpl]=useState("");
  const [duration,  setDuration] = useState("permanent");
  const [notes,     setNotes]    = useState("");
  // Step 2 — Resources
  const [cpu,       setCpu]      = useState(2);
  const [ram,       setRam]      = useState(4);
  const [disk,      setDisk]     = useState(50);
  const [diskType,  setDiskType] = useState("HDD");  // SSD | HDD
  const [host,      setHost]     = useState("");
  const [ds,        setDs]       = useState("");
  const [includeLicense, setIncludeLicense] = useState(false);  // OS license
  const [includeInternet, setIncludeInternet] = useState(false); // internet access

  // Auto-derive disk type from selected datastore's disk_type field (ESXi-detected)
  useEffect(()=>{
    if(!ds) return;  // user toggled manually — don't override when no ds selected
    // find the datastore object from vcRes
    const allDs = [
      ...(vcRes?.datastores||[]),
      ...(vcRes?.hosts||[]).flatMap(h=>h.datastores||[]),
    ];
    const found = allDs.find(d=>d.name===ds);
    if(found?.disk_type) setDiskType(found.disk_type);
    else setDiskType(/ssd/i.test(ds)?"SSD":"HDD"); // fallback
  },[ds]);

  // Reset datastore selection when disk type changes and current ds no longer matches
  useEffect(()=>{
    if(!ds) return;
    const allDs = [
      ...(vcRes?.datastores||[]),
      ...(vcRes?.hosts||[]).flatMap(h=>h.datastores||[]),
    ];
    const found = allDs.find(d=>d.name===ds);
    if(found && found.disk_type && found.disk_type !== diskType) setDs("");
  },[diskType]);
  // Step 3 — Network & IP
  const [network,   setNetwork]  = useState("");
  const [ipMode,    setIpMode]   = useState("dhcp");  // dhcp | static
  const [ipAddr,    setIpAddr]   = useState("");
  const [subnet,    setSubnet]   = useState("255.255.255.0");
  const [gateway,   setGateway]  = useState("");
  const [dns1,      setDns1]     = useState("");
  const [dns2,      setDns2]     = useState("");
  const [hostname,  setHostname] = useState("");
  const [domain,    setDomain]   = useState("");

  // Pricing
  const [pricing, setPricing] = useState(null);
  useEffect(()=>{ fetchPricing().then(setPricing).catch(()=>setPricing(DEFAULT_PRICING)); },[]);

  // ── Platform & OCP state ──
  const [platform,setPlatform]=useState("vmware");
  const [ocpCluster,setOcpCluster]=useState((ocpData?.clusters||[])[0]?.id||"");
  const [ocpNs,setOcpNs]=useState("");
  const [ocpWorkloadName,setOcpWorkloadName]=useState("");
  const [ocpWorkloadType,setOcpWorkloadType]=useState("Deployment");
  const [ocpImage,setOcpImage]=useState("");
  const [ocpImageCustom,setOcpImageCustom]=useState("");
  const [ocpCpuReq,setOcpCpuReq]=useState("100m");
  const [ocpCpuLim,setOcpCpuLim]=useState("500m");
  const [ocpMemReq,setOcpMemReq]=useState("256Mi");
  const [ocpMemLim,setOcpMemLim]=useState("512Mi");
  const [ocpReplicas,setOcpReplicas]=useState(1);
  const [ocpPvcSize,setOcpPvcSize]=useState("10");
  const [ocpStorageClass,setOcpStorageClass]=useState("");
  const [ocpDuration,setOcpDuration]=useState("permanent");
  const [ocpNotes,setOcpNotes]=useState("");
  // ── Nutanix state ──
  const [nutPcId,setNutPcId]=useState((nutData?.pcs||[])[0]?.id||"");
  const [nutCluster,setNutCluster]=useState("");
  const [nutVmName,setNutVmName]=useState("");
  const [nutImage,setNutImage]=useState("");
  const [nutImageCustom,setNutImageCustom]=useState("");
  const [nutImages,setNutImages]=useState([]);
  const [nutImagesLoading,setNutImagesLoading]=useState(false);
  const [nutCpu,setNutCpu]=useState(2);
  const [nutRam,setNutRam]=useState(4);
  const [nutDisk,setNutDisk]=useState(50);
  const [nutDiskType,setNutDiskType]=useState("HDD");
  const [nutNetwork,setNutNetwork]=useState("");
  const [nutDuration,setNutDuration]=useState("permanent");
  const [nutNotes,setNutNotes]=useState("");
  // Fetch Nutanix images when PC changes
  useEffect(()=>{
    if(!nutPcId) return;
    setNutImagesLoading(true); setNutImages([]);
    fetchNutanixImages(nutPcId).then(imgs=>setNutImages(imgs||[])).catch(()=>setNutImages([])).finally(()=>setNutImagesLoading(false));
  },[nutPcId]);

  // Auto-fill hostname from VM name
  useEffect(()=>{ if(!hostname&&vmName) setHostname(vmName); },[vmName]);

  useEffect(()=>{
    if(vcId){
      setVcRes(null);
      fetchVCResources(vcId).then(setVcRes).catch(()=>{});
      setTmplLoad(true); setTemplates([]);
      fetchVCTemplates(vcId).then(r=>{ setTemplates(r.templates||[]); }).catch(()=>{}).finally(()=>setTmplLoad(false));
    }
  },[vcId]);

  // Derive effective template name
  const effectiveTemplate = osTemp==="__custom" ? customTmpl : osTemp;
  // Auto-detect OS license type from selected template's guest_os or template name
  const detectedLicType = detectLicType(
    templates.find(t=>t.name===osTemp)?.guest_os || osTemp || customTmpl || ""
  );

  // Validate IP address format
  const validIP = (ip) => /^(\d{1,3}\.){3}\d{1,3}$/.test(ip) && ip.split(".").every(n=>Number(n)<=255);
  const ipValid = ipMode==="dhcp" || (validIP(ipAddr) && ipAddr!="" && gateway!="" && dns1!="");

  async function submit(){
    setBusy(true);
    try{
      const fullNotes = duration!=="permanent" ? `[Duration: ${duration}] ${notes}` : notes;
      const req = await submitVMRequest({
        vcenter_id:vcId, vm_name:vmName.trim(), cpu, ram_gb:ram,
        disk_gb:disk, os_template:effectiveTemplate||"custom",
        host, datastore:ds, network, notes:fullNotes,
        ip_mode:ipMode, ip_address:ipAddr, subnet_mask:subnet,
        gateway, dns1, dns2,
        hostname:hostname||vmName.trim(), domain,
        include_license:includeLicense,
        license_type:includeLicense?detectedLicType:"",
        include_internet:includeInternet,
      });
      setResult({ok:true,req}); onSubmitted&&onSubmitted();
    }catch(e){ setResult({ok:false,msg:e.message}); }
    setBusy(false);
  }

  async function submitOCP(){
    setBusy(true);
    try{
      const effOcpImage=ocpImage==="__custom"?ocpImageCustom:ocpImage;
      const clusterName=(ocpData?.clusters||[]).find(c=>c.id===ocpCluster)?.name||ocpCluster;
      const fullNotes=`[Platform:OpenShift][Cluster:${clusterName}][Namespace:${ocpNs}][Type:${ocpWorkloadType}][Image:${effOcpImage}][CPU:${ocpCpuReq}→${ocpCpuLim}][Mem:${ocpMemReq}→${ocpMemLim}][Replicas:${ocpReplicas}][Storage:${ocpPvcSize}Gi/${ocpStorageClass||"default"}]${ocpDuration!=="permanent"?`[Duration:${ocpDuration}]`:""} ${ocpNotes}`.trim();
      const req=await submitVMRequest({vcenter_id:"openshift",vm_name:ocpWorkloadName,cpu:0,ram_gb:0,disk_gb:parseInt(ocpPvcSize)||0,os_template:effOcpImage,network:ocpNs,notes:fullNotes,hostname:ocpWorkloadName});
      setResult({ok:true,req}); onSubmitted&&onSubmitted();
    }catch(e){ setResult({ok:false,msg:e.message}); }
    setBusy(false);
  }

  async function submitNutanix(){
    setBusy(true);
    try{
      const effNutImage=nutImage==="__custom"?nutImageCustom:nutImage;
      const pcName=(nutData?.pcs||[]).find(pc=>pc.id===nutPcId)?.name||nutPcId;
      const fullNotes=`[Platform:Nutanix][PC:${pcName}][Cluster:${nutCluster||"auto"}][Image:${effNutImage}][Network:${nutNetwork||"auto"}][DiskType:${nutDiskType}]${nutDuration!=="permanent"?`[Duration:${nutDuration}]`:""} ${nutNotes}`.trim();
      const req=await submitVMRequest({vcenter_id:"nutanix",vm_name:nutVmName,cpu:nutCpu,ram_gb:nutRam,disk_gb:nutDisk,os_template:effNutImage,network:nutNetwork,notes:fullNotes,hostname:nutVmName});
      setResult({ok:true,req}); onSubmitted&&onSubmitted();
    }catch(e){ setResult({ok:false,msg:e.message}); }
    setBusy(false);
  }

  const valid1     = vcId && vmName.trim().length >= 3;
  const STEPS      = ["Basics","Resources","Network & IP","Confirm"];
  const ocpSteps   = ["Basics","Resources","Confirm"];
  const nutSteps   = ["Basics","Resources","Confirm"];
  const effOcpImg  = ocpImage==="__custom"?ocpImageCustom:ocpImage;
  const effNutImg   = nutImage==="__custom"?nutImageCustom:nutImage;
  const validOCP1  = ocpCluster&&ocpNs.trim().length>=1&&ocpWorkloadName.trim().length>=3&&effOcpImg.trim().length>=1;
  const validNut1  = nutPcId&&nutVmName.trim().length>=3;
  const curSteps   = platform==="vmware"?STEPS:platform==="openshift"?ocpSteps:nutSteps;
  const plColor    = platform==="vmware"?"#3b82f6":platform==="openshift"?"#ef4444":"#22c55e";

  function nextStep(){ setStep(s=>Math.min(s+1, curSteps.length)); }
  function prevStep(){ setStep(s=>Math.max(s-1, 1)); }

  return(
    <div className="overlay" onClick={onClose}>
      <div className="modal" style={{width:640}} onClick={e=>e.stopPropagation()}>
        {/* Header */}
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:16}}>
          <div>
            <div style={{fontWeight:800,fontSize:16,letterSpacing:"-.2px"}}>
              {platform==="vmware"?"🖥️ Request VMware Virtual Machine":platform==="openshift"?"🔴 Request OpenShift Workload":"🟩 Request Nutanix AHV Virtual Machine"}
            </div>
            <div style={{fontSize:11,color:p.textMute,marginTop:2}}>
              {platform==="vmware"?"Deploy a VM on VMware vCenter infrastructure":platform==="openshift"?"Deploy containerised workloads on OpenShift cluster":"Deploy a VM on Nutanix hyper-converged infrastructure"}
            </div>
          </div>
          <button className="btn btn-ghost btn-sm" onClick={onClose}>✕</button>
        </div>

        {/* ── Platform Selector ── */}
        {!result&&(
          <div style={{display:"grid",gridTemplateColumns:vmwareOnly?"1fr":`1fr 1fr 1fr`,gap:8,marginBottom:18,padding:"12px 14px",background:p.panelAlt,borderRadius:12,border:`1px solid ${p.border}`}}>
            {[
              {id:"vmware",   icon:"🖥️", label:"VMware vCenter", sub:"Virtual Machines on ESXi",    color:"#3b82f6"},
              {id:"openshift",icon:"🔴", label:"OpenShift",       sub:"Container Workloads on OCP",  color:"#ef4444"},
              {id:"nutanix",  icon:"🟩", label:"Nutanix AHV",     sub:"VMs on Hyper-Converged Infra",color:"#22c55e"},
            ].filter(pl=>!vmwareOnly||pl.id==="vmware").map(pl=>{
              const active=platform===pl.id;
              return(
                <div key={pl.id}
                  onClick={()=>{ if(platform!==pl.id){setPlatform(pl.id);setStep(1);setResult(null);} }}
                  style={{padding:"10px 12px",borderRadius:9,cursor:"pointer",transition:"all .15s",
                    background:active?`${pl.color}15`:p.surface||"#0c1525",
                    border:`2px solid ${active?pl.color:p.border}`,
                    boxShadow:active?`0 0 0 3px ${pl.color}20`:"none"}}>
                  <div style={{display:"flex",alignItems:"center",gap:8}}>
                    <span style={{fontSize:22,flexShrink:0}}>{pl.icon}</span>
                    <div style={{flex:1,minWidth:0}}>
                      <div style={{fontWeight:700,fontSize:12,color:active?pl.color:p.text,lineHeight:1.2}}>{pl.label}</div>
                      <div style={{fontSize:10,color:p.textMute,marginTop:1,lineHeight:1.3}}>{pl.sub}</div>
                    </div>
                    {active&&<div style={{width:7,height:7,borderRadius:"50%",background:pl.color,boxShadow:`0 0 6px ${pl.color}`,flexShrink:0}}/>}
                  </div>
                </div>
              );
            })}
          </div>
        )}

        {/* Step indicators */}
        {!result&&(
          <div style={{display:"flex",gap:3,marginBottom:20}}>
            {curSteps.map((s,i)=>(
              <div key={s} style={{flex:1,padding:"5px 0",textAlign:"center",borderRadius:6,
                fontSize:10,fontWeight:600,
                background:step>i+1?p.green:step===i+1?plColor:p.panelAlt,
                color:step>=i+1?"#fff":p.textMute,transition:"all .2s"}}>
                {step>i+1?"✓ ":""}{s}
              </div>
            ))}
          </div>
        )}

        {/* ── STEP 1: Basics ── */}
        {platform==="vmware"&&step===1&&(
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <div className="g2">
              <div><label>vCenter *</label>
                <select value={vcId} onChange={e=>setVcId(e.target.value)}>
                  {vcenters.map(v=><option key={v.id} value={v.id}>{v.name} ({v.host})</option>)}
                </select>
              </div>
              <div><label>VM Name * (no spaces)</label>
                <input value={vmName}
                  onChange={e=>{ const v=e.target.value.replace(/ /g,"-"); setVmName(v); if(!hostname||hostname===vmName) setHostname(v); }}
                  placeholder="e.g. prod-webserver-01"/>
                {vmName.length>0&&vmName.trim().length<3&&(
                  <div style={{fontSize:10,color:p.red,marginTop:3}}>Min 3 characters</div>
                )}
              </div>
            </div>

            {/* Template selector */}
            <div>
              <label>OS Template
                {tmplLoad&&<span style={{fontSize:10,color:p.yellow,marginLeft:6}}>⏳ Loading from vCenter…</span>}
                {!tmplLoad&&templates.length>0&&<span style={{fontSize:10,color:p.green,marginLeft:6}}>✅ {templates.length} found</span>}
                {!tmplLoad&&templates.length===0&&vcId&&<span style={{fontSize:10,color:p.textMute,marginLeft:6}}>None found — enter manually</span>}
              </label>
              {templates.length>0
                ?<select value={osTemp} onChange={e=>{
                    const v=e.target.value; setOsTemp(v);
                    if(v&&v!=="__custom"){
                      const t=templates.find(t=>t.name===v);
                      if(t){ setCpu(t.cpu||cpu); setRam(Math.round(t.ram_gb)||ram); setDisk(Math.round(t.disk_gb)||disk); }
                    }
                  }}>
                    <option value="">— Select template —</option>
                    {templates.map(t=>(
                      <option key={t.name} value={t.name}>
                        {t.name} · {t.guest_os} · {t.cpu}vCPU · {fmtGB(t.ram_gb)} · {fmtGB(t.disk_gb)}
                      </option>
                    ))}
                    <option value="__custom">✏️ Type custom name…</option>
                  </select>
                :<input value={customTmpl} onChange={e=>setCustomTmpl(e.target.value)}
                    placeholder="e.g. windows2022template, rhel9-base (or leave blank)"/>
              }
              {osTemp==="__custom"&&(
                <input style={{marginTop:6}} value={customTmpl} onChange={e=>setCustomTmpl(e.target.value)}
                  placeholder="Type exact template name from vCenter…"/>
              )}
              {osTemp&&osTemp!=="__custom"&&(()=>{
                const t=templates.find(t=>t.name===osTemp);
                return t?<div style={{fontSize:10,color:p.green,marginTop:3,padding:"4px 8px",
                  background:`${p.green}10`,borderRadius:5,border:`1px solid ${p.green}25`}}>
                  ✅ Template found · OS: {t.guest_os} · Resources auto-filled on next step
                </div>:null;
              })()}
              {/* License checkbox — shown when a paid OS is detected */}
              {detectedLicType&&(
                <label style={{display:"flex",alignItems:"center",gap:8,marginTop:6,fontSize:12,
                  padding:"7px 10px",borderRadius:7,cursor:"pointer",
                  background:includeLicense?`#7c3aed15`:`${p.panelAlt}`,
                  border:`1px solid ${includeLicense?"#7c3aed50":p.border}`}}>
                  <input type="checkbox" checked={includeLicense}
                    onChange={e=>setIncludeLicense(e.target.checked)}
                    style={{accentColor:"#7c3aed",width:14,height:14}}/>
                  <span>
                    {detectedLicType==="windows"?"🪟 Include Windows Server SPLA license":"🎩 Include RHEL subscription license"}
                    {" "}
                    {(()=>{
                      const inr = detectedLicType==="windows"?(pricing?.windows_license_month_inr||12500):(pricing?.rhel_license_month_inr||10000);
                      const usd = pricing?.usd_rate||83.5;
                      return(
                        <span style={{color:"#7c3aed",fontWeight:700}}>
                          (₹{Number(inr).toLocaleString("en-IN")}/VM/mo &nbsp;/&nbsp; ${(inr/usd).toFixed(0)}/VM/mo)
                        </span>
                      );
                    })()}
                  </span>
                </label>
              )}
            </div>

            <div className="g2">
              <div><label>Duration</label>
                <select value={duration} onChange={e=>setDuration(e.target.value)}>
                  {["permanent","1 week","2 weeks","1 month","3 months","6 months","1 year"].map(d=>(
                    <option key={d} value={d}>{d.charAt(0).toUpperCase()+d.slice(1)}</option>
                  ))}
                </select>
              </div>
              <div><label>Purpose / Notes</label>
                <input value={notes} onChange={e=>setNotes(e.target.value)} placeholder="What is this VM for?"/>
              </div>
            </div>
          </div>
        )}

        {/* ── STEP 2: Resources ── */}
        {platform==="vmware"&&step===2&&(
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            {effectiveTemplate&&<div style={{padding:"8px 12px",background:`${p.green}10`,borderRadius:7,
              border:`1px solid ${p.green}30`,fontSize:12,color:p.green}}>
              📦 Template: <b>{effectiveTemplate}</b> — resources pre-filled, adjust if needed
            </div>}
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10}}>
              <div><label>CPU Cores</label>
                <select value={cpu} onChange={e=>setCpu(Number(e.target.value))}>
                  {[1,2,4,8,16,32].map(n=><option key={n} value={n}>{n} vCPU{n>1?"s":""}</option>)}
                </select>
              </div>
              <div><label>RAM (GB)</label>
                <select value={ram} onChange={e=>setRam(Number(e.target.value))}>
                  {[1,2,4,8,16,32,64,128].map(n=><option key={n} value={n}>{n} GB</option>)}
                </select>
              </div>
              <div><label>Disk (GB)</label>
                <select value={disk} onChange={e=>setDisk(Number(e.target.value))}>
                  {[20,40,50,80,100,200,500,1000].map(n=><option key={n} value={n}>{n} GB</option>)}
                </select>
              </div>
            </div>
            {/* ── Disk Type selector ── */}
            <div style={{display:"flex",alignItems:"center",gap:8}}>
              <span style={{fontSize:12,color:p.textMute,minWidth:90}}>💾 Disk Type:</span>
              {[["SSD","🟦 SSD","#0ea5e9","Flash/NVMe — faster, higher cost"],
                ["HDD","🟫 HDD","#78716c","Spinning disk — standard cost"]].map(([t,label,clr,tip])=>(
                <button key={t} title={tip} onClick={()=>setDiskType(t)}
                  style={{padding:"4px 12px",borderRadius:20,border:`1.5px solid ${diskType===t?clr:p.border}`,
                    cursor:"pointer",fontSize:12,fontWeight:diskType===t?700:400,
                    background:diskType===t?`${clr}20`:p.panelAlt,
                    color:diskType===t?clr:p.textMute,transition:"all .12s"}}>
                  {label}
                </button>
              ))}
              <span style={{fontSize:10,color:p.textMute}}>
                {ds
                  ? `auto-detected via ESXi SMART from: ${ds}`
                  : "Select a datastore — type auto-detected via ESXi SMART/ATA"
                }
              </span>
            </div>
            {/* ── Cost Estimator ── */}
            {pricing&&(()=>{
              const pr = pricing;
              const usd = pr.usd_rate||83.5;
              const diskRate = diskType==="SSD"?(pr.ssd_per_gb_month_inr||15):(pr.hdd_per_gb_month_inr||pr.disk_per_gb_month_inr||8);
              const cpuCost  = cpu  * (pr.cpu_per_core_month_inr||500);
              const ramCost  = ram  * (pr.ram_per_gb_month_inr||200);
              const diskCost = disk * diskRate;
              const licRate  = includeLicense&&detectedLicType==="windows"?(pr.windows_license_month_inr||12500):includeLicense&&detectedLicType==="rhel"?(pr.rhel_license_month_inr||10000):0;
              const inetRate = includeInternet?(pr.internet_per_vm_month_inr||1500):0;
              const monthly  = cpuCost + ramCost + diskCost + licRate + inetRate;
              const daily    = monthly / 30;
              const yearly   = monthly * 12;
              return(
                <div style={{padding:"12px 14px",background:`${p.accent}10`,borderRadius:8,
                  border:`1px solid ${p.accent}30`}}>
                  <div style={{fontWeight:700,fontSize:12,color:p.accent,marginBottom:8,display:"flex",alignItems:"center",gap:8}}>
                    💰 Estimated Cost (On-Prem Internal Chargeback)
                    <span style={{fontSize:11,fontWeight:600,padding:"2px 8px",borderRadius:12,
                      background:diskType==="SSD"?"#0ea5e920":"#78716c20",
                      color:diskType==="SSD"?"#0ea5e9":"#78716c",
                      border:`1px solid ${diskType==="SSD"?"#0ea5e950":"#78716c50"}`}}>
                      {diskType==="SSD"?"🟦 SSD Storage":"🟫 HDD Storage"}
                    </span>
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginBottom:10}}>
                    {[
                      {l:"CPU ("+cpu+" vCPU)",            c:cpuCost},
                      {l:"RAM ("+ram+" GB)",              c:ramCost},
                      {l:"Disk ("+disk+" GB · "+diskType+")", c:diskCost},
                      ...(licRate>0?[{l:(detectedLicType==="windows"?"🪟 Win Server License":"🎩 RHEL License"),c:licRate}]:[]),
                      ...(inetRate>0?[{l:"🌐 Internet Access",c:inetRate}]:[]),
                    ].map(({l,c:cost})=>(
                      <div key={l} style={{textAlign:"center",padding:"6px 4px",background:p.panelAlt,
                        borderRadius:6,border:`1px solid ${p.border}`}}>
                        <div style={{fontSize:11,color:p.textMute,marginBottom:2}}>{l}</div>
                        <div style={{fontWeight:700,fontSize:13,color:p.text}}>₹{Math.round(cost).toLocaleString("en-IN")}/mo</div>
                        <div style={{fontSize:10,color:p.textMute}}>${(cost/usd).toFixed(1)}/mo</div>
                      </div>
                    ))}
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8}}>
                    {[["Daily",daily],["Monthly",monthly],["Yearly",yearly]].map(([lbl,val])=>(
                      <div key={lbl} style={{textAlign:"center",padding:"8px 4px",background:p.panelAlt,
                        borderRadius:6,border:`1px solid ${p.accent}30`}}>
                        <div style={{fontSize:10,color:p.textMute,textTransform:"uppercase",letterSpacing:".5px"}}>{lbl}</div>
                        <div style={{fontWeight:800,fontSize:15,color:p.accent}}>₹{Math.round(val).toLocaleString("en-IN")}</div>
                        <div style={{fontSize:11,color:p.textMute}}>${(val/usd).toFixed(2)}</div>
                      </div>
                    ))}
                  </div>
                  <div style={{fontSize:10,color:p.textMute,marginTop:6,lineHeight:"1.6"}}>
                    Rates: ₹{pr.cpu_per_core_month_inr}/vCPU/mo · ₹{pr.ram_per_gb_month_inr}/GB RAM/mo ·{" "}
                    {diskType==="SSD"?`₹${pr.ssd_per_gb_month_inr||15}/GB SSD/mo`:`₹${pr.hdd_per_gb_month_inr||pr.disk_per_gb_month_inr||8}/GB HDD/mo`} · 1 USD=₹{usd}
                    &nbsp;|&nbsp;🟦 SSD=₹{pr.ssd_per_gb_month_inr||15}/GB&nbsp;·&nbsp;🟫 HDD=₹{pr.hdd_per_gb_month_inr||pr.disk_per_gb_month_inr||8}/GB
                    &nbsp;|&nbsp;🪟 Win=₹{pr.windows_license_month_inr||12500}/VM/mo&nbsp;·&nbsp;🎩 RHEL=₹{pr.rhel_license_month_inr||10000}/VM/mo
                    {!ds&&<span style={{color:p.yellow}}>&nbsp;· Select a datastore for auto disk-type detection</span>}
                  </div>
                </div>
              );
            })()}

            <div className="g2">
              <div>
                <label>Preferred Host (optional)
                  {diskType==="SSD"&&(()=>{
                    const ssdHosts=(vcRes?.hosts||[]).filter(h=>(h.datastores||[]).some(d=>d.disk_type==="SSD"));
                    return ssdHosts.length>0
                      ?<span style={{fontSize:10,color:"#0ea5e9",marginLeft:6}}>🟦 {ssdHosts.length} host{ssdHosts.length>1?"s":""} with SSD</span>
                      :<span style={{fontSize:10,color:p.yellow,marginLeft:6}}>⚠️ No hosts with SSD detected</span>;
                  })()}
                </label>
                <select value={host} onChange={e=>{ setHost(e.target.value); setDs(""); setNetwork(""); }}>
                  <option value="">— Auto Select —</option>
                  {(()=>{
                    const allHosts = vcRes?.hosts||[];
                    // filter hosts: if SSD selected, only show hosts that have ≥1 SSD datastore
                    const filtered = diskType==="SSD"
                      ? allHosts.filter(h=>(h.datastores||[]).some(d=>d.disk_type==="SSD"))
                      : allHosts;
                    return filtered.map(h=>{
                      const hasSsd=(h.datastores||[]).some(d=>d.disk_type==="SSD");
                      const hasHdd=(h.datastores||[]).some(d=>d.disk_type!=="SSD");
                      const badge = hasSsd&&hasHdd?" 🟦🟫":hasSsd?" 🟦 SSD":" 🟫 HDD";
                      return <option key={h.name} value={h.name}>
                        {h.name}{badge} · {Math.round(100-h.cpu_free_pct)}% CPU · {fmtGB(h.ram_free_gb)} RAM free
                      </option>;
                    });
                  })()}
                </select>
                {host&&<div style={{fontSize:10,color:p.cyan,marginTop:2}}>
                  ℹ️ Datastore & Network dropdowns now filtered for this host
                </div>}
              </div>
              <div><label>Preferred Datastore (optional)
                {(()=>{
                  const hObj=(vcRes?.hosts||[]).find(h=>h.name===host);
                  const dsList = host&&hObj?.datastores?.length>0 ? hObj.datastores : (vcRes?.datastores||[]);
                  const matchDs = dsList.filter(d=>d.disk_type===diskType);
                  const total   = dsList.length;
                  const match   = matchDs.length;
                  if(!total) return null;
                  return <span style={{fontSize:10,color:match>0?"#0ea5e9":p.yellow,marginLeft:6}}>
                    {diskType==="SSD"?"🟦":"🟫"} {match}/{total} {diskType} datastore{match!==1?"s":""
                  }</span>;
                })()}
              </label>
                <select value={ds} onChange={e=>setDs(e.target.value)}>
                  <option value="">— Auto Select —</option>
                  {(()=>{
                    const hObj=(vcRes?.hosts||[]).find(h=>h.name===host);
                    const dsList = host&&hObj?.datastores?.length>0 ? hObj.datastores : (vcRes?.datastores||[]);
                    // Show matching type first, others dimmed
                    const matching  = dsList.filter(d=>d.disk_type===diskType);
                    const rest      = dsList.filter(d=>d.disk_type!==diskType);
                    const renderOpt = (d,dim=false)=>{
                      const icon = d.disk_type==="SSD"?"🟦":"🟫";
                      return <option key={d.name} value={d.name}>
                        {dim?"── ":""}{icon} {d.disk_type} · {d.name} ({fmtGB(d.free_gb)} free)
                      </option>;
                    };
                    return [
                      ...matching.map(d=>renderOpt(d,false)),
                      ...(rest.length>0?[<option key="__sep" disabled>── Other type ──────────</option>]:[] ),
                      ...rest.map(d=>renderOpt(d,true)),
                    ];
                  })()}
                </select>
              </div>
            </div>
          </div>
        )}

        {/* ── STEP 3: Network & IP ── */}
        {platform==="vmware"&&step===3&&(
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            {/* Network / VLAN */}
            <div>
              <label>Network / VLAN / Port Group
                {vcRes===null&&<span style={{fontSize:10,color:p.yellow,marginLeft:6}}>⏳ Loading…</span>}
                {vcRes&&(vcRes.networks||[]).length===0&&<span style={{fontSize:10,color:p.textMute,marginLeft:6}}>None found</span>}
                {vcRes&&(vcRes.networks||[]).length>0&&<span style={{fontSize:10,color:p.green,marginLeft:6}}>✅ {vcRes.networks.length} available</span>}
              </label>
              {(()=>{
                const hObj=(vcRes?.hosts||[]).find(h=>h.name===host);
                const netList = host&&hObj?.networks?.length>0 ? hObj.networks : (vcRes?.networks||[]);
                return netList.length>0
                  ?<select value={network} onChange={e=>setNetwork(e.target.value)}>
                      <option value="">— Auto Select —</option>
                      {netList.map(n=>(
                        <option key={n.name} value={n.name}>{n.name}{n.type?" ("+n.type+")":""}</option>
                      ))}
                    </select>
                  :<input value={network} onChange={e=>setNetwork(e.target.value)}
                      placeholder="Type port group / VLAN name (optional)"/>;
              })()}
            </div>

            {/* IP Assignment mode toggle */}
            <div>
              <label>IP Assignment</label>
              <div style={{display:"flex",gap:8}}>
                {[["dhcp","🔄 DHCP (auto)","Let the network assign IP automatically"],
                  ["static","📌 Static IP","Set a fixed IP address via VMware Guest Customization"]].map(([mode,label,desc])=>(
                  <div key={mode} onClick={()=>setIpMode(mode)}
                    style={{flex:1,padding:"10px 12px",borderRadius:8,cursor:"pointer",
                      background:ipMode===mode?`${p.accent}20`:p.panelAlt,
                      border:`1.5px solid ${ipMode===mode?p.accent:p.border}`,
                      transition:"all .15s"}}>
                    <div style={{fontWeight:600,fontSize:12,color:ipMode===mode?p.accent:p.text}}>{label}</div>
                    <div style={{fontSize:10,color:p.textMute,marginTop:2}}>{desc}</div>
                  </div>
                ))}
              </div>
            </div>

            {/* Static IP fields */}
            {ipMode==="static"&&(
              <div style={{display:"flex",flexDirection:"column",gap:10,padding:12,
                background:p.panelAlt,borderRadius:8,border:`1px solid ${p.accent}30`}}>
                <div style={{fontSize:11,color:p.accent,fontWeight:600,marginBottom:2}}>
                  📌 Static IP via VMware Guest Customization
                  <span style={{color:p.textMute,fontWeight:400,marginLeft:6}}>— requires VMware Tools in template</span>
                </div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
                  <div>
                    <label>IP Address *</label>
                    <input value={ipAddr} onChange={e=>setIpAddr(e.target.value)}
                      placeholder="e.g. 192.168.1.100"
                      style={{borderColor:ipAddr&&!validIP(ipAddr)?p.red:""}}/>
                    {ipAddr&&!validIP(ipAddr)&&<div style={{fontSize:10,color:p.red,marginTop:2}}>Invalid IP format</div>}
                  </div>
                  <div>
                    <label>Subnet Mask *</label>
                    <input value={subnet} onChange={e=>setSubnet(e.target.value)} placeholder="255.255.255.0"/>
                  </div>
                  <div>
                    <label>Default Gateway *</label>
                    <input value={gateway} onChange={e=>setGateway(e.target.value)} placeholder="e.g. 192.168.1.1"/>
                  </div>
                  <div>
                    <label>Hostname</label>
                    <input value={hostname} onChange={e=>setHostname(e.target.value)} placeholder={vmName||"hostname"}/>
                    <div style={{fontSize:10,color:p.textMute,marginTop:2}}>Auto-filled from VM name</div>
                  </div>
                  <div>
                    <label>DNS Primary *</label>
                    <input value={dns1} onChange={e=>setDns1(e.target.value)} placeholder="e.g. 172.17.65.134"/>
                  </div>
                  <div>
                    <label>DNS Secondary</label>
                    <input value={dns2} onChange={e=>setDns2(e.target.value)} placeholder="e.g. 8.8.8.8 (optional)"/>
                  </div>
                </div>
                <div>
                  <label>Domain (optional)</label>
                  <input value={domain} onChange={e=>setDomain(e.target.value)} placeholder="e.g. sdxtest.local"/>
                </div>
                {!ipValid&&ipAddr&&<div style={{fontSize:11,color:p.yellow,padding:"6px 10px",
                  background:`${p.yellow}10`,borderRadius:6,border:`1px solid ${p.yellow}30`}}>
                  ⚠️ Fill in IP, Gateway, and DNS Primary to proceed
                </div>}
              </div>
            )}

            {ipMode==="dhcp"&&(
              <div style={{padding:"8px 12px",background:`${p.cyan}10`,borderRadius:7,
                border:`1px solid ${p.cyan}30`,fontSize:11,color:p.textMute}}>
                ℹ️ The VM will obtain an IP automatically from your DHCP server.
                The IP will appear in the dashboard once VMware Tools reports it (usually within 2–3 minutes of first boot).
              </div>
            )}

            {/* Internet Access */}
            {pricing&&(()=>{
              const inr = pricing.internet_per_vm_month_inr||1500;
              const usd = pricing.usd_rate||83.5;
              return(
                <label style={{display:"flex",alignItems:"center",gap:8,padding:"10px 12px",
                  borderRadius:8,cursor:"pointer",
                  background:includeInternet?`#0891b215`:`${p.panelAlt}`,
                  border:`1.5px solid ${includeInternet?"#0891b2":p.border}`,
                  transition:"all .15s"}}>
                  <input type="checkbox" checked={includeInternet}
                    onChange={e=>setIncludeInternet(e.target.checked)}
                    style={{accentColor:"#0891b2",width:14,height:14}}/>
                  <span style={{flex:1}}>
                    <span style={{fontWeight:600,fontSize:12,color:includeInternet?"#0891b2":p.text}}>
                      🌐 Internet Access Required
                    </span>
                    <span style={{fontSize:11,color:p.textMute,marginLeft:8}}>
                      Corporate on-prem internet circuit
                    </span>
                  </span>
                  <span style={{fontWeight:700,fontSize:12,color:"#0891b2",whiteSpace:"nowrap"}}>
                    ₹{Number(inr).toLocaleString("en-IN")} / ${(inr/usd).toFixed(0)} per VM/mo
                  </span>
                </label>
              );
            })()}
          </div>
        )}

        {/* ── STEP 4: Confirm ── */}
        {platform==="vmware"&&step===4&&!result&&(
          <div style={{display:"flex",flexDirection:"column",gap:10}}>
            <div style={{padding:14,background:p.panelAlt,borderRadius:10,border:`1px solid ${p.border}`}}>
              <div style={{fontWeight:600,fontSize:11,color:p.textSub,marginBottom:10,textTransform:"uppercase",letterSpacing:".5px"}}>Request Summary</div>
              {[
                ["VM Name",     vmName],
                ["vCenter",     vcenters.find(v=>v.id===vcId)?.name],
                ["Template",    effectiveTemplate||"— Admin will assign —"],
                ["CPU",         `${cpu} vCPUs`],
                ["RAM",         `${fmtGB(ram)}`],
                ["Disk",        `${fmtGB(disk)}`],
                ["Host",        host||"Auto"],
                ["Datastore",   ds||"Auto"],
                ["Network",     network||"Auto"],
                ["IP Mode",     ipMode==="static"?`Static: ${ipAddr}`:"DHCP (auto)"],
                ...(ipMode==="static"?[
                  ["Gateway",   gateway||"—"],
                  ["DNS",       [dns1,dns2].filter(Boolean).join(", ")||"—"],
                  ["Hostname",  hostname||vmName],
                  ["Domain",    domain||"—"],
                ]:[]),
                ["Duration",    duration],
                ["Notes",       notes||"—"],
                ...(detectedLicType?[["OS License", includeLicense?(detectedLicType==="windows"?"🪟 Windows Server (SPLA billed)":"🎩 RHEL (subscription billed)"):"— Not included"]]:[]),
                ["Internet", includeInternet?"🌐 Required (billed ₹1,500/mo)": "— Not required"],
              ].map(([k,v])=>(
                <div key={k} style={{display:"flex",justifyContent:"space-between",
                  padding:"5px 0",borderBottom:`1px solid ${p.border}22`,fontSize:12}}>
                  <span style={{color:p.textMute,minWidth:90}}>{k}</span>
                  <b style={{textAlign:"right",maxWidth:340,overflow:"hidden",textOverflow:"ellipsis",
                    color:k==="IP Mode"&&ipMode==="static"?p.cyan:p.text}}>{v}</b>
                </div>
              ))}
            </div>
            {pricing&&(()=>{
              const pr=pricing, usd=pr.usd_rate||83.5;
              const diskRate = diskType==="SSD"?(pr.ssd_per_gb_month_inr||15):(pr.hdd_per_gb_month_inr||pr.disk_per_gb_month_inr||8);
              const licRate  = includeLicense&&detectedLicType==="windows"?(pr.windows_license_month_inr||12500):includeLicense&&detectedLicType==="rhel"?(pr.rhel_license_month_inr||10000):0;
              const inetRate = includeInternet?(pr.internet_per_vm_month_inr||1500):0;
              const monthly=(cpu*(pr.cpu_per_core_month_inr||500))+(ram*(pr.ram_per_gb_month_inr||200))+(disk*diskRate)+licRate+inetRate;
              return(
                <div style={{padding:"10px 12px",background:`${p.accent}10`,borderRadius:7,
                  border:`1px solid ${p.accent}30`,fontSize:12}}>
                  <div style={{fontWeight:700,color:p.accent,marginBottom:4,display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"}}>
                    💰 Estimated Cost
                    <span style={{fontWeight:600,padding:"2px 7px",borderRadius:10,fontSize:11,
                      background:diskType==="SSD"?"#0ea5e920":"#78716c20",
                      color:diskType==="SSD"?"#0ea5e9":"#78716c"}}>
                      {diskType==="SSD"?"🟦 SSD":"🟫 HDD"} @ ₹{diskRate}/GB/mo
                    </span>
                    {licRate>0&&<span style={{fontWeight:600,padding:"2px 7px",borderRadius:10,fontSize:11,
                      background:"#7c3aed20",color:"#7c3aed"}}>
                      {detectedLicType==="windows"?"🪟":"🎩"} License +₹{licRate.toLocaleString("en-IN")}/mo / ${(licRate/usd).toFixed(0)}/mo
                    </span>}
                    {inetRate>0&&<span style={{fontWeight:600,padding:"2px 7px",borderRadius:10,fontSize:11,
                      background:"#0891b220",color:"#0891b2"}}>
                      🌐 Internet +₹{inetRate.toLocaleString("en-IN")}/mo / ${(inetRate/usd).toFixed(0)}/mo
                    </span>}
                  </div>
                  <div style={{display:"flex",gap:16}}>
                    <span>Daily: <b>₹{Math.round(monthly/30).toLocaleString("en-IN")}</b> / ${(monthly/30/usd).toFixed(2)}</span>
                    <span>Monthly: <b>₹{Math.round(monthly).toLocaleString("en-IN")}</b> / ${(monthly/usd).toFixed(2)}</span>
                    <span>Yearly: <b>₹{Math.round(monthly*12).toLocaleString("en-IN")}</b> / ${(monthly*12/usd).toFixed(0)}</span>
                  </div>
                </div>
              );
            })()}
            <div style={{padding:"10px 12px",background:`${p.yellow}10`,borderRadius:7,
              border:`1px solid ${p.yellow}30`,fontSize:12,color:p.textMute}}>
              ⏳ Your request will be reviewed by an admin before provisioning begins.
              {ipMode==="static"&&<span style={{color:p.cyan}}> Static IP will be applied via VMware Guest Customization on first boot.</span>}
            </div>
          </div>
        )}

        {/* ══════════════ OPENSHIFT FORM ══════════════ */}
        {/* ── OCP STEP 1: Basics ── */}
        {platform==="openshift"&&step===1&&(
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <div style={{padding:"8px 12px",borderRadius:8,background:"#ef444410",border:"1px solid #ef444430",display:"flex",alignItems:"center",gap:10,fontSize:12,color:"#ef4444",fontWeight:600}}>
              <span style={{fontSize:16}}>🔴</span> OpenShift Workload Request
              <span style={{fontWeight:400,color:p.textMute,marginLeft:4}}>— will go through admin approval queue</span>
            </div>
            <div><label>OpenShift Cluster *</label>
              {(ocpData?.clusters||[]).length>0
                ?<select value={ocpCluster} onChange={e=>setOcpCluster(e.target.value)}>
                    <option value="">— Select cluster —</option>
                    {(ocpData.clusters||[]).map(c=><option key={c.id} value={c.id}>{c.name}</option>)}
                  </select>
                :<input value={ocpCluster} onChange={e=>setOcpCluster(e.target.value)} placeholder="e.g. prod-cluster-01"/>
              }
            </div>
            <div className="g2">
              <div><label>Namespace / Project *</label>
                <input value={ocpNs} onChange={e=>setOcpNs(e.target.value)} placeholder="e.g. webapp-prod"/>
              </div>
              <div><label>Workload Name * (min 3 chars)</label>
                <input value={ocpWorkloadName} onChange={e=>setOcpWorkloadName(e.target.value.replace(/ /g,"-"))} placeholder="e.g. nginx-frontend"/>
              </div>
            </div>
            <div className="g2">
              <div><label>Workload Type</label>
                <select value={ocpWorkloadType} onChange={e=>setOcpWorkloadType(e.target.value)}>
                  {["Deployment","StatefulSet","DaemonSet","Job","CronJob"].map(t=><option key={t}>{t}</option>)}
                </select>
              </div>
              <div><label>Container Image *</label>
                <select value={ocpImage} onChange={e=>setOcpImage(e.target.value)}>
                  <option value="">— Select image —</option>
                  {OCP_COMMON_IMAGES.map(img=><option key={img} value={img}>{img}</option>)}
                  <option value="__custom">✏️ Enter custom image…</option>
                </select>
                {ocpImage==="__custom"&&<input style={{marginTop:6}} value={ocpImageCustom} onChange={e=>setOcpImageCustom(e.target.value)} placeholder="e.g. registry.io/myapp:v2"/>}
              </div>
            </div>
            <div className="g2">
              <div><label>Duration</label>
                <select value={ocpDuration} onChange={e=>setOcpDuration(e.target.value)}>
                  {["permanent","1 week","2 weeks","1 month","3 months","6 months","1 year"].map(d=><option key={d} value={d}>{d.charAt(0).toUpperCase()+d.slice(1)}</option>)}
                </select>
              </div>
              <div><label>Purpose / Notes</label>
                <input value={ocpNotes} onChange={e=>setOcpNotes(e.target.value)} placeholder="What is this workload for?"/>
              </div>
            </div>
          </div>
        )}
        {/* ── OCP STEP 2: Resources ── */}
        {platform==="openshift"&&step===2&&(
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <div style={{padding:"8px 12px",background:"#ef444410",borderRadius:7,border:"1px solid #ef444430",fontSize:12,color:"#ef4444"}}>
              🔴 Cluster: <b>{(ocpData?.clusters||[]).find(c=>c.id===ocpCluster)?.name||ocpCluster}</b>
              &nbsp;·&nbsp;Namespace: <b>{ocpNs}</b>
              &nbsp;·&nbsp;Type: <b>{ocpWorkloadType}</b>
            </div>
            <div>
              <label>CPU — Request / Limit</label>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                <div>
                  <div style={{fontSize:10,color:p.textMute,marginBottom:3}}>Request (guaranteed)</div>
                  <select value={ocpCpuReq} onChange={e=>setOcpCpuReq(e.target.value)}>
                    {["50m","100m","200m","250m","500m","1","2","4"].map(v=><option key={v}>{v}</option>)}
                  </select>
                </div>
                <div>
                  <div style={{fontSize:10,color:p.textMute,marginBottom:3}}>Limit (max burst)</div>
                  <select value={ocpCpuLim} onChange={e=>setOcpCpuLim(e.target.value)}>
                    {["100m","250m","500m","1","2","4","8"].map(v=><option key={v}>{v}</option>)}
                  </select>
                </div>
              </div>
            </div>
            <div>
              <label>Memory — Request / Limit</label>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                <div>
                  <div style={{fontSize:10,color:p.textMute,marginBottom:3}}>Request (guaranteed)</div>
                  <select value={ocpMemReq} onChange={e=>setOcpMemReq(e.target.value)}>
                    {["64Mi","128Mi","256Mi","512Mi","1Gi","2Gi","4Gi"].map(v=><option key={v}>{v}</option>)}
                  </select>
                </div>
                <div>
                  <div style={{fontSize:10,color:p.textMute,marginBottom:3}}>Limit (max burst)</div>
                  <select value={ocpMemLim} onChange={e=>setOcpMemLim(e.target.value)}>
                    {["128Mi","256Mi","512Mi","1Gi","2Gi","4Gi","8Gi"].map(v=><option key={v}>{v}</option>)}
                  </select>
                </div>
              </div>
            </div>
            <div className="g2">
              <div><label>Replicas</label>
                <select value={ocpReplicas} onChange={e=>setOcpReplicas(Number(e.target.value))}>
                  {[1,2,3,5,10,20].map(n=><option key={n} value={n}>{n}</option>)}
                </select>
              </div>
              <div><label>Persistent Storage — Size (Gi) &amp; Storage Class</label>
                <div style={{display:"flex",gap:6}}>
                  <input type="number" min="0" value={ocpPvcSize} onChange={e=>setOcpPvcSize(e.target.value)} placeholder="0 = none" style={{flex:1}}/>
                  <input value={ocpStorageClass} onChange={e=>setOcpStorageClass(e.target.value)} placeholder="storage class (optional)" style={{flex:1.5}}/>
                </div>
              </div>
            </div>
            <div style={{padding:"10px 14px",background:p.panelAlt,borderRadius:8,border:`1px solid ${p.border}`,fontSize:12}}>
              <div style={{fontWeight:600,color:"#ef4444",marginBottom:6}}>📊 Resource Summary</div>
              <div style={{display:"flex",gap:16,flexWrap:"wrap",color:p.textMute}}>
                <span>CPU: <b style={{color:p.text}}>{ocpCpuReq}</b> req / <b style={{color:p.text}}>{ocpCpuLim}</b> limit</span>
                <span>Memory: <b style={{color:p.text}}>{ocpMemReq}</b> req / <b style={{color:p.text}}>{ocpMemLim}</b> limit</span>
                <span>Replicas: <b style={{color:p.text}}>{ocpReplicas}</b></span>
                {parseInt(ocpPvcSize)>0&&<span>PVC: <b style={{color:p.text}}>{ocpPvcSize}Gi {ocpStorageClass&&`(${ocpStorageClass})`}</b></span>}
              </div>
            </div>
          </div>
        )}
        {/* ── OCP STEP 3: Confirm ── */}
        {platform==="openshift"&&step===3&&!result&&(
          <div style={{display:"flex",flexDirection:"column",gap:12}}>
            <div style={{padding:14,background:p.panelAlt,borderRadius:10,border:`1px solid ${p.border}`}}>
              <div style={{fontWeight:700,fontSize:11,color:"#ef4444",marginBottom:10,textTransform:"uppercase",letterSpacing:".8px"}}>🔴 OpenShift Request Summary</div>
              {[
                ["Cluster",    (ocpData?.clusters||[]).find(c=>c.id===ocpCluster)?.name||ocpCluster],
                ["Namespace",  ocpNs],
                ["Workload",   `${ocpWorkloadName} (${ocpWorkloadType})`],
                ["Image",      effOcpImg],
                ["CPU",        `${ocpCpuReq} req / ${ocpCpuLim} limit`],
                ["Memory",     `${ocpMemReq} req / ${ocpMemLim} limit`],
                ["Replicas",   ocpReplicas],
                ["Storage",    parseInt(ocpPvcSize)>0?`${ocpPvcSize}Gi / ${ocpStorageClass||"default class"}`:`Not required`],
                ["Duration",   ocpDuration],
                ["Notes",      ocpNotes||"—"],
              ].map(([k,v])=>(
                <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"5px 0",borderBottom:`1px solid ${p.border}22`,fontSize:12}}>
                  <span style={{color:p.textMute,minWidth:90}}>{k}</span>
                  <b style={{textAlign:"right",maxWidth:340,overflow:"hidden",textOverflow:"ellipsis",color:p.text}}>{v}</b>
                </div>
              ))}
            </div>
            <div style={{padding:"10px 12px",background:"#ef444410",borderRadius:7,border:"1px solid #ef444430",fontSize:12,color:p.textMute}}>
              ⏳ Your OpenShift workload request will be reviewed by an admin before deployment.
            </div>
          </div>
        )}

        {/* ══════════════ NUTANIX FORM ══════════════ */}
        {/* ── NUT STEP 1: Basics ── */}
        {platform==="nutanix"&&step===1&&(
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <div style={{padding:"8px 12px",borderRadius:8,background:"#22c55e10",border:"1px solid #22c55e30",display:"flex",alignItems:"center",gap:10,fontSize:12,color:"#22c55e",fontWeight:600}}>
              <span style={{fontSize:16}}>🟩</span> Nutanix AHV VM Request
              <span style={{fontWeight:400,color:p.textMute,marginLeft:4}}>— will go through admin approval queue</span>
            </div>
            <div><label>Prism Central *</label>
              {(nutData?.pcs||[]).length>0
                ?<select value={nutPcId} onChange={e=>setNutPcId(e.target.value)}>
                    <option value="">— Select Prism Central —</option>
                    {(nutData.pcs||[]).map(pc=><option key={pc.id} value={pc.id}>{pc.name}{pc.host?` (${pc.host})`:""}</option>)}
                  </select>
                :<input value={nutPcId} onChange={e=>setNutPcId(e.target.value)} placeholder="Prism Central hostname or IP"/>
              }
            </div>
            <div className="g2">
              <div><label>AHV Cluster (optional)</label>
                <input value={nutCluster} onChange={e=>setNutCluster(e.target.value)} placeholder="e.g. Cluster-A"/>
              </div>
              <div><label>VM Name * (min 3 chars)</label>
                <input value={nutVmName} onChange={e=>setNutVmName(e.target.value.replace(/ /g,"-"))} placeholder="e.g. prod-server-01"/>
                {nutVmName.length>0&&nutVmName.trim().length<3&&<div style={{fontSize:10,color:p.red,marginTop:3}}>Min 3 characters</div>}
              </div>
            </div>
            <div><label>OS Image / Template *</label>
              {nutImagesLoading
                ?<div style={{padding:"8px 12px",fontSize:12,color:p.textMute}}>⏳ Loading images from Prism Central…</div>
                :<select value={nutImage} onChange={e=>setNutImage(e.target.value)}>
                  <option value="">— Select image —</option>
                  {nutImages.filter(i=>i.image_type==="DISK_IMAGE").map(i=><option key={i.uuid} value={i.name}>{i.name}{i.size_bytes>0?` (${(i.size_bytes/1073741824).toFixed(1)} GiB)`:""}</option>)}
                  <option value="__custom">✏️ Enter custom image name…</option>
                </select>
              }
              {nutImage==="__custom"&&<input style={{marginTop:6}} value={nutImageCustom} onChange={e=>setNutImageCustom(e.target.value)} placeholder="e.g. CentOS-7-x86_64, Windows2022-Base"/>}
              {!nutImagesLoading&&nutImages.length===0&&nutPcId&&<div style={{fontSize:10,color:p.yellow,marginTop:3}}>⚠ No images found — enter a name manually above</div>}
            </div>
            <div className="g2">
              <div><label>Duration</label>
                <select value={nutDuration} onChange={e=>setNutDuration(e.target.value)}>
                  {["permanent","1 week","2 weeks","1 month","3 months","6 months","1 year"].map(d=><option key={d} value={d}>{d.charAt(0).toUpperCase()+d.slice(1)}</option>)}
                </select>
              </div>
              <div><label>Purpose / Notes</label>
                <input value={nutNotes} onChange={e=>setNutNotes(e.target.value)} placeholder="What is this VM for?"/>
              </div>
            </div>
          </div>
        )}
        {/* ── NUT STEP 2: Resources ── */}
        {platform==="nutanix"&&step===2&&(
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <div style={{padding:"8px 12px",background:"#22c55e10",borderRadius:7,border:"1px solid #22c55e30",fontSize:12,color:"#22c55e"}}>
              🟩 PC: <b>{(nutData?.pcs||[]).find(pc=>pc.id===nutPcId)?.name||nutPcId}</b>
              {nutCluster&&<> &nbsp;·&nbsp; Cluster: <b>{nutCluster}</b></>}
              &nbsp;·&nbsp; VM: <b>{nutVmName}</b>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10}}>
              <div><label>vCPU Cores</label>
                <select value={nutCpu} onChange={e=>setNutCpu(Number(e.target.value))}>
                  {[1,2,4,8,16,32].map(n=><option key={n} value={n}>{n} vCPU{n>1?"s":""}</option>)}
                </select>
              </div>
              <div><label>RAM (GB)</label>
                <select value={nutRam} onChange={e=>setNutRam(Number(e.target.value))}>
                  {[1,2,4,8,16,32,64,128].map(n=><option key={n} value={n}>{n} GB</option>)}
                </select>
              </div>
              <div><label>Disk (GB)</label>
                <select value={nutDisk} onChange={e=>setNutDisk(Number(e.target.value))}>
                  {[20,50,100,200,500,1000].map(n=><option key={n} value={n}>{n} GB</option>)}
                </select>
              </div>
            </div>
            <div className="g2">
              <div><label>Network / VLAN (optional)</label>
                <input value={nutNetwork} onChange={e=>setNutNetwork(e.target.value)} placeholder="e.g. VLAN-100, default"/>
              </div>
              <div><label>Disk Type</label>
                <div style={{display:"flex",gap:8,marginTop:4}}>
                  {[["SSD","🟦 SSD","#0ea5e9"],["HDD","🟫 HDD","#78716c"]].map(([t,lbl,clr])=>(
                    <button key={t} onClick={()=>setNutDiskType(t)}
                      style={{flex:1,padding:"7px",borderRadius:7,border:`1.5px solid ${nutDiskType===t?clr:p.border}`,
                        cursor:"pointer",fontSize:12,fontWeight:nutDiskType===t?700:400,
                        background:nutDiskType===t?`${clr}20`:p.panelAlt,color:nutDiskType===t?clr:p.textMute,transition:"all .12s"}}>
                      {lbl}
                    </button>
                  ))}
                </div>
              </div>
            </div>
            <div style={{padding:"10px 14px",background:p.panelAlt,borderRadius:8,border:`1px solid ${p.border}`,fontSize:12}}>
              <div style={{fontWeight:600,color:"#22c55e",marginBottom:6}}>📊 Resource Summary</div>
              <div style={{display:"flex",gap:16,flexWrap:"wrap",color:p.textMute}}>
                <span>vCPU: <b style={{color:p.text}}>{nutCpu}</b></span>
                <span>RAM: <b style={{color:p.text}}>{nutRam} GB</b></span>
                <span>Disk: <b style={{color:p.text}}>{nutDisk} GB ({nutDiskType})</b></span>
                {nutNetwork&&<span>Network: <b style={{color:p.text}}>{nutNetwork}</b></span>}
              </div>
            </div>
          </div>
        )}
        {/* ── NUT STEP 3: Confirm ── */}
        {platform==="nutanix"&&step===3&&!result&&(
          <div style={{display:"flex",flexDirection:"column",gap:12}}>
            <div style={{padding:14,background:p.panelAlt,borderRadius:10,border:`1px solid ${p.border}`}}>
              <div style={{fontWeight:700,fontSize:11,color:"#22c55e",marginBottom:10,textTransform:"uppercase",letterSpacing:".8px"}}>🟩 Nutanix VM Request Summary</div>
              {[
                ["Prism Central",(nutData?.pcs||[]).find(pc=>pc.id===nutPcId)?.name||nutPcId],
                ["AHV Cluster",  nutCluster||"— Auto assign"],
                ["VM Name",      nutVmName],
                ["OS Image",     effNutImg||"— Admin will assign"],
                ["vCPU",         `${nutCpu} core${nutCpu>1?"s":""}`],
                ["RAM",          `${nutRam} GB`],
                ["Disk",         `${nutDisk} GB (${nutDiskType})`],
                ["Network",      nutNetwork||"— Auto assign"],
                ["Duration",     nutDuration],
                ["Notes",        nutNotes||"—"],
              ].map(([k,v])=>(
                <div key={k} style={{display:"flex",justifyContent:"space-between",padding:"5px 0",borderBottom:`1px solid ${p.border}22`,fontSize:12}}>
                  <span style={{color:p.textMute,minWidth:100}}>{k}</span>
                  <b style={{textAlign:"right",maxWidth:340,overflow:"hidden",textOverflow:"ellipsis",color:p.text}}>{v}</b>
                </div>
              ))}
            </div>
            <div style={{padding:"10px 12px",background:"#22c55e10",borderRadius:7,border:"1px solid #22c55e30",fontSize:12,color:p.textMute}}>
              ⏳ Your Nutanix VM request will be reviewed by an admin before provisioning begins.
            </div>
          </div>
        )}

        {/* ── Result ── */}
        {result&&(
          <div style={{textAlign:"center",padding:24}}>
            <div style={{fontSize:48,marginBottom:12}}>{result.ok?"🎉":"❌"}</div>
            {result.ok
              ?<><div style={{fontWeight:700,color:p.green,marginBottom:8}}>Request Submitted!</div>
                <div style={{fontSize:13,color:p.textMute}}>
                  Request: <b style={{color:p.accent}}>{result.req?.req_number}</b>
                </div>
                <div style={{fontSize:12,color:p.textMute,marginTop:4}}>Track it under the VM Requests page.</div></>
              :<><div style={{fontWeight:700,color:p.red,marginBottom:8}}>Submission Failed</div>
                <div style={{fontSize:12,color:p.textMute}}>{result.msg}</div></>
            }
          </div>
        )}

        {/* ── Navigation buttons ── */}
        {!result&&(
          <div style={{display:"flex",gap:8,justifyContent:"space-between",
            marginTop:20,paddingTop:16,borderTop:`1px solid ${p.border}`}}>
            <button className="btn btn-ghost" onClick={step===1?onClose:prevStep}>
              {step===1?"Cancel":"← Back"}
            </button>
            <div style={{display:"flex",gap:8}}>
              {/* VMware */}
              {platform==="vmware"&&step<4&&(
                <button className="btn btn-primary"
                  disabled={step===1&&!valid1||(step===3&&ipMode==="static"&&!ipValid)}
                  onClick={nextStep}>
                  Next →
                </button>
              )}
              {platform==="vmware"&&step===4&&(
                <button className="btn btn-success" onClick={submit} disabled={busy}>
                  {busy?"Submitting…":"🚀 Submit Request"}
                </button>
              )}
              {/* OpenShift */}
              {platform==="openshift"&&step<3&&(
                <button className="btn btn-primary"
                  style={{background:"#ef4444",borderColor:"#ef444480"}}
                  disabled={step===1&&!validOCP1}
                  title={step===1&&!validOCP1?"Fill in Cluster, Namespace, Workload Name, and Image":""}
                  onClick={nextStep}>
                  Next →
                </button>
              )}
              {platform==="openshift"&&step===3&&(
                <button className="btn btn-success"
                  style={{background:"#ef4444",borderColor:"#ef444480"}}
                  onClick={submitOCP} disabled={busy}>
                  {busy?"Submitting…":"🔴 Submit OCP Request"}
                </button>
              )}
              {/* Nutanix */}
              {platform==="nutanix"&&step<3&&(
                <button className="btn btn-primary"
                  style={{background:"#22c55e",borderColor:"#22c55e80",color:"#fff"}}
                  disabled={step===1&&!validNut1}
                  title={step===1&&!validNut1?"Fill in Prism Central and VM Name (min 3 chars)":""}
                  onClick={nextStep}>
                  Next →
                </button>
              )}
              {platform==="nutanix"&&step===3&&(
                <button className="btn btn-success"
                  style={{background:"#22c55e",borderColor:"#22c55e80",color:"#fff"}}
                  onClick={submitNutanix} disabled={busy}>
                  {busy?"Submitting…":"🟩 Submit Nutanix Request"}
                </button>
              )}
            </div>
          </div>
        )}
        {result&&(
          <div style={{display:"flex",justifyContent:"center",marginTop:16}}>
            <button className="btn btn-ghost" onClick={onClose}>Close</button>
          </div>
        )}
      </div>
    </div>
  );
}

// ─── REQUESTS PAGE ────────────────────────────────────────────────────────────
function RequestsPage({currentUser, vcenters, p}) {
  const [requests,  setRequests] = useState([]);
  const [loading,   setLoading]  = useState(true);
  const [selected,  setSelected] = useState(null);
  const [filter,    setFilter]   = useState("all");
  const [platformTab,setPlatformTab]=useState("all");
  const [adminNotes,setAdminNotes]= useState("");
  const [overrides, setOverrides]= useState({});
  const [busy,      setBusy]     = useState(false);
  const [msg,       setMsg]      = useState(null);
  async function load(){ setLoading(true); try{ setRequests(await fetchRequests()); }catch{} setLoading(false); }
  useEffect(()=>{ load(); },[]);
  async function doReview(decision){
    setBusy(true); setMsg(null);
    try{
      await reviewRequest(selected.req_number,decision,adminNotes,overrides);
      setMsg({ok:true,text:`${selected.req_number} ${decision}`});
      setSelected(null); setAdminNotes(""); setOverrides({}); await load();
    }catch(e){ setMsg({ok:false,text:e.message}); }
    setBusy(false);
  }
  const byPlatform = requests.filter(r=>{
    if(platformTab==="all") return true;
    if(platformTab==="openshift") return r.vcenter_id==="openshift";
    if(platformTab==="nutanix")   return r.vcenter_id==="nutanix";
    return r.vcenter_id!=="openshift"&&r.vcenter_id!=="nutanix"; // vmware
  });
  const filtered=byPlatform.filter(r=>filter==="all"||r.status===filter);
  const sc={pending:p.yellow,approved:p.green,declined:p.red,provisioning:p.cyan,done:p.green,failed:p.red};
  const isAdmin=currentUser?.role==="admin";
  const vmwareCount  = requests.filter(r=>r.vcenter_id!=="openshift"&&r.vcenter_id!=="nutanix").length;
  const ocpCount     = requests.filter(r=>r.vcenter_id==="openshift").length;
  const nutCount     = requests.filter(r=>r.vcenter_id==="nutanix").length;
  const PLATFORM_TABS=[
    {id:"all",      label:"All Platforms", icon:"🌐", count:requests.length},
    {id:"vmware",   label:"VMware",        icon:"🖥️", count:vmwareCount},
    {id:"openshift",label:"OpenShift",     icon:"🔴", count:ocpCount},
    {id:"nutanix",  label:"Nutanix",       icon:"🟦", count:nutCount},
  ];
  return(
    <div className="g-gap">
      {msg&&<div style={{padding:"10px 14px",borderRadius:8,background:msg.ok?`${p.green}15`:`${p.red}15`,
        border:`1px solid ${msg.ok?p.green:p.red}40`,color:msg.ok?p.green:p.red,fontSize:13,fontWeight:500}}>
        {msg.ok?"✅":"❌"} {msg.text} <button className="btn btn-ghost btn-sm" style={{marginLeft:8}} onClick={()=>setMsg(null)}>✕</button>
      </div>}
      {/* Platform tabs */}
      <div style={{display:"flex",gap:6,flexWrap:"wrap",borderBottom:`2px solid ${p.border}`,paddingBottom:4}}>
        {PLATFORM_TABS.map(pt=>{
          const active=platformTab===pt.id;
          const color=pt.id==="openshift"?p.red:pt.id==="nutanix"?"#4a90d9":pt.id==="vmware"?p.accent:p.textSub;
          return(
            <button key={pt.id} onClick={()=>{setPlatformTab(pt.id);setFilter("all");}}
              style={{display:"flex",alignItems:"center",gap:5,padding:"6px 14px",borderRadius:"6px 6px 0 0",
                border:`1px solid ${active?color:p.border}`,borderBottom:"none",
                background:active?`${color}15`:p.panel,cursor:"pointer",fontWeight:active?700:400,
                color:active?color:p.textSub,fontSize:13,transition:"all .15s"}}>
              <span>{pt.icon}</span> {pt.label}
              <span style={{fontSize:11,padding:"1px 6px",borderRadius:10,background:active?`${color}25`:p.panelAlt,
                color:active?color:p.textMute,fontWeight:600}}>{pt.count}</span>
            </button>
          );
        })}
      </div>
      <div style={{display:"flex",gap:6,flexWrap:"wrap",alignItems:"center"}}>
        {["all","pending","approved","declined","done","failed"].map(f=>(
          <button key={f} onClick={()=>setFilter(f)} className={`btn btn-sm ${filter===f?"btn-primary":"btn-ghost"}`} style={{textTransform:"capitalize"}}>
            {f} ({f==="all"?byPlatform.length:byPlatform.filter(r=>r.status===f).length})
          </button>
        ))}
        <div style={{flex:1}}/><button className="btn btn-ghost btn-sm" onClick={load}>↺ Refresh</button>
      </div>
      {loading?<div style={{padding:40,textAlign:"center"}}><div className="spinner"/></div>:(
        <div className="card" style={{overflow:"hidden"}}>
          <div className="tbl-wrap" style={{maxHeight:"calc(100vh - 220px)"}}>
            <table>
              <thead><tr>
                <th>REQ #</th><th>VM NAME</th><th>REQUESTER</th><th>CPU</th><th>RAM</th><th>DISK</th>
                <th>OS / TEMPLATE</th><th>PLATFORM</th><th>STATUS</th><th>DATE</th>{isAdmin&&<th>ACTIONS</th>}
              </tr></thead>
              <tbody>
                {filtered.length===0&&<tr><td colSpan={isAdmin?11:10} style={{textAlign:"center",padding:32,color:p.textMute}}>No requests</td></tr>}
                {filtered.map(r=>{
                  const c=sc[r.status]||p.textMute;
                  const isNtx=r.platform==="nutanix";
                  const ntxPlatLbl=r.ntx_pc_name?`🟦 ${r.ntx_pc_name} › ${r.ntx_cluster_name||"?"}`:`🟦 Nutanix`;
                  const vc=vcenters.find(v=>v.id===r.vcenter_id);
                  const platformLbl=isNtx?ntxPlatLbl:(vc?.name||r.vcenter_id||"VMware");
                  return(<tr key={r.req_number}>
                    <td><span style={{fontFamily:"monospace",color:p.accent,fontWeight:600}}>{r.req_number}</span></td>
                    <td><b>{r.vm_name}</b></td>
                    <td style={{color:p.textSub}}>{r.requester}</td>
                    <td>{r.approved_cpu||r.cpu}c</td>
                    <td>{r.approved_ram_gb||r.ram_gb}GB</td>
                    <td>{r.approved_disk_gb||r.disk_gb}GB</td>
                    <td style={{fontSize:12,color:p.textMute}}>{isNtx?"AHV Custom":r.os_template}</td>
                    <td style={{fontSize:12}}>
                      <span style={{fontSize:11,fontWeight:600,padding:"2px 7px",borderRadius:4,
                        background:isNtx?"#024DA118":"#64748b12",
                        border:`1px solid ${isNtx?"#024DA140":"#64748b30"}`,
                        color:isNtx?"#4a90d9":p.textMute,whiteSpace:"nowrap"}}>
                        {platformLbl}
                      </span>
                    </td>
                    <td><span className="badge" style={{background:`${c}18`,color:c,border:`1px solid ${c}30`}}>{r.status.toUpperCase()}</span></td>
                    <td style={{fontSize:11,color:p.textMute}}>{r.created_at?.slice(0,16)}</td>
                    {isAdmin&&<td>
                      {r.status==="pending"&&<button className="btn btn-primary btn-sm" onClick={()=>{setSelected(r);setOverrides({cpu:r.cpu,ram_gb:r.ram_gb,disk_gb:r.disk_gb,host:r.host,datastore:r.datastore,network:r.network});}}>Review</button>}
                      {r.status==="done"&&<span style={{color:p.green,fontSize:11}}>✅ Done</span>}
                      {r.status==="failed"&&<span style={{color:p.red,fontSize:11}}>❌ Failed</span>}
                    </td>}
                  </tr>);
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}
      {selected&&((
        ()=>{
          const isNtx=selected.platform==="nutanix";
          let ntxDisks=[],ntxNics=[];
          try{ntxDisks=JSON.parse(selected.ntx_disks||"[]");}catch{}
          try{ntxNics =JSON.parse(selected.ntx_nics ||"[]");}catch{}
          return(
        <div className="overlay" onClick={()=>setSelected(null)}>
          <div className="modal" style={{width:isNtx?600:520,maxHeight:"90vh",overflowY:"auto"}} onClick={e=>e.stopPropagation()}>
            <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:16}}>
              <div style={{display:"flex",alignItems:"center",gap:8}}>
                <span style={{fontSize:22}}>{isNtx?"🟦":"⚙️"}</span>
                <div style={{fontWeight:700,fontSize:16}}>📋 Review {selected.req_number}</div>
              </div>
              <button className="btn btn-ghost btn-sm" onClick={()=>setSelected(null)}>✕</button>
            </div>

            {/* Platform banner */}
            <div style={{padding:"6px 12px",borderRadius:7,marginBottom:12,
              background:isNtx?"#024DA112":"#64748b10",
              border:`1px solid ${isNtx?"#024DA135":"#64748b25"}`,
              fontSize:12,fontWeight:600,color:isNtx?"#4a90d9":p.textSub}}>
              {isNtx?`🟦 Nutanix — PC: ${selected.ntx_pc_name||"?"} › Cluster: ${selected.ntx_cluster_name||"?"}`:`⚙️ VMware — vCenter: ${vcenters.find(v=>v.id===selected.vcenter_id)?.name||selected.vcenter_id}`}
            </div>

            <div style={{padding:12,background:p.panelAlt,borderRadius:8,border:`1px solid ${p.border}`,fontSize:12,marginBottom:14}}>
              <div style={{fontWeight:600,marginBottom:8,color:p.textSub}}>REQUESTED BY {selected.requester}</div>
              {[["VM",selected.vm_name],["CPU",`${selected.cpu} vCPUs${isNtx&&selected.num_cores_per_vcpu>1?` (${selected.num_cores_per_vcpu} cores/socket)`:""}`],
                ["RAM",`${selected.ram_gb} GiB`],["Disk",isNtx?`${selected.disk_gb} GiB total`:`${selected.disk_gb} GB`],
                ["Notes",selected.notes||"—"]].map(([k,v])=>(
                <div key={k} style={{display:"flex",gap:8,marginBottom:3}}>
                  <span style={{color:p.textMute,minWidth:50}}>{k}:</span><b>{v}</b>
                </div>
              ))}
            </div>

            {/* Nutanix-specific storage and network details */}
            {isNtx&&ntxDisks.length>0&&(
              <div style={{marginBottom:14}}>
                <div style={{fontWeight:600,fontSize:12,color:p.textSub,marginBottom:8}}>💾 STORAGE DEVICES</div>
                <div style={{display:"flex",flexDirection:"column",gap:5}}>
                  {ntxDisks.map((d,i)=>(
                    <div key={i} style={{padding:"6px 10px",borderRadius:6,background:p.panelAlt,
                      border:`1px solid ${p.border}`,fontSize:12,display:"flex",gap:10,flexWrap:"wrap"}}>
                      <span style={{fontWeight:700,color:d.type==="CDROM"?p.yellow:"#4a90d9"}}>{d.type==="CDROM"?"💿":"💾"} {d.type} {i+1}</span>
                      <span style={{color:p.textMute}}>{d.bus_type}</span>
                      {d.type==="DISK"&&d.size_bytes>0&&<span style={{color:p.text}}>{(d.size_bytes/1073741824).toFixed(0)} GiB</span>}
                      {d.storage_container_name&&<span style={{color:p.cyan}}>📦 {d.storage_container_name}</span>}
                      {d.clone_from_image&&d.image_name&&<span style={{color:p.green}}>📀 {d.image_name}</span>}
                    </div>
                  ))}
                </div>
              </div>
            )}
            {isNtx&&ntxNics.length>0&&(
              <div style={{marginBottom:14}}>
                <div style={{fontWeight:600,fontSize:12,color:p.textSub,marginBottom:8}}>🌐 NETWORK INTERFACES</div>
                <div style={{display:"flex",flexDirection:"column",gap:5}}>
                  {ntxNics.map((n,i)=>(
                    <div key={i} style={{padding:"6px 10px",borderRadius:6,background:p.panelAlt,
                      border:`1px solid ${p.border}`,fontSize:12,display:"flex",gap:10,alignItems:"center"}}>
                      <span style={{fontWeight:700,color:p.green}}>🔌 NIC {i+1}</span>
                      <span style={{color:p.text}}>{n.subnet_name||"—"}</span>
                      {n.vlan_id>0&&<span style={{color:p.textMute}}>VLAN {n.vlan_id}</span>}
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div style={{marginBottom:14}}>
              <div style={{fontWeight:600,fontSize:12,color:p.textSub,marginBottom:8}}>✏️ MODIFY RESOURCES</div>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8}}>
                {[["CPU","cpu",[1,2,4,6,8,12,16,24,32]],["RAM GiB","ram_gb",[1,2,4,6,8,12,16,24,32,48,64]],["Disk GiB","disk_gb",[20,40,50,80,100,200,500]]].map(([lbl,key,opts])=>(
                  <div key={key}><label style={{fontSize:10}}>{lbl}</label>
                    <select value={overrides[key]||""} onChange={e=>setOverrides(o=>({...o,[key]:Number(e.target.value)}))}>
                      {opts.map(n=><option key={n} value={n}>{n}</option>)}
                    </select>
                  </div>
                ))}
              </div>
            </div>
            <div style={{marginBottom:16}}>
              <label>Admin Notes (visible to requester)</label>
              <input value={adminNotes} onChange={e=>setAdminNotes(e.target.value)} placeholder="Optional notes…"/>
            </div>
            <div style={{display:"flex",gap:8,justifyContent:"flex-end",paddingTop:16,borderTop:`1px solid ${p.border}`}}>
              <button className="btn btn-ghost" onClick={()=>setSelected(null)} disabled={busy}>Cancel</button>
              <button className="btn btn-danger" onClick={()=>doReview("declined")} disabled={busy}>✕ Decline</button>
              <button className="btn btn-success" onClick={()=>doReview("approved")} disabled={busy}>
                {busy?"Processing…":`✓ Approve${isNtx?" & Create VM":" & Provision"}`}
              </button>
            </div>
          </div>
        </div>
          );
        })()
      )}
    </div>
  );
}

// ─── PROJECT UTILIZATION CHART ───────────────────────────────────────────────
function TagUtilizationDonut({rows, p, title="Team Tag-wise VM Utilization (%)"}) {
  const [hovered, setHovered] = useState(null);
  const total = rows.reduce((a,b)=>a+Number(b?.vm_count||0),0);
  const size = 240;
  const stroke = 24;
  const radius = (size - stroke) / 2;
  const cx = size / 2;
  const cy = size / 2;
  const c = 2 * Math.PI * radius;
  const palette = [p.cyan, p.accent, p.green, p.yellow, p.purple, p.orange, "#14b8a6", p.grey];
  let offset = 0;

  if(!total){
    return (
      <div className="card" style={{padding:16}}>
        <div className="card-title" style={{marginBottom:8}}>{title}</div>
        <div style={{fontSize:12,color:p.textMute}}>No tagged VM data available for chart.</div>
      </div>
    );
  }

  return (
    <div className="card" style={{overflow:"hidden"}}>
      <div className="card-header"><span className="card-title">{title}</span></div>
      <div style={{display:"grid",gridTemplateColumns:"280px 1fr",gap:10,padding:12,alignItems:"start"}}>
        <div style={{position:"relative",display:"flex",flexDirection:"column",alignItems:"center"}}>
          <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`}>
            <g transform={`rotate(-90 ${cx} ${cy})`}>
              <circle cx={cx} cy={cy} r={radius} fill="none" stroke={`${p.border}`} strokeWidth={stroke} />
              {rows.map((r, idx)=>{
                const val = Number(r.vm_count||0);
                const pct = total ? (val/total)*100 : 0;
                const len = (pct/100)*c;
                const segment = (
                  <circle
                    key={r.tag}
                    cx={cx}
                    cy={cy}
                    r={radius}
                    fill="none"
                    stroke={palette[idx % palette.length]}
                    strokeWidth={stroke}
                    strokeDasharray={`${len} ${c-len}`}
                    strokeDashoffset={-offset}
                    strokeLinecap="butt"
                    style={{cursor:"pointer"}}
                    onMouseEnter={()=>setHovered({
                      tag:r.tag,
                      pct,
                      vm_count:r.vm_count,
                      cpu:r.cpu_cores,
                      mem:r.ram_gb,
                      disk:r.disk_gb,
                    })}
                    onMouseLeave={()=>setHovered(null)}
                  />
                );
                offset += len;
                return segment;
              })}
            </g>
            <text x={cx} y={cy-4} textAnchor="middle" style={{fontSize:26,fontWeight:700,fill:p.accent}}>{total}</text>
            <text x={cx} y={cy+16} textAnchor="middle" style={{fontSize:11,fill:p.textMute}}>Total Tagged VMs</text>
          </svg>
          <div style={{marginTop:6,fontSize:12,color:p.textSub,minHeight:40,textAlign:"center"}}>
            {hovered
              ? <span><b style={{color:p.cyan}}>{hovered.tag}</b> · {hovered.pct.toFixed(1)}% · VMs {hovered.vm_count} · CPU {hovered.cpu} · MEM {Number(hovered.mem||0).toFixed(1)}GB · HDD {Number(hovered.disk||0).toFixed(1)}GB</span>
              : <span>Hover over the circular chart to view team/tag utilization %</span>}
          </div>
        </div>
        <div className="tbl-wrap" style={{maxHeight:250}}>
          <table>
            <thead><tr><th>TAG</th><th>%</th><th>VMS</th></tr></thead>
            <tbody>
              {rows.map((r,idx)=>{
                const pct = total ? (Number(r.vm_count||0)/total)*100 : 0;
                return (
                  <tr key={r.tag}>
                    <td><span style={{display:"inline-flex",alignItems:"center",gap:6}}><span style={{width:8,height:8,borderRadius:99,background:palette[idx%palette.length]}}/> {r.tag}</span></td>
                    <td>{pct.toFixed(1)}%</td>
                    <td>{r.vm_count}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}

function ProjectUtilizationChartPage({selectedVC, p}) {
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  const load = useCallback(async()=>{
    setLoading(true); setError(null);
    try{
      const d = await fetchProjectUtilization(selectedVC);
      setData({ ...((d&&typeof d==="object")?d:{}), tags:Array.isArray(d?.tags)?d.tags:[] });
    }catch(e){ setError(e.message || "Failed to load chart data"); }
    setLoading(false);
  }, [selectedVC]);

  useEffect(()=>{ load(); }, [load]);

  if(loading) return <LoadState msg="Loading utilization chart…"/>;
  if(error) return <ErrState msg={error} onRetry={load}/>;

  const rows = (data?.tags||[]).filter(r=>r&&typeof r==="object").map((r,idx)=>(
    { tag:String(r.tag??`Tag-${idx+1}`), vm_count:Number(r.vm_count||0), cpu_cores:Number(r.cpu_cores||0), ram_gb:Number(r.ram_gb||0), disk_gb:Number(r.disk_gb||0) }
  )).sort((a,b)=>b.vm_count-a.vm_count);

  return (
    <div className="g-gap">
      <TagUtilizationDonut rows={rows} p={p} title="Team Tag-wise VM Utilization (%)"/>
    </div>
  );
}

// ─── PROJECT UTILIZATION PAGE ────────────────────────────────────────────────
function ProjectUtilizationPage({selectedVC, currentUser, p}) {
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [drafts, setDrafts] = useState({});
  const [savingTag, setSavingTag] = useState("");
  const [mailOpenTag, setMailOpenTag] = useState("");
  const [mailHoverTag, setMailHoverTag] = useState("");
  const [pricing, setPricing] = useState(null);

  useEffect(()=>{ fetchPricing().then(setPricing).catch(()=>{}); }, []);

  const canEditOwner = currentUser?.role === "admin" || currentUser?.role === "operator";
  const scopeKey = selectedVC === "all" ? "all" : selectedVC;

  const load = useCallback(async()=>{
    setLoading(true); setError(null);
    try {
      const d = await fetchProjectUtilization(selectedVC);
      const safe = {
        ...((d && typeof d === "object") ? d : {}),
        tags: Array.isArray(d?.tags) ? d.tags : [],
      };
      setData(safe);
    } catch(e){
      setError(e.message || "Failed to load project utilization");
    }
    setLoading(false);
  }, [selectedVC]);

  useEffect(()=>{ load(); }, [load]);

  const rawRows = Array.isArray(data?.tags) ? data.tags : [];
  const rows = rawRows
    .filter(r => r && typeof r === "object")
    .map((r, idx) => ({
      tag: String(r.tag ?? `Tag-${idx+1}`),
      owner: String(r.owner || ""),
      owner_email: String(r.owner_email || ""),
      vm_count: Number(r.vm_count || 0),
      running_vms: Number(r.running_vms || 0),
      stopped_vms: Number(r.stopped_vms || 0),
      cpu_cores: Number(r.cpu_cores || 0),
      ram_gb: Number(r.ram_gb || 0),
      disk_gb: Number(r.disk_gb || 0),
      chargeback_inr: Number(r.chargeback_inr || 0),
      chargeback_usd: Number(r.chargeback_usd || 0),
      vms: Array.isArray(r.vms) ? r.vms.filter(v=>v && typeof v === "object") : [],
    }))
    .sort((a,b)=>b.vm_count-a.vm_count);

  useEffect(()=>{
    const next = {};
    rows.forEach(r=>{
      next[r.tag] = {
        owner_name: r.owner || "",
        owner_email: r.owner_email || "",
      };
    });
    setDrafts(next);
  }, [data?.tags]);

  const totalVMs = rows.reduce((a,b)=>a+Number(b?.vm_count||0),0);
  const totalCpu = rows.reduce((a,b)=>a+Number(b?.cpu_cores||0),0);
  const totalRam = rows.reduce((a,b)=>a+Number(b?.ram_gb||0),0);
  const totalDisk= rows.reduce((a,b)=>a+Number(b?.disk_gb||0),0);
  const totalCbInr = rows.reduce((a,b)=>a+Number(b?.chargeback_inr||0),0);
  const usdRate = Number(pricing?.usd_rate || 83.5);

  const fmtInr = (v)=>{
    if (!v || v===0) return "—";
    if (v>=10000000) return `₹${(v/10000000).toFixed(2)}Cr`;
    if (v>=100000)   return `₹${(v/100000).toFixed(2)}L`;
    if (v>=1000)     return `₹${(v/1000).toFixed(1)}K`;
    return `₹${v.toFixed(0)}`;
  };
  const fmtUsd = (inr)=>{
    const u = inr / usdRate;
    if (u>=1000000) return `$${(u/1000000).toFixed(2)}M`;
    if (u>=1000)    return `$${(u/1000).toFixed(1)}K`;
    return `$${u.toFixed(0)}`;
  };

  const esc = (v)=>String(v ?? "")
    .replace(/&/g,"&amp;")
    .replace(/</g,"&lt;")
    .replace(/>/g,"&gt;")
    .replace(/\"/g,"&quot;")
    .replace(/'/g,"&#39;");

  const openTagWindow = (tagObj)=>{
    const tagName = String(tagObj?.tag || "VM Tag");
    const ownerName = (drafts[tagName]?.owner_name ?? tagObj?.owner ?? "") || "";
    const ownerEmail = (drafts[tagName]?.owner_email ?? tagObj?.owner_email ?? "") || "";
    const powerOn = Number(tagObj?.running_vms || 0);
    const powerOff = Number(tagObj?.stopped_vms || 0);
    const vms = (Array.isArray(tagObj?.vms) ? tagObj.vms : [])
      .slice()
      .sort((a,b)=>Number(b.utilization_score||0)-Number(a.utilization_score||0))
      .map((vm, i)=>({
        index: i+1,
        name: vm.name || "",
        status: vm.status || "",
        cpu: Number(vm.cpu || 0),
        ram_gb: Number(vm.ram_gb || 0),
        disk_gb: Number(vm.disk_gb || 0),
        disk_type: vm.disk_type || "HDD",
        disk_rate_inr: Number(vm.disk_rate_inr || 0),
        host: vm.host || "",
        vcenter_name: vm.vcenter_name || "",
        guest_os: vm.guest_os || "",
        license_type: vm.license_type || "",
        license_cost_inr: vm.license_cost_inr != null ? Number(vm.license_cost_inr) : null,
        has_internet: Boolean(vm.has_internet),
        internet_cost_inr: vm.internet_cost_inr != null ? Number(vm.internet_cost_inr) : null,
        utilization_score: Number(vm.utilization_score || 0),
        vm_age_days: vm.vm_age_days != null ? Number(vm.vm_age_days) : null,
        chargeback_inr: vm.chargeback_inr != null ? Number(vm.chargeback_inr) : null,
        chargeback_usd: vm.chargeback_usd != null ? Number(vm.chargeback_usd) : null,
      }));

    const isAdmin = currentUser?.role === "admin";
    const win = window.open("", "_blank", "width=1280,height=800");
    if(!win) return;
    const doc = win.document;
    const tagCbInr = Number(tagObj?.chargeback_inr || 0);
    const tagCbUsd = Number(tagObj?.chargeback_usd || 0);
    const headers = ["#","VM","STATUS","OWNER","POWER_ON","POWER_OFF","CPU","RAM_GB","DISK_GB","DISK_TYPE","DISK_RATE_INR","HOST","VCENTER","GUEST_OS","LICENSE_TYPE","LICENSE_COST_INR","INTERNET","INTERNET_COST_INR","UTILIZATION_SCORE","VM_AGE_DAYS","CHARGEBACK_INR","CHARGEBACK_USD"];
    const csv = [headers.join(","), ...vms.map(r=>[
      r.index, r.name, r.status, ownerName, powerOn, powerOff, r.cpu, r.ram_gb, r.disk_gb, r.disk_type, r.disk_rate_inr, r.host, r.vcenter_name,
      r.guest_os,
      r.license_type||"",
      r.license_cost_inr!=null?r.license_cost_inr.toFixed(2):"",
      r.has_internet?"yes":"no",
      r.internet_cost_inr!=null?r.internet_cost_inr.toFixed(2):"",
      r.utilization_score.toFixed(1),
      r.vm_age_days != null ? r.vm_age_days : "",
      r.chargeback_inr != null ? r.chargeback_inr.toFixed(2) : "",
      r.chargeback_usd != null ? r.chargeback_usd.toFixed(2) : "",
    ].map(x=>`\"${String(x).replace(/\"/g,'\"\"')}\"`).join(","))].join("\n");
    const txt = [
      `VM Tag: ${tagName}`,
      `Owner: ${ownerName || "—"}`,
      `Owner Email: ${ownerEmail || "—"}`,
      `Power ON: ${powerOn}`,
      `Power OFF: ${powerOff}`,
      `Chargeback: ₹${tagCbInr.toLocaleString()} / $${tagCbUsd.toFixed(2)}`,
      "",
      headers.join(" | "),
      ...vms.map(r=>[
        r.index, r.name, r.status, ownerName, powerOn, powerOff, r.cpu, r.ram_gb, r.disk_gb, r.disk_type, r.disk_rate_inr,
        r.host, r.vcenter_name, r.guest_os,
        r.license_type||"none",
        r.license_cost_inr!=null?`₹${r.license_cost_inr.toFixed(2)}`:"N/A",
        r.utilization_score.toFixed(1),
        r.vm_age_days != null ? r.vm_age_days : "N/A",
        r.chargeback_inr != null ? `₹${r.chargeback_inr.toFixed(2)}` : "N/A",
        r.chargeback_usd != null ? `$${r.chargeback_usd.toFixed(2)}` : "N/A",
      ].join(" | "))
    ].join("\n");
    const rowsHtml = vms.map(r=>{
      const ageDays = r.vm_age_days != null ? r.vm_age_days : null;
      const ageStr = ageDays != null ? (ageDays >= 365 ? `${(ageDays/365).toFixed(1)}y` : `${ageDays}d`) : "N/A";
      const cbInr = r.chargeback_inr != null ? `₹${Number(r.chargeback_inr).toLocaleString('en-IN',{maximumFractionDigits:0})}` : "";
      const cbUsd = r.chargeback_usd != null ? ` / $${Number(r.chargeback_usd).toFixed(0)}` : "";
      const dtBg = r.disk_type==="SSD" ? "#dbeafe" : "#fef3c7";
      const dtClr = r.disk_type==="SSD" ? "#1d4ed8" : "#92400e";
      const dtIcon = r.disk_type==="SSD" ? "🟦" : "🟫";
      const dtRate = r.disk_rate_inr ? `₹${r.disk_rate_inr}/GB` : "";
      const licIcon = r.license_type==="windows"?"🪟":r.license_type==="rhel"?"🎩":"";
      const licLabel = r.license_type==="windows"?"Windows":r.license_type==="rhel"?"RHEL":"";
      const licBg = r.license_type?"#ede9fe":"#f8fafc";
      const licClr = r.license_type?"#6d28d9":"#94a3b8";
      const licCostStr = r.license_cost_inr!=null&&r.license_cost_inr>0
        ? `₹${Number(r.license_cost_inr).toLocaleString('en-IN',{maximumFractionDigits:0})}/mo / $${(Number(r.license_cost_inr)/usdRate).toFixed(0)}/mo` : "—";
      const inetCostStr = r.internet_cost_inr!=null&&r.internet_cost_inr>0
        ? `₹${Number(r.internet_cost_inr).toLocaleString('en-IN',{maximumFractionDigits:0})} / $${(Number(r.internet_cost_inr)/usdRate).toFixed(0)}` : "—";
      const inetToggleHtml = isAdmin
        ? `<label style="display:flex;align-items:center;gap:4px;cursor:pointer;margin-top:2px">
            <input type="checkbox" ${r.has_internet?"checked":""} onchange="toggleInternet('${r.name.replace(/'/g,"\\'")}',(this.checked))"
              style="accent-color:#0891b2;width:13px;height:13px;"/>
            <span style="font-size:10px;color:#0369a1;font-weight:600;">${r.has_internet?"🌐 ON":"— OFF"}</span>
           </label>`
        : `<span style="font-size:11px;font-weight:600;color:${r.has_internet?"#0891b2":"#94a3b8"}">${r.has_internet?"🌐 Yes":"— No"}</span>`;
      return `<tr>
        <td>${r.index}</td><td>${esc(r.name)}</td><td>${esc(r.status)}</td><td>${esc(ownerName || "—")}</td>
        <td>${powerOn}</td><td>${powerOff}</td><td>${r.cpu}</td>
        <td>${r.ram_gb.toFixed(1)}</td>
        <td>${r.disk_gb.toFixed(1)}<br/><span style="background:${dtBg};color:${dtClr};border-radius:4px;padding:1px 5px;font-size:10px;font-weight:700;">${dtIcon} ${esc(r.disk_type||"HDD")} ${dtRate}</span></td>
        <td><span style="background:${licBg};color:${licClr};border-radius:4px;padding:2px 6px;font-size:10px;font-weight:700;">${licIcon?licIcon+" "+licLabel:"Free"}</span><br/><span style="font-size:10px;color:#64748b;">${licCostStr}</span></td>
        <td>${inetToggleHtml}<br/><span style="font-size:10px;color:#64748b;">${inetCostStr}</span></td>
        <td>${esc(r.host)}</td>
        <td>${esc(r.vcenter_name)}</td><td>${r.utilization_score.toFixed(1)}%</td>
        <td>${ageStr}</td><td class="cb">${cbInr}${cbUsd}</td>
      </tr>`;
    }).join("");

    const _origin = window.location.origin;
    doc.open();
    doc.write(`<!doctype html><html><head><title>${esc(tagName)} - Tagged VMs</title>
      <style>
      @page{margin:20mm 14mm 20mm 14mm}
      *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;color-adjust:exact!important}
      body{font-family:Arial,sans-serif;padding:18px;color:#0f172a}
      h2{margin:0 0 6px}.sub{color:#475569;font-size:12px;margin-bottom:10px}
      .actions{display:flex;gap:8px;margin-bottom:12px}
      button{padding:6px 10px;border:1px solid #cbd5e1;background:#f8fafc;border-radius:6px;cursor:pointer}
      table{width:100%;border-collapse:collapse;font-size:12px}
      th,td{border:1px solid #cbd5e1;padding:6px;text-align:left}
      th{background:#f1f5f9;position:sticky;top:0}.cb{color:#166534;font-weight:600}
      .print-header,.print-footer{display:none}
      @media print{
        .actions{display:none!important}
        .print-header{display:flex!important;position:fixed;top:0;left:0;right:0;height:44px;
          align-items:center;padding:0 8mm;border-bottom:1.5px solid #334155;
          background:#fff;z-index:9999}
        .print-footer{display:flex!important;position:fixed;bottom:0;left:0;right:0;height:28px;
          align-items:center;justify-content:center;
          border-top:1px solid #e2e8f0;background:#fff;
          font-size:10px;color:#64748b;z-index:9999;font-family:Arial,sans-serif;letter-spacing:.3px}
        body{padding-top:54px;padding-bottom:36px}
      }
      </style>
      </head><body>
      <div class="print-header"><img src="${_origin}/wings.png" height="34" style="object-fit:contain" alt="Wipro Wings"/></div>
      <div class="print-footer">CaaS Portal &mdash; Wipro Confidential</div>
      <h2>VM Tag: ${esc(tagName)}</h2><div class="sub">Owner: ${esc(ownerName || "—")} ${ownerEmail?`(${esc(ownerEmail)})`:""} · Power ON: ${powerOn} · Power OFF: ${powerOff} · Total VMs: ${vms.length} · Chargeback: ₹${tagCbInr.toLocaleString('en-IN',{maximumFractionDigits:0})} / $${tagCbUsd.toFixed(2)} · Sorted by utilization (High → Low)</div>
      <div class="actions"><button id="expCsv">Export CSV</button><button id="expTxt">Export TXT</button><button id="expPdf">Export PDF</button>${isAdmin?`<span style="font-size:11px;color:#0891b2;margin-left:8px;font-weight:600;">🌐 Admin: toggle Internet checkboxes to enable/disable per-VM internet charges</span>`:""}</div>
      <table><thead><tr><th>#</th><th>VM</th><th>Status</th><th>Owner</th><th>Power On</th><th>Power Off</th><th>CPU</th><th>RAM GB</th><th>Disk GB / Type</th><th>OS License</th><th>Internet ${isAdmin?"(Admin toggle)":""}</th><th>Host</th><th>vCenter</th><th>Utilization</th><th>VM Age</th><th>Chargeback</th></tr></thead>
      <tbody>${rowsHtml || '<tr><td colspan="16" style="text-align:center">No VMs found for this tag</td></tr>'}</tbody></table>
      <script>
        async function toggleInternet(vmName, enabled){
          try{
            const r = await fetch('${_origin}/api/admin/internet-vms/toggle',{
              method:'POST', credentials:'include',
              headers:{'Content-Type':'application/json'},
              body: JSON.stringify({vm_name: vmName, enabled: enabled})
            });
            if(!r.ok){ const e=await r.json(); alert('Error: '+(e.detail||r.statusText)); }
          }catch(e){ alert('Network error: '+e.message); }
        }
      </script>
      </body></html>`);
    doc.close();

    const download = (content, type, filename)=>{
      const blob = new Blob([content], {type});
      const a = doc.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = filename;
      a.click();
      URL.revokeObjectURL(a.href);
    };
    doc.getElementById("expCsv")?.addEventListener("click", ()=>download(csv, "text/csv;charset=utf-8;", `tag_${tagName.replace(/[^a-zA-Z0-9_-]+/g,"_")}.csv`));
    doc.getElementById("expTxt")?.addEventListener("click", ()=>download(txt, "text/plain;charset=utf-8;", `tag_${tagName.replace(/[^a-zA-Z0-9_-]+/g,"_")}.txt`));
    doc.getElementById("expPdf")?.addEventListener("click", ()=>win.print());
  };

  const onDraftChange = (tag, key, value)=>{
    setDrafts(prev=>({
      ...prev,
      [tag]: { ...(prev[tag] || { owner_name:"", owner_email:"" }), [key]: value },
    }));
  };

  const saveOwner = async(tag)=>{
    const d = drafts[tag] || { owner_name:"", owner_email:"" };
    try {
      setSavingTag(tag);
      await updateProjectTagOwner(tag, d.owner_name || "", d.owner_email || "", scopeKey);
      setData(prev=>{
        if(!prev || !Array.isArray(prev.tags)) return prev;
        return {
          ...prev,
          tags: prev.tags.map(t=>String(t.tag)===String(tag)
            ? { ...t, owner: d.owner_name || "", owner_email: d.owner_email || "" }
            : t),
        };
      });
    } catch(e){
      setError(e.message || "Failed to update owner");
    } finally {
      setSavingTag("");
    }
  };

  const openOverallPdfWindow = ()=>{
    const win = window.open("", "_blank", "width=1300,height=820");
    if(!win) return;
    const doc = win.document;
    const now = new Date().toLocaleString();
    const vcLabel = selectedVC==="all"?"All vCenters":selectedVC;
    const rowsHtml = rows.map((r,i)=>`
      <tr>
        <td>${i+1}</td>
        <td><b>${esc(r.tag)}</b></td>
        <td>${r.vm_count}</td>
        <td style="color:#16a34a;font-weight:700">${r.running_vms}</td>
        <td style="color:#dc2626;font-weight:700">${r.stopped_vms}</td>
        <td>${r.cpu_cores}</td>
        <td>${Number(r.ram_gb||0).toFixed(1)}</td>
        <td>${Number(r.disk_gb||0).toFixed(1)}</td>
        <td style="color:#16a34a;font-weight:600">${r.chargeback_inr>0?fmtInr(r.chargeback_inr):"—"}</td>
        <td style="color:#6b7280;font-size:11px">${r.chargeback_inr>0?fmtUsd(r.chargeback_inr):"—"}</td>
        <td>${esc(r.owner||"—")}</td>
        <td style="color:#6b7280;font-size:11px">${esc(r.owner_email||"—")}</td>
      </tr>`).join("");
    const totInr = fmtInr(totalCbInr);
    const totUsd = fmtUsd(totalCbInr);
    const _origin = window.location.origin;
    doc.open();
    doc.write(`<!doctype html><html><head><title>Project Utilization - All Tags</title>
    <style>
    @page{margin:20mm 14mm 20mm 14mm}
    *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;color-adjust:exact!important}
    body{font-family:Arial,sans-serif;font-size:12px;color:#1e1b4b;margin:0;padding:0;background:#fff}
    .pdf-header{display:flex;align-items:center;justify-content:space-between;border-bottom:3px solid #6d28d9;padding-bottom:10px;margin-bottom:18px}
    .pdf-header img{height:48px}
    .pdf-header-right{text-align:right}
    .pdf-title{font-size:20px;font-weight:800;color:#6d28d9;margin-bottom:2px}
    .pdf-sub{font-size:12px;color:#5b21b6}
    .kpi-row{display:flex;gap:12px;margin-bottom:18px;flex-wrap:wrap}
    .kpi{background:#f5f3ff;border:1px solid #ddd6fe;border-radius:8px;padding:10px 18px;flex:1;min-width:120px}
    .kpi-val{font-size:20px;font-weight:800;color:#6d28d9}
    .kpi-lbl{font-size:10px;color:#8b80c0;text-transform:uppercase;letter-spacing:.5px}
    table{width:100%;border-collapse:collapse;font-size:11px}
    th{background:#6d28d9;color:#fff;padding:7px 8px;text-align:left;font-size:10px;letter-spacing:.5px;text-transform:uppercase}
    td{padding:6px 8px;border-bottom:1px solid #ede9fe}
    tr:nth-child(even) td{background:#faf9ff}
    tr:hover td{background:#f0eefb}
    tfoot td{background:#ede9fe;font-weight:700;color:#4c1d95;border-top:2px solid #6d28d9}
    .actions{display:flex;gap:8px;margin-bottom:16px}
    button{padding:8px 18px;border:none;border-radius:6px;cursor:pointer;font-size:13px;font-weight:600}
    .btn-pdf{background:#6d28d9;color:#fff}
    .btn-close{background:#e5e7eb;color:#374151}
    @media print{.actions{display:none!important}
    .pdf-footer{position:fixed;bottom:0;left:0;right:0;text-align:center;font-size:10px;color:#8b80c0;border-top:1px solid #ddd6fe;padding:6px 0}}
    </style></head><body>
    <div class="actions">
      <button class="btn-pdf" onclick="window.print()">🖨️ Export PDF</button>
      <button class="btn-close" onclick="window.close()">✕ Close</button>
    </div>
    <div class="pdf-header">
      <img src="${_origin}/wings.png" alt="Wipro Wings"/>
      <div class="pdf-header-right">
        <div class="pdf-title">Project Utilization Report</div>
        <div class="pdf-sub">VMware Tags — ${esc(vcLabel)}</div>
        <div style="font-size:10px;color:#8b80c0;margin-top:4px">Generated: ${now}</div>
      </div>
    </div>
    <div class="kpi-row">
      <div class="kpi"><div class="kpi-val">${rows.length}</div><div class="kpi-lbl">Total Tags</div></div>
      <div class="kpi"><div class="kpi-val">${totalVMs}</div><div class="kpi-lbl">Total VMs</div></div>
      <div class="kpi"><div class="kpi-val">${totalCpu}</div><div class="kpi-lbl">CPU Cores</div></div>
      <div class="kpi"><div class="kpi-val">${Math.round(totalRam)} GB</div><div class="kpi-lbl">Total RAM</div></div>
      <div class="kpi"><div class="kpi-val">${Math.round(totalDisk)} GB</div><div class="kpi-lbl">Total Disk</div></div>
      <div class="kpi"><div class="kpi-val" style="color:#16a34a">${totInr}</div><div class="kpi-lbl">Total Chargeback</div></div>
    </div>
    <table>
      <thead><tr><th>#</th><th>VM Tag</th><th>VMs</th><th>Power ON</th><th>Power OFF</th><th>CPU</th><th>RAM (GB)</th><th>Disk (GB)</th><th>Chargeback (INR)</th><th>Chargeback (USD)</th><th>Owner</th><th>Owner Email</th></tr></thead>
      <tbody>${rowsHtml}</tbody>
      <tfoot><tr>
        <td colspan="2">TOTAL</td>
        <td>${totalVMs}</td><td></td><td></td>
        <td>${totalCpu}</td>
        <td>${Math.round(totalRam)}</td>
        <td>${Math.round(totalDisk)}</td>
        <td>${totInr}</td><td>${totUsd}</td><td colspan="2"></td>
      </tr></tfoot>
    </table>
    <div class="pdf-footer">CaaS Portal — Wipro Confidential | Project Utilization Report | ${now}</div>
    </body></html>`);
    doc.close();
  };

  const triggerMailAndCopy = (email)=>{
    const e = String(email || "").trim();
    if(!e) return;
    try { navigator.clipboard?.writeText(e); } catch {}
    try { window.location.href = `mailto:${e}`; } catch {}
  };

  const askCopyEmail = (email)=>{
    const e = String(email || "").trim();
    if(!e) return;
    const ok = window.confirm(`Copy this email?\n\n${e}`);
    if(!ok) return;
    try { navigator.clipboard?.writeText(e); } catch {}
  };

  if(loading) return <LoadState msg="Loading project utilization by VMware tags…"/>;
  if(error)   return <ErrState msg={error} onRetry={load}/>;

  return (
    <div className="g-gap">
      <div className="g4">
        <KPI icon="🏷️" label="Tags" value={rows.length} color={p.cyan} sub="VMware tags found"/>
        <KPI icon="🖥️" label="Tagged VMs" value={totalVMs} color={p.green} sub="Counted across tag groups"/>
        <KPI icon="⚡" label="CPU Cores" value={totalCpu} color={p.accent} sub="Aggregated by tag"/>
        <KPI icon="🧠" label="RAM / Disk" value={`${Math.round(totalRam)} / ${Math.round(totalDisk)}`} color={p.cyan} sub="GB by tag"/>
        <KPI icon="💰" label="Chargeback" value={fmtInr(totalCbInr)} color={p.green} sub={`${fmtUsd(totalCbInr)} cumulative`}/>
      </div>

      <TagUtilizationDonut rows={rows} p={p} title="Team Tag-wise VM Utilization (%)"/>

      <div className="card" style={{overflow:"hidden"}}>
        <div className="card-header">
          <span className="card-title">Project Utilization (VMware Tags)</span>
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            <span style={{fontSize:11,color:p.textMute}}>{selectedVC==="all"?"All vCenters":selectedVC}</span>
            <button className="btn btn-sm" onClick={openOverallPdfWindow}
              style={{background:`${p.accent}18`,color:p.accent,border:`1px solid ${p.accent}40`,fontWeight:600}}>
              🖨️ Export PDF
            </button>
          </div>
        </div>
        <div className="tbl-wrap" style={{maxHeight:"calc(100vh - 300px)"}}>
          <table>
            <thead>
              <tr>
                <th>VM TAG</th><th>VM COUNT</th><th>POWER ON</th><th>POWER OFF</th><th>CPU</th><th>MEM (GB)</th><th>STORAGE (GB)</th><th>CHARGEBACK</th><th>OWNER</th>
              </tr>
            </thead>
            <tbody>
              {rows.length===0&&(
                <tr><td colSpan={9} style={{textAlign:"center",padding:28,color:p.textMute}}>No tagged VMs found</td></tr>
              )}
              {rows.map((r)=>{
                const c = p.cyan;
                const d = drafts[r.tag] || { owner_name:r.owner || "", owner_email:r.owner_email || "" };
                return (
                  <tr key={r.tag}>
                    <td>
                      <button className="btn btn-ghost btn-sm" onClick={()=>openTagWindow(r)} title="Open tagged VM list"
                        style={{padding:"2px 8px",borderColor:`${c}40`,color:c,background:`${c}10`}}>{r.tag}</button>
                    </td>
                    <td><M>{r.vm_count}</M></td>
                    <td style={{color:p.green,fontWeight:700}}>{r.running_vms}</td>
                    <td style={{color:p.red,fontWeight:700}}>{r.stopped_vms}</td>
                    <td>{r.cpu_cores}</td>
                    <td>{Number(r.ram_gb||0).toFixed(1)}</td>
                    <td>
                      {Number(r.disk_gb||0).toFixed(1)}
                      {(()=>{
                        const ssdVMs = (r.vms||[]).filter(v=>v.disk_type==="SSD");
                        const hddVMs = (r.vms||[]).filter(v=>v.disk_type!=="SSD");
                        const ssdGb = ssdVMs.reduce((a,v)=>a+Number(v.disk_gb||0),0);
                        const hddGb = hddVMs.reduce((a,v)=>a+Number(v.disk_gb||0),0);
                        if(!ssdGb && !hddGb) return null;
                        return <div style={{fontSize:10,color:p.textMute,marginTop:2,lineHeight:"1.5"}}>
                          {ssdGb>0&&<span style={{color:"#0ea5e9",marginRight:4}}>🟦 SSD {ssdGb.toFixed(0)}GB</span>}
                          {hddGb>0&&<span style={{color:"#78716c"}}>🟫 HDD {hddGb.toFixed(0)}GB</span>}
                        </div>;
                      })()}
                    </td>
                    <td style={{color:p.green,fontWeight:600,whiteSpace:"nowrap"}}>
                      <div>{fmtInr(r.chargeback_inr)}</div>
                      {r.chargeback_inr>0 && <div style={{fontSize:10,color:p.textMute}}>{fmtUsd(r.chargeback_inr)}</div>}
                    </td>
                    <td style={{overflow:"visible",whiteSpace:"normal",position:"relative"}}>
                      <div style={{display:"flex",alignItems:"center",gap:6,position:"relative"}}>
                        {canEditOwner ? (
                          <>
                            <input value={d.owner_name} onChange={e=>onDraftChange(r.tag,"owner_name",e.target.value)} placeholder="Owner name"
                              style={{minWidth:120,maxWidth:170,padding:"4px 8px",fontSize:12}} />
                            {!d.owner_email ? (
                              <button className="btn btn-ghost btn-sm" onClick={()=>setMailOpenTag(t=>t===r.tag?"":r.tag)} title="Set owner email">📫</button>
                            ) : (
                              <button
                                className="btn btn-ghost btn-sm"
                                onMouseEnter={()=>setMailHoverTag(r.tag)}
                                onMouseLeave={()=>setMailHoverTag("")}
                                onClick={()=>askCopyEmail(d.owner_email)}
                                title="Owner email available"
                              >📫</button>
                            )}
                            <button className="btn btn-primary btn-sm" onClick={()=>saveOwner(r.tag)} disabled={savingTag===r.tag}>{savingTag===r.tag?"...":"Save"}</button>
                            {mailOpenTag===r.tag && (
                              <div style={{position:"absolute",top:"calc(100% + 4px)",left:0,zIndex:20,background:p.panel,border:`1px solid ${p.border}`,borderRadius:8,padding:8,minWidth:220,boxShadow:"0 8px 24px rgba(0,0,0,.25)"}}>
                                <div style={{fontSize:10,color:p.textMute,marginBottom:4}}>Owner Email</div>
                                <input value={d.owner_email} onChange={e=>onDraftChange(r.tag,"owner_email",e.target.value)} placeholder="owner@company.com"
                                  style={{padding:"5px 8px",fontSize:12,marginBottom:6}} />
                                <div style={{display:"flex",gap:6,justifyContent:"flex-end"}}>
                                  <button className="btn btn-ghost btn-sm" onClick={()=>{if(d.owner_email){navigator.clipboard?.writeText(d.owner_email);}}}>Copy</button>
                                  <button className="btn btn-ghost btn-sm" onClick={()=>triggerMailAndCopy(d.owner_email)} disabled={!d.owner_email}>Mail</button>
                                  <button className="btn btn-primary btn-sm" onClick={()=>saveOwner(r.tag)} disabled={savingTag===r.tag}>Save</button>
                                </div>
                              </div>
                            )}
                            {mailHoverTag===r.tag && !!d.owner_email && (
                              <div
                                onMouseEnter={()=>setMailHoverTag(r.tag)}
                                onMouseLeave={()=>setMailHoverTag("")}
                                style={{position:"absolute",top:"calc(100% + 4px)",left:0,zIndex:20,background:p.panel,border:`1px solid ${p.border}`,borderRadius:8,padding:8,minWidth:220,boxShadow:"0 8px 24px rgba(0,0,0,.25)"}}
                              >
                                <div style={{fontSize:10,color:p.textMute,marginBottom:4}}>Owner Email</div>
                                <div style={{fontSize:12,color:p.textSub}}>{d.owner_email}</div>
                              </div>
                            )}
                          </>
                        ) : (
                          <>
                            <span style={{fontSize:12,color:p.textSub}}>{r.owner || "—"}</span>
                            <button
                              className="btn btn-ghost btn-sm"
                              onMouseEnter={()=>setMailHoverTag(r.tag)}
                              onMouseLeave={()=>setMailHoverTag("")}
                              onClick={()=>askCopyEmail(r.owner_email)}
                              title={r.owner_email?"Click to copy email":"No email set"}
                            >📫</button>
                            {mailHoverTag===r.tag && (
                              <div
                                onMouseEnter={()=>setMailHoverTag(r.tag)}
                                onMouseLeave={()=>setMailHoverTag("")}
                                style={{position:"absolute",top:"calc(100% + 4px)",left:0,zIndex:20,background:p.panel,border:`1px solid ${p.border}`,borderRadius:8,padding:8,minWidth:220,boxShadow:"0 8px 24px rgba(0,0,0,.25)"}}
                              >
                                <div style={{fontSize:10,color:p.textMute,marginBottom:4}}>Owner Email</div>
                                <div style={{fontSize:12,color:p.textSub}}>{r.owner_email || "No email set"}</div>
                              </div>
                            )}
                          </>
                        )}
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      <div style={{fontSize:11,color:p.textMute}}>{data?.note}</div>
    </div>
  );
}

// ─── AD & DNS PAGE ───────────────────────────────────────────────────────────
function ADDNSPage({currentUser, p}) {
  const isAdmin    = currentUser?.role === "admin";
  const canWrite   = isAdmin || currentUser?.role === "operator";

  const [tab,        setTab]        = useState("users");
  // ── AD Users state ──
  const [users,      setUsers]      = useState([]);
  const [uLoad,      setULoad]      = useState(false);
  const [uQ,         setUQ]         = useState("");
  const [uModal,     setUModal]     = useState(null); // "create"|"reset"|"groups"
  const [uTarget,    setUTarget]    = useState(null);
  const [uForm,      setUForm]      = useState({username:"",display_name:"",password:"",email:"",department:"",title:"",ou_dn:"",pw_never_expires:false,must_change_pw:false});
  const [uMsg,       setUMsg]       = useState(null);
  const [copyQ,      setCopyQ]      = useState("");
  const [copyFrom,   setCopyFrom]   = useState(null); // user object to copy groups from
  // ── AD Groups state ──
  const [groups,     setGroups]     = useState([]);
  const [gLoad,      setGLoad]      = useState(false);
  const [gQ,         setGQ]         = useState("");
  const [gModal,     setGModal]     = useState(null); // "create"|"members"|"addmember"
  const [gTarget,    setGTarget]    = useState(null);
  const [gForm,      setGForm]      = useState({name:"",description:""});
  const [gMemberDN,  setGMemberDN]  = useState("");
  const [gMsg,       setGMsg]       = useState(null);
  // ── Computers ──
  const [computers,  setComputers]  = useState([]);
  const [cLoad,      setCLoad]      = useState(false);
  const [cQ,         setCQ]         = useState("");
  // ── OUs ──
  const [ous,        setOUs]        = useState([]);
  const [ouLoad,     setOULoad]     = useState(false);
  // ── DNS state ──
  const [zones,      setZones]      = useState([]);
  const [zLoad,      setZLoad]      = useState(false);
  const [selZone,    setSelZone]    = useState("");
  const [records,    setRecords]    = useState([]);
  const [rLoad,      setRLoad]      = useState(false);
  const [dnsMsg,     setDNSMsg]     = useState(null);
  const [addRec,     setAddRec]     = useState(false);
  const [recForm,    setRecForm]    = useState({hostname:"",rtype:"A",data:"",ttl:3600});
  const [createPtr,  setCreatePtr]  = useState(false);
  const [confirmDel, setConfirmDel] = useState(null); // {type, payload, label}
  const [busy,       setBusy]       = useState(false);

  // ── Loaders ──────────────────────────────────────────────────────────────
  const loadUsers = async (q="") => {
    setULoad(true); setUMsg(null);
    try { const d = await adListUsers(q); setUsers(d.users||[]); if(d.error) setUMsg({ok:false,msg:d.error}); }
    catch(e){ setUMsg({ok:false,msg:e.message}); }
    finally { setULoad(false); }
  };
  const loadGroups = async (q="") => {
    setGLoad(true); setGMsg(null);
    try { const d = await adListGroups(q); setGroups(d.groups||[]); if(d.error) setGMsg({ok:false,msg:d.error}); }
    catch(e){ setGMsg({ok:false,msg:e.message}); }
    finally { setGLoad(false); }
  };
  const loadComputers = async (q="") => {
    setCLoad(true);
    try { const d = await adListComputers(q); setComputers(d.computers||[]); }
    catch(e){} finally { setCLoad(false); }
  };
  const loadOUs = async () => {
    setOULoad(true);
    try { const d = await adListOUs(); setOUs(d.ous||[]); }
    catch(e){} finally { setOULoad(false); }
  };
  const loadZones = async () => {
    setZLoad(true); setDNSMsg(null);
    try {
      const d = await dnsListZones();
      const raw = d.zones||[];
      // Sort: Primary+AD-integrated forward zones first, other forward, then reverse
      const sorted = [...raw].sort((a,b)=>{
        const scoreZ = z => {
          if(z.is_reverse) return 100;
          if(z.type==="Primary"&&z.ds_integrated) return 0;
          if(z.type==="Primary") return 1;
          return 2;
        };
        const s = scoreZ(a)-scoreZ(b);
        if(s!==0) return s;
        return a.name.localeCompare(b.name);
      });
      setZones(sorted);
      // Auto-select the best forward zone if none selected yet
      setSelZone(cur => {
        if(cur) return cur;
        const best = sorted.find(z=>!z.is_reverse&&z.type==="Primary"&&z.ds_integrated)
                  || sorted.find(z=>!z.is_reverse&&z.type==="Primary")
                  || sorted.find(z=>!z.is_reverse)
                  || sorted[0];
        return best ? best.name : "";
      });
      if(d.error) setDNSMsg({ok:false,msg:d.error});
    }
    catch(e){ setDNSMsg({ok:false,msg:e.message}); }
    finally { setZLoad(false); }
  };
  const loadRecords = async (zone) => {
    setRLoad(true); setDNSMsg(null);
    try { const d = await dnsListRecords(zone); setRecords(d.records||[]); if(d.error) setDNSMsg({ok:false,msg:d.error}); }
    catch(e){ setDNSMsg({ok:false,msg:e.message}); }
    finally { setRLoad(false); }
  };

  useEffect(()=>{
    if(tab==="users")    loadUsers();
    if(tab==="groups")   loadGroups();
    if(tab==="computers")loadComputers();
    if(tab==="ous")      loadOUs();
    if(tab==="dns")      loadZones();
  },[tab]);

  useEffect(()=>{ if(selZone) loadRecords(selZone); },[selZone]);

  // ── confirm helper ────────────────────────────────────────────────────────
  const confirm = (label, payload, type) => setConfirmDel({label, payload, type});

  const execConfirm = async () => {
    if(!confirmDel) return;
    setBusy(true);
    try {
      const {type, payload} = confirmDel;
      let r;
      if(type==="del_user")    { r = await adDeleteUser(payload.dn); if(r.success){ setUsers(u=>u.filter(x=>x.dn!==payload.dn)); setUMsg({ok:true,msg:`User "${payload.username}" deleted.`}); } else setUMsg({ok:false,msg:r.error}); }
      if(type==="del_group")   { r = await adDeleteGroup(payload.dn); if(r.success){ setGroups(g=>g.filter(x=>x.dn!==payload.dn)); setGMsg({ok:true,msg:`Group "${payload.name}" deleted.`}); } else setGMsg({ok:false,msg:r.error}); }
      if(type==="del_rec")     { r = await dnsDeleteRecord(payload.zone,payload.hostname,payload.rtype); if(r.success){ setDNSMsg({ok:true,msg:"Record deleted."}); loadRecords(selZone); } else setDNSMsg({ok:false,msg:r.error}); }
      if(type==="flush_cache") { r = await dnsFlushCache(); setDNSMsg({ok:r.success,msg:r.success?"DNS cache flushed successfully.":r.error}); }
      if(type==="rem_member")  { r = await adGroupMember(payload.group_dn, payload.user_dn, false); if(r.success){ loadGroups(); setGTarget(g=>({...g,members:g.members.filter(m=>m!==payload.user_cn)})); setGMsg({ok:true,msg:"Member removed."}); } else setGMsg({ok:false,msg:r.error}); }
    } catch(e){ setUMsg({ok:false,msg:e.message}); }
    finally { setBusy(false); setConfirmDel(null); }
  };

  // ── shared styles ─────────────────────────────────────────────────────────
  const inp = {width:"100%",padding:"7px 10px",borderRadius:6,border:`1px solid ${p.border}`,background:p.surface,color:p.text,fontSize:13,outline:"none"};
  const btn = (col="#3b82f6",sm=false) => ({padding:sm?"4px 10px":"7px 16px",borderRadius:6,border:`1px solid ${col}44`,background:`${col}22`,color:col,fontWeight:700,fontSize:sm?11:12,cursor:"pointer"});
  const badge = (ok) => ({display:"inline-block",padding:"2px 8px",borderRadius:4,fontSize:10,fontWeight:700,background:ok?"#10b98122":"#ef444422",color:ok?"#10b981":"#ef4444",border:`1px solid ${ok?"#10b98144":"#ef444444"}`});
  const TH = ({children,w})=>(<th style={{padding:"8px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:p.grey,borderBottom:`2px solid ${p.border}`,textTransform:"uppercase",letterSpacing:".4px",whiteSpace:"nowrap",width:w||"auto"}}>{children}</th>);
  const TD = ({children,style={}})=>(<td style={{padding:"7px 10px",borderBottom:`1px solid ${p.border}33`,verticalAlign:"middle",...style}}>{children}</td>);

  // ── Export helpers ────────────────────────────────────────────────────────
  const exportCSV = (rows, cols, filename) => {
    const esc = v => { const s=String(v??''); return s.includes(',')||s.includes('"')||s.includes('\n')?`"${s.replace(/"/g,'""')}"`:s; };
    const lines = [cols.map(c=>esc(c.label)).join(','), ...rows.map(r=>cols.map(c=>esc(r[c.key]??'')).join(','))];
    const blob = new Blob([lines.join('\n')], {type:'text/csv'});
    const a = document.createElement('a'); a.href=URL.createObjectURL(blob); a.download=filename; a.click();
  };

  const exportPDF = (title, cols, rows, meta='') => {
    const ts = new Date().toLocaleString();
    const esc = s => String(s??'—').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    const head = cols.map(c=>`<th style="padding:7px 10px;text-align:left;font-size:10px;font-weight:700;color:#64748b;border-bottom:2px solid #2d1b69;text-transform:uppercase;letter-spacing:.4px;background:#12082a">${esc(c.label)}</th>`).join('');
    const body = rows.map((r,i)=>`<tr style="background:${i%2===0?'#1a1035':'#130d28'}">${cols.map(c=>`<td style="padding:6px 10px;border-bottom:1px solid #2d1b6933;font-size:11px;color:#e2e8f0;vertical-align:middle">${esc(r[c.key])}</td>`).join('')}</tr>`).join('');
    const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${esc(title)}</title>
<style>@media print{.np{display:none!important}body{background:#fff!important;color:#000!important}td,th{color:#000!important;border-color:#ddd!important}tr{background:#fff!important}}
*{box-sizing:border-box;margin:0;padding:0}body{background:#0f0a1e;color:#e2e8f0;font-family:'Segoe UI',Arial,sans-serif}
.hdr{background:linear-gradient(135deg,#12082a,#1e0a3c);padding:16px 28px;border-bottom:2px solid #7c3aed44;display:flex;align-items:center;gap:18px}
.hdr img{height:48px}.hdr h1{font-size:18px;font-weight:800;color:#e2e8f0}.hdr p{font-size:12px;color:#94a3b8;margin-top:3px}
table{width:100%;border-collapse:collapse;border:1px solid #2d1b69;border-radius:8px;overflow:hidden}
.wrap{padding:18px 28px}.pbtn{background:linear-gradient(135deg,#7c3aed,#06b6d4);color:#fff;border:none;padding:9px 20px;border-radius:7px;font-size:13px;font-weight:700;cursor:pointer}
.footer{text-align:center;color:#475569;font-size:11px;padding:14px;border-top:1px solid #2d1b69;margin-top:12px}
.kpi{display:inline-block;background:#1a1035;border:1px solid #2d1b69;border-radius:8px;padding:8px 18px;margin:0 6px 10px 0;text-align:center}
.kv{font-size:20px;font-weight:800;color:#a78bfa}.kl{font-size:10px;color:#64748b;text-transform:uppercase}
</style></head><body>
<div class="hdr"><img src="/wings.png" onerror="this.style.display='none'" alt="Wipro">
<div style="flex:1"><h1>🌲 ${esc(title)}</h1><p>AD &amp; DNS Management &bull; ${esc(meta)} &bull; ${rows.length} records &bull; ${esc(ts)}</p></div>
<button class="pbtn np" onclick="window.print()">🖨️ Export / Print PDF</button></div>
<div class="wrap">
<div style="margin-bottom:14px"><div class="kpi"><div class="kv">${rows.length}</div><div class="kl">Total Records</div></div></div>
<table><thead><tr>${head}</tr></thead><tbody>${body||`<tr><td colspan="${cols.length}" style="padding:24px;text-align:center;color:#475569">No data</td></tr>`}</tbody></table>
<div class="footer">${esc(title)} &bull; Wipro Confidential &bull; ${esc(ts)}</div></div></body></html>`;
    const tab2=window.open('','_blank'); if(tab2){tab2.document.write(html);tab2.document.close();}
  };

  // ── TABS ─────────────────────────────────────────────────────────────────
  const TABS = [
    {id:"users",     label:"👤 AD Users",     cnt:users.length},
    {id:"groups",    label:"👥 AD Groups",    cnt:groups.length},
    {id:"computers", label:"🖥️ Computers",   cnt:computers.length},
    {id:"ous",       label:"🗂️ OUs",         cnt:ous.length},
    {id:"dns",       label:"🌐 DNS",          cnt:zones.length},
  ];

  // ─── RENDER ──────────────────────────────────────────────────────────────
  return (
    <div style={{padding:"0 0 40px"}}>
      {/* Header */}
      <div style={{marginBottom:16}}>
        <div style={{fontWeight:700,fontSize:20,color:p.text}}>🌲 Active Directory & DNS</div>
        <div style={{fontSize:12,color:p.textMute,marginTop:2}}>Manage AD users, groups, computers, OUs and DNS records · {currentUser?.domain||"sdxtest.local"}</div>
      </div>

      {/* Tab bar */}
      <div style={{display:"flex",gap:4,marginBottom:18,borderBottom:`1px solid ${p.border}`,paddingBottom:0}}>
        {TABS.map(t=>(
          <button key={t.id} onClick={()=>setTab(t.id)}
            style={{padding:"8px 16px",borderRadius:"8px 8px 0 0",border:`1px solid ${tab===t.id?p.accent:p.border}`,borderBottom:tab===t.id?`2px solid ${p.accent}`:`1px solid ${p.border}`,
              background:tab===t.id?`${p.accent}18`:p.panel,color:tab===t.id?p.accent:p.textMute,
              fontWeight:700,fontSize:12,cursor:"pointer",marginBottom:-1,transition:"all .15s"}}>
            {t.label}{t.cnt>0&&<span style={{marginLeft:5,padding:"1px 6px",borderRadius:10,fontSize:9,background:`${tab===t.id?p.accent:p.grey}33`,color:tab===t.id?p.accent:p.grey}}>{t.cnt}</span>}
          </button>
        ))}
      </div>

      {/* ════ AD USERS TAB ════════════════════════════════════════════════════ */}
      {tab==="users" && (
        <div>
          {uMsg && <div style={{padding:"8px 14px",borderRadius:7,marginBottom:10,fontSize:12,fontWeight:600,background:uMsg.ok?"#10b98118":"#ef444418",color:uMsg.ok?"#10b981":"#ef4444",border:`1px solid ${uMsg.ok?"#10b98144":"#ef444444"}`}}>{uMsg.ok?"✅":"⚠️"} {uMsg.msg}</div>}
          <div style={{display:"flex",gap:8,marginBottom:12,alignItems:"center",flexWrap:"wrap"}}>
            <input placeholder="Search users…" value={uQ} onChange={e=>setUQ(e.target.value)}
              onKeyDown={e=>e.key==="Enter"&&loadUsers(uQ)}
              style={{...inp,width:240}} />
            <button onClick={()=>loadUsers(uQ)} style={btn(p.cyan,true)}>🔍 Search</button>
            <button onClick={()=>loadUsers("")} style={btn(p.grey,true)}>↺ All</button>
            {canWrite&&<button onClick={()=>{setUForm({username:"",display_name:"",password:"",email:"",department:"",title:"",ou_dn:"",pw_never_expires:false,must_change_pw:false});setUMsg(null);setCopyQ("");setCopyFrom(null);setUModal("create");}} style={btn(p.green)}>＋ Create User</button>}
            <div style={{marginLeft:"auto",display:"flex",gap:5}}>
              <button onClick={()=>exportCSV(users,[{key:"username",label:"Username"},{key:"display_name",label:"Display Name"},{key:"email",label:"Email"},{key:"department",label:"Department"},{key:"title",label:"Title"},{key:"enabled",label:"Enabled"},{key:"locked",label:"Locked"},{key:"created",label:"Created"}],`AD-Users-${new Date().toISOString().slice(0,10)}.csv`)} style={btn("#10b981",true)} disabled={!users.length}>⬇ CSV</button>
              <button onClick={()=>exportPDF("AD Users",
                [{key:"username",label:"Username"},{key:"display_name",label:"Display Name"},{key:"email",label:"Email"},{key:"department",label:"Dept"},{key:"title",label:"Title"},{key:"enabled",label:"Enabled"},{key:"locked",label:"Locked"}],
                users.map(u=>({...u,enabled:u.enabled?"Yes":"No",locked:u.locked?"Yes":"No"})),"AD Users") } style={btn("#f97316",true)} disabled={!users.length}>📄 PDF</button>
            </div>
          </div>
          {uLoad ? <div style={{textAlign:"center",padding:40,color:p.textMute}}>⏳ Loading users…</div> : (
            <div style={{overflowX:"auto",borderRadius:8,border:`1px solid ${p.border}`,background:p.panel}}>
              <table style={{width:"100%",borderCollapse:"collapse"}}>
                <thead><tr style={{background:p.surface}}>
                  <TH>Username</TH><TH>Display Name</TH><TH>Email</TH>
                  <TH>Department</TH><TH>Title</TH><TH>Status</TH><TH>Groups</TH><TH>Actions</TH>
                </tr></thead>
                <tbody>
                  {users.length===0&&<tr><td colSpan={8} style={{padding:32,textAlign:"center",color:p.textMute}}>No users found</td></tr>}
                  {users.map((u,i)=>(
                    <tr key={u.dn} style={{background:i%2===0?p.panel:p.panelAlt}}>
                      <TD><span style={{fontFamily:"monospace",color:p.cyan,fontSize:12}}>{u.username}</span></TD>
                      <TD><span style={{color:p.text,fontSize:12}}>{u.display_name||"—"}</span></TD>
                      <TD><span style={{fontSize:11,color:p.textMute}}>{u.email||"—"}</span></TD>
                      <TD><span style={{fontSize:11,color:p.textMute}}>{u.department||"—"}</span></TD>
                      <TD><span style={{fontSize:11,color:p.textMute}}>{u.title||"—"}</span></TD>
                      <TD>
                        <div style={{display:"flex",gap:4,flexWrap:"wrap"}}>
                          <span style={badge(u.enabled)}>{u.enabled?"Enabled":"Disabled"}</span>
                          {u.locked&&<span style={{...badge(false),background:"#f59e0b22",color:"#f59e0b",border:"1px solid #f59e0b44"}}>Locked</span>}
                        </div>
                      </TD>
                      <TD><span style={{fontSize:10,color:p.grey}}>{u.groups.slice(0,3).join(", ")||"—"}{u.groups.length>3?` +${u.groups.length-3}`:""}</span></TD>
                      <TD>
                        {canWrite&&(<div style={{display:"flex",gap:4,flexWrap:"wrap"}}>
                          <button onClick={async()=>{setBusy(true);const r=await adSetEnabled(u.dn,!u.enabled);setBusy(false);if(r.success){setUsers(us=>us.map(x=>x.dn===u.dn?{...x,enabled:!u.enabled}:x));setUMsg({ok:true,msg:`${u.username} ${!u.enabled?"enabled":"disabled"}.`});}else setUMsg({ok:false,msg:r.error});}} style={btn(u.enabled?"#ef4444":"#10b981",true)} disabled={busy}>{u.enabled?"Disable":"Enable"}</button>
                          {u.locked&&<button onClick={async()=>{setBusy(true);const r=await adUnlockUser(u.dn);setBusy(false);if(r.success){setUsers(us=>us.map(x=>x.dn===u.dn?{...x,locked:false}:x));setUMsg({ok:true,msg:`${u.username} unlocked.`});}else setUMsg({ok:false,msg:r.error});}} style={btn("#f59e0b",true)} disabled={busy}>🔓 Unlock</button>}
                          <button onClick={()=>{setUTarget(u);setUForm({password:""});setUModal("reset");}} style={btn("#a78bfa",true)}>🔑 Passwd</button>
                          {canWrite&&<button onClick={()=>confirm(`Delete user "${u.username}"?`,u,"del_user")} style={btn("#ef4444",true)}>🗑</button>}
                        </div>)}
                      </TD>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          {/* Create User Modal */}
          {uModal==="create"&&(
            <div style={{position:"fixed",inset:0,background:"#000a",zIndex:1000,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={(e)=>{if(e.target===e.currentTarget){setUModal(null);setCopyFrom(null);setCopyQ("");}}}>
              <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,padding:28,width:500,maxHeight:"92vh",overflowY:"auto"}}>
                <div style={{fontWeight:700,fontSize:16,color:p.text,marginBottom:18}}>➕ Create AD User</div>

                {/* ── Copy from existing user ─────────────────────────── */}
                <div style={{marginBottom:14,padding:"10px 14px",borderRadius:8,background:`${p.accent}0f`,border:`1px solid ${p.accent}33`}}>
                  <div style={{fontSize:11,fontWeight:700,color:p.accent,marginBottom:6}}>📋 Copy Groups from Existing User <span style={{fontWeight:400,color:p.textMute}}>(optional – type 3+ letters)</span></div>
                  <div style={{position:"relative"}}>
                    <input
                      placeholder="Search by username or display name…"
                      value={copyFrom ? `${copyFrom.username} — ${copyFrom.display_name}` : copyQ}
                      onChange={e=>{ setCopyFrom(null); setCopyQ(e.target.value); }}
                      onFocus={()=>{ if(copyFrom) setCopyFrom(null); }}
                      style={{...inp, paddingRight: copyFrom ? 30 : undefined}}
                    />
                    {copyFrom && (
                      <button onClick={()=>{setCopyFrom(null);setCopyQ("");}} title="Clear"
                        style={{position:"absolute",right:6,top:"50%",transform:"translateY(-50%)",background:"none",border:"none",color:p.textMute,cursor:"pointer",fontSize:14}}>✕</button>
                    )}
                    {/* Suggestions dropdown */}
                    {!copyFrom && copyQ.length>=3 && (()=>{
                      const q = copyQ.toLowerCase();
                      const hits = users.filter(u=> u.username.toLowerCase().includes(q) || (u.display_name||'').toLowerCase().includes(q) ).slice(0,8);
                      return hits.length>0 ? (
                        <div style={{position:"absolute",top:"100%",left:0,right:0,zIndex:10,background:p.surface,border:`1px solid ${p.border}`,borderRadius:7,boxShadow:"0 4px 18px #0006",maxHeight:200,overflowY:"auto",marginTop:2}}>
                          {hits.map(u=>(
                            <div key={u.dn}
                              onClick={()=>{setCopyFrom(u);setCopyQ("");}}
                              style={{padding:"8px 12px",cursor:"pointer",borderBottom:`1px solid ${p.border}22`,display:"flex",flexDirection:"column",gap:2}}
                              onMouseEnter={e=>e.currentTarget.style.background=`${p.accent}22`}
                              onMouseLeave={e=>e.currentTarget.style.background=""}
                            >
                              <span style={{fontSize:12,fontWeight:700,color:p.cyan}}>{u.username}</span>
                              <span style={{fontSize:10,color:p.textMute}}>{u.display_name}{u.department?` · ${u.department}`:""}{u.groups.length>0?` · ${u.groups.length} group${u.groups.length>1?"s":""}`:""}  </span>
                            </div>
                          ))}
                        </div>
                      ) : <div style={{position:"absolute",top:"100%",left:0,right:0,zIndex:10,background:p.surface,border:`1px solid ${p.border}`,borderRadius:7,padding:"10px 12px",fontSize:11,color:p.textMute,marginTop:2}}>No matches</div>;
                    })()}
                  </div>
                  {copyFrom && copyFrom.groups.length>0 && (
                    <div style={{marginTop:8,fontSize:10,color:p.textMute}}>
                      Will add to <strong style={{color:p.text}}>{copyFrom.groups.length} group{copyFrom.groups.length>1?"s":""}</strong>:{" "}
                      {copyFrom.groups.slice(0,6).join(", ")}{copyFrom.groups.length>6?` +${copyFrom.groups.length-6} more`:""}
                    </div>
                  )}
                  {copyFrom && copyFrom.groups.length===0 && (
                    <div style={{marginTop:8,fontSize:10,color:p.textMute}}>Selected user has no group memberships to copy.</div>
                  )}
                </div>

                {/* ── Basic fields ─────────────────────────────────────── */}
                {[["Username *","username"],["Display Name *","display_name"],["Email","email"],["Department","department"],["Title","title"],["OU DN (blank = CN=Users)","ou_dn"]].map(([lbl,key])=>(
                  <div key={key} style={{marginBottom:10}}>
                    <div style={{fontSize:11,color:p.textMute,marginBottom:3}}>{lbl}</div>
                    <input type="text" value={uForm[key]} onChange={e=>setUForm(f=>({...f,[key]:e.target.value}))} style={inp}/>
                  </div>
                ))}

                {/* ── Password ─────────────────────────────────────────── */}
                <div style={{marginBottom:10}}>
                  <div style={{fontSize:11,color:p.textMute,marginBottom:3}}>Password *</div>
                  <input type="password" value={uForm.password} onChange={e=>setUForm(f=>({...f,password:e.target.value}))} style={inp}/>
                </div>

                {/* ── Password policy ──────────────────────────────────── */}
                <div style={{padding:"10px 14px",borderRadius:8,marginBottom:14,background:`${p.surface}`,border:`1px solid ${p.border}`}}>
                  <div style={{fontSize:11,fontWeight:700,color:p.text,marginBottom:8}}>🔒 Password Policy</div>
                  {[
                    {val:"normal",     label:"Normal (user can change, expires per policy)"},
                    {val:"never",      label:"Password never expires"},
                    {val:"mustchange", label:"User must change password at next logon"},
                  ].map(opt=>(
                    <label key={opt.val} style={{display:"flex",alignItems:"center",gap:8,marginBottom:6,cursor:"pointer",fontSize:12,color:p.text}}>
                      <input type="radio" name="pw_policy" value={opt.val}
                        checked={opt.val==="never"?uForm.pw_never_expires : opt.val==="mustchange"?uForm.must_change_pw : (!uForm.pw_never_expires&&!uForm.must_change_pw)}
                        onChange={()=>setUForm(f=>({...f,
                          pw_never_expires: opt.val==="never",
                          must_change_pw:   opt.val==="mustchange",
                        }))}
                        style={{accentColor:p.accent}}
                      />
                      {opt.label}
                    </label>
                  ))}
                </div>

                {uMsg&&<div style={{fontSize:12,color:uMsg.ok?"#10b981":"#ef4444",marginBottom:8}}>{uMsg.ok?"✅":"⚠️"} {uMsg.msg}</div>}
                <div style={{display:"flex",gap:8,marginTop:14}}>
                  <button onClick={async()=>{
                    if(!uForm.username||!uForm.display_name||!uForm.password){
                      setUMsg({ok:false,msg:"Username, display name and password are required."});
                      return;
                    }
                    setBusy(true);
                    const r = await adCreateUser(uForm);
                    if(r.success){
                      // Add to copied groups
                      if(copyFrom && copyFrom.group_dns && copyFrom.group_dns.length>0){
                        const gErrs=[];
                        for(const gdn of copyFrom.group_dns){
                          const gr = await adGroupMember(gdn, r.dn, true);
                          if(!gr.success) gErrs.push(gdn.split(",")[0].replace("CN=",""));
                        }
                        if(gErrs.length){
                          setUMsg({ok:true,msg:`User "${uForm.username}" created. Could not add to: ${gErrs.join(", ")}.`});
                        } else {
                          setUMsg({ok:true,msg:`User "${uForm.username}" created and added to ${copyFrom.group_dns.length} group${copyFrom.group_dns.length>1?"s":""}.`});
                        }
                      } else {
                        setUMsg({ok:true,msg:`User "${uForm.username}" created successfully.`});
                      }
                      loadUsers();
                      setBusy(false);
                      setCopyFrom(null); setCopyQ("");
                      setUModal(null);
                    } else {
                      setBusy(false);
                      setUMsg({ok:false,msg:r.error||"Failed to create user."});
                    }
                  }} style={btn(p.green)} disabled={busy}>✔ Create</button>
                  <button onClick={()=>{setUModal(null);setCopyFrom(null);setCopyQ("");}} style={btn(p.grey)}>Cancel</button>
                </div>
              </div>
            </div>
          )}

          {/* Reset Password Modal */}
          {uModal==="reset"&&uTarget&&(
            <div style={{position:"fixed",inset:0,background:"#000a",zIndex:1000,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={(e)=>{if(e.target===e.currentTarget)setUModal(null);}}>
              <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,padding:28,width:360}}>
                <div style={{fontWeight:700,fontSize:16,color:p.text,marginBottom:8}}>🔑 Reset Password</div>
                <div style={{fontSize:12,color:p.textMute,marginBottom:14}}>User: <strong style={{color:p.cyan}}>{uTarget.username}</strong></div>
                <div style={{marginBottom:10}}>
                  <div style={{fontSize:11,color:p.textMute,marginBottom:3}}>New Password *</div>
                  <input type="password" value={uForm.password||""} onChange={e=>setUForm(f=>({...f,password:e.target.value}))} style={inp}/>
                </div>
                {uMsg&&<div style={{fontSize:12,color:uMsg.ok?"#10b981":"#ef4444",marginBottom:8}}>{uMsg.ok?"✅":"⚠️"} {uMsg.msg}</div>}
                <div style={{display:"flex",gap:8,marginTop:12}}>
                  <button onClick={async()=>{if(!uForm.password){setUMsg({ok:false,msg:"Password required."});return;}setBusy(true);const r=await adResetPassword(uTarget.dn,uForm.password);setBusy(false);if(r.success){setUMsg({ok:true,msg:"Password reset successfully."});setTimeout(()=>setUModal(null),1200);}else setUMsg({ok:false,msg:r.error||"Failed"});}} style={btn("#a78bfa")} disabled={busy}>✔ Reset</button>
                  <button onClick={()=>setUModal(null)} style={btn(p.grey)}>Cancel</button>
                </div>
              </div>
            </div>
          )}
        </div>
      )}

      {/* ════ AD GROUPS TAB ═══════════════════════════════════════════════════ */}
      {tab==="groups" && (
        <div>
          {gMsg && <div style={{padding:"8px 14px",borderRadius:7,marginBottom:10,fontSize:12,fontWeight:600,background:gMsg.ok?"#10b98118":"#ef444418",color:gMsg.ok?"#10b981":"#ef4444",border:`1px solid ${gMsg.ok?"#10b98144":"#ef444444"}`}}>{gMsg.ok?"✅":"⚠️"} {gMsg.msg}</div>}
          <div style={{display:"flex",gap:8,marginBottom:12,alignItems:"center",flexWrap:"wrap"}}>
            <input placeholder="Search groups…" value={gQ} onChange={e=>setGQ(e.target.value)}
              onKeyDown={e=>e.key==="Enter"&&loadGroups(gQ)} style={{...inp,width:240}}/>
            <button onClick={()=>loadGroups(gQ)} style={btn(p.cyan,true)}>🔍 Search</button>
            <button onClick={()=>loadGroups("")} style={btn(p.grey,true)}>↺ All</button>
            {canWrite&&<button onClick={()=>{setGForm({name:"",description:""});setGMsg(null);setGModal("create");}} style={btn(p.green)}>＋ Create Group</button>}
            <div style={{marginLeft:"auto",display:"flex",gap:5}}>
              <button onClick={()=>exportCSV(groups,[{key:"name",label:"Group Name"},{key:"sam",label:"SAM Account"},{key:"description",label:"Description"},{key:"member_count",label:"Member Count"},{key:"created",label:"Created"}],`AD-Groups-${new Date().toISOString().slice(0,10)}.csv`)} style={btn("#10b981",true)} disabled={!groups.length}>⬇ CSV</button>
              <button onClick={()=>exportPDF("AD Groups",
                [{key:"name",label:"Group Name"},{key:"sam",label:"SAM Account"},{key:"description",label:"Description"},{key:"member_count",label:"Members"},{key:"created",label:"Created"}],
                groups,"AD Groups")} style={btn("#f97316",true)} disabled={!groups.length}>📄 PDF</button>
            </div>
          </div>
          {gLoad ? <div style={{textAlign:"center",padding:40,color:p.textMute}}>⏳ Loading groups…</div> : (
            <div style={{overflowX:"auto",borderRadius:8,border:`1px solid ${p.border}`,background:p.panel}}>
              <table style={{width:"100%",borderCollapse:"collapse"}}>
                <thead><tr style={{background:p.surface}}>
                  <TH>Group Name</TH><TH>SAM Account</TH><TH>Description</TH><TH>Members</TH><TH>Created</TH><TH>Actions</TH>
                </tr></thead>
                <tbody>
                  {groups.length===0&&<tr><td colSpan={6} style={{padding:32,textAlign:"center",color:p.textMute}}>No groups found</td></tr>}
                  {groups.map((g,i)=>(
                    <tr key={g.dn} style={{background:i%2===0?p.panel:p.panelAlt}}>
                      <TD><span style={{color:p.accent,fontWeight:600,fontSize:12}}>{g.name}</span></TD>
                      <TD><span style={{fontFamily:"monospace",fontSize:11,color:p.textMute}}>{g.sam||"—"}</span></TD>
                      <TD><span style={{fontSize:11,color:p.textMute}}>{g.description||"—"}</span></TD>
                      <TD>
                        <span style={{fontSize:11,color:p.cyan,cursor:"pointer",textDecoration:"underline dotted"}}
                          onClick={()=>{setGTarget(g);setGModal("members");setGMsg(null);}}>
                          {g.member_count} member{g.member_count!==1?"s":""}
                        </span>
                      </TD>
                      <TD><span style={{fontSize:10,color:p.grey}}>{g.created?g.created.split("T")[0]:""}</span></TD>
                      <TD>
                        {canWrite&&(<div style={{display:"flex",gap:4}}>
                          <button onClick={()=>{setGTarget(g);setGModal("members");setGMsg(null);}} style={btn(p.cyan,true)}>👥 Members</button>
                          {canWrite&&<button onClick={()=>confirm(`Delete group "${g.name}"?`,g,"del_group")} style={btn("#ef4444",true)}>🗑</button>}
                        </div>)}
                      </TD>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          {/* Create Group Modal */}
          {gModal==="create"&&(
            <div style={{position:"fixed",inset:0,background:"#000a",zIndex:1000,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={(e)=>{if(e.target===e.currentTarget)setGModal(null);}}>
              <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,padding:28,width:380}}>
                <div style={{fontWeight:700,fontSize:16,color:p.text,marginBottom:18}}>➕ Create AD Group</div>
                {[["Group Name *","name"],["Description","description"]].map(([lbl,key])=>(
                  <div key={key} style={{marginBottom:10}}>
                    <div style={{fontSize:11,color:p.textMute,marginBottom:3}}>{lbl}</div>
                    <input value={gForm[key]} onChange={e=>setGForm(f=>({...f,[key]:e.target.value}))} style={inp}/>
                  </div>
                ))}
                {gMsg&&<div style={{fontSize:12,color:gMsg.ok?"#10b981":"#ef4444",marginBottom:8}}>{gMsg.ok?"✅":"⚠️"} {gMsg.msg}</div>}
                <div style={{display:"flex",gap:8,marginTop:14}}>
                  <button onClick={async()=>{if(!gForm.name){setGMsg({ok:false,msg:"Group name required."});return;}setBusy(true);const r=await adCreateGroup(gForm);setBusy(false);if(r.success){setGMsg({ok:true,msg:`Group "${gForm.name}" created.`});loadGroups();setGModal(null);}else setGMsg({ok:false,msg:r.error||"Failed"});}} style={btn(p.green)} disabled={busy}>✔ Create</button>
                  <button onClick={()=>setGModal(null)} style={btn(p.grey)}>Cancel</button>
                </div>
              </div>
            </div>
          )}

          {/* Group Members Modal */}
          {gModal==="members"&&gTarget&&(
            <div style={{position:"fixed",inset:0,background:"#000a",zIndex:1000,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={(e)=>{if(e.target===e.currentTarget)setGModal(null);}}>
              <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,padding:28,width:480,maxHeight:"80vh",overflowY:"auto"}}>
                <div style={{fontWeight:700,fontSize:16,color:p.text,marginBottom:4}}>👥 {gTarget.name}</div>
                <div style={{fontSize:11,color:p.textMute,marginBottom:14}}>{gTarget.description||""}</div>
                {gMsg&&<div style={{fontSize:12,color:gMsg.ok?"#10b981":"#ef4444",marginBottom:8}}>{gMsg.ok?"✅":"⚠️"} {gMsg.msg}</div>}
                {/* Add member */}
                {canWrite&&<div style={{display:"flex",gap:6,marginBottom:14}}>
                  <input placeholder="User DN to add…" value={gMemberDN} onChange={e=>setGMemberDN(e.target.value)} style={{...inp,flex:1,fontSize:11}}/>
                  <button onClick={async()=>{if(!gMemberDN.trim()){setGMsg({ok:false,msg:"Enter a DN."});return;}setBusy(true);const r=await adGroupMember(gTarget.dn,gMemberDN.trim(),true);setBusy(false);if(r.success){setGMsg({ok:true,msg:"Member added."});loadGroups();setGTarget(g=>({...g,members:[...(g.members||[]),gMemberDN.split(",")[0].replace("CN=","")]}));setGMemberDN("");}else setGMsg({ok:false,msg:r.error||"Failed"});}} style={btn(p.green,true)} disabled={busy}>＋ Add</button>
                </div>}
                {/* Member list */}
                {gTarget.members&&gTarget.members.length>0?(
                  <table style={{width:"100%",borderCollapse:"collapse"}}>
                    <thead><tr style={{background:p.surface}}><TH>Member CN</TH>{canWrite&&<TH w="80px">Remove</TH>}</tr></thead>
                    <tbody>
                      {gTarget.members.map((m,i)=>(
                        <tr key={i} style={{background:i%2===0?p.panel:p.panelAlt}}>
                          <TD><span style={{fontSize:12,color:p.text}}>{m}</span></TD>
                          {canWrite&&<TD>
                            <button onClick={()=>{const udn=users.find(u=>u.username===m||u.display_name===m)?.dn||`CN=${m},CN=Users,${("DC=sdxtest,DC=local")}`;confirm(`Remove "${m}" from group?`,{group_dn:gTarget.dn,user_dn:udn,user_cn:m},"rem_member");}} style={btn("#ef4444",true)}>✕</button>
                          </TD>}
                        </tr>
                      ))}
                    </tbody>
                  </table>
                ):<div style={{textAlign:"center",padding:20,color:p.textMute}}>No members</div>}
                <button onClick={()=>setGModal(null)} style={{...btn(p.grey),marginTop:16}}>Close</button>
              </div>
            </div>
          )}
        </div>
      )}

      {/* ════ COMPUTERS TAB ═══════════════════════════════════════════════════ */}
      {tab==="computers" && (
        <div>
          <div style={{display:"flex",gap:8,marginBottom:12,alignItems:"center"}}>
            <input placeholder="Search computers…" value={cQ} onChange={e=>setCQ(e.target.value)}
              onKeyDown={e=>e.key==="Enter"&&loadComputers(cQ)} style={{...inp,width:240}}/>
            <button onClick={()=>loadComputers(cQ)} style={btn(p.cyan,true)}>🔍 Search</button>
            <button onClick={()=>loadComputers("")} style={btn(p.grey,true)}>↺ All</button>
            <div style={{marginLeft:"auto",display:"flex",gap:5}}>
              <button onClick={()=>exportCSV(computers,[{key:"name",label:"Name"},{key:"dns",label:"DNS Hostname"},{key:"os",label:"OS"},{key:"os_version",label:"OS Version"},{key:"enabled",label:"Enabled"},{key:"created",label:"Created"}],`AD-Computers-${new Date().toISOString().slice(0,10)}.csv`)} style={btn("#10b981",true)} disabled={!computers.length}>⬇ CSV</button>
              <button onClick={()=>exportPDF("AD Computers",
                [{key:"name",label:"Name"},{key:"dns",label:"DNS Hostname"},{key:"os",label:"OS"},{key:"os_version",label:"OS Version"},{key:"enabled",label:"Status"},{key:"created",label:"Created"}],
                computers.map(c=>({...c,enabled:c.enabled?"Active":"Disabled"})),"AD Computers")} style={btn("#f97316",true)} disabled={!computers.length}>📄 PDF</button>
            </div>
          </div>
          {cLoad ? <div style={{textAlign:"center",padding:40,color:p.textMute}}>⏳ Loading…</div> : (
            <div style={{overflowX:"auto",borderRadius:8,border:`1px solid ${p.border}`,background:p.panel}}>
              <table style={{width:"100%",borderCollapse:"collapse"}}>
                <thead><tr style={{background:p.surface}}>
                  <TH>Computer Name</TH><TH>DNS Hostname</TH><TH>OS</TH><TH>OS Version</TH><TH>Status</TH><TH>Created</TH>
                </tr></thead>
                <tbody>
                  {computers.length===0&&<tr><td colSpan={6} style={{padding:32,textAlign:"center",color:p.textMute}}>No computers found</td></tr>}
                  {computers.map((c,i)=>(
                    <tr key={c.dn} style={{background:i%2===0?p.panel:p.panelAlt}}>
                      <TD><span style={{color:p.cyan,fontFamily:"monospace",fontSize:12}}>{c.name}</span></TD>
                      <TD><span style={{fontSize:11,color:p.textMute}}>{c.dns||"—"}</span></TD>
                      <TD><span style={{fontSize:11,color:p.text}}>{c.os||"—"}</span></TD>
                      <TD><span style={{fontSize:11,color:p.textMute}}>{c.os_version||"—"}</span></TD>
                      <TD><span style={badge(c.enabled)}>{c.enabled?"Active":"Disabled"}</span></TD>
                      <TD><span style={{fontSize:10,color:p.grey}}>{c.created?c.created.split("T")[0]:""}</span></TD>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )}

      {/* ════ OUs TAB ═════════════════════════════════════════════════════════ */}
      {tab==="ous" && (
        <div>
          <div style={{display:"flex",gap:8,marginBottom:12,alignItems:"center"}}>
            <button onClick={loadOUs} style={btn(p.cyan,true)}>↺ Refresh</button>
            <div style={{marginLeft:"auto",display:"flex",gap:5}}>
              <button onClick={()=>exportCSV(ous,[{key:"name",label:"OU Name"},{key:"dn",label:"Distinguished Name"},{key:"description",label:"Description"}],`AD-OUs-${new Date().toISOString().slice(0,10)}.csv`)} style={btn("#10b981",true)} disabled={!ous.length}>⬇ CSV</button>
              <button onClick={()=>exportPDF("AD Organizational Units",
                [{key:"name",label:"OU Name"},{key:"dn",label:"Distinguished Name"},{key:"description",label:"Description"}],
                ous,"OUs")} style={btn("#f97316",true)} disabled={!ous.length}>📄 PDF</button>
            </div>
          </div>
          {ouLoad ? <div style={{textAlign:"center",padding:40,color:p.textMute}}>⏳ Loading…</div> : (
            <div style={{overflowX:"auto",borderRadius:8,border:`1px solid ${p.border}`,background:p.panel}}>
              <table style={{width:"100%",borderCollapse:"collapse"}}>
                <thead><tr style={{background:p.surface}}><TH>OU Name</TH><TH>Distinguished Name</TH><TH>Description</TH></tr></thead>
                <tbody>
                  {ous.length===0&&<tr><td colSpan={3} style={{padding:32,textAlign:"center",color:p.textMute}}>No OUs found</td></tr>}
                  {ous.map((o,i)=>(
                    <tr key={o.dn} style={{background:i%2===0?p.panel:p.panelAlt}}>
                      <TD><span style={{color:p.accent,fontWeight:600}}>{o.name}</span></TD>
                      <TD><span style={{fontFamily:"monospace",fontSize:10,color:p.textMute}}>{o.dn}</span></TD>
                      <TD><span style={{fontSize:11,color:p.textMute}}>{o.description||"—"}</span></TD>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      )}

      {/* ════ DNS TAB ══════════════════════════════════════════════════════════ */}
      {tab==="dns" && (
        <div>
          {dnsMsg && <div style={{padding:"8px 14px",borderRadius:7,marginBottom:10,fontSize:12,fontWeight:600,background:dnsMsg.ok?"#10b98118":"#ef444418",color:dnsMsg.ok?"#10b981":"#ef4444",border:`1px solid ${dnsMsg.ok?"#10b98144":"#ef444444"}`}}>{dnsMsg.ok?"✅":"⚠️"} {dnsMsg.msg}</div>}
          <div style={{display:"flex",gap:16,alignItems:"flex-start",flexWrap:"wrap"}}>
            {/* Zone list */}
            <div style={{width:220,flexShrink:0}}>
              <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:8}}>
                <span style={{fontSize:12,fontWeight:700,color:p.text}}>DNS Zones</span>
                <button onClick={loadZones} style={btn(p.grey,true)}>↺</button>
              </div>
              {canWrite&&<button onClick={()=>confirm("Flush entire DNS server cache?",{},"flush_cache")} style={{...btn("#f59e0b",true),width:"100%",marginBottom:8}}>🧹 Flush Cache</button>}
              {zLoad ? <div style={{color:p.textMute,fontSize:12,padding:8}}>Loading…</div> : (
                <div style={{borderRadius:8,border:`1px solid ${p.border}`,overflow:"hidden"}}>
                  {zones.length===0&&<div style={{padding:16,color:p.textMute,fontSize:12,textAlign:"center"}}>No zones</div>}
                  {(()=>{
                    const fwd = zones.filter(z=>!z.is_reverse);
                    const rev = zones.filter(z=>z.is_reverse);
                    const ZoneRow = z=>(
                      <div key={z.name} onClick={()=>setSelZone(z.name)}
                        style={{padding:"8px 12px",cursor:"pointer",borderBottom:`1px solid ${p.border}33`,
                          background:selZone===z.name?`${p.accent}22`:p.panel,
                          color:selZone===z.name?p.accent:p.text,fontSize:12,fontWeight:selZone===z.name?700:400}}>
                        <div>▶ {z.name}</div>
                        <div style={{fontSize:10,color:p.grey}}>{z.type}{z.ds_integrated?" · AD-integrated":""}</div>
                      </div>
                    );
                    return(<>
                      {fwd.length>0&&<div style={{padding:"5px 10px",fontSize:9,fontWeight:800,letterSpacing:".8px",textTransform:"uppercase",color:p.cyan,background:`${p.cyan}0f`,borderBottom:`1px solid ${p.border}33`}}>▸ Forward Lookup Zones</div>}
                      {fwd.map(z=>ZoneRow(z))}
                      {rev.length>0&&<div style={{padding:"5px 10px",fontSize:9,fontWeight:800,letterSpacing:".8px",textTransform:"uppercase",color:p.grey,background:`${p.grey}0f`,borderBottom:`1px solid ${p.border}33`,borderTop:fwd.length?`1px solid ${p.border}`:undefined}}>◂ Reverse Lookup Zones</div>}
                      {rev.map(z=>(
                        <div key={z.name} onClick={()=>setSelZone(z.name)}
                          style={{padding:"8px 12px",cursor:"pointer",borderBottom:`1px solid ${p.border}33`,
                            background:selZone===z.name?`${p.accent}22`:p.panel,
                            color:selZone===z.name?p.accent:p.text,fontSize:12,fontWeight:selZone===z.name?700:400}}>
                          <div>◀ {z.name}</div>
                          <div style={{fontSize:10,color:p.grey}}>{z.type}{z.ds_integrated?" · AD-integrated":""}</div>
                        </div>
                      ))}
                    </>);
                  })()}
                </div>
              )}
            </div>

            {/* Records panel */}
            <div style={{flex:1,minWidth:0}}>
              {!selZone ? (
                <div style={{textAlign:"center",padding:60,color:p.textMute}}>← Select a zone to view records</div>
              ) : (
                <>
                  <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:10,flexWrap:"wrap",gap:6}}>
                    <span style={{fontWeight:700,fontSize:14,color:p.text}}>📋 Records: <span style={{color:p.accent}}>{selZone}</span></span>
                    <div style={{display:"flex",gap:6}}>
                      <button onClick={()=>loadRecords(selZone)} style={btn(p.grey,true)}>↺ Refresh</button>
                      {canWrite&&<button onClick={()=>{setRecForm({hostname:"",rtype:"A",data:"",ttl:3600});setDNSMsg(null);setCreatePtr(false);setAddRec(true);}} style={btn(p.green,true)}>＋ Add Record</button>}
                      <button onClick={()=>exportCSV(records,[{key:"hostname",label:"Hostname"},{key:"type",label:"Type"},{key:"data",label:"Data"},{key:"ttl",label:"TTL"}],`DNS-${selZone}-${new Date().toISOString().slice(0,10)}.csv`)} style={btn("#10b981",true)} disabled={!records.length}>⬇ CSV</button>
                      <button onClick={()=>exportPDF(`DNS Records — ${selZone}`,
                        [{key:"hostname",label:"Hostname"},{key:"type",label:"Type"},{key:"data",label:"Data"},{key:"ttl",label:"TTL"}],
                        records,selZone)} style={btn("#f97316",true)} disabled={!records.length}>📄 PDF</button>
                    </div>
                  </div>
                  {rLoad ? <div style={{textAlign:"center",padding:40,color:p.textMute}}>⏳ Loading records…</div> : (
                    <div style={{overflowX:"auto",borderRadius:8,border:`1px solid ${p.border}`,background:p.panel}}>
                      <table style={{width:"100%",borderCollapse:"collapse"}}>
                        <thead><tr style={{background:p.surface}}>
                          <TH>Hostname</TH><TH w="70px">Type</TH><TH>Data</TH><TH w="90px">TTL</TH>{canWrite&&<TH w="80px">Delete</TH>}
                        </tr></thead>
                        <tbody>
                          {records.length===0&&<tr><td colSpan={5} style={{padding:24,textAlign:"center",color:p.textMute}}>No records</td></tr>}
                          {records.map((r,i)=>(
                            <tr key={i} style={{background:i%2===0?p.panel:p.panelAlt}}>
                              <TD><span style={{fontFamily:"monospace",fontSize:11,color:p.cyan}}>{r.hostname}</span></TD>
                              <TD><span style={{padding:"1px 6px",borderRadius:4,fontSize:10,fontWeight:700,background:`${p.accent}22`,color:p.accent,border:`1px solid ${p.accent}44`}}>{r.type}</span></TD>
                              <TD><span style={{fontSize:11,color:p.text,fontFamily:"monospace"}}>{r.data}</span></TD>
                              <TD><span style={{fontSize:10,color:p.grey}}>{String(r.ttl).replace("PT","").toLowerCase()}</span></TD>
                              {canWrite&&<TD><button onClick={()=>confirm(`Delete ${r.type} record "${r.hostname}"?`,{zone:selZone,hostname:r.hostname,rtype:r.type},"del_rec")} style={btn("#ef4444",true)}>🗑</button></TD>}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  )}
                </>
              )}
            </div>
          </div>

          {/* Add Record Modal */}
          {addRec&&(
            <div style={{position:"fixed",inset:0,background:"#000a",zIndex:1000,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={(e)=>{if(e.target===e.currentTarget)setAddRec(false);}}>
              <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,padding:28,width:420}}>
                <div style={{fontWeight:700,fontSize:16,color:p.text,marginBottom:4}}>➕ Add DNS Record</div>
                <div style={{fontSize:11,color:p.textMute,marginBottom:16}}>Zone: <strong style={{color:p.accent}}>{selZone}</strong></div>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
                  <div>
                    <div style={{fontSize:11,color:p.textMute,marginBottom:3}}>Hostname *</div>
                    <input value={recForm.hostname} onChange={e=>setRecForm(f=>({...f,hostname:e.target.value}))} placeholder="e.g. server01 or @" style={inp}/>
                  </div>
                  <div>
                    <div style={{fontSize:11,color:p.textMute,marginBottom:3}}>Type *</div>
                    <select value={recForm.rtype} onChange={e=>{setRecForm(f=>({...f,rtype:e.target.value}));if(e.target.value!=="A")setCreatePtr(false);}} style={{...inp}}>
                      {["A","AAAA","CNAME","PTR","TXT","MX"].map(t=><option key={t}>{t}</option>)}
                    </select>
                  </div>
                </div>
                <div style={{marginTop:10}}>
                  <div style={{fontSize:11,color:p.textMute,marginBottom:3}}>
                    Data * {recForm.rtype==="MX"&&<span style={{color:p.grey}}>(format: "10 mail.domain.com")</span>}
                  </div>
                  <input value={recForm.data} onChange={e=>setRecForm(f=>({...f,data:e.target.value}))} placeholder={recForm.rtype==="A"?"e.g. 192.168.1.10":recForm.rtype==="CNAME"?"e.g. server.domain.com":"..."} style={inp}/>
                </div>
                <div style={{marginTop:10}}>
                  <div style={{fontSize:11,color:p.textMute,marginBottom:3}}>TTL (seconds)</div>
                  <input type="number" value={recForm.ttl} onChange={e=>setRecForm(f=>({...f,ttl:parseInt(e.target.value)||3600}))} style={{...inp,width:120}}/>
                </div>
                {/* PTR checkbox — only for A records */}
                {recForm.rtype==="A"&&(()=>{
                  const parts=(recForm.data||'').trim().split('.');
                  const validIP=parts.length===4&&parts.every(p=>/^\d+$/.test(p)&&+p<=255);
                  const ptrZone=validIP?`${parts[2]}.${parts[1]}.${parts[0]}.in-addr.arpa`:null;
                  const ptrHost=validIP?parts[3]:null;
                  const fqdn=recForm.hostname&&selZone?(recForm.hostname==='@'?selZone+'.':`${recForm.hostname}.${selZone}.`):null;
                  return(
                    <div style={{marginTop:12,padding:"10px 12px",borderRadius:8,border:`1px solid ${createPtr?p.accent:p.border}`,background:createPtr?`${p.accent}0a`:p.panelAlt}}>
                      <label style={{display:"flex",alignItems:"center",gap:10,cursor:"pointer"}}>
                        <input type="checkbox" checked={createPtr} onChange={e=>setCreatePtr(e.target.checked)}
                          style={{width:15,height:15,accentColor:p.accent,flexShrink:0,cursor:"pointer"}}/>
                        <div>
                          <span style={{fontSize:12,fontWeight:700,color:createPtr?p.accent:p.text}}>Also create PTR record (Reverse DNS)</span>
                          <div style={{fontSize:11,color:p.textMute,marginTop:2}}>Automatically adds a matching PTR entry in the reverse zone</div>
                        </div>
                      </label>
                      {createPtr&&(
                        <div style={{marginTop:10,paddingTop:10,borderTop:`1px solid ${p.border}`,display:"flex",flexDirection:"column",gap:6}}>
                          {!validIP&&<div style={{fontSize:11,color:"#f59e0b"}}>⚠️ Enter a valid IPv4 address above to auto-compute the PTR zone.</div>}
                          {validIP&&<>
                            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                              <div>
                                <div style={{fontSize:10,color:p.textMute,marginBottom:2}}>PTR Reverse Zone</div>
                                <div style={{fontSize:11,fontFamily:"monospace",color:p.cyan,background:p.panel,border:`1px solid ${p.border}`,borderRadius:6,padding:"5px 8px"}}>{ptrZone}</div>
                              </div>
                              <div>
                                <div style={{fontSize:10,color:p.textMute,marginBottom:2}}>PTR Hostname (last octet)</div>
                                <div style={{fontSize:11,fontFamily:"monospace",color:p.cyan,background:p.panel,border:`1px solid ${p.border}`,borderRadius:6,padding:"5px 8px"}}>{ptrHost}</div>
                              </div>
                            </div>
                            <div>
                              <div style={{fontSize:10,color:p.textMute,marginBottom:2}}>PTR Data (FQDN points to)</div>
                              <div style={{fontSize:11,fontFamily:"monospace",color:p.cyan,background:p.panel,border:`1px solid ${p.border}`,borderRadius:6,padding:"5px 8px"}}>{fqdn||<span style={{color:"#f59e0b"}}>Enter hostname above</span>}</div>
                            </div>
                          </>}
                        </div>
                      )}
                    </div>
                  );
                })()}
                {dnsMsg&&<div style={{fontSize:12,color:dnsMsg.ok?"#10b981":"#ef4444",marginTop:8}}>{dnsMsg.ok?"✅":"⚠️"} {dnsMsg.msg}</div>}
                <div style={{display:"flex",gap:8,marginTop:16}}>
                  <button onClick={async()=>{
                    if(!recForm.hostname||!recForm.data){setDNSMsg({ok:false,msg:"Hostname and data required."});return;}
                    setBusy(true);
                    const r=await dnsAddRecord({zone:selZone,...recForm});
                    if(!r.success){setBusy(false);setDNSMsg({ok:false,msg:r.error||"Failed"});return;}
                    // Optionally create PTR
                    if(createPtr&&recForm.rtype==="A"){
                      const parts=(recForm.data||'').trim().split('.');
                      const validIP=parts.length===4&&parts.every(p=>/^\d+$/.test(p)&&+p<=255);
                      if(validIP){
                        const ptrZone=`${parts[2]}.${parts[1]}.${parts[0]}.in-addr.arpa`;
                        const ptrHost=parts[3];
                        const fqdn=recForm.hostname==='@'?selZone+'.':`${recForm.hostname}.${selZone}.`;
                        const rp=await dnsAddRecord({zone:ptrZone,hostname:ptrHost,rtype:"PTR",data:fqdn,ttl:recForm.ttl});
                        setBusy(false);
                        if(rp.success){setDNSMsg({ok:true,msg:"A record added ✔  PTR record added ✔"});}
                        else{setDNSMsg({ok:true,msg:`A record added ✔  PTR failed: ${rp.error||"unknown error"}`});}
                      } else {
                        setBusy(false);
                        setDNSMsg({ok:true,msg:"A record added ✔  (PTR skipped — invalid IP)"});
                      }
                    } else {
                      setBusy(false);
                      setDNSMsg({ok:true,msg:"Record added."});
                    }
                    setAddRec(false);setCreatePtr(false);loadRecords(selZone);
                  }} style={btn(p.green)} disabled={busy}>✔ Add Record</button>
                  <button onClick={()=>{setAddRec(false);setCreatePtr(false);}} style={btn(p.grey)}>Cancel</button>
                </div>
              </div>
            </div>
          )}
        </div>
      )}

      {/* ════ CONFIRM DIALOG ══════════════════════════════════════════════════ */}
      {confirmDel&&(
        <div style={{position:"fixed",inset:0,background:"#000a",zIndex:2000,display:"flex",alignItems:"center",justifyContent:"center"}}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,padding:28,width:380,textAlign:"center"}}>
            <div style={{fontSize:24,marginBottom:10}}>⚠️</div>
            <div style={{fontWeight:700,fontSize:15,color:p.text,marginBottom:6}}>Confirm Action</div>
            <div style={{fontSize:13,color:p.textMute,marginBottom:20}}>{confirmDel.label}</div>
            <div style={{display:"flex",gap:10,justifyContent:"center"}}>
              <button onClick={execConfirm} style={btn("#ef4444")} disabled={busy}>{busy?"Processing…":"Confirm"}</button>
              <button onClick={()=>setConfirmDel(null)} style={btn(p.grey)}>Cancel</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── AUDIT PAGE ───────────────────────────────────────────────────────────────
function AuditPage({currentUser, p}) {
  const [logs,   setLogs]   = useState([]);
  const [loading,setLoading]= useState(true);
  const [q,      setQ]      = useState("");
  const [dateFrom,setDateFrom]=useState("");
  const [dateTo,setDateTo]=useState("");
  const isAdmin=currentUser?.role==="admin"||currentUser?.role==="operator";

  useEffect(()=>{
    (isAdmin?fetchAuditLog(500):fetchMyAudit())
      .then(setLogs).catch(()=>{}).finally(()=>setLoading(false));
  },[]);

  // Risk level calculation
  function riskLevel(l){
    const a=l.action||"";
    if(a.includes("DELETE")||a.includes("FAIL")||a.includes("ROLE_UPDATE")||(l.result&&l.result!=="ok")) return "HIGH";
    if(a.includes("POWER")||a.includes("SNAPSHOT")||a.includes("RECONFIGURE")||a.includes("CLONE")) return "MEDIUM";
    return "LOW";
  }
  const riskColor={HIGH:"#ef4444",MEDIUM:"#f59e0b",LOW:"#10b981"};
  const riskBg={HIGH:"#ef444415",MEDIUM:"#f59e0b15",LOW:"#10b98115"};

  // Action category filter
  function matchesFilter(l){
    if(actionFilter==="all") return true;
    const a=(l.action||"").toUpperCase();
    if(actionFilter==="login")     return a.includes("LOGIN");
    if(actionFilter==="power")     return a.includes("POWER")||a.includes("RESTART")||a.includes("REBOOT");
    if(actionFilter==="snapshot")  return a.includes("SNAPSHOT");
    if(actionFilter==="request")   return a.includes("REQUEST")||a.includes("APPROV")||a.includes("DECLIN");
    if(actionFilter==="role")      return a.includes("ROLE")||a.includes("USER_DELETE")||a.includes("USER_ADD");
    if(actionFilter==="delete")    return a.includes("DELETE");
    if(actionFilter==="security")  return a.includes("FAIL")||a.includes("BLOCK")||a.includes("DENIED")||riskLevel(l)==="HIGH";
    return true;
  }

  const filtered=logs.filter(l=>{
    if(!matchesFilter(l)) return false;
    const textOk = !q||[l.username,l.action,l.target,l.detail,l.ip].some(s=>s?.toLowerCase().includes(q.toLowerCase()));
    if(!textOk) return false;
    if(dateFrom){const d=new Date(l.ts+"Z");if(d<new Date(dateFrom)) return false;}
    if(dateTo){const d=new Date(l.ts+"Z");if(d>new Date(dateTo+"T23:59:59Z")) return false;}
    return true;
  });

  // Stats
  const highRisk=logs.filter(l=>riskLevel(l)==="HIGH").length;
  const medRisk=logs.filter(l=>riskLevel(l)==="MEDIUM").length;
  const failures=logs.filter(l=>(l.result&&l.result!=="ok")||(l.action||"").includes("FAIL")).length;
  const logins=logs.filter(l=>(l.action||"").includes("LOGIN")).length;

  function exportCSV(){
    const cols=["ts","username","role","action","target","detail","result","ip"];
    const rows=filtered.map(l=>cols.map(c=>`"${(l[c]||"").replace(/"/g,'""')}"`).join(","));
    const csv=[cols.join(","),...rows].join("\n");
    const blob=new Blob([csv],{type:"text/csv"});
    const a=document.createElement("a");
    a.href=URL.createObjectURL(blob);
    a.download=`audit_log_${new Date().toISOString().slice(0,10)}.csv`;
    a.click();
  }

  const ac=(a)=>a==="USER_DELETE"?p.red:a==="USER_ROLE_UPDATE"?p.purple:a?.includes("FAIL")||a?.includes("LOGIN_FAIL")?p.red:a?.includes("LOGIN")?p.green:a?.includes("POWER")||a?.includes("SNAPSHOT")?p.cyan:a?.includes("REQUEST")||a?.includes("APPROV")||a?.includes("DECLIN")?p.purple:p.textSub;
  const actionLabel=(a)=>a==="USER_DELETE"?"🗑 USER_DELETE":a==="USER_ROLE_UPDATE"?"🛡 USER_ROLE_UPDATE":a;

  const FILTER_CHIPS=[
    {id:"all",label:"All Events"},
    {id:"login",label:"🔑 Logins"},
    {id:"power",label:"⚡ VM Power"},
    {id:"snapshot",label:"📸 Snapshots"},
    {id:"request",label:"📋 Requests"},
    {id:"role",label:"🛡 Role/User"},
    {id:"delete",label:"🗑 Deletes"},
    {id:"security",label:"🚨 Security"},
  ];

  return(
    <div className="g-gap">
      {/* Summary tiles */}
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(120px,1fr))",gap:10}}>
        {[
          {label:"Total Events",value:logs.length,color:p.accent,icon:"📋"},
          {label:"High Risk",value:highRisk,color:"#ef4444",icon:"🚨"},
          {label:"Medium Risk",value:medRisk,color:"#f59e0b",icon:"⚠️"},
          {label:"Failures",value:failures,color:"#ef4444",icon:"✗"},
          {label:"Login Events",value:logins,color:"#10b981",icon:"🔑"},
        ].map(t=>(
          <div key={t.label} style={{background:`${t.color}08`,border:`1px solid ${t.color}25`,borderRadius:10,padding:"10px 14px"}}>
            <div style={{fontSize:10,color:p.textMute,fontWeight:700,textTransform:"uppercase",letterSpacing:".4px"}}>{t.icon} {t.label}</div>
            <div style={{fontSize:22,fontWeight:800,color:t.color,marginTop:3}}>{t.value}</div>
          </div>
        ))}
      </div>

      {/* Filters row */}
      <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"}}>
        <input style={{maxWidth:260,flex:"1 1 160px"}} placeholder="Search user, action, target, IP…" value={q} onChange={e=>setQ(e.target.value)}/>
        <input type="date" value={dateFrom} onChange={e=>setDateFrom(e.target.value)}
          title="From date"
          style={{padding:"5px 8px",borderRadius:6,border:`1px solid ${p.border}`,background:p.panel,color:p.text,fontSize:12}}/>
        <input type="date" value={dateTo} onChange={e=>setDateTo(e.target.value)}
          title="To date"
          style={{padding:"5px 8px",borderRadius:6,border:`1px solid ${p.border}`,background:p.panel,color:p.text,fontSize:12}}/>
        {(dateFrom||dateTo)&&<button className="btn btn-ghost btn-sm" onClick={()=>{setDateFrom("");setDateTo("");}}>✕ Clear</button>}
        <button onClick={exportCSV}
          style={{padding:"5px 12px",borderRadius:6,border:`1px solid ${p.accent}40`,background:`${p.accent}12`,color:p.accent,fontSize:12,fontWeight:600,cursor:"pointer",whiteSpace:"nowrap"}}>
          ⬇ Export CSV
        </button>
        <span style={{fontSize:12,color:p.textMute,whiteSpace:"nowrap"}}>{filtered.length} events</span>
      </div>

      {/* Action filter chips */}
      <div style={{display:"flex",gap:6,flexWrap:"wrap"}}>
        {FILTER_CHIPS.map(f=>(
          <button key={f.id}
            className={`btn btn-sm ${actionFilter===f.id?"btn-primary":"btn-ghost"}`}
            onClick={()=>setActionFilter(f.id)}
            style={actionFilter==="security"&&f.id==="security"?{background:"#ef444420",border:"1.5px solid #ef444460",color:"#ef4444"}:{}}>
            {f.label}
          </button>
        ))}
      </div>

      {loading?<div style={{padding:40,textAlign:"center"}}><div className="spinner"/></div>:(
        <div className="card" style={{overflow:"hidden"}}>
          <div className="tbl-wrap" style={{maxHeight:"calc(100vh - 260px)"}}>
            <table>
              <thead><tr>
                <th>RISK</th><th>TIME</th><th>USER</th><th>ROLE</th>
                <th>ACTION</th><th>TARGET</th><th>DETAIL</th><th>RESULT</th>
              </tr></thead>
              <tbody>
                {filtered.length===0&&<tr><td colSpan={8} style={{textAlign:"center",padding:32,color:p.textMute}}>No audit events</td></tr>}
                {filtered.map((l,i)=>{
                  const risk=riskLevel(l);
                  return(
                    <tr key={i} style={{background:risk==="HIGH"?`#ef444406`:""}}>
                      <td>
                        <span style={{padding:"2px 7px",borderRadius:5,fontSize:10,fontWeight:700,
                          background:riskBg[risk],color:riskColor[risk],border:`1px solid ${riskColor[risk]}30`}}>
                          {risk}
                        </span>
                      </td>
                      <td><span style={{fontFamily:"monospace",fontSize:11,color:p.textMute}}>{l.ts ? (d=>d.toLocaleDateString([],{year:"numeric",month:"2-digit",day:"2-digit"})+" "+d.toLocaleTimeString([],{hour:"2-digit",minute:"2-digit",second:"2-digit",hour12:false}))(new Date(l.ts+"Z")) : "—"}</span></td>
                      <td><b style={{color:p.accent}}>{l.username}</b>{l.ip&&<span style={{fontSize:10,color:p.textMute,display:"block"}}>{l.ip}</span>}</td>
                      <td><span className="badge" style={{background:`${p.purple}18`,color:p.purple,border:`1px solid ${p.purple}28`}}>{l.role||"—"}</span></td>
                      <td><span style={{fontFamily:"monospace",fontSize:12,color:ac(l.action),fontWeight:600}}>{actionLabel(l.action)}</span></td>
                      <td style={{color:p.textSub,fontSize:12}}>{l.target||"—"}</td>
                      <td style={{color:p.textMute,fontSize:11,maxWidth:200,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}} title={l.detail}>{l.detail||"—"}</td>
                      <td><span style={{fontSize:11,fontWeight:600,color:l.result==="ok"?p.green:p.red}}>{l.result==="ok"?"✓":"✗"} {l.result||"—"}</span></td>
                    </tr>
                  );
                } </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── USERS PAGE ───────────────────────────────────────────────────────────────
function UsersPage({currentUser, p}) {
  const [users,  setUsers]  = useState([]);
  const [loading,setLoading]= useState(true);
  const [msg,    setMsg]    = useState(null);
  const [q,      setQ]      = useState("");
  const [showAdd,setShowAdd]= useState(false);
  const [newUser,setNewUser]= useState({username:"",display_name:"",email:"",role:"viewer"});
  const [addBusy,setAddBusy]= useState(false);
  const [showLocalAdd,setShowLocalAdd]= useState(false);
  const [localUser,setLocalUser]= useState({username:"",display_name:"",email:"",role:"viewer",password:"",showPw:false});
  const [localBusy,setLocalBusy]= useState(false);
  const isAdmin = currentUser?.role==="admin";
  const [adSuggestions,setAdSuggestions] = useState([]);

  useEffect(()=>{ fetchUsers().then(setUsers).catch(()=>{}).finally(()=>setLoading(false)); },[]);

  async function changeRole(username, role){
    if(!isAdmin) return;
    try{
      await updateUserRole(username,role);
      setUsers(us=>us.map(u=>u.username===username?{...u,role}:u));
      setMsg({ok:true,text:`✅ ${username} role updated to ${role}`});
      setTimeout(()=>setMsg(null),3000);
    }catch(e){ setMsg({ok:false,text:e.message}); }
  }

  async function removeUser(username){
    if(!isAdmin) return;
    if(!window.confirm(`Delete '${username}' from dashboard user list?`)) return;
    try{
      await deleteUser(username);
      setUsers(us=>us.filter(u=>u.username!==username));
      setMsg({ok:true,text:`✅ ${username} deleted from dashboard`});
      setTimeout(()=>setMsg(null),3000);
    }catch(e){ setMsg({ok:false,text:e.message}); }
  }

  async function addUser(){
    if(!newUser.username.trim()) return;
    setAddBusy(true);
    try{
      await addADUser({username:newUser.username.trim(),display_name:newUser.display_name,email:newUser.email,role:newUser.role});
      setUsers(us=>{
        const exists=us.find(u=>u.username===newUser.username.trim());
        if(exists) return us.map(u=>u.username===newUser.username.trim()?{...u,role:newUser.role,email:newUser.email||u.email,display_name:newUser.display_name||u.display_name}:u);
        return [...us,{...newUser,auth_source:"ad",last_login:null}];
      });
      setMsg({ok:true,text:`✅ ${newUser.username} added with role ${newUser.role}`});
      setNewUser({username:"",display_name:"",email:"",role:"viewer"});
      setShowAdd(false);
      setTimeout(()=>setMsg(null),3000);
    }catch(e){ setMsg({ok:false,text:e.message}); }
    setAddBusy(false);
  }

  async function addLocalUser(){
    if(!localUser.username.trim()||!localUser.password) return;
    setLocalBusy(true);
    try{
      const r=await createLocalUser({username:localUser.username.trim(),display_name:localUser.display_name,email:localUser.email,role:localUser.role,password:localUser.password});
      setUsers(us=>{
        const exists=us.find(u=>u.username===localUser.username.trim());
        if(exists) return us.map(u=>u.username===localUser.username.trim()?{...r.user,...u,...r.user}:u);
        return [...us,{...r.user}];
      });
      setMsg({ok:true,text:`✅ Local user "${localUser.username}" created with role ${localUser.role}`});
      setLocalUser({username:"",display_name:"",email:"",role:"viewer",password:"",showPw:false});
      setShowLocalAdd(false);
      setTimeout(()=>setMsg(null),3000);
    }catch(e){ setMsg({ok:false,text:e.message}); }
    setLocalBusy(false);
  }

  const rc={admin:p.red,operator:p.orange,viewer:p.cyan,requester:p.purple};
  const ROLE_DESC={admin:"Full access — manage VMs, AD/DNS, users, approve requests",operator:"Operate VMs, manage AD users, groups & DNS records",viewer:"Read-only — view all data, no actions",requester:"Submit VM requests only"};
  const filtered = users.filter(u=>!q||[u.username,u.display_name,u.email,u.role].some(s=>s?.toLowerCase().includes(q.toLowerCase())));

  function openRoleMatrixWindow(){
    const MATRIX = [
      { category: "Dashboard & Navigation", rows: [
        { feature: "Overview / Dashboard",              admin:"✅", operator:"✅", viewer:"✅", requester:"✅" },
        { feature: "Virtual Machines page",             admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Project Utilization (Chargeback)",  admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Capacity (Hosts & Datastores)",     admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Snapshots",                         admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Networks",                          admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "IPAM (IP Address Management)",      admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Asset Management",                  admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "VM Requests",                       admin:"✅", operator:"✅", viewer:"👁 View only", requester:"✅" },
        { feature: "Audit Log",                         admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "AD & DNS Management",               admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Users & Roles page",                admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
      ]},
      { category: "VM Actions", rows: [
        { feature: "VM Power On / Off / Restart",       admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Snapshot (Create)",                 admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Snapshot (Delete)",                 admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Clone VM",                          admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Migrate VM (vMotion)",              admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Reconfigure CPU / RAM / Disk",      admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Delete VM (permanent)",             admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
      ]},
      { category: "Active Directory Management", rows: [
        { feature: "Browse AD Users",                   admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Create AD User (with group copy)",  admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Enable / Disable AD User",          admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Unlock AD User Account",            admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Reset AD User Password",            admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Delete AD User",                    admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Create AD Group",                   admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Add / Remove Group Members",        admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Delete AD Group",                   admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
      ]},
      { category: "DNS Management", rows: [
        { feature: "View DNS Zones",                    admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "View DNS Records (A/CNAME/MX/PTR/SRV/NS)", admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Add DNS Record",                    admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Delete DNS Record",                 admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Flush DNS Server Cache",            admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
      ]},
      { category: "Capacity & Host Actions", rows: [
        { feature: "View Host / Datastore metrics",     admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Host Maintenance Mode actions",     admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
      ]},
      { category: "IPAM & Asset Management", rows: [
        { feature: "View IP Address Inventory (IPAM)",  admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Add / Edit / Delete IP Records",    admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "View Asset Inventory",              admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Add / Edit / Delete Assets",        admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
      ]},
      { category: "Project Utilization", rows: [
        { feature: "View Tag-wise Chargeback",          admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Edit Tag Owner Name / Email",       admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Export VM Tag Reports",             admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
      ]},
      { category: "VM Requests", rows: [
        { feature: "Submit VM Provisioning Request (＋ Request VM)", admin:"✅", operator:"✅", viewer:"✗",  requester:"✅" },
        { feature: "Approve / Reject Requests",         admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "View All Requests",                 admin:"✅", operator:"✅", viewer:"✅", requester:"Own only" },
      ]},
      { category: "Red Hat OpenShift", rows: [
        { feature: "View OpenShift Clusters",                     admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Add / Edit / Delete OCP Cluster",             admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
        { feature: "Live Nodes (status, CPU, RAM)",               admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Live Pods (status, phase, age, logs)",        admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Namespaces / Projects",                       admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Cluster Operators health",                    admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Applications — Routes (clickable URLs)",      admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Events (Warning / Normal)",                   admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Storage Classes",                             admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Topology view",                               admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Node Actions (Cordon / Uncordon / Drain)",    admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Set Red Hat OpenShift AI (RHOAI) URL",        admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
      ]},
      { category: "Nutanix Prism Central", rows: [
        { feature: "View Nutanix Prism Centrals",                 admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Add / Edit / Delete Prism Central",           admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
        { feature: "Test Prism Central Connectivity",             admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Live Clusters (AOS, nodes, state)",           admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Live VMs (power state, CPU, RAM, IP)",        admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Live Hosts (CPU, RAM, IPMI, CVM IP)",         admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Storage Containers (usage, RF, compression)", admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Networks (VLAN, IP pool ranges)",             admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Alerts (Critical / Warning)",                 admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "VM Power On / Off / Reset",                   admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "VM Snapshot Creation",                        admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Submit Nutanix VM Request",                   admin:"✅", operator:"✅", viewer:"✗",  requester:"✅" },
        { feature: "Approve / Reject Nutanix VM Request",         admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
      ]},
      { category: "Ansible Automation Platform (AAP)", rows: [
        { feature: "View AAP Instances / Inventories",        admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "View Job Templates & Credentials",         admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Launch Job Template (with extra-vars)",    admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "View Live Job Execution (stdout log)",     admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "View Activity Stream / Automation Audit",  admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Add / Edit / Delete AAP Instance",         admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
      ]},
      { category: "Chargeback & Pricing", rows: [
        { feature: "View VMware Chargeback Page",              admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "View OCP Chargeback Page",                 admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "View Nutanix Chargeback Page",             admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
        { feature: "Edit Platform Pricing Rates (all)",        admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
        { feature: "Export Chargeback Report (PDF)",           admin:"✅", operator:"✅", viewer:"✅", requester:"✗"  },
      ]},
      { category: "Settings & Administration", rows: [
        { feature: "View Pricing Rates",                admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Edit Pricing Rates",                admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
        { feature: "Save Alert Thresholds",             admin:"✅", operator:"✅", viewer:"✗",  requester:"✗"  },
        { feature: "Manage vCenters",                   admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
        { feature: "Manage Portal Users & Roles",       admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
        { feature: "Manage Notifications Banner",       admin:"✅", operator:"✗",  viewer:"✗",  requester:"✗"  },
        { feature: "Change Theme (Dark / Light / Wings)", admin:"✅", operator:"✅", viewer:"✅", requester:"✅" },
      ]},
    ];

    const cellHtml = (val) => {
      if(val==="✅") return `<td class="c-yes">✅</td>`;
      if(val==="✗")  return `<td class="c-no">✗</td>`;
      return `<td class="c-special">${val}</td>`;
    };

    const rowsHtml = MATRIX.map(group=>`
      <tr class="cat-row"><td colspan="5">${group.category}</td></tr>
      ${group.rows.map(r=>`
        <tr>
          <td class="feat">${r.feature}</td>
          ${cellHtml(r.admin)}${cellHtml(r.operator)}${cellHtml(r.viewer)}${cellHtml(r.requester)}
        </tr>`).join("")}
    `).join("");

    const win = window.open("","_blank","width=860,height=720");
    if(!win) return;
    const doc = win.document;
    doc.open();
    doc.write(`<!doctype html><html><head><title>LaaS Dashboard — Role Permission Matrix</title>
    <meta charset="utf-8"/>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap');
      *{box-sizing:border-box;margin:0;padding:0}
      body{font-family:'Outfit',Arial,sans-serif;background:#0d1117;color:#e2e8f0;padding:28px 32px;font-size:13px}
      h1{font-size:20px;font-weight:700;margin-bottom:4px;color:#f1f5f9}
      .subtitle{font-size:12px;color:#64748b;margin-bottom:22px}
      .actions{display:flex;gap:8px;margin-bottom:18px;align-items:center}
      button{padding:7px 16px;border-radius:7px;font-family:inherit;font-size:12px;font-weight:600;cursor:pointer;border:1px solid}
      .btn-pdf{background:#6366f115;border-color:#6366f155;color:#a5b4fc}
      .btn-pdf:hover{background:#6366f125}
      .btn-close{background:#ef444415;border-color:#ef444455;color:#fca5a5}
      table{width:100%;border-collapse:collapse;font-size:12.5px}
      th{padding:9px 12px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;color:#94a3b8;background:#161b27;border-bottom:2px solid #2d3748;text-align:center;white-space:nowrap}
      th.feat-h{text-align:left}
      td{padding:8px 12px;border-bottom:1px solid #1e293b;vertical-align:middle}
      td.feat{color:#cbd5e1;font-weight:500}
      td.c-yes{text-align:center;font-size:15px}
      td.c-no{text-align:center;font-size:14px;font-weight:700;color:#ef4444}
      td.c-special{text-align:center;font-size:11px;color:#f59e0b;font-weight:600}
      tr.cat-row td{background:#1e293b;color:#7dd3fc;font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:1px;padding:7px 12px;border-top:2px solid #334155}
      tr:hover td:not(.cat-row td){background:#1a2033}
      .role-admin{color:#ef4444;font-weight:700}
      .role-operator{color:#f97316;font-weight:700}
      .role-viewer{color:#06b6d4;font-weight:700}
      .role-requester{color:#a855f7;font-weight:700}
      .legend{display:flex;gap:18px;margin-bottom:16px;flex-wrap:wrap}
      .leg-item{display:flex;align-items:center;gap:6px;font-size:12px}
      .leg-check{font-size:14px}
      .header-band{background:linear-gradient(135deg,#1e1b4b,#0d1117);border:1px solid #312e81;border-radius:10px;padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;gap:12px}
      .badge-role{display:inline-block;padding:2px 10px;border-radius:12px;font-size:11px;font-weight:700}
      @page{margin:20mm 14mm 20mm 14mm}
      *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;color-adjust:exact!important}
      .print-header,.print-footer{display:none}
      @media print{
        body{background:#fff;color:#0f172a;padding:16px;padding-top:54px;padding-bottom:36px}
        .actions{display:none!important}
        h1,th,td.feat{color:#0f172a}
        .subtitle{color:#475569}
        th{background:#f1f5f9!important;color:#334155!important}
        tr.cat-row td{background:#e0f2fe!important;color:#0369a1!important}
        td.c-no{color:#dc2626!important}
        td.c-special{color:#d97706!important}
        td.c-yes{color:inherit}
        .header-band{background:#f8fafc!important;border-color:#e2e8f0!important;color:#0f172a!important}
        .role-admin{color:#dc2626!important}.role-operator{color:#ea580c!important}.role-viewer{color:#0891b2!important}.role-requester{color:#9333ea!important}
        tr:hover td{background:transparent}
        table{font-size:11px}
        .legend{border:1px solid #e2e8f0;padding:8px;border-radius:6px}
        .print-header{display:flex!important;position:fixed;top:0;left:0;right:0;height:44px;
          align-items:center;padding:0 8mm;border-bottom:1.5px solid #334155;
          background:#fff;z-index:9999}
        .print-footer{display:flex!important;position:fixed;bottom:0;left:0;right:0;height:28px;
          align-items:center;justify-content:center;
          border-top:1px solid #e2e8f0;background:#fff;
          font-size:10px;color:#64748b;z-index:9999;font-family:Arial,sans-serif;letter-spacing:.3px}
      }
    </style></head>
    <body>
    <div class="print-header"><img src="${window.location.origin}/wings.png" height="34" style="object-fit:contain" alt="Wipro Wings"/></div>
    <div class="print-footer">CaaS Portal &mdash; Wipro Confidential</div>
    <div class="header-band">
      <span style="font-size:28px">🔐</span>
      <div>
        <h1>Role Permission Matrix</h1>
        <div class="subtitle">LaaS Dashboard — Lab as a Service &nbsp;·&nbsp; Generated ${new Date().toLocaleString()}</div>
      </div>
    </div>

    <div class="legend">
      <div class="leg-item"><span class="leg-check">✅</span> Permitted</div>
      <div class="leg-item"><span style="color:#ef4444;font-weight:700;font-size:14px">✗</span> Not Permitted</div>
      <div class="leg-item"><span style="color:#f59e0b;font-weight:700">Special</span> Conditional / Limited access</div>
    </div>

    <div class="actions">
      <button class="btn-pdf" onclick="window.print()">🖨️ Export PDF</button>
      <button class="btn-close" onclick="window.close()">✕ Close</button>
    </div>

    <table>
      <thead>
        <tr>
          <th class="feat-h" style="width:38%">Feature / Permission</th>
          <th><span class="role-admin">Admin</span></th>
          <th><span class="role-operator">Operator</span></th>
          <th><span class="role-viewer">Viewer</span></th>
          <th><span class="role-requester">Requester</span></th>
        </tr>
      </thead>
      <tbody>${rowsHtml}</tbody>
    </table>
    </body></html>`);
    doc.close();
  }

  return(
    <div className="g-gap">
      {msg&&<div style={{padding:"10px 14px",borderRadius:8,fontSize:13,fontWeight:500,
        background:msg.ok?`${p.green}15`:`${p.red}15`,color:msg.ok?p.green:p.red,border:`1px solid ${msg.ok?p.green:p.red}40`}}>
        {msg.text}
      </div>}

      {/* Role legend */}
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:4}}>
        <span className="section-label" style={{marginBottom:0}}>Role Overview</span>
        <button
          className="btn btn-primary btn-sm"
          onClick={openRoleMatrixWindow}
          title="View full permission matrix in new window"
          style={{gap:6,fontWeight:600}}>
          📋 Role Matrix
        </button>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8}}>
        {Object.entries(ROLE_DESC).map(([role,desc])=>{
          const c=rc[role]||p.textMute;
          return(
            <div key={role} style={{padding:"10px 12px",borderRadius:8,background:p.panelAlt,border:`1px solid ${c}30`}}>
              <div style={{fontWeight:700,fontSize:12,color:c,textTransform:"uppercase",marginBottom:3}}>{role}</div>
              <div style={{fontSize:11,color:p.textMute,lineHeight:1.4}}>{desc}</div>
            </div>
          );
        })}
      </div>

      {/* Create Local User (admin only) */}
      {isAdmin&&(
        <div className="card" style={{overflow:"hidden"}}>
          <div className="card-header">
            <span className="card-title">🔑 Create Local User <span style={{fontSize:11,color:p.textMute,fontWeight:400}}>(AD-independent fallback)</span></span>
            <button className="btn btn-sm" onClick={()=>setShowLocalAdd(s=>!s)}
              style={{background:`${p.purple}18`,color:p.purple,border:`1px solid ${p.purple}40`,fontWeight:600}}>
              {showLocalAdd?"▲ Hide":"▼ Create Local User"}
            </button>
          </div>
          {showLocalAdd&&(
            <div style={{padding:16}}>
              <div style={{padding:"8px 12px",background:`${p.yellow}12`,border:`1px solid ${p.yellow}30`,borderRadius:7,fontSize:12,color:p.yellow,marginBottom:14}}>
                ⚡ Local users bypass AD and can log in even when AD is unreachable. Use for emergency/fallback access.
              </div>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:12}}>
                <div>
                  <label>Username *</label>
                  <input value={localUser.username} onChange={e=>setLocalUser(n=>({...n,username:e.target.value}))}
                    placeholder="e.g. john.doe"/>
                </div>
                <div>
                  <label>Display Name</label>
                  <input value={localUser.display_name} onChange={e=>setLocalUser(n=>({...n,display_name:e.target.value}))}
                    placeholder="Full name"/>
                </div>
                <div>
                  <label>Email</label>
                  <input value={localUser.email} onChange={e=>setLocalUser(n=>({...n,email:e.target.value}))}
                    placeholder="user@domain.com" type="email"/>
                </div>
                <div>
                  <label>Password * (min 6 chars)</label>
                  <div style={{display:"flex",gap:6}}>
                    <input value={localUser.password} onChange={e=>setLocalUser(n=>({...n,password:e.target.value}))}
                      type={localUser.showPw?"text":"password"} placeholder="Set a strong password" style={{flex:1}}/>
                    <button className="btn btn-ghost btn-sm" onClick={()=>setLocalUser(n=>({...n,showPw:!n.showPw}))}
                      title={localUser.showPw?"Hide password":"Show password"}>
                      {localUser.showPw?"🙈":"👁"}
                    </button>
                  </div>
                </div>
              </div>
              <div style={{display:"grid",gridTemplateColumns:"1fr auto",gap:12,alignItems:"flex-end"}}>
                <div>
                  <label>Assign Role</label>
                  <div style={{display:"flex",gap:6}}>
                    {["admin","operator","viewer","requester"].map(r=>{
                      const rc2={admin:p.red,operator:p.orange,viewer:p.cyan,requester:p.purple};
                      const isSel=localUser.role===r;
                      return(
                        <div key={r} onClick={()=>setLocalUser(n=>({...n,role:r}))}
                          style={{flex:1,padding:"8px 4px",textAlign:"center",borderRadius:7,cursor:"pointer",
                            fontSize:11,fontWeight:isSel?700:500,
                            background:isSel?`${rc2[r]}25`:`${rc2[r]}08`,
                            border:`1.5px solid ${isSel?rc2[r]:rc2[r]+"30"}`,
                            color:isSel?rc2[r]:p.textMute,transition:"all .15s"}}>
                          {r}
                        </div>
                      );
                    })}
                  </div>
                </div>
                <button className="btn btn-success" onClick={addLocalUser}
                  disabled={localBusy||!localUser.username.trim()||localUser.password.length<6}
                  style={{padding:"10px 20px",fontSize:13,fontWeight:600}}>
                  {localBusy?"Creating…":"✓ Create Local User"}
                </button>
              </div>
            </div>
          )}
        </div>
      )}

      {/* Add AD user form (admin only) */}
      {isAdmin&&(
        <div className="card" style={{overflow:"hidden"}}>
          <div className="card-header">
            <span className="card-title">➕ Add / Pre-Assign AD User Role</span>
            <button className="btn btn-primary btn-sm" onClick={()=>setShowAdd(s=>!s)}>
              {showAdd?"▲ Hide":"▼ Add User"}
            </button>
          </div>
          {showAdd&&(
            <div style={{padding:16}}>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12,marginBottom:12}}>
                <div style={{position:"relative"}}>
                  <label>Search AD Username *</label>
                  <input value={newUser.username}
                    onChange={e=>{
                      const v=e.target.value;
                      setNewUser(n=>({...n,username:v,display_name:""}));
                      if(v.length>=2){
                        // 1. Show local DB matches IMMEDIATELY (sync — instant feedback)
                        const ql=v.toLowerCase();
                        const localMatches=users.filter(u=>
                          u.username.toLowerCase().includes(ql)||
                          (u.display_name||"").toLowerCase().includes(ql)||
                          (u.email||"").toLowerCase().includes(ql)
                        );
                        setAdSuggestions(localMatches.slice(0,10));
                        // 2. Also fire AD search (async — merges in when ready)
                        if(v.length>=3){
                          searchADUsers(v).then(adResults=>{
                            setAdSuggestions(prev=>{
                              // Merge AD results, keeping local-only entries
                              const seen=new Set(adResults.map(r=>r.username));
                              const localOnly=prev.filter(p=>!seen.has(p.username));
                              return [...adResults,...localOnly].slice(0,12);
                            });
                          }).catch(()=>{}); // keep local results on AD failure
                        }
                      } else {
                        setAdSuggestions([]);
                      }
                    }}
                    placeholder="Type 2+ letters to search users…" autoFocus/>
                  {adSuggestions.length>0&&(
                    <div style={{position:"absolute",top:"100%",left:0,right:0,zIndex:200,
                      background:p.panel,border:`1px solid ${p.border}`,borderRadius:8,
                      boxShadow:"0 8px 24px rgba(0,0,0,.35)",overflow:"hidden",marginTop:2}}>
                      {adSuggestions.map(u=>(
                        <div key={u.username}
                          onClick={()=>{
                            setNewUser(n=>({...n,username:u.username,display_name:u.display_name||"",email:u.email||""}));
                            setAdSuggestions([]);
                          }}
                          style={{padding:"8px 12px",cursor:"pointer",display:"flex",alignItems:"center",
                            gap:10,fontSize:13,borderBottom:`1px solid ${p.border}22`,transition:"background .1s"}}
                          onMouseEnter={e=>e.currentTarget.style.background=p.panelAlt}
                          onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                          <div style={{width:28,height:28,borderRadius:"50%",flexShrink:0,
                            background:`linear-gradient(135deg,${p.accent}60,${p.cyan}40)`,
                            display:"flex",alignItems:"center",justifyContent:"center",
                            fontSize:10,fontWeight:700,color:p.accent}}>
                            {u.username.slice(0,2).toUpperCase()}
                          </div>
                          <div>
                            <div style={{fontWeight:600,color:p.text}}>{u.username}</div>
                            <div style={{fontSize:11,color:p.textMute}}>{u.display_name||"—"} · {u.auth_source==="ad"?"AD":"Local"}</div>
                          </div>
                          <span className="badge" style={{marginLeft:"auto",background:`${(rc[u.role]||p.textMute)}18`,color:rc[u.role]||p.textMute,border:`1px solid ${(rc[u.role]||p.textMute)}30`}}>{u.role}</span>
                        </div>
                      ))}
                      <div style={{padding:"6px 12px",fontSize:11,color:p.textMute,background:p.panelAlt,
                        borderTop:`1px solid ${p.border}`}}>
                        {adSuggestions.length} match{adSuggestions.length!==1?"es":""} · or type full username to add new
                      </div>
                    </div>
                  )}
                </div>
                <div>
                  <label>Display Name</label>
                  <input value={newUser.display_name}
                    onChange={e=>setNewUser(n=>({...n,display_name:e.target.value}))}
                    placeholder="Auto-filled or enter manually"/>
                </div>
                <div>
                  <label>Email <span style={{fontWeight:400,color:p.textMute}}>(auto-filled from AD)</span></label>
                  <input value={newUser.email}
                    onChange={e=>setNewUser(n=>({...n,email:e.target.value}))}
                    placeholder="user@sdxtest.local" type="email"/>
                </div>
              </div>
              <div style={{display:"grid",gridTemplateColumns:"1fr auto",gap:12,alignItems:"flex-end"}}>
                <div>
                  <label>Assign Role</label>
                  <div style={{display:"flex",gap:6}}>
                    {["admin","operator","viewer","requester"].map(r=>{
                      const rc2={admin:p.red,operator:p.orange,viewer:p.cyan,requester:p.purple};
                      const isSelected=newUser.role===r;
                      return(
                        <div key={r} onClick={()=>setNewUser(n=>({...n,role:r}))}
                          style={{flex:1,padding:"8px 4px",textAlign:"center",borderRadius:7,cursor:"pointer",
                            fontSize:11,fontWeight:isSelected?700:500,
                            background:isSelected?`${rc2[r]}25`:`${rc2[r]}08`,
                            border:`1.5px solid ${isSelected?rc2[r]:rc2[r]+"30"}`,
                            color:isSelected?rc2[r]:p.textMute,transition:"all .15s"}}>
                          {r}
                        </div>
                      );
                    })}
                  </div>
                  <div style={{fontSize:10,color:p.textMute,marginTop:5}}>
                    {ROLE_DESC[newUser.role]}
                  </div>
                </div>
                <button className="btn btn-success" onClick={addUser}
                  disabled={addBusy||!newUser.username.trim()}
                  style={{padding:"10px 20px",fontSize:13,fontWeight:600}}>
                  {addBusy?"Adding…":"✓ Add User"}
                </button>
              </div>
            </div>
          )}
        </div>
      )}

      {/* Users table */}
      {!isAdmin&&(
        <div style={{padding:"10px 14px",borderRadius:8,fontSize:13,background:`${p.yellow}10`,
          border:`1px solid ${p.yellow}30`,color:p.yellow}}>
          👁️ You have read-only access to user list. Only Admins can modify roles.
        </div>
      )}
      <div style={{display:"flex",gap:8,alignItems:"center"}}>
        <input style={{maxWidth:280,flex:1}} placeholder="Search username, name, email, role…"
          value={q} onChange={e=>setQ(e.target.value)}/>
        <span style={{fontSize:12,color:p.textMute}}>{filtered.length} / {users.length} users</span>
      </div>

      {loading?<div style={{padding:40,textAlign:"center"}}><div className="spinner"/></div>:(
        <div className="card" style={{overflow:"hidden"}}>
          <div className="card-header">
            <span className="card-title">All Users — AD &amp; Local ({users.length})</span>
            <span style={{fontSize:11,color:p.textMute}}>sdxtest.local · Auto-synced on login</span>
          </div>
          <div className="tbl-wrap" style={{maxHeight:"calc(100vh - 340px)"}}>
            <table>
              <thead><tr>
                <th>USERNAME</th><th>DISPLAY NAME</th><th>EMAIL</th>
                <th>ROLE</th><th>SOURCE</th><th>LAST LOGIN</th>
                {isAdmin&&<th style={{width:230}}>ACTIONS</th>}
              </tr></thead>
              <tbody>
                {filtered.length===0&&<tr><td colSpan={7} style={{textAlign:"center",padding:24,color:p.textMute}}>No users found</td></tr>}
                {filtered.map(u=>{
                  const c=rc[u.role]||p.textMute;
                  const isMe=u.username===currentUser?.username;
                  return(<tr key={u.username} style={{opacity:isMe?1:undefined}}>
                    <td>
                      <div style={{display:"flex",alignItems:"center",gap:7}}>
                        <div style={{width:26,height:26,borderRadius:"50%",flexShrink:0,
                          background:`linear-gradient(135deg,${c}88,${c}44)`,
                          border:`1px solid ${c}40`,
                          display:"flex",alignItems:"center",justifyContent:"center",
                          fontSize:10,fontWeight:700,color:c}}>
                          {(u.username||"?").slice(0,2).toUpperCase()}
                        </div>
                        <span style={{fontWeight:700,color:p.accent}}>{u.username}</span>
                        {isMe&&<span style={{fontSize:9,background:`${p.green}20`,color:p.green,border:`1px solid ${p.green}30`,borderRadius:4,padding:"1px 5px",fontWeight:700}}>YOU</span>}
                      </div>
                    </td>
                    <td style={{fontWeight:500}}>{u.display_name||"—"}</td>
                    <td style={{color:p.textMute,fontSize:12}}>{u.email||"—"}</td>
                    <td><span className="badge" style={{background:`${c}18`,color:c,border:`1px solid ${c}28`}}>{u.role}</span></td>
                    <td style={{fontSize:11}}>
                      {u.auth_source==="ad"
                        ? <span style={{color:p.cyan}}>🔐 AD</span>
                        : <span style={{color:p.purple,fontWeight:600}}>🔑 Local</span>}
                    </td>
                    <td style={{fontSize:11,color:p.textMute}}>{u.last_login?.slice(0,16)||"—"}</td>
                    {isAdmin&&<td>{isMe
                      ?<span style={{fontSize:11,color:p.textMute}}>— (you)</span>
                      :<div style={{display:"flex",alignItems:"center",gap:8}}>
                        <select value={u.role} style={{width:130,fontSize:12,padding:"3px 8px"}}
                          onChange={e=>changeRole(u.username,e.target.value)}>
                          {["admin","operator","viewer","requester"].map(r=><option key={r} value={r}>{r}</option>)}
                        </select>
                        {u.username!=="admin"&&(
                          <button className="btn btn-danger btn-sm" onClick={()=>removeUser(u.username)}>
                            Delete
                          </button>
                        )}
                      </div>
                    }</td>}
                  </tr>);
                })}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  );
}



// ─── DELETE VM FROM DISK MODAL (Admin only) ───────────────────────────────────
function DeleteVMModal({vm, onClose, onDone, p}){
  const [confirm, setConfirm] = useState("");
  const [busy, setBusy] = useState(false);
  const [err, setErr] = useState(null);
  const correct = vm.name;

  async function doDelete(){
    if(confirm !== correct) return;
    setBusy(true); setErr(null);
    try{
      await deleteVMFromDisk(vm.vcenter_id, vm.name);
      onDone&&onDone();
    }catch(e){ setErr(e.message); setBusy(false); }
  }

  return(
    <div className="overlay" onClick={onClose}>
      <div className="modal" style={{width:460}} onClick={e=>e.stopPropagation()}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:16}}>
          <div style={{fontWeight:700,fontSize:16,color:p.red}}>&#128465; Delete VM from Disk</div>
          <button className="btn btn-ghost btn-sm" onClick={onClose}>✕</button>
        </div>
        <div style={{padding:"14px",background:`${p.red}10`,border:`1px solid ${p.red}35`,borderRadius:8,marginBottom:16}}>
          <div style={{fontWeight:700,fontSize:14,color:p.red,marginBottom:6}}>⚠️ This action is IRREVERSIBLE</div>
          <div style={{fontSize:13,color:p.text}}>VM <b style={{color:p.accent}}>{vm.name}</b> and all its disk files will be permanently deleted from <b>{vm.vcenter_name||vm.vcenter_id}</b>.</div>
          <div style={{fontSize:12,color:p.textMute,marginTop:6}}>Host: {vm.host} · Status: {vm.status} · Disk: {vm.disk_gb}GB</div>
        </div>
        <div style={{marginBottom:16}}>
          <label style={{fontSize:12,color:p.textMute}}>Type the VM name to confirm: <b style={{color:p.red}}>{correct}</b></label>
          <input value={confirm} onChange={e=>setConfirm(e.target.value)}
            placeholder={correct} style={{marginTop:6,borderColor:confirm===correct?p.green:p.border}}/>
        </div>
        {err&&<div style={{color:p.red,fontSize:12,marginBottom:10}}>✗ {err}</div>}
        <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
          <button className="btn btn-ghost" onClick={onClose}>Cancel</button>
          <button className="btn btn-danger" onClick={doDelete}
            disabled={confirm!==correct||busy}>
            {busy?"⏳ Deleting…":"&#128465; Delete Permanently"}
          </button>
        </div>
      </div>
    </div>
  );
}

// ─── SNAPSHOT SELECT + DELETE MODAL (for VM with multiple snapshots) ──────────
function SnapshotDeleteModal({vm, snapshots, onClose, onDone, p}){
  const vmSnaps = snapshots.filter(s=>s.vm_name===vm.name && s.vcenter_id===vm.vcenter_id);
  const [selected, setSelected] = useState(vmSnaps[0]?.snapshot_name||"");
  const [busy, setBusy] = useState(false);
  const [err, setErr] = useState(null);
  const [ok, setOk] = useState(null);

  async function doDelete(){
    if(!selected) return;
    setBusy(true); setErr(null);
    try{
      await deleteSnapshot(vm.vcenter_id, vm.name, selected);
      setOk(`Snapshot "${selected}" deleted`);
      setTimeout(()=>{ onDone&&onDone(); },1800);
    }catch(e){ setErr(e.message); setBusy(false); }
  }

  return(
    <div className="overlay" onClick={onClose}>
      <div className="modal" style={{width:440}} onClick={e=>e.stopPropagation()}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:16}}>
          <div style={{fontWeight:700,fontSize:15}}>&#128248; Delete Snapshot — <span style={{color:p.accent}}>{vm.name}</span></div>
          <button className="btn btn-ghost btn-sm" onClick={onClose}>✕</button>
        </div>
        {vmSnaps.length===0
          ? <div style={{color:p.textMute,textAlign:"center",padding:20}}>No snapshots found for this VM.</div>
          : <>
            <div style={{marginBottom:14}}>
              <label>Select snapshot to delete ({vmSnaps.length} total)</label>
              <select value={selected} onChange={e=>setSelected(e.target.value)} style={{marginTop:6}}>
                {vmSnaps.map((s,i)=>(
                  <option key={i} value={s.snapshot_name}>
                    {s.snapshot_name}{s.age_days?" · "+s.age_days+"d old":""}{s.size_gb?" · "+s.size_gb+"GB":""}
                  </option>
                ))}
              </select>
            </div>
            {selected&&(()=>{
              const s=vmSnaps.find(x=>x.snapshot_name===selected);
              return s?<div style={{padding:"10px 12px",background:p.panelAlt,borderRadius:7,
                border:`1px solid ${p.border}`,fontSize:12,color:p.textMute,marginBottom:14}}>
                <div><b>Name:</b> {s.snapshot_name}</div>
                {s.description&&<div><b>Desc:</b> {s.description}</div>}
                {s.created&&<div><b>Created:</b> {s.created}</div>}
                {s.age_days&&<div><b>Age:</b> {s.age_days} days</div>}
                {s.size_gb&&<div><b>Size:</b> {s.size_gb} GB</div>}
              </div>:null;
            })()}
            {err&&<div style={{color:p.red,fontSize:12,marginBottom:10}}>✗ {err}</div>}
            {ok&&<div style={{color:p.green,fontSize:12,marginBottom:10}}>✅ {ok}</div>}
            <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
              <button className="btn btn-ghost" onClick={onClose}>Cancel</button>
              <button className="btn btn-danger" onClick={doDelete} disabled={!selected||busy}>
                {busy?"⏳ Deleting…":"&#128465; Delete Snapshot"}
              </button>
            </div>
          </>
        }
      </div>
    </div>
  );
}

// ─── Topology Modal ────────────────────────────────────────────────────────────
function TopologyModal({target, onClose, p}) {
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [err, setErr] = useState(null);

  useEffect(() => {
    setLoading(true); setErr(null); setData(null);
    const fn = target.type === "vm" ? fetchVMTopology : fetchHostTopology;
    fn(target.vcenter_id, target.name)
      .then(d => { setData(d); setLoading(false); })
      .catch(e => { setErr(e.message); setLoading(false); });
  }, [target]);

  function exportTopologyPDF() {
    if (!data) return;
    const origin = window.location.origin;
    const isVM = target.type === "vm";
    const now = new Date().toLocaleString();
    const statusDot = (s) => s==="poweredOn"||s==="connected"?"#10b981":s==="poweredOff"||s==="disconnected"?"#ef4444":"#f59e0b";

    let body = "";
    if (isVM) {
      const sc = statusDot(data.status);
      body += `
        <div class="node-card accent">
          <div class="node-title">💻 ${data.name}</div>
          <div class="node-sub">${data.guest_os||"OS N/A"} &nbsp;·&nbsp; Host: ${data.host}</div>
          <div class="tags">
            <span class="tag" style="background:${sc}18;color:${sc};border:1px solid ${sc}40">${data.status==="poweredOn"?"● ON":data.status==="poweredOff"?"● OFF":"● "+data.status}</span>
            <span class="tag blue">⚡ ${data.cpu} vCPU</span>
            <span class="tag purple">🧠 ${data.ram_gb} GB RAM</span>
          </div>
          ${data.uuid?`<div class="mono">UUID: ${data.uuid}</div>`:""}
          ${data.annotation?`<div class="note">📝 ${data.annotation}</div>`:""}
        </div>
        <div class="section-grid">
          <div>
            <div class="section-hdr green">💾 STORAGE</div>
            ${data.disks.length===0?`<div class="empty">No disk info</div>`:""}
            ${data.disks.map(d=>`
              <div class="sub-card">
                <div class="sub-title">${d.label}</div>
                <div class="tags"><span class="tag green">${d.capacity_gb} GB</span>${d.thin?`<span class="tag yellow">Thin</span>`:""}</div>
                ${d.file_path?`<div class="mono">${d.file_path}</div>`:""}
                ${d.datastore?`<div class="arrow">▼</div><div class="sub-card green-border"><div class="icon-label">🗄️ ${d.datastore}</div></div>`:""}
              </div>`).join("")}
          </div>
          <div>
            <div class="section-hdr cyan">🌐 NETWORKING</div>
            ${data.nics.length===0?`<div class="empty">No NIC info</div>`:""}
            ${data.nics.map(n=>`
              <div class="sub-card" style="border-left:3px solid #06b6d4">
                <div class="sub-title">${n.label} <span class="tag" style="background:#06b6d418;color:#06b6d4;border:1px solid #06b6d430">${n.type}</span></div>
                <div class="mono">MAC: ${n.mac||"—"}</div>
                ${n.ips&&n.ips.length?`<div class="green-text">IP: ${n.ips.join(", ")}</div>`:""}
                <div class="tags"><span class="tag ${n.connected?"green":"red"}">${n.connected?"Connected":"Disconnected"}</span></div>
                ${n.portgroup?`<div class="arrow">▼</div>
                  <div class="sub-card" style="background:#06b6d408;border:1px solid #06b6d425">
                    <div class="icon-label" style="color:#06b6d4">🔀 Portgroup: <b>${n.portgroup}</b></div>
                    ${n.vlan!=="—"?`<span class="tag yellow">VLAN ${n.vlan}</span>`:""}
                  </div>`:""}
                ${n.switch&&n.switch!=="—"?`<div class="arrow">▼</div>
                  <div class="sub-card" style="background:#6d28d918;border:1px solid #6d28d930">
                    <div class="icon-label" style="color:#a78bfa">${n.switch_type==="DVS"?"🔗 DVS":"🔌 vSwitch"}: <b>${n.switch}</b></div>
                    <span class="tag purple">${n.switch_type}</span>
                  </div>`:""}
              </div>`).join("")}
          </div>
        </div>`;
    } else {
      const sc = statusDot(data.status);
      body += `
        <div class="node-card accent">
          <div class="node-title">🖥️ ${data.name}</div>
          <div class="node-sub">${data.cpu_model||"CPU N/A"}</div>
          <div class="tags">
            <span class="tag" style="background:${sc}18;color:${sc};border:1px solid ${sc}40">● ${data.status}</span>
            <span class="tag blue">⚡ ${data.cpu_cores} Cores · ${data.cpu_used_pct}% used</span>
            <span class="tag purple">🧠 ${data.ram_used_gb}/${data.ram_total_gb} GB RAM</span>
          </div>
        </div>
        <div class="four-grid">
          <div>
            <div class="section-hdr green">💻 VMs (${data.vms.length})</div>
            ${data.vms.length===0?`<div class="empty">None</div>`:""}
            ${data.vms.map(v=>`
              <div class="sub-card" style="border-left:3px solid ${statusDot(v.status)}">
                <div class="sub-title small">${v.name}</div>
                <div class="tags">
                  <span class="tag" style="background:${statusDot(v.status)}18;color:${statusDot(v.status)};border:1px solid ${statusDot(v.status)}40">${v.status==="poweredOn"?"ON":"OFF"}</span>
                  <span style="font-size:9px;color:#94a3b8">${v.cpu}c · ${v.ram_gb}G</span>
                </div>
              </div>`).join("")}
          </div>
          <div>
            <div class="section-hdr cyan">🔌 vSwitches (${data.vswitches.length + data.dvs_uplinks.length})</div>
            ${data.vswitches.map(vs=>`
              <div class="sub-card" style="border-left:3px solid #06b6d4">
                <div class="sub-title small" style="color:#06b6d4">${vs.name}</div>
                <div style="font-size:9px;color:#94a3b8">MTU:${vs.mtu} Ports:${vs.num_ports}</div>
                ${vs.uplinks.length?`<div style="font-size:9px;color:#f59e0b">↑ ${vs.uplinks.join(", ")}</div>`:""}
                ${vs.portgroups.map(pg=>`<div class="portgroup-row">🔀 ${pg.name} <span class="tag yellow">VLAN ${pg.vlan}</span></div>`).join("")}
              </div>`).join("")}
            ${data.dvs_uplinks.map(dvs=>`
              <div class="sub-card" style="border-left:3px solid #e879f9">
                <div class="sub-title small" style="color:#e879f9">${dvs.dvs_name} <span class="tag" style="background:#e879f918;color:#e879f9;border:1px solid #e879f930">DVS</span></div>
                <div style="font-size:9px;color:#94a3b8">Ports:${dvs.num_ports}</div>
                ${dvs.uplinks.length?`<div style="font-size:9px;color:#f59e0b">↑ ${dvs.uplinks.join(", ")}</div>`:""}
                ${dvs.portgroups.map(pg=>`<div class="portgroup-row">🔀 ${pg.name} <span class="tag yellow">VLAN ${pg.vlan}</span></div>`).join("")}
              </div>`).join("")}
          </div>
          <div>
            <div class="section-hdr orange">🔌 pNICs (${data.pnics.length})</div>
            ${data.pnics.map(n=>`
              <div class="sub-card" style="border-left:3px solid ${n.speed_mb>=10000?"#e879f9":n.speed_mb>=1000?"#10b981":"#f59e0b"}">
                <div class="sub-title small">${n.device}</div>
                <div class="mono xsmall">${n.mac}</div>
                <div class="tags">
                  <span class="tag" style="background:${n.speed_mb>=10000?"#e879f9":n.speed_mb>=1000?"#10b981":"#f59e0b"}18;color:${n.speed_mb>=10000?"#e879f9":n.speed_mb>=1000?"#10b981":"#f59e0b"};border:1px solid ${n.speed_mb>=10000?"#e879f9":n.speed_mb>=1000?"#10b981":"#f59e0b"}40">
                    ${n.speed_mb>=1000?`${n.speed_mb/1000}Gbps`:n.speed_mb?`${n.speed_mb}Mbps`:"Link down"}
                  </span>
                  ${n.driver?`<span style="font-size:9px;color:#94a3b8">${n.driver}</span>`:""}
                </div>
                ${n.neighbor&&n.neighbor.protocol?`
                  <div class="neighbor-box">
                    <div class="neighbor-hdr">🔗 ${n.neighbor.protocol} NEIGHBOR</div>
                    ${n.neighbor.system_name?`<div class="neighbor-row"><b>${n.neighbor.system_name}</b></div>`:""}
                    ${n.neighbor.device_id?`<div class="neighbor-row">Device ID: <span class="mono">${n.neighbor.device_id}</span></div>`:""}
                    ${n.neighbor.port_id?`<div class="neighbor-row">Port: <span class="mono">${n.neighbor.port_id}</span></div>`:""}
                    ${n.neighbor.hw_platform?`<div class="neighbor-row">Platform: ${n.neighbor.hw_platform}</div>`:""}
                    ${n.neighbor.mgmt_addr?`<div class="neighbor-row" style="color:#06b6d4">Mgmt: <span class="mono">${n.neighbor.mgmt_addr}</span></div>`:""}
                  </div>`:""}
              </div>`).join("")}
          </div>
          <div>
            <div class="section-hdr purple">🔷 VMkernel (${data.vmknics.length})</div>
            ${data.vmknics.map(v=>`
              <div class="sub-card" style="border-left:3px solid #8b5cf6">
                <div class="sub-title small" style="color:#8b5cf6">${v.device}</div>
                ${v.ip?`<div class="mono xsmall green-text">${v.ip}</div>`:""}
                ${v.mac?`<div class="mono xsmall">${v.mac}</div>`:""}
                <div class="tags">
                  ${v.portgroup?`<span class="tag cyan">${v.portgroup}</span>`:""}
                  ${v.vlan!==undefined?`<span class="tag yellow">VLAN ${v.vlan}</span>`:""}
                  <span style="font-size:9px;color:#94a3b8">MTU:${v.mtu}</span>
                </div>
              </div>`).join("")}
          </div>
        </div>`;
    }

    const html = `<!DOCTYPE html><html><head><meta charset="utf-8"/>
    <title>Topology — ${data.name}</title>
    <style>
      @page{margin:18mm 12mm 18mm 12mm}
      *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;box-sizing:border-box}
      body{font-family:Arial,sans-serif;font-size:11px;color:#1e293b;background:#fff;padding:16px;max-width:1100px;margin:auto}
      .print-header,.print-footer{display:none}
      @media print{
        .print-header{display:flex!important;position:fixed;top:0;left:0;right:0;height:44px;
          align-items:center;padding:0 8mm;border-bottom:2px solid #6d28d9;background:#fff;z-index:9999;gap:10px}
        .print-footer{display:flex!important;position:fixed;bottom:0;left:0;right:0;height:26px;
          align-items:center;justify-content:space-between;padding:0 8mm;
          border-top:1px solid #e2e8f0;background:#fff;font-size:9px;color:#64748b;z-index:9999}
        body{padding-top:56px;padding-bottom:34px}
        .no-print{display:none!important}
      }
      .print-btn{background:linear-gradient(135deg,#7c3aed,#6d28d9);color:#fff;border:none;
        padding:8px 20px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:700;margin-bottom:16px}
      .doc-title{font-size:20px;font-weight:800;color:#1e293b;margin-bottom:2px}
      .doc-sub{font-size:11px;color:#64748b;margin-bottom:16px}
      .node-card{border-radius:10px;padding:12px 16px;margin-bottom:14px;border:1px solid #e2e8f0}
      .node-card.accent{background:#6d28d908;border-color:#6d28d930}
      .node-title{font-size:16px;font-weight:800;color:#0f172a;margin-bottom:3px}
      .node-sub{font-size:11px;color:#64748b;margin-bottom:6px}
      .tags{display:flex;flex-wrap:wrap;gap:4px;margin:4px 0}
      .tag{display:inline-block;font-size:9px;font-weight:700;padding:2px 7px;border-radius:12px}
      .tag.blue{background:#3b82f618;color:#3b82f6;border:1px solid #3b82f630}
      .tag.purple{background:#8b5cf618;color:#8b5cf6;border:1px solid #8b5cf630}
      .tag.green{background:#10b98118;color:#10b981;border:1px solid #10b98130}
      .tag.cyan{background:#06b6d418;color:#06b6d4;border:1px solid #06b6d430}
      .tag.yellow{background:#f59e0b18;color:#d97706;border:1px solid #f59e0b30}
      .tag.red{background:#ef444418;color:#ef4444;border:1px solid #ef444430}
      .tag.orange{background:#f9731618;color:#f97316;border:1px solid #f9731630}
      .mono{font-family:monospace;font-size:10px;color:#475569}
      .mono.xsmall{font-size:9px}
      .green-text{color:#10b981;font-size:10px}
      .note{font-size:10px;color:#64748b;font-style:italic;margin-top:4px}
      .arrow{text-align:center;color:#94a3b8;font-size:10px;line-height:1.2;padding:1px 0}
      .section-hdr{font-size:10px;font-weight:800;letter-spacing:1px;padding:5px 8px;
        border-radius:6px 6px 0 0;margin-bottom:6px;text-align:center}
      .section-hdr.green{background:#10b98112;color:#10b981;border:1px solid #10b98125}
      .section-hdr.cyan{background:#06b6d412;color:#06b6d4;border:1px solid #06b6d425}
      .section-hdr.orange{background:#f9731612;color:#f97316;border:1px solid #f9731625}
      .section-hdr.purple{background:#8b5cf612;color:#8b5cf6;border:1px solid #8b5cf625}
      .sub-card{border:1px solid #e2e8f0;border-radius:7px;padding:7px 9px;margin-bottom:6px;background:#fff;font-size:10px}
      .sub-card.green-border{border-left:2px solid #10b981}
      .sub-title{font-weight:700;color:#0f172a;margin-bottom:3px}
      .sub-title.small{font-size:10px}
      .icon-label{font-size:10px;font-weight:600;margin-bottom:2px}
      .empty{font-size:10px;color:#94a3b8;text-align:center;padding:8px;border:1px solid #f1f5f9;border-radius:6px}
      .portgroup-row{font-size:9px;color:#334155;padding:2px 0;border-top:1px solid #f1f5f9;margin-top:3px;display:flex;align-items:center;gap:4px;flex-wrap:wrap}
      .neighbor-box{margin-top:5px;padding:5px 7px;background:#6d28d910;border:1px solid #6d28d928;border-radius:6px}
      .neighbor-hdr{font-size:9px;font-weight:800;color:#7c3aed;letter-spacing:.5px;margin-bottom:3px}
      .neighbor-row{font-size:9px;color:#334155;line-height:1.5}
      .section-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-top:8px}
      .four-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:8px}
      @media print{
        .section-grid,.four-grid{page-break-inside:avoid}
      }
    </style></head><body>
    <div class="print-header">
      <img src="${origin}/wings.png" height="32" style="object-fit:contain" alt="Wipro"/>
      <span style="font-weight:800;font-size:13px;color:#1e293b">CaaS Portal &mdash; Topology Report</span>
    </div>
    <div class="print-footer">
      <span>${data.vcenter_name||data.vcenter_id} &mdash; ${data.name}</span>
      <span>CaaS Portal &mdash; Wipro Confidential &mdash; ${now}</span>
    </div>
    <button class="print-btn no-print" onclick="window.print()">🖨️ Export / Print PDF</button>
    <div class="doc-title">${isVM?"💻 VM":"🖥️ ESXi Host"} Topology — ${data.name}</div>
    <div class="doc-sub">vCenter: ${data.vcenter_name||data.vcenter_id} &nbsp;·&nbsp; Generated: ${now}</div>
    ${body}
    <script>
      document.querySelector('.print-btn')?.addEventListener('click',()=>window.print());
    <\/script>
    </body></html>`;

    const w = window.open("", "_blank");
    if (w) { w.document.write(html); w.document.close(); }
  }

  const card = (style={}) => ({
    background: p.panel, border: `1px solid ${p.border}`,
    borderRadius: 10, padding: "10px 14px", ...style
  });
  const tag = (color) => ({
    display:"inline-block", fontSize:10, fontWeight:700,
    padding:"2px 7px", borderRadius:20,
    background:`${color}18`, color, border:`1px solid ${color}30`
  });
  const connector = {
    width: 2, background: `${p.border}`, alignSelf:"stretch",
    margin:"0 auto", flexShrink:0
  };
  const hConnector = {
    height: 2, background: p.border, flexShrink:0
  };
  const statusColor = (s) => s==="poweredOn"||s==="connected"?"#10b981":s==="poweredOff"||s==="disconnected"?"#ef4444":"#f59e0b";

  const NicTypeColor = {vmxnet3:"#06b6d4",vmxnet2:"#3b82f6",e1000e:"#8b5cf6",e1000:"#7c3aed",pcnet32:"#f59e0b"};

  return (
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.75)",backdropFilter:"blur(6px)",zIndex:4000,
      display:"flex",alignItems:"center",justifyContent:"center",padding:16}} onClick={onClose}>
      <div style={{background:p.surface,border:`1px solid ${p.border}`,borderRadius:16,
        width:"min(98vw,1140px)",maxHeight:"90vh",display:"flex",flexDirection:"column",
        boxShadow:"0 32px 80px rgba(0,0,0,.6)",overflow:"hidden"}}
        onClick={e=>e.stopPropagation()}>

        {/* Header */}
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",
          padding:"14px 20px",borderBottom:`1px solid ${p.border}`,
          background:`linear-gradient(90deg,${p.panel},${p.surface})`,flexShrink:0}}>
          <div style={{display:"flex",alignItems:"center",gap:10}}>
            <span style={{fontSize:22}}>{target.type==="vm"?"💻":"🖥️"}</span>
            <div>
              <div style={{fontWeight:800,fontSize:17,color:p.text}}>{target.name}</div>
              <div style={{fontSize:11,color:p.textMute}}>
                {target.type==="vm"?"Virtual Machine Topology":"ESXi Host Topology"}
                {" · "}<span style={{color:p.cyan}}>{target.vcenter_name||target.vcenter_id}</span>
              </div>
            </div>
          </div>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            {data&&<button onClick={exportTopologyPDF}
              style={{background:"linear-gradient(135deg,#7c3aed,#6d28d9)",color:"#fff",border:"none",
                borderRadius:8,padding:"5px 14px",cursor:"pointer",fontWeight:700,fontSize:12,
                boxShadow:"0 2px 12px rgba(109,40,217,.4)"}}>
              🖨️ Export PDF
            </button>}
            <button onClick={onClose} style={{background:`${p.red}18`,border:`1px solid ${p.red}35`,
              borderRadius:8,padding:"4px 12px",cursor:"pointer",color:p.red,fontWeight:700,fontSize:13}}>✕ Close</button>
          </div>
        </div>

        {/* Body */}
        <div style={{overflowY:"auto",padding:20,flex:1}}>
          {loading && (
            <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",
              padding:60,gap:14}}>
              <div className="spinner" style={{width:36,height:36,borderWidth:4}}/>
              <div style={{fontSize:13,color:p.textMute}}>Fetching topology from vCenter…</div>
            </div>
          )}
          {err && (
            <div style={{textAlign:"center",padding:40,color:p.red}}>⚠️ {err}</div>
          )}

          {/* ── VM Topology ── */}
          {data && target.type==="vm" && (
            <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:0}}>
              {/* VM root node */}
              <div style={{...card({background:`${p.accent}12`,border:`1px solid ${p.accent}40`,
                width:"100%",maxWidth:720})}}>
                <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:8}}>
                  <div style={{display:"flex",alignItems:"center",gap:10}}>
                    <span style={{fontSize:26}}>💻</span>
                    <div>
                      <div style={{fontWeight:800,fontSize:16,color:p.text}}>{data.name}</div>
                      <div style={{fontSize:11,color:p.textMute,marginTop:2}}>{data.guest_os||"OS N/A"}</div>
                    </div>
                  </div>
                  <div style={{display:"flex",gap:6,flexWrap:"wrap",alignItems:"center"}}>
                    <span style={tag(statusColor(data.status))}>{data.status==="poweredOn"?"● ON":data.status==="poweredOff"?"● OFF":"● "+data.status}</span>
                    <span style={tag(p.cyan)}>⚡ {data.cpu}c vCPU</span>
                    <span style={tag(p.purple)}>🧠 {data.ram_gb}GB RAM</span>
                    <span style={tag(p.textSub)}>🖥️ {data.host}</span>
                  </div>
                </div>
                {data.uuid && <div style={{fontSize:10,color:p.textMute,marginTop:8,fontFamily:"monospace"}}>UUID: {data.uuid}</div>}
                {data.annotation && <div style={{fontSize:11,color:p.textSub,marginTop:4,fontStyle:"italic"}}>📝 {data.annotation}</div>}
              </div>

              {/* Connector */}
              <div style={{display:"flex",justifyContent:"center",height:24}}>
                <div style={{width:2,height:"100%",background:p.border}}/>
              </div>

              {/* Two-column: Storage | Networking */}
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:16,width:"100%",maxWidth:720,alignItems:"start"}}>

                {/* ── STORAGE ── */}
                <div style={{display:"flex",flexDirection:"column",gap:0,alignItems:"center"}}>
                  <div style={{...card({background:`${p.green}10`,border:`1px solid ${p.green}30`,
                    width:"100%",textAlign:"center",borderRadius:"10px 10px 0 0",padding:"6px 10px"})}}>
                    <span style={{fontSize:11,fontWeight:800,color:p.green,letterSpacing:1}}>💾 STORAGE</span>
                  </div>
                  <div style={{width:2,height:12,background:p.border}}/>
                  <div style={{display:"flex",flexDirection:"column",gap:8,width:"100%"}}>
                    {data.disks.length===0 && <div style={{...card({textAlign:"center",color:p.textMute,fontSize:11})}}>No disk info</div>}
                    {data.disks.map((d,i)=>(
                      <div key={i} style={{display:"flex",flexDirection:"column",gap:0,alignItems:"center"}}>
                        <div style={card({width:"100%"})}>
                          <div style={{fontWeight:700,fontSize:12,color:p.text}}>{d.label}</div>
                          <div style={{display:"flex",gap:6,marginTop:4,flexWrap:"wrap"}}>
                            <span style={tag(p.green)}>{d.capacity_gb} GB</span>
                            {d.thin && <span style={tag(p.yellow)}>Thin</span>}
                          </div>
                          {d.file_path && <div style={{fontSize:9,color:p.textMute,marginTop:4,fontFamily:"monospace",wordBreak:"break-all"}}>{d.file_path}</div>}
                        </div>
                        {d.datastore && <>
                          <div style={{width:2,height:10,background:`${p.green}60`}}/>
                          <div style={card({background:`${p.green}08`,border:`1px solid ${p.green}25`,width:"100%",textAlign:"center"})}>
                            <div style={{fontSize:10,fontWeight:700,color:p.green}}>🗄️ {d.datastore}</div>
                          </div>
                        </>}
                      </div>
                    ))}
                  </div>
                </div>

                {/* ── NETWORKING ── */}
                <div style={{display:"flex",flexDirection:"column",gap:0,alignItems:"center"}}>
                  <div style={{...card({background:`${p.cyan}10`,border:`1px solid ${p.cyan}30`,
                    width:"100%",textAlign:"center",borderRadius:"10px 10px 0 0",padding:"6px 10px"})}}>
                    <span style={{fontSize:11,fontWeight:800,color:p.cyan,letterSpacing:1}}>🌐 NETWORKING</span>
                  </div>
                  <div style={{width:2,height:12,background:p.border}}/>
                  <div style={{display:"flex",flexDirection:"column",gap:10,width:"100%"}}>
                    {data.nics.length===0 && <div style={{...card({textAlign:"center",color:p.textMute,fontSize:11})}}>No NIC info</div>}
                    {data.nics.map((n,i)=>{
                      const nc = NicTypeColor[n.type.toLowerCase()]||p.purple;
                      return (
                        <div key={i} style={{display:"flex",flexDirection:"column",gap:0,alignItems:"center"}}>
                          {/* NIC card */}
                          <div style={card({width:"100%",borderLeft:`3px solid ${nc}`})}>
                            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                              <span style={{fontWeight:700,fontSize:12,color:p.text}}>{n.label}</span>
                              <span style={tag(nc)}>{n.type}</span>
                            </div>
                            <div style={{fontSize:10,color:p.textMute,fontFamily:"monospace",marginTop:3}}>MAC: {n.mac||"—"}</div>
                            {n.ips&&n.ips.length>0 && <div style={{fontSize:10,color:p.green,marginTop:2}}>IP: {n.ips.join(", ")}</div>}
                            <div style={{marginTop:4}}>
                              <span style={tag(n.connected?"#10b981":"#ef4444")}>{n.connected?"Connected":"Disconnected"}</span>
                            </div>
                          </div>
                          {/* Portgroup */}
                          {n.portgroup && <>
                            <div style={{width:2,height:10,background:`${p.cyan}60`}}/>
                            <div style={card({background:`${p.cyan}08`,border:`1px solid ${p.cyan}25`,width:"100%"})}>
                              <div style={{fontSize:10,fontWeight:700,color:p.cyan}}>🔀 Portgroup</div>
                              <div style={{fontWeight:600,fontSize:12,color:p.text,marginTop:2}}>{n.portgroup}</div>
                              {n.vlan!=="—"&&<div style={{marginTop:3}}><span style={tag(p.yellow)}>VLAN {n.vlan}</span></div>}
                            </div>
                          </>}
                          {/* Switch */}
                          {n.switch && n.switch!=="—" && <>
                            <div style={{width:2,height:10,background:`${p.accent}60`}}/>
                            <div style={card({background:`${p.accent}08`,border:`1px solid ${p.accent}25`,width:"100%"})}>
                              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                                <div>
                                  <div style={{fontSize:10,fontWeight:700,color:p.accent}}>{n.switch_type==="DVS"?"🔗 Distributed vSwitch":"🔌 Standard vSwitch"}</div>
                                  <div style={{fontWeight:600,fontSize:12,color:p.text,marginTop:2}}>{n.switch}</div>
                                </div>
                                <span style={tag(n.switch_type==="DVS"?"#e879f9":p.blue||"#3b82f6")}>{n.switch_type}</span>
                              </div>
                            </div>
                          </>}
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* ── HOST Topology ── */}
          {data && target.type==="host" && (
            <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:0}}>
              {/* Host root node */}
              <div style={{...card({background:`${p.accent}12`,border:`1px solid ${p.accent}40`,width:"100%"})}}>
                <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:8}}>
                  <div style={{display:"flex",alignItems:"center",gap:10}}>
                    <span style={{fontSize:26}}>🖥️</span>
                    <div>
                      <div style={{fontWeight:800,fontSize:16,color:p.text}}>{data.name}</div>
                      <div style={{fontSize:11,color:p.textMute,marginTop:2}}>{data.cpu_model||"CPU N/A"}</div>
                    </div>
                  </div>
                  <div style={{display:"flex",gap:6,flexWrap:"wrap",alignItems:"center"}}>
                    <span style={tag(statusColor(data.status))}>● {data.status}</span>
                    <span style={tag(p.cyan)}>⚡ {data.cpu_cores} Cores {data.cpu_used_pct}% used</span>
                    <span style={tag(p.purple)}>🧠 {data.ram_used_gb}/{data.ram_total_gb}GB RAM</span>
                  </div>
                </div>
              </div>

              <div style={{width:2,height:20,background:p.border}}/>

              {/* 4-column grid */}
              <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:12,width:"100%",alignItems:"start"}}>

                {/* VMs */}
                <div style={{display:"flex",flexDirection:"column",gap:6}}>
                  <div style={{...card({background:`${p.green}10`,border:`1px solid ${p.green}30`,
                    textAlign:"center",borderRadius:"10px 10px 0 0",padding:"6px 8px"})}}>
                    <span style={{fontSize:10,fontWeight:800,color:p.green}}>💻 VMs ({data.vms.length})</span>
                  </div>
                  {data.vms.length===0&&<div style={{...card({textAlign:"center",color:p.textMute,fontSize:10})}}>None</div>}
                  {data.vms.map((v,i)=>{
                    const sc=statusColor(v.status);
                    return (
                      <div key={i} style={card({borderLeft:`3px solid ${sc}`,padding:"6px 10px"})}>
                        <div style={{fontWeight:600,fontSize:11,color:p.text,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}} title={v.name}>{v.name}</div>
                        <div style={{display:"flex",gap:4,marginTop:3,flexWrap:"wrap"}}>
                          <span style={tag(sc)}>{v.status==="poweredOn"?"ON":"OFF"}</span>
                          <span style={{fontSize:9,color:p.textMute}}>{v.cpu}c·{v.ram_gb}G</span>
                        </div>
                      </div>
                    );
                  })}
                </div>

                {/* vSwitches */}
                <div style={{display:"flex",flexDirection:"column",gap:6}}>
                  <div style={{...card({background:`${p.cyan}10`,border:`1px solid ${p.cyan}30`,
                    textAlign:"center",borderRadius:"10px 10px 0 0",padding:"6px 8px"})}}>
                    <span style={{fontSize:10,fontWeight:800,color:p.cyan}}>🔌 vSwitches ({data.vswitches.length})</span>
                  </div>
                  {data.vswitches.length===0&&<div style={{...card({textAlign:"center",color:p.textMute,fontSize:10})}}>None</div>}
                  {data.vswitches.map((vs,i)=>(
                    <div key={i} style={card({borderLeft:`3px solid ${p.cyan}`})}>
                      <div style={{fontWeight:700,fontSize:11,color:p.cyan}}>{vs.name}</div>
                      <div style={{fontSize:9,color:p.textMute}}>MTU:{vs.mtu} · Ports:{vs.num_ports}</div>
                      {vs.uplinks.length>0 && <div style={{fontSize:9,color:p.yellow,marginTop:3}}>↑ {vs.uplinks.join(", ")}</div>}
                      {vs.portgroups.map((pg,j)=>(
                        <div key={j} style={{marginTop:4,paddingLeft:6,borderLeft:`2px solid ${p.border}`}}>
                          <div style={{fontSize:10,color:p.text}}>🔀 {pg.name}</div>
                          <span style={tag(p.yellow)}>VLAN {pg.vlan}</span>
                        </div>
                      ))}
                    </div>
                  ))}
                  {/* DVS */}
                  {data.dvs_uplinks.map((dvs,i)=>(
                    <div key={i} style={card({borderLeft:`3px solid #e879f9`})}>
                      <div style={{fontWeight:700,fontSize:11,color:"#e879f9"}}>🔗 {dvs.dvs_name}</div>
                      <span style={tag("#e879f9")}>DVS</span>
                      <div style={{fontSize:9,color:p.textMute}}>Ports:{dvs.num_ports}</div>
                      {dvs.uplinks.length>0&&<div style={{fontSize:9,color:p.yellow,marginTop:2}}>↑ {dvs.uplinks.join(", ")}</div>}
                      {dvs.portgroups.map((pg,j)=>(
                        <div key={j} style={{marginTop:4,paddingLeft:6,borderLeft:`2px solid ${p.border}`}}>
                          <div style={{fontSize:10,color:p.text}}>🔀 {pg.name}</div>
                          <span style={tag(p.yellow)}>VLAN {pg.vlan}</span>
                        </div>
                      ))}
                    </div>
                  ))}
                </div>

                {/* Physical NICs */}
                <div style={{display:"flex",flexDirection:"column",gap:6}}>
                  <div style={{...card({background:`${p.orange}10`,border:`1px solid ${p.orange}30`,
                    textAlign:"center",borderRadius:"10px 10px 0 0",padding:"6px 8px"})}}>
                    <span style={{fontSize:10,fontWeight:800,color:p.orange}}>🔌 pNICs ({data.pnics.length})</span>
                  </div>
                  {data.pnics.length===0&&<div style={{...card({textAlign:"center",color:p.textMute,fontSize:10})}}>None</div>}
                  {data.pnics.map((n,i)=>(
                    <div key={i} style={card({borderLeft:`3px solid ${n.speed_mb>=10000?"#e879f9":n.speed_mb>=1000?p.green:p.yellow}`,padding:"6px 10px"})}>
                      <div style={{fontWeight:700,fontSize:11,color:p.text}}>{n.device}</div>
                      <div style={{fontSize:9,color:p.textMute,fontFamily:"monospace"}}>{n.mac}</div>
                      <div style={{display:"flex",gap:4,marginTop:3,flexWrap:"wrap"}}>
                        <span style={tag(n.speed_mb>=10000?"#e879f9":n.speed_mb>=1000?p.green:p.yellow)}>
                          {n.speed_mb>=1000?`${n.speed_mb/1000}Gbps`:n.speed_mb?`${n.speed_mb}Mbps`:"Link down"}
                        </span>
                        {n.driver&&<span style={{fontSize:9,color:p.textMute}}>{n.driver}</span>}
                      </div>
                      {n.neighbor&&n.neighbor.protocol&&(
                        <div style={{marginTop:6,padding:"5px 7px",background:`${p.accent}10`,
                          border:`1px solid ${p.accent}30`,borderRadius:6}}>
                          <div style={{fontSize:9,fontWeight:800,color:p.accent,letterSpacing:1,marginBottom:3}}>
                            🔗 {n.neighbor.protocol} NEIGHBOR
                          </div>
                          {n.neighbor.system_name&&<div style={{fontSize:10,color:p.text,fontWeight:600}}>{n.neighbor.system_name}</div>}
                          {n.neighbor.device_id&&<div style={{fontSize:9,color:p.textSub}}>Device ID: <span style={{fontFamily:"monospace"}}>{n.neighbor.device_id}</span></div>}
                          {n.neighbor.port_id&&<div style={{fontSize:9,color:p.textSub}}>Port: <span style={{fontFamily:"monospace"}}>{n.neighbor.port_id}</span></div>}
                          {n.neighbor.hw_platform&&<div style={{fontSize:9,color:p.textMute}}>Platform: {n.neighbor.hw_platform}</div>}
                          {n.neighbor.mgmt_addr&&<div style={{fontSize:9,color:p.cyan,fontFamily:"monospace"}}>Mgmt: {n.neighbor.mgmt_addr}</div>}
                        </div>
                      )}
                    </div>
                  ))}
                </div>

                {/* VMkernel NICs */}
                <div style={{display:"flex",flexDirection:"column",gap:6}}>
                  <div style={{...card({background:`${p.purple}10`,border:`1px solid ${p.purple}30`,
                    textAlign:"center",borderRadius:"10px 10px 0 0",padding:"6px 8px"})}}>
                    <span style={{fontSize:10,fontWeight:800,color:p.purple}}>🔷 VMkernel ({data.vmknics.length})</span>
                  </div>
                  {data.vmknics.length===0&&<div style={{...card({textAlign:"center",color:p.textMute,fontSize:10})}}>None</div>}
                  {data.vmknics.map((v,i)=>(
                    <div key={i} style={card({borderLeft:`3px solid ${p.purple}`,padding:"6px 10px"})}>
                      <div style={{fontWeight:700,fontSize:11,color:p.purple}}>{v.device}</div>
                      {v.ip&&<div style={{fontSize:10,color:p.green,fontFamily:"monospace"}}>{v.ip}</div>}
                      {v.mac&&<div style={{fontSize:9,color:p.textMute,fontFamily:"monospace"}}>{v.mac}</div>}
                      <div style={{display:"flex",gap:4,marginTop:3,flexWrap:"wrap"}}>
                        {v.portgroup&&<span style={tag(p.cyan)}>{v.portgroup}</span>}
                        {v.vlan!==undefined&&<span style={tag(p.yellow)}>VLAN {v.vlan}</span>}
                        <span style={{fontSize:9,color:p.textMute}}>MTU:{v.mtu}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}
        </div>

        {/* Footer */}
        <div style={{borderTop:`1px solid ${p.border}`,padding:"10px 20px",display:"flex",
          alignItems:"center",justifyContent:"space-between",flexShrink:0,background:p.panel}}>
          <div style={{fontSize:10,color:p.textMute}}>
            Live data from <span style={{color:p.cyan}}>{target.vcenter_name||target.vcenter_id}</span> · Click outside to close
          </div>
          <div style={{display:"flex",gap:8}}>
            {data&&<button onClick={exportTopologyPDF}
              style={{background:"linear-gradient(135deg,#7c3aed,#6d28d9)",color:"#fff",border:"none",
                borderRadius:7,padding:"5px 14px",cursor:"pointer",fontWeight:700,fontSize:12,
                boxShadow:"0 2px 12px rgba(109,40,217,.4)"}}>
              🖨️ Export PDF
            </button>}
            <button onClick={onClose} style={{background:`${p.accent}18`,border:`1px solid ${p.accent}35`,
              borderRadius:7,padding:"5px 16px",cursor:"pointer",color:p.accent,fontWeight:700,fontSize:12}}>Close</button>
          </div>
        </div>
      </div>
    </div>
  );
}

function VMActionModal({vm, action, vcenters, onClose, onDone, p}) {
  const [busy,    setBusy]    = useState(false);
  const [result,  setResult]  = useState(null); // {ok, msg}
  const [resources, setResources] = useState(null); // {hosts, datastores}

  // Snapshot fields
  const [snapName, setSnapName]   = useState(`snapshot-${new Date().toISOString().slice(0,10)}`);
  const [snapDesc, setSnapDesc]   = useState("");
  const [snapMem,  setSnapMem]    = useState(false);

  // Clone fields
  const [cloneName,   setCloneName]   = useState(`${vm.name}-clone`);
  const [cloneHost,   setCloneHost]   = useState("");
  const [cloneDS,     setCloneDS]     = useState("");
  const [cloneVC,     setCloneVC]     = useState(vm.vcenter_id);
  const [clonePowerOn,setClonePowerOn]= useState(false);
  const [cloneResources, setCloneResources] = useState(null);

  // Migrate fields
  const [migHost, setMigHost] = useState("");
  const [migDS,   setMigDS]   = useState("");
  const [migVC,   setMigVC]   = useState(vm.vcenter_id);
  const [migResources, setMigResources] = useState(null);

  // Load resources when VC changes for clone/migrate
  useEffect(() => {
    if (action === "clone" && cloneVC) {
      fetchVCResources(cloneVC).then(r => setCloneResources(r)).catch(()=>{});
    }
  }, [cloneVC, action]);

  useEffect(() => {
    if (action === "migrate" && migVC) {
      fetchVCResources(migVC).then(r => setMigResources(r)).catch(()=>{});
    }
  }, [migVC, action]);

  async function submit() {
    setBusy(true); setResult(null);
    try {
      let res;
      if (action === "snapshot") {
        if (!snapName.trim()) { setResult({ok:false,msg:"Snapshot name required"}); setBusy(false); return; }
        res = await createSnapshot(vm.vcenter_id, vm.name, snapName.trim(), snapDesc, snapMem);
      } else if (action === "clone") {
        if (!cloneName.trim()) { setResult({ok:false,msg:"Clone name required"}); setBusy(false); return; }
        res = await cloneVM(vm.vcenter_id, vm.name, cloneName.trim(),
                            cloneHost||null, cloneDS||null,
                            cloneVC !== vm.vcenter_id ? cloneVC : null,
                            clonePowerOn);
      } else if (action === "migrate") {
        const crossVC = migVC !== vm.vcenter_id;
        if (crossVC && !migHost) { setResult({ok:false,msg:"Cross-vCenter migration requires a destination host"}); setBusy(false); return; }
        if (!crossVC && !migHost && !migDS) { setResult({ok:false,msg:"Select a destination host and/or datastore"}); setBusy(false); return; }
        res = await migrateVM(vm.vcenter_id, vm.name,
                              migHost||null, migDS||null,
                              crossVC ? migVC : null);
      }
      setResult({ok:true, msg: res.message});
      setTimeout(() => { onDone(); onClose(); }, 2000);
    } catch(e) {
      setResult({ok:false, msg: e.message});
    }
    setBusy(false);
  }

  const titles = { snapshot:"📸 Create Snapshot", clone:"📋 Clone VM", migrate:"🚀 Migrate VM" };
  const colors = { snapshot: p.cyan, clone: p.purple, migrate: p.orange };
  const c = colors[action] || p.accent;

  return (
    <div className="overlay" onClick={onClose}>
      <div className="modal" style={{width:480}} onClick={e=>e.stopPropagation()}>
        {/* Header */}
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:20}}>
          <div>
            <div style={{fontWeight:700,fontSize:16,color:c}}>{titles[action]}</div>
            <div style={{fontSize:12,color:p.textMute,marginTop:2}}>
              VM: <span style={{color:p.accent,fontWeight:600}}>{vm.name}</span>
              {" · "}<span style={{color:p.textMute}}>{vm.vcenter_name}</span>
            </div>
          </div>
          <button className="btn btn-ghost btn-sm" onClick={onClose}>✕</button>
        </div>

        {/* ── SNAPSHOT FORM ── */}
        {action === "snapshot" && (
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <div>
              <label>Snapshot Name *</label>
              <input value={snapName} onChange={e=>setSnapName(e.target.value)}
                placeholder="e.g. pre-patching-2025-03-07"/>
            </div>
            <div>
              <label>Description</label>
              <input value={snapDesc} onChange={e=>setSnapDesc(e.target.value)}
                placeholder="Optional description…"/>
            </div>
            <div style={{display:"flex",alignItems:"center",gap:10,padding:"10px 12px",
              background:p.panelAlt,borderRadius:8,border:`1px solid ${p.border}`}}>
              <input type="checkbox" id="snapMem" checked={snapMem}
                onChange={e=>setSnapMem(e.target.checked)}
                style={{width:16,height:16,accentColor:p.cyan,cursor:"pointer"}}/>
              <label htmlFor="snapMem" style={{margin:0,cursor:"pointer",fontSize:13,fontWeight:500}}>
                Include VM memory state
              </label>
            </div>
            <div style={{fontSize:11,color:p.textMute,padding:"8px 12px",
              background:`${p.yellow}10`,borderRadius:7,border:`1px solid ${p.yellow}30`}}>
              ⚠️ VM will remain running. Snapshot may briefly pause disk I/O.
            </div>
          </div>
        )}

        {/* ── CLONE FORM ── */}
        {action === "clone" && (
          <div style={{display:"flex",flexDirection:"column",gap:14}}>
            <div>
              <label>Clone Name *</label>
              <input value={cloneName} onChange={e=>setCloneName(e.target.value)}
                placeholder="e.g. my-vm-clone"/>
            </div>
            <div>
              <label>Destination vCenter</label>
              <select value={cloneVC} onChange={e=>setCloneVC(e.target.value)}>
                {vcenters.map(v=>(
                  <option key={v.id} value={v.id}>{v.name} ({v.host})</option>
                ))}
              </select>
            </div>
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
              <div>
                <label>Destination Host</label>
                <select value={cloneHost} onChange={e=>setCloneHost(e.target.value)}>
                  <option value="">— Same as source —</option>
                  {(cloneResources?.hosts||[]).map(h=>(
                    <option key={h.name} value={h.name}>{h.name}</option>
                  ))}
                </select>
              </div>
              <div>
                <label>Destination Datastore</label>
                <select value={cloneDS} onChange={e=>setCloneDS(e.target.value)}>
                  <option value="">— Same as source —</option>
                  {(cloneResources?.datastores||[]).map(d=>(
                    <option key={d.name} value={d.name}>{d.name} ({fmtGB(d.free_gb)} free)</option>
                  ))}
                </select>
              </div>
            </div>
            <div style={{display:"flex",alignItems:"center",gap:10,padding:"10px 12px",
              background:p.panelAlt,borderRadius:8,border:`1px solid ${p.border}`}}>
              <input type="checkbox" id="clonePow" checked={clonePowerOn}
                onChange={e=>setClonePowerOn(e.target.checked)}
                style={{width:16,height:16,accentColor:p.purple,cursor:"pointer"}}/>
              <label htmlFor="clonePow" style={{margin:0,cursor:"pointer",fontSize:13,fontWeight:500}}>
                Power on clone after creation
              </label>
            </div>
            <div style={{fontSize:11,color:p.textMute,padding:"8px 12px",
              background:`${p.purple}10`,borderRadius:7,border:`1px solid ${p.purple}30`}}>
              ⏱️ Clone may take several minutes depending on VM size.
            </div>
          </div>
        )}

        {/* ── MIGRATE FORM ── */}
        {action === "migrate" && (
          <div style={{display:"flex",flexDirection:"column",gap:12}}>
            {/* Current location */}
            <div style={{padding:"10px 12px",background:p.panelAlt,borderRadius:7,
              border:`1px solid ${p.border}`,fontSize:12}}>
              <div style={{fontWeight:600,color:p.textSub,marginBottom:4,fontSize:11,textTransform:"uppercase",letterSpacing:".5px"}}>Current Location</div>
              <div style={{display:"flex",gap:16}}>
                <span style={{color:p.textMute}}>Host: <b style={{color:p.text}}>{vm.host||"Unknown"}</b></span>
                <span style={{color:p.textMute}}>vCenter: <b style={{color:p.accent}}>{vm.vcenter_name||vm.vcenter_id}</b></span>
              </div>
            </div>
            {/* Migration type guide */}
            <div style={{padding:"8px 12px",background:`${p.orange}10`,borderRadius:7,
              border:`1px solid ${p.orange}30`,fontSize:11,color:p.textMute}}>
              <b style={{color:p.orange}}>🚀 Migration types:</b> Pick a new <b>host</b> = vMotion (live, zero downtime) · Pick a new <b>datastore</b> = Storage vMotion · Pick both = Full relocate
            </div>
            {/* Destination vCenter */}
            <div>
              <label>Destination vCenter</label>
              <select value={migVC} onChange={e=>{setMigVC(e.target.value);setMigHost("");setMigDS("");}}>
                {vcenters.map(v=>(
                  <option key={v.id} value={v.id}>{v.name} ({v.id}){v.id===vm.vcenter_id?" — current":""}</option>
                ))}
              </select>
              {migVC!==vm.vcenter_id&&(
                <div style={{fontSize:10,color:p.yellow,marginTop:3}}>⚠️ Cross-vCenter: requires vSphere 6.0+ and both vCenters reachable</div>
              )}
            </div>
            {/* Host + Datastore */}
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
              <div>
                <label>Destination Host {migVC!==vm.vcenter_id&&<span style={{color:p.red,fontSize:10}}>*required</span>}</label>
                {migResources===null
                  ?<div style={{padding:"8px 10px",fontSize:11,color:p.yellow,background:p.panelAlt,borderRadius:7,border:`1px solid ${p.border}`}}>⏳ Loading hosts…</div>
                  :<select value={migHost} onChange={e=>setMigHost(e.target.value)}>
                    <option value="">— Keep current host —</option>
                    {(migResources?.hosts||[]).map(h=>(
                      <option key={h.name} value={h.name}>
                        {h.name}{h.name===vm.host?" (current)":""} · {Math.round(100-(h.cpu_free_pct||100))}% CPU used · {h.ram_free_gb||0}GB RAM free
                      </option>
                    ))}
                  </select>
                }
              </div>
              <div>
                <label>Destination Datastore</label>
                {migResources===null
                  ?<div style={{padding:"8px 10px",fontSize:11,color:p.yellow,background:p.panelAlt,borderRadius:7,border:`1px solid ${p.border}`}}>⏳ Loading datastores…</div>
                  :<select value={migDS} onChange={e=>setMigDS(e.target.value)}>
                    <option value="">— Keep current datastore —</option>
                    {(migResources?.datastores||[]).map(d=>(
                      <option key={d.name} value={d.name}>{d.name} ({fmtGB(d.free_gb)} free)</option>
                    ))}
                  </select>
                }
              </div>
            </div>
            {/* Validation hint */}
            {!migHost&&!migDS&&migVC===vm.vcenter_id&&(
              <div style={{fontSize:11,color:p.textMute,padding:"6px 10px",background:p.panelAlt,
                borderRadius:6,border:`1px solid ${p.border}`}}>
                💡 Select a destination host and/or datastore to migrate to
              </div>
            )}
          </div>
        )}

        {/* Result message */}
        {result && (
          <div style={{marginTop:16,padding:"10px 14px",borderRadius:8,
            background:result.ok?`${p.green}15`:`${p.red}15`,
            border:`1px solid ${result.ok?p.green:p.red}40`,
            color:result.ok?p.green:p.red,fontSize:13,fontWeight:500}}>
            {result.ok ? "✅" : "❌"} {result.msg}
          </div>
        )}

        {/* Footer buttons */}
        <div style={{display:"flex",gap:8,justifyContent:"flex-end",marginTop:20,paddingTop:16,
          borderTop:`1px solid ${p.border}`}}>
          <button className="btn btn-ghost" onClick={onClose} disabled={busy}>Cancel</button>
          <button className="btn" disabled={busy}
            style={{background:`${c}18`,border:`1px solid ${c}55`,color:c}}
            onClick={submit}>
            {busy
              ? <><span className="spin" style={{width:14,height:14,borderWidth:2}}/>  Working…</>
              : titles[action]
            }
          </button>
        </div>
      </div>
    </div>
  );
}


// ─── USER PROFILE ─────────────────────────────────────────────────────────────
function UserProfile({user, dark, theme="dark", currentUser, onLogout, onToggleTheme, onSetTheme, p}) {
  const [open, setOpen]     = useState(false);
  const [modal, setModal]   = useState(false); // settings modal
  const [tab, setTab]       = useState("profile");
  const [saved, setSaved]   = useState(false);

  // Settings state
  const [cpuThr,  setCpuThr]  = useState(parseInt(localStorage.getItem("thr_cpu")||"85"));
  const [ramThr,  setRamThr]  = useState(parseInt(localStorage.getItem("thr_ram")||"85"));
  const [diskThr, setDiskThr] = useState(parseInt(localStorage.getItem("thr_disk")||"80"));

  const roles = { admin: "Administrator", viewer: "Read-Only Viewer" };
  const role  = localStorage.getItem("user_role") || "admin";

  function saveSettings() {
    localStorage.setItem("thr_cpu",  cpuThr);
    localStorage.setItem("thr_ram",  ramThr);
    localStorage.setItem("thr_disk", diskThr);
    setSaved(true);
    setTimeout(()=>setSaved(false), 2000);
  }

  const initials = (user||"AD").slice(0,2).toUpperCase();

  return(
    <div style={{position:"relative"}}>
      {/* Avatar button */}
      <div onClick={()=>setOpen(o=>!o)}
        style={{display:"flex",alignItems:"center",gap:8,padding:"4px 8px",borderRadius:8,
          cursor:"pointer",border:`1px solid ${open?p.accent:p.border}`,background:open?`${p.accent}12`:p.panelAlt,
          transition:"all .15s"}}
        onMouseEnter={e=>e.currentTarget.style.borderColor=p.accent}
        onMouseLeave={e=>!open&&(e.currentTarget.style.borderColor=p.border)}>
        <div style={{width:30,height:30,borderRadius:"50%",
          background:`linear-gradient(135deg,${p.accent},${p.cyan})`,
          display:"flex",alignItems:"center",justifyContent:"center",
          fontSize:12,fontWeight:700,color:"#fff",flexShrink:0}}>
          {initials}
        </div>
        <div style={{lineHeight:1.2}}>
          <div style={{fontSize:12,fontWeight:700,color:p.text}}>{user||"admin"}</div>
          <div style={{fontSize:10,color:p.textMute}}>{roles[role]||"Administrator"}</div>
        </div>
        <span style={{fontSize:10,color:p.textMute,marginLeft:2}}>{open?"▲":"▼"}</span>
      </div>

      {/* Dropdown */}
      {open&&(
        <div style={{position:"absolute",right:0,top:"calc(100% + 6px)",width:220,
          background:p.panel,border:`1px solid ${p.border}`,borderRadius:10,
          boxShadow:"0 8px 32px rgba(0,0,0,.35)",zIndex:999,overflow:"hidden",animation:"fadeUp .15s ease"}}>

          {/* Header */}
          <div style={{padding:"12px 14px",borderBottom:`1px solid ${p.border}`,background:p.panelAlt}}>
            <div style={{display:"flex",alignItems:"center",gap:10}}>
              <div style={{width:38,height:38,borderRadius:"50%",
                background:`linear-gradient(135deg,${p.accent},${p.cyan})`,
                display:"flex",alignItems:"center",justifyContent:"center",
                fontSize:15,fontWeight:700,color:"#fff"}}>
                {initials}
              </div>
              <div>
                <div style={{fontWeight:700,fontSize:13}}>{user||"admin"}</div>
                <div style={{fontSize:10,color:p.textMute}}>{roles[role]||"Administrator"}</div>
                <div style={{fontSize:10,color:p.green,marginTop:2}}>● Online</div>
              </div>
            </div>
          </div>

          {/* Menu items */}
          {[
            {icon:"⚙️", label:"Settings",  action:()=>{setModal(true);setOpen(false);}},
            {icon:"🎨", label:"Switch Theme", action:()=>{setModal(true);setTab("profile");setOpen(false);}},  
          ].map(item=>(
            <div key={item.label} onClick={item.action}
              style={{display:"flex",alignItems:"center",gap:10,padding:"10px 14px",cursor:"pointer",
                fontSize:13,fontWeight:500,transition:"background .12s"}}
              onMouseEnter={e=>e.currentTarget.style.background=p.panelAlt}
              onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
              <span style={{fontSize:16}}>{item.icon}</span>{item.label}
            </div>
          ))}

          <div style={{height:1,background:p.border,margin:"4px 0"}}/>

          {/* Logout */}
          <div onClick={()=>{onLogout();setOpen(false);}}
            style={{display:"flex",alignItems:"center",gap:10,padding:"10px 14px",cursor:"pointer",
              fontSize:13,fontWeight:500,color:p.red,transition:"background .12s"}}
            onMouseEnter={e=>e.currentTarget.style.background=`${p.red}12`}
            onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
            <span style={{fontSize:16}}>🚪</span>Logout
          </div>
        </div>
      )}

      {/* Settings Modal */}
      {modal&&(
        <div className="overlay" onClick={()=>setModal(false)}>
          <div className="modal" onClick={e=>e.stopPropagation()} style={{width:500}}>
            <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:20}}>
              <div style={{fontWeight:700,fontSize:16}}>⚙️ Settings</div>
              <button className="btn btn-ghost btn-sm" onClick={()=>setModal(false)}>✕</button>
            </div>

            {/* Tabs */}
            <div style={{display:"flex",gap:4,marginBottom:20,borderBottom:`1px solid ${p.border}`,paddingBottom:8}}>
              <button className="btn btn-sm btn-primary">👤 Profile</button>
            </div>

            {tab==="profile"&&(
              <div style={{display:"flex",flexDirection:"column",gap:16}}>
                <div style={{display:"flex",alignItems:"center",gap:14,padding:16,
                  background:p.panelAlt,borderRadius:10,border:`1px solid ${p.border}`}}>
                  <div style={{width:56,height:56,borderRadius:"50%",
                    background:`linear-gradient(135deg,${p.accent},${p.cyan})`,
                    display:"flex",alignItems:"center",justifyContent:"center",
                    fontSize:22,fontWeight:700,color:"#fff"}}>
                    {initials}
                  </div>
                  <div>
                    <div style={{fontWeight:700,fontSize:15}}>{user||"admin"}</div>
                    <div style={{fontSize:12,color:p.textMute,marginTop:2}}>{roles[role]||"Administrator"}</div>
                  </div>
                </div>

                <div>
                  <label>Role</label>
                  <div style={{padding:"8px 12px",background:p.panelAlt,borderRadius:7,
                    border:`1px solid ${p.border}`,fontSize:13,fontWeight:500}}>
                    {roles[role]||"Administrator"}
                  </div>
                  <div style={{fontSize:11,color:p.textMute,marginTop:4}}>
                    {role==="admin"
                      ? "✅ Full access — manage VMs, users, vCenters, pricing and all settings"
                      : role==="operator"
                      ? "🛠️ Operator — perform VM/host actions, manage snapshots and thresholds. No user or pricing management."
                      : role==="requester"
                      ? "📋 Requester — submit and track VM provisioning requests."
                      : "👁️ Viewer — read-only access to all dashboards. No actions permitted."}
                  </div>
                </div>

                <div>
                  <label>Theme</label>
                  <div style={{display:"flex",gap:8}}>
                    {[["dark","🌙 Dark"],["light","☀️ Light"],["wings","🟣 Wings"]].map(([id,label])=>(
                      <button key={id} onClick={()=>onSetTheme(id)}
                        className={`btn ${theme===id?"btn-primary":"btn-ghost"}`}
                        style={{flex:1}}>{label}</button>
                    ))}
                  </div>
                  {theme==="wings"&&<div style={{fontSize:11,color:p.textMute,marginTop:6}}>🟣 Wipro Wings — purple enterprise theme</div>}
                </div>
              </div>
            )}




          </div>
        </div>
      )}
    </div>
  );
}


// ─── NOTIFICATION EDITOR ─────────────────────────────────────────────────────
function NotifEditor({notifs,onSave,onClose,p}){
  const [items,setItems]=useState(notifs.map(n=>({...n})));
  const [newText,setNewText]=useState("");
  const [newPrio,setNewPrio]=useState("info");

  function addNotif(){
    if(!newText.trim()) return;
    setItems(prev=>[...prev,{id:Date.now(),text:newText.trim(),priority:newPrio,ts:new Date().toISOString()}]);
    setNewText("");
  }
  function removeNotif(id){ setItems(prev=>prev.filter(n=>n.id!==id)); }

  const colors={info:p.cyan,warning:p.yellow,critical:p.red,success:p.green};

  return(
    <div style={{flexShrink:0,background:p.panelAlt,borderBottom:`1px solid ${p.border}`,
      padding:"10px 14px",animation:"fadeUp .15s ease"}}>
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:10}}>
        <span style={{fontWeight:700,fontSize:12,color:p.cyan}}>📢 Manage Notifications</span>
        <span style={{fontSize:11,color:p.textMute}}>Shown to all users in the ticker</span>
        <div style={{flex:1}}/>
        <button className="btn btn-success btn-sm" onClick={()=>onSave(items)}>✓ Save & Publish</button>
        <button className="btn btn-ghost btn-sm" onClick={onClose}>✕</button>
      </div>

      {/* Add new */}
      <div style={{display:"flex",gap:8,marginBottom:8,alignItems:"flex-end"}}>
        <div style={{flex:1}}>
          <label>New Announcement</label>
          <input value={newText} onChange={e=>setNewText(e.target.value)}
            onKeyDown={e=>e.key==="Enter"&&addNotif()}
            placeholder="e.g. Maintenance window tonight 22:00–02:00 on Prod vCenter"/>
        </div>
        <div style={{width:130}}>
          <label>Type</label>
          <select value={newPrio} onChange={e=>setNewPrio(e.target.value)}>
            <option value="info">ℹ️ Info</option>
            <option value="warning">⚠️ Warning</option>
            <option value="critical">🔴 Critical</option>
            <option value="success">✅ Success</option>
          </select>
        </div>
        <button className="btn btn-primary btn-sm" style={{marginBottom:1}} onClick={addNotif}
          disabled={!newText.trim()}>+ Add</button>
      </div>

      {/* List */}
      {items.length===0
        ?<div style={{fontSize:12,color:p.textMute,padding:"6px 0"}}>No active notifications. Add one above.</div>
        :<div style={{display:"flex",flexDirection:"column",gap:4,maxHeight:140,overflowY:"auto"}}>
          {items.map(n=>{
            const c=colors[n.priority]||p.cyan;
            return(
              <div key={n.id} style={{display:"flex",alignItems:"center",gap:8,padding:"6px 10px",
                borderRadius:6,background:`${c}10`,border:`1px solid ${c}25`}}>
                <span style={{fontSize:9,fontWeight:700,padding:"2px 6px",borderRadius:3,
                  background:`${c}20`,color:c,border:`1px solid ${c}30`,flexShrink:0,textTransform:"uppercase"}}>
                  {n.priority}
                </span>
                <span style={{flex:1,fontSize:12,color:p.text}}>{n.text}</span>
                <span style={{fontSize:10,color:p.textMute,flexShrink:0}}>{n.ts?.slice(0,16)}</span>
                <button onClick={()=>removeNotif(n.id)}
                  style={{background:"transparent",border:"none",cursor:"pointer",fontSize:14,color:p.textMute,padding:"0 4px"}}>✕</button>
              </div>
            );
          })}
        </div>
      }
    </div>
  );
}


// OpenShift page - code-split for performance
const OpenShiftPage = lazy(() => import('./OpenShiftPage'));
// Nutanix page - code-split for performance
const NutanixPage = lazy(() => import('./NutanixPage'));
// Ansible Automation Platform page - code-split for performance
const AnsiblePage = lazy(() => import('./AnsiblePage'));

// ─── STORAGE PAGE ──────────────────────────────────────────
const _STOR_VENDORS = [
  {id:"NetApp",       label:"NetApp",       icon:"🔷", color:"#8b5cf6"},
  {id:"Dell-EMC",     label:"Dell EMC",     icon:"🔵", color:"#3b82f6"},
  {id:"HPE",          label:"HPE",          icon:"🟢", color:"#10b981"},
  {id:"Pure Storage", label:"Pure Storage", icon:"🟠", color:"#f97316"},
  {id:"IBM",          label:"IBM",          icon:"🔴", color:"#ef4444"},
  {id:"Hitachi",      label:"Hitachi",      icon:"🟡", color:"#f59e0b"},
];
function _storFmt(bytes){
  if(!bytes||isNaN(bytes))return"—";
  if(bytes>=1e15)return(bytes/1e15).toFixed(2)+" PB";
  if(bytes>=1e12)return(bytes/1e12).toFixed(2)+" TB";
  if(bytes>=1e9) return(bytes/1e9).toFixed(1)+" GB";
  return(bytes/1e6).toFixed(0)+" MB";
}

function _storFmtBytes(b){if(!b)return"0 B";const u=["B","KB","MB","GB","TB","PB"];let i=0,v=b;while(v>=1024&&i<u.length-1){v/=1024;i++;}return v.toFixed(i<2?0:1)+" "+u[i];}

function StorageArrayCard({arr,p,onRemove,currentUser}){
  const [open,setOpen]         = useState(false);
  const [liveData,setLive]     = useState(null);
  const [loading,setLoading]   = useState(false);
  const [liveErr,setLiveErr]   = useState("");
  const [tab,setTab]           = useState("overview");
  const [adminOp,setAdminOp]   = useState(null);   // "vol"|"lun"|"igroup"|null
  const [adminForm,setAdminF]  = useState({});
  const [adminBusy,setABusy]   = useState(false);
  const [adminMsg,setAMsg]     = useState({t:"",m:""});
  const [snapVol,setSnapVol]   = useState(null);    // {uuid,name}
  const [snapList,setSnapList] = useState([]);
  const [snapBusy,setSnapBusy] = useState(false);
  const [newSnap,setNewSnap]   = useState("");
  const [svms,setSvms]         = useState([]);
  const [aggs,setAggs]         = useState([]);
  const [selSvm,setSelSvm]     = useState(null);
  const [topoVol,setTopoVol]   = useState(null);  // volume topology panel

  const vd = _STOR_VENDORS.find(v=>v.id===arr.vendor)||{icon:"🗂️",color:"#3b82f6",label:arr.vendor};
  const isNetApp = arr.vendor==="NetApp";
  const isAdmin  = currentUser?.role==="admin";
  const canAct   = isAdmin || currentUser?.role==="operator";

  async function expand(){
    const next=!open; setOpen(next);
    if(next&&!liveData&&!loading){
      setLoading(true); setLiveErr("");
      try{const d=await fetchStorageArrayData(arr.id); setLive(d);}
      catch(e){setLiveErr(e.message||"Failed to fetch live data");}
      finally{setLoading(false);}
    }
  }
  async function refresh(){
    setLive(null); setLoading(true); setLiveErr(""); setTab("overview");
    setAdminOp(null); setAMsg({t:"",m:""}); setSnapVol(null);
    try{const d=await fetchStorageArrayData(arr.id); setLive(d);}
    catch(e){setLiveErr(e.message);}
    finally{setLoading(false);}
  }
  async function loadMeta(){
    if(svms.length||aggs.length) return;
    try{
      const [sv,ag]=await Promise.all([fetchNetAppSvms(arr.id), fetchNetAppAggregates(arr.id)]);
      setSvms(sv); setAggs(ag);
    }catch(_){}
  }
  function openAdmin(op){ setAMsg({t:"",m:""}); setAdminF({}); setAdminOp(op); if(isNetApp) loadMeta(); }
  async function doAdmin(op,payload){
    setABusy(true); setAMsg({t:"",m:""});
    try{
      if(op==="create_vol")    await createNetAppVolume(arr.id, payload);
      else if(op==="del_vol")  await deleteNetAppVolume(arr.id, payload.uuid);
      else if(op==="create_lun")   await createNetAppLun(arr.id, payload);
      else if(op==="del_lun")      await deleteNetAppLun(arr.id, payload.uuid);
      else if(op==="create_ig")    await createNetAppIgroup(arr.id, {...payload, initiators:(payload.initiators||"").split("\n").map(s=>s.trim()).filter(Boolean)});
      else if(op==="del_ig")       await deleteNetAppIgroup(arr.id, payload.uuid);
      setAMsg({t:"ok",m:"Done — refreshing…"}); setAdminOp(null); setAdminF({});
      setTimeout(refresh,600);
    }catch(e){ setAMsg({t:"err",m:e.message}); }
    finally{ setABusy(false); }
  }
  async function loadSnaps(vol){
    setSnapVol(vol); setSnapBusy(true); setSnapList([]); setNewSnap("");
    try{const sl=await fetchNetAppSnapshots(arr.id,vol.uuid); setSnapList(sl);}
    catch(_){}
    finally{setSnapBusy(false);}
  }
  async function doSnap(op,payload){
    setSnapBusy(true);
    try{
      if(op==="create") await createNetAppSnapshot(arr.id, payload.vuuid, {name:payload.name});
      else if(op==="delete") await deleteNetAppSnapshot(arr.id, payload.vuuid, payload.uuid);
      if(snapVol) await loadSnaps(snapVol);
      setNewSnap("");
    }catch(e){alert(e.message);}
    finally{setSnapBusy(false);}
  }

  const cap     = liveData?.capacity;
  const sys     = liveData?.system;
  const perf    = liveData?.perf||{};
  const volList = liveData?.volume_list||[];
  const lunList = liveData?.lun_list||[];
  const diskList= liveData?.disk_list||[];
  const igList  = liveData?.igroup_list||[];
  const aggList = liveData?.agg_list||[];
  const nicList = liveData?.nic_list||[];
  const smList  = liveData?.snapmirror_list||[];
  const emsList = liveData?.ems_events||[];
  const svmList = liveData?.svm_list||[];
  const svmDetails = liveData?.svm_details||[];
  const nfsExports = liveData?.nfs_export_list||[];
  const cifsList   = liveData?.cifs_share_list||[];
  const used_pct= cap?.used_pct||0;
  const bc      = used_pct>80?"#ef4444":used_pct>60?"#f59e0b":"#10b981";
  const siteLabel=arr.site==="dr"?"DR Site":arr.site==="other"?"Other":"Primary DC";

  const tabs=[
    {id:"overview",  label:"Overview"},
    {id:"volumes",   label:`Volumes${liveData?` (${liveData.volumes??volList.length})`:""}`},
    ...(isNetApp&&liveData?[{id:"luns",label:`LUNs (${liveData.luns??lunList.length})`}]:[]),
    ...(isNetApp&&aggList.length?[{id:"tiers",label:`Local Tiers (${aggList.length})`}]:[]),
    {id:"drives",    label:`Drives${liveData?` (${liveData.disks??diskList.length})`:""}`},
    {id:"hosts",     label:`Hosts${isNetApp&&liveData?` (${liveData.igroups??igList.length})`:liveData&&liveData.hosts!=null?` (${liveData.hosts})`:""}`},
    ...(isNetApp&&nicList.length?[{id:"network",label:`Network (${nicList.length})`}]:[]),
    ...(isNetApp&&(smList.length||liveData?.snapmirror)?[{id:"protection",label:`Protection${smList.length?` (${smList.length})`:""}`}]:[]),
    ...(isNetApp&&emsList.length?[{id:"events",label:`Events (${emsList.length})`}]:[]),
    ...(isNetApp&&liveData?[{id:"shares",label:`Shares (NFS: ${nfsExports.length} | CIFS: ${cifsList.length})`}]:[]),
    ...(isNetApp&&(svmDetails.length||svmList.length)?[{id:"svms",label:`Storage VMs (${(svmDetails.length||svmList.length)})`}]:[]),
    ...(liveData&&sys?.node_details?.length>1?[{id:"nodes",label:`Nodes (${sys.node_details.length})`}]:[]),
  ];

  const TH=({c,r})=><th style={{padding:"5px 8px",textAlign:r?"right":"left",fontSize:9,textTransform:"uppercase",letterSpacing:".4px",color:p.textMute,fontWeight:600,borderBottom:`1px solid ${p.border}`,whiteSpace:"nowrap"}}>{c}</th>;
  const TD=({c,r,mono,bold,color,wrap})=><td style={{padding:"5px 8px",fontSize:11,textAlign:r?"right":"left",fontFamily:mono?"monospace":undefined,fontWeight:bold?700:400,color:color||p.text,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`,wordBreak:wrap?"break-all":undefined}}>{c}</td>;
  function stateChip(s){const c=s==="online"||s==="present"||s==="healthy"||s==="connected"?"#10b981":s==="offline"||s==="error"||s==="broken"?"#ef4444":"#f59e0b";return<span style={{padding:"1px 6px",borderRadius:8,fontSize:9,fontWeight:700,background:c+"18",border:`1px solid ${c}35`,color:c}}>{s||"—"}</span>;}
  function FAF({label,value,onChange,type="text",opts}){
    return<div style={{flex:1,minWidth:120}}>
      <div style={{fontSize:9,color:p.textMute,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",marginBottom:3}}>{label}</div>
      {opts?<select value={value||""} onChange={e=>onChange(e.target.value)} style={{width:"100%",padding:"6px 9px",borderRadius:7,border:`1px solid ${p.border}`,background:p.panelAlt,color:p.text,fontSize:11,outline:"none"}}>
        <option value="">-- select --</option>
        {opts.map(o=><option key={o.v||o} value={o.v||o}>{o.l||o}</option>)}
      </select>:type==="textarea"?
      <textarea value={value||""} onChange={e=>onChange(e.target.value)} rows={3} style={{width:"100%",padding:"6px 9px",borderRadius:7,border:`1px solid ${p.border}`,background:p.panelAlt,color:p.text,fontSize:11,outline:"none",resize:"vertical",boxSizing:"border-box"}} placeholder="One per line"/>:
      <input type={type} value={value||""} onChange={e=>onChange(e.target.value)} style={{width:"100%",padding:"6px 9px",borderRadius:7,border:`1px solid ${p.border}`,background:p.panelAlt,color:p.text,fontSize:11,outline:"none",boxSizing:"border-box"}}/>}
    </div>;
  }
  function AdminBar({opId,label}){
    return canAct&&isNetApp?<button title={`Create a new ${label.replace('Create ','')}`} onClick={()=>openAdmin(opId)} style={{padding:"4px 12px",borderRadius:7,border:"1px solid #3b82f630",background:"#3b82f610",color:"#3b82f6",fontSize:10,fontWeight:700,cursor:"pointer"}}>＋ {label}</button>:null;
  }

  // ── Volume Topology Panel ─────────────────────────────────────────────────────
  function VolumeTopoPanel({v}){
    const outgoing = smList.filter(r=>r.source_vol===v.name&&r.source_svm===v.svm);
    const incoming = smList.filter(r=>r.dest_vol===v.name&&r.dest_svm===v.svm);
    const volLuns  = lunList.filter(l=>l.volume===v.name&&l.svm===v.svm);
    const hasRel   = outgoing.length>0||incoming.length>0;
    function VolCard({vol,label,hl,isThis}){
      const ex=volList.find(vl=>vl.name===vol.name&&vl.svm===vol.svm);
      const vc2=ex?.used_pct>80?"#ef4444":ex?.used_pct>60?"#f59e0b":"#10b981";
      return(
        <div style={{flex:"0 0 200px",padding:"11px 13px",borderRadius:9,border:`2px solid ${hl||p.border}`,background:isThis?p.panelAlt:p.panel,boxShadow:isThis?`0 0 8px ${hl}30`:"none"}}>
          <div style={{fontSize:8,color:hl||p.textMute,textTransform:"uppercase",letterSpacing:".6px",fontWeight:700,marginBottom:5}}>{label}</div>
          <div style={{fontWeight:800,fontSize:12,color:p.text,fontFamily:"monospace",marginBottom:7,wordBreak:"break-all"}}>📦 {vol.name}</div>
          {[{l:"SVM",v:vol.svm||"—"},{l:"Type",v:ex?.type||"—"},{l:"State",v:ex?.state},{l:"Path",v:ex?.junction_path||"—"},{l:"Size",v:ex?.total_bytes?_storFmtBytes(ex.total_bytes):"—"},{l:"Used",v:ex?.total_bytes?(ex.used_pct+"%"):"—"},{l:"Snap Policy",v:ex?.snapshot_policy||"—"}].map(({l,v:val})=>(
            <div key={l} style={{display:"flex",justifyContent:"space-between",fontSize:9,marginBottom:2}}>
              <span style={{color:p.textMute,minWidth:60}}>{l}</span>
              {l==="State"?<span>{val?stateChip(val):"—"}</span>:
                <span style={{color:l==="Used"?vc2:p.text,fontWeight:l==="Used"?700:500,fontFamily:l==="Path"||l==="SVM"?"monospace":undefined,textAlign:"right",maxWidth:110,wordBreak:"break-all"}}>{val}</span>}
            </div>
          ))}
        </div>
      );
    }
    function SmArrow({r,dir}){
      const sc=r.state==="snapmirrored"?"#10b981":r.state==="uninitialized"?"#f59e0b":"#3b82f6";
      const hc=r.healthy===true?"#10b981":r.healthy===false?"#ef4444":"#f59e0b";
      return(
        <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:"0 10px",flexShrink:0}}>
          <div style={{fontSize:9,color:p.textMute,marginBottom:5,fontWeight:600}}>{dir==="out"?"replicates to ▶▶":"◄◄ replicated from"}</div>
          <div style={{padding:"8px 11px",borderRadius:8,border:`1px solid ${sc}40`,background:`${sc}08`,textAlign:"center",minWidth:115}}>
            <div style={{fontSize:8,fontWeight:800,color:sc,textTransform:"uppercase",letterSpacing:".5px",marginBottom:4}}>SnapMirror</div>
            <div style={{fontSize:10,fontWeight:700,color:p.text,marginBottom:3}}>{r.policy||"—"}</div>
            <div style={{fontSize:9,color:p.textMute,marginBottom:2}}>State <span style={{color:sc,fontWeight:700}}>{r.state||"—"}</span></div>
            <div style={{fontSize:9,color:p.textMute,marginBottom:2}}>Lag <span style={{color:p.text}}>{r.lag_time||"—"}</span></div>
            <div style={{fontSize:9,fontWeight:700,color:hc}}>{r.healthy===true?"✓ Healthy":r.healthy===false?"✗ Unhealthy":"? Unknown"}</div>
          </div>
          <div style={{fontSize:18,color:sc,marginTop:4,lineHeight:1}}>{dir==="out"?"→":"←"}</div>
        </div>
      );
    }
    return(
      <div style={{padding:"12px 14px",background:p.panelAlt+"cc"}}>
        <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:14,flexWrap:"wrap"}}>
          <span style={{fontWeight:800,fontSize:12,color:p.text}}>📡 Data Flow Topology</span>
          <span style={{fontFamily:"monospace",fontWeight:700,color:"#8b5cf6",fontSize:12}}>{v.name}</span>
          <span style={{fontSize:10,color:p.textMute}}>SVM: <strong style={{color:p.text}}>{v.svm}</strong></span>
          {stateChip(v.state)}
          {!hasRel&&<span style={{fontSize:10,padding:"1px 8px",borderRadius:8,background:"#10b98115",border:"1px solid #10b98130",color:"#10b981"}}>Standalone</span>}
          <button onClick={()=>setTopoVol(null)} title="Close topology" style={{marginLeft:"auto",padding:"2px 10px",borderRadius:6,border:`1px solid ${p.border}`,background:"none",color:p.textMute,fontSize:11,cursor:"pointer"}}>✕ Close</button>
        </div>
        {!hasRel&&(
          <div style={{display:"flex",justifyContent:"center",marginBottom:12}}>
            <VolCard vol={{name:v.name,svm:v.svm}} label="STANDALONE VOLUME" hl="#10b981" isThis={true}/>
          </div>
        )}
        {outgoing.map((r,i)=>(
          <div key={i} style={{display:"flex",alignItems:"center",marginBottom:10,overflowX:"auto",paddingBottom:4}}>
            <VolCard vol={{name:v.name,svm:v.svm}} label="SOURCE • This Volume" hl="#8b5cf6" isThis={true}/>
            <SmArrow r={r} dir="out"/>
            <VolCard vol={{name:r.dest_vol,svm:r.dest_svm}} label="DESTINATION" hl="#06b6d4"/>
          </div>
        ))}
        {incoming.map((r,i)=>(
          <div key={i} style={{display:"flex",alignItems:"center",marginBottom:10,overflowX:"auto",paddingBottom:4}}>
            <VolCard vol={{name:r.source_vol,svm:r.source_svm}} label="SOURCE" hl="#f59e0b"/>
            <SmArrow r={r} dir="in"/>
            <VolCard vol={{name:v.name,svm:v.svm}} label="DESTINATION • This Volume" hl="#8b5cf6" isThis={true}/>
          </div>
        ))}
        {volLuns.length>0&&(
          <div style={{marginTop:10,padding:"10px 12px",borderRadius:8,border:`1px solid ${p.border}`,background:p.panel}}>
            <div style={{fontSize:9,fontWeight:700,color:p.textMute,marginBottom:7,textTransform:"uppercase",letterSpacing:".4px"}}>LUNs in this volume ({volLuns.length})</div>
            <div style={{display:"flex",flexWrap:"wrap",gap:6}}>
              {volLuns.map((lun,j)=>(
                <div key={j} style={{padding:"5px 10px",borderRadius:7,border:`1px solid ${p.border}`,background:p.panelAlt}}>
                  <div style={{fontFamily:"monospace",fontWeight:700,fontSize:10,color:p.text}}>{lun.name}</div>
                  <div style={{fontSize:9,color:p.textMute,marginTop:2}}>
                    {lun.os_type&&<span style={{marginRight:6}}>{lun.os_type}</span>}
                    {lun.total_bytes?<span style={{marginRight:6}}>{_storFmtBytes(lun.total_bytes)}</span>:null}
                    <span style={{color:lun.mapped?"#10b981":"#6b7280",fontWeight:700}}>{lun.mapped?"✓ Mapped":"Unmapped"}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
        <div style={{marginTop:10,display:"flex",flexWrap:"wrap",gap:8,fontSize:9,color:p.textMute}}>
          <span style={{padding:"2px 7px",borderRadius:5,border:"1px solid #8b5cf640",background:"#8b5cf608",color:"#8b5cf6"}}>■ This volume</span>
          <span style={{padding:"2px 7px",borderRadius:5,border:"1px solid #f59e0b40",background:"#f59e0b08",color:"#f59e0b"}}>■ Source</span>
          <span style={{padding:"2px 7px",borderRadius:5,border:"1px solid #06b6d440",background:"#06b6d408",color:"#06b6d4"}}>■ Destination</span>
          <span style={{padding:"2px 7px",borderRadius:5,border:"1px solid #10b98140",background:"#10b98108",color:"#10b981"}}>■ Healthy / Standalone</span>
          <span style={{padding:"2px 7px",borderRadius:5,border:"1px solid #ef444440",background:"#ef444408",color:"#ef4444"}}>■ Unhealthy</span>
        </div>
      </div>
    );
  }

  // ── Overview Tab ─────────────────────────────────────────────────────────────
  function OverviewTab(){return(
    <>
      <div style={{padding:"11px 14px",borderRadius:8,background:p.panel,border:`1px solid ${p.border}`,marginBottom:10}}>
        <div style={{fontWeight:700,fontSize:11,color:p.text,marginBottom:8}}>System</div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(160px,1fr))",gap:7}}>
          {[{l:"Array Name",v:sys?.name||arr.name},{l:"Model",v:sys?.model||"—"},{l:"Serial Number",v:sys?.serial||"—"},{l:"OS / Version",v:sys?.version||"—"},{l:"Nodes / Controllers",v:sys?.nodes!=null?String(sys.nodes):"—"},{l:"Site",v:siteLabel}].map(({l,v})=>(
            <div key={l} style={{padding:"6px 9px",borderRadius:7,background:p.panelAlt,border:`1px solid ${p.border}`}}>
              <div style={{fontSize:9,color:p.textMute,textTransform:"uppercase",letterSpacing:".4px",marginBottom:2}}>{l}</div>
              <div style={{fontSize:11,fontWeight:700,color:p.text,wordBreak:"break-all"}}>{v}</div>
            </div>
          ))}
        </div>
      </div>
      {cap&&cap.total_bytes>0&&(
        <div style={{padding:"11px 14px",borderRadius:8,background:p.panel,border:`1px solid ${p.border}`,marginBottom:10}}>
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
            <span style={{fontWeight:700,fontSize:11,color:p.text}}>Capacity</span>
            <div style={{display:"flex",gap:14,fontSize:10}}>
              <span>Used <strong style={{color:bc}}>{_storFmt(cap.used_bytes)}</strong></span>
              <span>Free <strong style={{color:"#10b981"}}>{_storFmt(cap.free_bytes)}</strong></span>
              <span>Total <strong style={{color:p.text}}>{_storFmt(cap.total_bytes)}</strong></span>
            </div>
          </div>
          <div style={{height:10,borderRadius:5,background:p.border,overflow:"hidden"}}>
            <div style={{height:"100%",width:used_pct+"%",background:`linear-gradient(90deg,${bc},${bc}bb)`,borderRadius:5}}/>
          </div>
        </div>
      )}
      <div style={{display:"grid",gridTemplateColumns:"repeat(4,1fr)",gap:8}}>
        {[
          {icon:"📦",label:"Volumes",     v:liveData.volumes!=null?String(liveData.volumes):"—",    c:"#8b5cf6"},
          {icon:"💾",label:"LUNs",        v:liveData.luns!=null?String(liveData.luns):"—",           c:"#3b82f6"},
          {icon:"💿",label:"Drives",      v:liveData.disks!=null?String(liveData.disks):"—",         c:"#f59e0b"},
          {icon:"🖥️",label:"Hosts/iGrps", v:liveData.igroups!=null?String(liveData.igroups):liveData.hosts!=null?String(liveData.hosts):"—", c:"#06b6d4"},
          {icon:"⚡",label:"IOPS Total",  v:perf.iops_total!=null?(Number(perf.iops_total)||0).toLocaleString():"—",c:"#10b981"},
          {icon:"⏱️",label:"Latency Read",v:perf.latency_read_us!=null?(Number(perf.latency_read_us)/1000).toFixed(2)+"ms":"—",c:"#a855f7"},
          {icon:"🚀",label:"Thput Read",  v:perf.throughput_read!=null?Number(perf.throughput_read).toFixed(1)+" GB/s":"—",c:"#f97316"},
          {icon:"🚀",label:"Thput Write", v:perf.throughput_write!=null?Number(perf.throughput_write).toFixed(1)+" GB/s":"—",c:"#ec4899"},
        ].map(({icon,label,v,c})=>(
          <div key={label} style={{padding:"10px 8px",borderRadius:8,background:p.panel,border:`1px solid ${p.border}`,textAlign:"center"}}>
            <div style={{fontSize:15,marginBottom:3}}>{icon}</div>
            <div style={{fontSize:13,fontWeight:900,color:c,lineHeight:1}}>{v}</div>
            <div style={{fontSize:9,color:p.textMute,marginTop:2,textTransform:"uppercase",letterSpacing:".4px"}}>{label}</div>
          </div>
        ))}
      </div>
    </>
  );}

  // ── Volumes Tab ───────────────────────────────────────────────────────────────
  function VolumesTab(){return(
    <div>
      {canAct&&isNetApp&&<div style={{marginBottom:10,display:"flex",gap:8,alignItems:"center"}}>
        <AdminBar opId="vol" label="Create Volume"/>
      </div>}
      {adminOp==="vol"&&(
        <div style={{padding:"12px 14px",borderRadius:8,background:p.panel,border:`1px solid ${p.border}`,marginBottom:10}}>
          <div style={{fontWeight:700,fontSize:11,color:p.text,marginBottom:10}}>Create Volume</div>
          <div style={{display:"flex",flexWrap:"wrap",gap:8,marginBottom:8}}>
            <FAF label="Volume Name *" value={adminForm.name} onChange={v=>setAdminF(f=>({...f,name:v}))}/>
            <FAF label="SVM *" value={adminForm.svm_name} onChange={v=>setAdminF(f=>({...f,svm_name:v}))} opts={(svmList.length?svmList:svms).map(s=>({v:s.name,l:s.name}))}/>
            <FAF label="Size (GiB) *" value={adminForm.size_gib} onChange={v=>setAdminF(f=>({...f,size_gib:v}))} type="number"/>
            <FAF label="Type" value={adminForm.type||"rw"} onChange={v=>setAdminF(f=>({...f,type:v}))} opts={[{v:"rw",l:"Read-Write"},{v:"dp",l:"Data Protection"}]}/>
            <FAF label="Guarantee" value={adminForm.guarantee||"none"} onChange={v=>setAdminF(f=>({...f,guarantee:v}))} opts={[{v:"none",l:"None"},{v:"volume",l:"Volume"}]}/>
            <FAF label="Aggregate" value={adminForm.aggregate} onChange={v=>setAdminF(f=>({...f,aggregate:v}))} opts={aggs.map(a=>({v:a.name,l:a.name}))}/>
            <FAF label="Junction Path" value={adminForm.junction_path} onChange={v=>setAdminF(f=>({...f,junction_path:v}))}/>
          </div>
          <div style={{display:"flex",gap:8,alignItems:"center"}}>
            <button disabled={adminBusy||!adminForm.name||!adminForm.svm_name||!adminForm.size_gib}
              onClick={()=>doAdmin("create_vol",{name:adminForm.name,svm_name:adminForm.svm_name,size_bytes:Math.round(Number(adminForm.size_gib)*1024*1024*1024),type:adminForm.type||"rw",guarantee:adminForm.guarantee||"none",aggregate:adminForm.aggregate||"",junction_path:adminForm.junction_path||""})}
              style={{padding:"5px 14px",borderRadius:7,border:"none",background:"#3b82f6",color:"#fff",fontSize:11,fontWeight:700,cursor:"pointer",opacity:adminBusy?0.5:1}}>
              {adminBusy?"Creating…":"✓ Create"}
            </button>
            <button onClick={()=>setAdminOp(null)} style={{padding:"5px 12px",borderRadius:7,border:`1px solid ${p.border}`,background:"none",color:p.textMute,fontSize:11,cursor:"pointer"}}>Cancel</button>
            {adminMsg.m&&<span style={{fontSize:11,color:adminMsg.t==="ok"?"#10b981":"#ef4444"}}>{adminMsg.m}</span>}
          </div>
        </div>
      )}
      {volList.length===0?<div style={{color:p.textMute,fontSize:12,padding:"20px 0",textAlign:"center"}}>No volumes found</div>:(
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
            <thead><tr style={{background:p.panel}}><TH c="Name"/><TH c="SVM"/><TH c="Type"/><TH c="State"/><TH c="Junction Path"/><TH c="Total" r/><TH c="Used" r/><TH c="Used%" r/><TH c="Snapshot Policy"/>{isNetApp&&<TH c="Actions"/>}</tr></thead>
            <tbody>
              {volList.map((v,i)=>{
                const vc=v.used_pct>80?"#ef4444":v.used_pct>60?"#f59e0b":"#10b981";
                const isSnapping=snapVol?.uuid===v.uuid;
                return(
                  <Fragment key={i}>
                    <tr style={{background:i%2===0?p.panel+"88":"transparent"}}>
                      <td style={{padding:"5px 8px",fontFamily:"monospace",fontWeight:700,color:p.text,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}>{v.name}</td>
                      <td style={{padding:"5px 8px",fontSize:11,color:p.textMute,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}>{v.svm||"—"}</td>
                      <td style={{padding:"5px 8px",fontSize:11,color:p.text,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}>{v.type||"—"}</td>
                      <td style={{padding:"5px 8px",fontSize:11,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}>{stateChip(v.state)}</td>
                      <td style={{padding:"5px 8px",fontSize:10,fontFamily:"monospace",color:p.textMute,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}>{v.junction_path||"—"}</td>
                      <td style={{padding:"5px 8px",fontSize:11,textAlign:"right",color:p.text,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}>{v.total_bytes?_storFmtBytes(v.total_bytes):"—"}</td>
                      <td style={{padding:"5px 8px",fontSize:11,textAlign:"right",color:p.text,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}>{v.used_bytes?_storFmtBytes(v.used_bytes):"—"}</td>
                      <td style={{padding:"5px 8px",fontSize:11,textAlign:"right",verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}><span style={{color:vc,fontWeight:700}}>{v.total_bytes?v.used_pct+"%":"—"}</span></td>
                      <td style={{padding:"5px 8px",fontSize:10,color:p.textMute,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}>{v.snapshot_policy||"—"}</td>
                      {isNetApp&&<td style={{padding:"5px 8px",verticalAlign:"top",borderBottom:`1px solid ${p.border}22`,whiteSpace:"nowrap"}}>
                        {canAct&&<button title="Snapshots: view, create, delete" onClick={()=>{if(snapVol?.uuid===v.uuid){setSnapVol(null);}else{loadSnaps({uuid:v.uuid,name:v.name});setTopoVol(null);}}} style={{marginRight:4,padding:"2px 7px",borderRadius:5,border:"1px solid #06b6d430",background:snapVol?.uuid===v.uuid?"#06b6d420":"none",color:"#06b6d4",fontSize:10,cursor:"pointer"}}>📸</button>}
                        <button title="View data flow topology for this volume" onClick={()=>{if(topoVol?.uuid===v.uuid){setTopoVol(null);}else{setTopoVol(v);setSnapVol(null);}}} style={{padding:"2px 7px",borderRadius:5,border:`1px solid ${topoVol?.uuid===v.uuid?"#8b5cf6":"#8b5cf630"}`,background:topoVol?.uuid===v.uuid?"#8b5cf620":"none",color:"#8b5cf6",fontSize:10,cursor:"pointer"}}>📡</button>
                      </td>}
                    </tr>
                    {snapVol?.uuid===v.uuid&&(
                      <tr><td colSpan={isNetApp?10:9} style={{padding:"10px 14px",background:p.panelAlt+"cc",borderBottom:`1px solid ${p.border}`}}>
                        <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:8}}>
                          <span style={{fontWeight:700,fontSize:11,color:p.text}}>📸 Snapshots — {v.name}</span>
                          {snapBusy&&<span style={{fontSize:10,color:p.textMute}}>Loading…</span>}
                          <span style={{marginLeft:"auto"}}/>
                          {canAct&&(
                            <div style={{display:"flex",gap:6,alignItems:"center"}}>
                              <input value={newSnap} onChange={e=>setNewSnap(e.target.value)} placeholder="snapshot name" style={{padding:"4px 8px",borderRadius:6,border:`1px solid ${p.border}`,background:p.panel,color:p.text,fontSize:11,outline:"none"}}/>
                              <button disabled={!newSnap.trim()||snapBusy} onClick={()=>doSnap("create",{vuuid:v.uuid,name:newSnap.trim()})} style={{padding:"4px 10px",borderRadius:6,border:"none",background:"#06b6d4",color:"#fff",fontSize:10,fontWeight:700,cursor:"pointer",opacity:snapBusy?0.5:1}}>＋ Create</button>
                            </div>
                          )}
                        </div>
                        {snapList.length===0&&!snapBusy?<div style={{fontSize:11,color:p.textMute}}>No snapshots</div>:(
                          <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                            <thead><tr><TH c="Name"/><TH c="State"/><TH c="Size" r/><TH c="Created"/>{canAct&&<TH c="Del"/>}</tr></thead>
                            <tbody>
                              {snapList.map((sn,j)=>(
                                <tr key={j} style={{background:j%2===0?p.panel+"66":"transparent"}}>
                                  <td style={{padding:"4px 8px",fontFamily:"monospace",fontSize:11,color:p.text}}>{sn.name}</td>
                                  <td style={{padding:"4px 8px",fontSize:11}}>{stateChip(sn.state)}</td>
                                  <td style={{padding:"4px 8px",fontSize:11,textAlign:"right",color:p.text}}>{sn.size?_storFmtBytes(sn.size):"—"}</td>
                                  <td style={{padding:"4px 8px",fontSize:10,color:p.textMute}}>{sn.created?new Date(sn.created).toLocaleString():"—"}</td>
                                  {canAct&&<td style={{padding:"4px 8px"}}><button onClick={()=>{if(window.confirm(`Delete snapshot "${sn.name}"?`))doSnap("delete",{vuuid:v.uuid,uuid:sn.uuid})}} style={{padding:"2px 6px",borderRadius:5,border:"1px solid #ef444430",background:"none",color:"#ef4444",fontSize:9,cursor:"pointer"}}>🗑</button></td>}
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        )}
                      </td></tr>
                    )}
                    {topoVol?.uuid===v.uuid&&(
                      <tr><td colSpan={isNetApp?10:9} style={{padding:0,borderBottom:`1px solid ${p.border}`}}>
                        <VolumeTopoPanel v={v}/>
                      </td></tr>
                    )}
                  </Fragment>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );}

  // ── LUNs Tab ──────────────────────────────────────────────────────────────────
  function LunsTab(){return(
    <div>
      {isAdmin&&isNetApp&&<div style={{marginBottom:10}}><AdminBar opId="lun" label="Create LUN"/></div>}
      {adminOp==="lun"&&(
        <div style={{padding:"12px 14px",borderRadius:8,background:p.panel,border:`1px solid ${p.border}`,marginBottom:10}}>
          <div style={{fontWeight:700,fontSize:11,color:p.text,marginBottom:10}}>Create LUN</div>
          <div style={{display:"flex",flexWrap:"wrap",gap:8,marginBottom:8}}>
            <FAF label="LUN Name *" value={adminForm.name} onChange={v=>setAdminF(f=>({...f,name:v}))}/>
            <FAF label="SVM *" value={adminForm.svm_name} onChange={v=>setAdminF(f=>({...f,svm_name:v}))} opts={(svmList.length?svmList:svms).map(s=>({v:s.name,l:s.name}))}/>
            <FAF label="Volume *" value={adminForm.volume} onChange={v=>setAdminF(f=>({...f,volume:v}))} opts={volList.map(v=>({v:v.name,l:v.name}))}/>
            <FAF label="Size (GiB) *" value={adminForm.size_gib} onChange={v=>setAdminF(f=>({...f,size_gib:v}))} type="number"/>
            <FAF label="OS Type" value={adminForm.os_type||"linux"} onChange={v=>setAdminF(f=>({...f,os_type:v}))} opts={["linux","windows","vmware","aix","hpux","solaris"]}/>
          </div>
          <div style={{display:"flex",gap:8,alignItems:"center"}}>
            <button disabled={adminBusy||!adminForm.name||!adminForm.svm_name||!adminForm.size_gib}
              onClick={()=>doAdmin("create_lun",{name:adminForm.name,svm_name:adminForm.svm_name,volume:adminForm.volume||"",size_bytes:Math.round(Number(adminForm.size_gib)*1024*1024*1024),os_type:adminForm.os_type||"linux"})}
              style={{padding:"5px 14px",borderRadius:7,border:"none",background:"#3b82f6",color:"#fff",fontSize:11,fontWeight:700,cursor:"pointer",opacity:adminBusy?0.5:1}}>
              {adminBusy?"Creating…":"✓ Create"}
            </button>
            <button onClick={()=>setAdminOp(null)} style={{padding:"5px 12px",borderRadius:7,border:`1px solid ${p.border}`,background:"none",color:p.textMute,fontSize:11,cursor:"pointer"}}>Cancel</button>
            {adminMsg.m&&<span style={{fontSize:11,color:adminMsg.t==="ok"?"#10b981":"#ef4444"}}>{adminMsg.m}</span>}
          </div>
        </div>
      )}
      {lunList.length===0?<div style={{color:p.textMute,fontSize:12,padding:"20px 0",textAlign:"center"}}>No LUNs found</div>:(
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
            <thead><tr style={{background:p.panel}}><TH c="Name"/><TH c="Path"/><TH c="SVM"/><TH c="Volume"/><TH c="Node"/><TH c="OS Type"/><TH c="State"/><TH c="Mapped"/><TH c="Serial"/><TH c="Size" r/><TH c="Used" r/></tr></thead>
            <tbody>
              {lunList.map((ln,i)=>(
                <tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
                  <td style={{padding:"5px 8px",fontFamily:"monospace",fontWeight:700,color:p.text,borderBottom:`1px solid ${p.border}22`}}>{ln.name||"—"}</td>
                  <TD c={ln.path||"—"} mono color={p.textMute}/>
                  <TD c={ln.svm||"—"} color={p.textMute}/><TD c={ln.volume||"—"} color={p.textMute}/>
                  <TD c={ln.node||"—"} color={p.textMute}/>
                  <TD c={ln.os_type||"—"}/>
                  <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}>{stateChip(ln.state)}</td>
                  <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}>
                    <span style={{padding:"1px 7px",borderRadius:6,fontSize:9,fontWeight:700,
                      background:ln.mapped?"#10b98115":"#6b728015",
                      border:`1px solid ${ln.mapped?"#10b98130":"#6b728030"}`,
                      color:ln.mapped?"#10b981":p.textMute}}>{ln.mapped?"Yes":"No"}</span>
                  </td>
                  <TD c={ln.serial||"—"} mono color={p.textMute}/>
                  <TD c={ln.total_bytes?_storFmtBytes(ln.total_bytes):"—"} r/><TD c={ln.used_bytes?_storFmtBytes(ln.used_bytes):"—"} r/>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );}

  // ── Local Tiers Tab ───────────────────────────────────────────────────────────
  function TiersTab(){return(
    <div style={{overflowX:"auto"}}>
      <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
        <thead><tr style={{background:p.panel}}><TH c="Aggregate"/><TH c="Node"/><TH c="State"/><TH c="Total" r/><TH c="Used" r/><TH c="Free" r/><TH c="Used%" r/></tr></thead>
        <tbody>
          {aggList.map((a,i)=>{const ac=a.used_pct>80?"#ef4444":a.used_pct>60?"#f59e0b":"#10b981";return(
            <tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
              <td style={{padding:"5px 8px",fontFamily:"monospace",fontWeight:700,color:p.text,borderBottom:`1px solid ${p.border}22`}}>{a.name}</td>
              <TD c={a.node||"—"} color={p.textMute}/><td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}>{stateChip(a.state)}</td>
              <TD c={a.total_bytes?_storFmtBytes(a.total_bytes):"—"} r/><TD c={a.used_bytes?_storFmtBytes(a.used_bytes):"—"} r/>
              <TD c={a.free_bytes?_storFmtBytes(a.free_bytes):"—"} r/>
              <td style={{padding:"5px 8px",textAlign:"right",borderBottom:`1px solid ${p.border}22`}}><span style={{color:ac,fontWeight:700}}>{a.used_pct}%</span></td>
            </tr>
          );})}
        </tbody>
      </table>
    </div>
  );}

  // ── Drives Tab ────────────────────────────────────────────────────────────────
  function DrivesTab(){return(
    diskList.length===0?<div style={{color:p.textMute,fontSize:12,padding:"20px 0",textAlign:"center"}}>No drive data available</div>:(
      <div style={{overflowX:"auto"}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
          <thead><tr style={{background:p.panel}}><TH c="Name"/><TH c="Type"/><TH c="Class"/><TH c="State"/><TH c="Model"/><TH c="Serial"/><TH c="Vendor"/><TH c="Node"/><TH c="Bay" r/><TH c="RPM" r/><TH c="Capacity" r/></tr></thead>
          <tbody>
            {diskList.map((d,i)=>(
              <tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
                <td style={{padding:"5px 8px",fontFamily:"monospace",fontWeight:700,color:p.text,borderBottom:`1px solid ${p.border}22`}}>{d.name}</td>
                <TD c={d.type||"—"}/><TD c={d.disk_class||"—"} color={p.textMute}/>
                <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}>{stateChip(d.state)}</td>
                <TD c={d.model||"—"}/><TD c={d.serial||"—"} mono color={p.textMute}/>
                <TD c={d.vendor||"—"} color={p.textMute}/><TD c={d.node||"—"} color={p.textMute}/>
                <TD c={d.bay!==""&&d.bay!=null?d.bay:"—"} r/>
                <TD c={d.rpm?Number(d.rpm).toLocaleString():"SSD/NVMe"} r color={p.textMute}/>
                <TD c={d.capacity?_storFmtBytes(d.capacity):"—"} r/>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  );}

  // ── Hosts / iGroups Tab ───────────────────────────────────────────────────────
  function HostsTab(){return(
    <div>
      {isAdmin&&isNetApp&&<div style={{marginBottom:10}}><AdminBar opId="igroup" label="Create iGroup"/></div>}
      {adminOp==="igroup"&&(
        <div style={{padding:"12px 14px",borderRadius:8,background:p.panel,border:`1px solid ${p.border}`,marginBottom:10}}>
          <div style={{fontWeight:700,fontSize:11,color:p.text,marginBottom:10}}>Create Initiator Group</div>
          <div style={{display:"flex",flexWrap:"wrap",gap:8,marginBottom:8}}>
            <FAF label="iGroup Name *" value={adminForm.name} onChange={v=>setAdminF(f=>({...f,name:v}))}/>
            <FAF label="SVM *" value={adminForm.svm_name} onChange={v=>setAdminF(f=>({...f,svm_name:v}))} opts={(svmList.length?svmList:svms).map(s=>({v:s.name,l:s.name}))}/>
            <FAF label="Protocol" value={adminForm.protocol||"iscsi"} onChange={v=>setAdminF(f=>({...f,protocol:v}))} opts={[{v:"iscsi",l:"iSCSI"},{v:"fcp",l:"FCP/FC"}]}/>
            <FAF label="OS Type" value={adminForm.os_type||"linux"} onChange={v=>setAdminF(f=>({...f,os_type:v}))} opts={["linux","windows","vmware","aix","hpux","solaris"]}/>
            <div style={{flex:"0 0 100%"}}><FAF label="Initiators (one per line)" value={adminForm.initiators} onChange={v=>setAdminF(f=>({...f,initiators:v}))} type="textarea"/></div>
          </div>
          <div style={{display:"flex",gap:8,alignItems:"center"}}>
            <button disabled={adminBusy||!adminForm.name||!adminForm.svm_name}
              onClick={()=>doAdmin("create_ig",{name:adminForm.name,svm_name:adminForm.svm_name,protocol:adminForm.protocol||"iscsi",os_type:adminForm.os_type||"linux",initiators:adminForm.initiators||""})}
              style={{padding:"5px 14px",borderRadius:7,border:"none",background:"#3b82f6",color:"#fff",fontSize:11,fontWeight:700,cursor:"pointer",opacity:adminBusy?0.5:1}}>
              {adminBusy?"Creating…":"✓ Create"}
            </button>
            <button onClick={()=>setAdminOp(null)} style={{padding:"5px 12px",borderRadius:7,border:`1px solid ${p.border}`,background:"none",color:p.textMute,fontSize:11,cursor:"pointer"}}>Cancel</button>
            {adminMsg.m&&<span style={{fontSize:11,color:adminMsg.t==="ok"?"#10b981":"#ef4444"}}>{adminMsg.m}</span>}
          </div>
        </div>
      )}
      {igList.length===0?<div style={{color:p.textMute,fontSize:12,padding:"20px 0",textAlign:"center"}}>No initiator groups found</div>:(
        igList.map((ig,i)=>(
          <div key={i} style={{marginBottom:8,border:`1px solid ${p.border}`,borderRadius:8,overflow:"hidden",background:p.panel}}>
            <div style={{padding:"8px 12px",background:"#3b82f608",borderBottom:`1px solid ${p.border}`,display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}}>
              <span style={{fontWeight:800,fontSize:12,color:p.text}}>🖥️ {ig.name}</span>
              <span style={{fontSize:10,padding:"1px 7px",borderRadius:8,background:"#3b82f615",border:"1px solid #3b82f630",color:"#3b82f6"}}>{ig.protocol?.toUpperCase()||"—"}</span>
              <span style={{fontSize:10,padding:"1px 7px",borderRadius:8,background:p.panelAlt,border:`1px solid ${p.border}`,color:p.textMute}}>{ig.os_type||"—"}</span>
              <span style={{fontSize:10,color:p.textMute}}>SVM: <strong style={{color:p.text}}>{ig.svm||"—"}</strong></span>
              <span style={{fontSize:10,color:p.textMute}}>{ig.initiator_count} initiator{ig.initiator_count!==1?"s":""}</span>

            </div>
            {ig.initiators?.length>0&&<div style={{padding:"8px 12px",display:"flex",flexWrap:"wrap",gap:5}}>
              {ig.initiators.map((ini,j)=><span key={j} style={{fontFamily:"monospace",fontSize:10,padding:"2px 8px",borderRadius:6,background:p.panelAlt,border:`1px solid ${p.border}`,color:p.text}}>{ini}</span>)}
            </div>}
          </div>
        ))
      )}
    </div>
  );}

  // ── Network Tab ───────────────────────────────────────────────────────────────
  function NetworkTab(){return(
    nicList.length===0?<div style={{color:p.textMute,fontSize:12,padding:"20px 0",textAlign:"center"}}>No network interfaces found</div>:(
      <div style={{overflowX:"auto"}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
          <thead><tr style={{background:p.panel}}><TH c="Interface"/><TH c="IP Address"/><TH c="Netmask"/><TH c="SVM"/><TH c="State"/><TH c="Node"/><TH c="Port"/><TH c="Service Policy"/></tr></thead>
          <tbody>
            {nicList.map((n,i)=>(
              <tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
                <td style={{padding:"5px 8px",fontWeight:700,color:p.text,borderBottom:`1px solid ${p.border}22`}}>{n.name}</td>
                <td style={{padding:"5px 8px",fontFamily:"monospace",fontWeight:700,color:"#06b6d4",borderBottom:`1px solid ${p.border}22`}}>{n.ip||"—"}</td>
                <TD c={n.netmask||"—"} color={p.textMute}/><TD c={n.svm||"—"} color={p.textMute}/>
                <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}>{stateChip(n.state)}</td>
                <TD c={n.node||"—"} color={p.textMute}/><TD c={n.port||"—"} color={p.textMute}/><TD c={n.policy||"—"} color={p.textMute}/>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  );}

  // ── Protection Tab ────────────────────────────────────────────────────────────
  function ProtectionTab(){return(
    smList.length===0?<div style={{color:p.textMute,fontSize:12,padding:"20px 0",textAlign:"center"}}>No SnapMirror relationships found</div>:(
      <div style={{overflowX:"auto"}}>
        <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
          <thead><tr style={{background:p.panel}}><TH c="Source"/><TH c="Source SVM"/><TH c="Destination"/><TH c="Dest SVM"/><TH c="State"/><TH c="Healthy"/><TH c="Lag Time"/><TH c="Policy"/></tr></thead>
          <tbody>
            {smList.map((r,i)=>{
              const hc=r.healthy===true?"#10b981":r.healthy===false?"#ef4444":"#f59e0b";
              return(<tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
                <TD c={r.source_vol||"—"} mono/><TD c={r.source_svm||"—"} color={p.textMute}/>
                <TD c={r.dest_vol||"—"} mono/><TD c={r.dest_svm||"—"} color={p.textMute}/>
                <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}>{stateChip(r.state)}</td>
                <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}><span style={{color:hc,fontWeight:700}}>{r.healthy===true?"✓ Yes":r.healthy===false?"✗ No":"—"}</span></td>
                <TD c={r.lag_time||"—"} color={p.textMute}/><TD c={r.policy||"—"} color={p.textMute}/>
              </tr>);})}
          </tbody>
        </table>
      </div>
    )
  );}

  // ── Events Tab ────────────────────────────────────────────────────────────────
  function EventsTab(){return(
    emsList.length===0?<div style={{color:p.textMute,fontSize:12,padding:"20px 0",textAlign:"center"}}>No EMS events found</div>:(
      <div>
        {emsList.map((ev,i)=>{
          const c=ev.severity==="critical"||ev.severity==="error"?"#ef4444":ev.severity==="warning"?"#f59e0b":"#64748b";
          return(<div key={i} style={{display:"flex",gap:10,padding:"7px 10px",borderRadius:7,background:i%2===0?p.panel:"transparent",marginBottom:3,border:`1px solid ${p.border}44`}}>
            <span style={{fontSize:10,fontWeight:700,color:c,minWidth:60,textTransform:"uppercase"}}>{ev.severity}</span>
            <span style={{fontSize:11,color:p.text,flex:1,wordBreak:"break-all"}}>{ev.message}</span>
            <span style={{fontSize:9,color:p.textMute,whiteSpace:"nowrap"}}>{ev.node}</span>
            <span style={{fontSize:9,color:p.textMute,whiteSpace:"nowrap"}}>{ev.time?new Date(ev.time).toLocaleString():""}</span>
          </div>);
        })}
      </div>
    )
  );}

  // ── Shares Tab (NFS + CIFS) ───────────────────────────────────────────────────
  function SharesTab(){return(
    <div>
      <div style={{fontWeight:700,fontSize:11,color:p.text,marginBottom:8,display:"flex",alignItems:"center",gap:6}}>
        <span style={{padding:"2px 8px",borderRadius:6,background:"#10b98118",border:"1px solid #10b98135",color:"#10b981",fontSize:10}}>NFS</span>
        Export Policies ({nfsExports.length})
      </div>
      {nfsExports.length===0?<div style={{color:p.textMute,fontSize:12,padding:"8px 0 16px"}}>No NFS export policies found</div>:(
        nfsExports.map((ep,i)=>(
          <div key={i} style={{marginBottom:8,border:`1px solid ${p.border}`,borderRadius:8,overflow:"hidden"}}>
            <div style={{padding:"7px 12px",background:"#10b98108",borderBottom:`1px solid ${p.border}`,display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}}>
              <span style={{fontWeight:700,fontSize:11,color:p.text}}>📁 {ep.name}</span>
              <span style={{fontSize:10,color:p.textMute}}>SVM: <strong style={{color:p.text}}>{ep.svm||"—"}</strong></span>
              <span style={{fontSize:10,color:p.textMute}}>{ep.rule_count} rule{ep.rule_count!==1?"s":""}</span>
            </div>
            {ep.rules&&ep.rules.length>0&&(
              <div style={{overflowX:"auto"}}>
                <table style={{width:"100%",borderCollapse:"collapse",fontSize:10}}>
                  <thead><tr style={{background:p.panel}}><TH c="#"/><TH c="Clients"/><TH c="Protocols"/><TH c="RO Rule"/><TH c="RW Rule"/></tr></thead>
                  <tbody>
                    {ep.rules.map((r,j)=>(
                      <tr key={j} style={{background:j%2===0?"transparent":p.panel+"44"}}>
                        <TD c={r.index} color={p.textMute}/>
                        <td style={{padding:"4px 8px",fontSize:10,borderBottom:`1px solid ${p.border}22`}}>
                          {(r.clients||[]).map((cl,k)=><span key={k} style={{fontFamily:"monospace",marginRight:4,padding:"1px 5px",borderRadius:4,background:p.panelAlt,border:`1px solid ${p.border}`,fontSize:9}}>{cl}</span>)}
                        </td>
                        <TD c={(r.protocols||[]).join(", ")||"—"} color={p.textMute}/>
                        <TD c={(r.ro_rule||[]).join(", ")||"—"} color="#10b981"/>
                        <TD c={(r.rw_rule||[]).join(", ")||"—"} color="#3b82f6"/>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        ))
      )}
      <div style={{fontWeight:700,fontSize:11,color:p.text,margin:"16px 0 8px",display:"flex",alignItems:"center",gap:6}}>
        <span style={{padding:"2px 8px",borderRadius:6,background:"#3b82f618",border:"1px solid #3b82f635",color:"#3b82f6",fontSize:10}}>CIFS/SMB</span>
        Shares ({cifsList.length})
      </div>
      {cifsList.length===0?<div style={{color:p.textMute,fontSize:12,padding:"8px 0"}}>No CIFS shares found</div>:(
        <div style={{overflowX:"auto"}}>
          <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
            <thead><tr style={{background:p.panel}}><TH c="Share Name"/><TH c="Path"/><TH c="SVM"/><TH c="Volume"/><TH c="Oplocks"/><TH c="Home Dir"/><TH c="ACLs"/></tr></thead>
            <tbody>
              {cifsList.map((sh,i)=>(
                <tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
                  <td style={{padding:"5px 8px",fontWeight:700,color:p.text,borderBottom:`1px solid ${p.border}22`}}>{"\\\\"}{sh.name}</td>
                  <TD c={sh.path||"—"} mono color={p.textMute}/>
                  <TD c={sh.svm||"—"} color={p.textMute}/>
                  <TD c={sh.volume||"—"} color={p.textMute}/>
                  <TD c={sh.oplocks?"Yes":"No"} color={sh.oplocks?"#10b981":p.textMute}/>
                  <TD c={sh.home_dir?"Yes":"No"} color={sh.home_dir?"#f59e0b":p.textMute}/>
                  <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}>
                    {(sh.acls||[]).map((a,j)=>(
                      <div key={j} style={{fontSize:9,marginBottom:2}}>
                        <span style={{fontWeight:700,color:p.text}}>{a.user}</span>
                        <span style={{color:p.textMute,margin:"0 4px"}}>{a.type}</span>
                        <span style={{color:"#3b82f6"}}>{a.permission}</span>
                      </div>
                    ))}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );}

  // ── Storage VMs Tab ───────────────────────────────────────────────────────────
  function StorageVMsTab(){const items=svmDetails.length?svmDetails:svmList;const sel=items.find(s=>s.name===selSvm)||null;return(
    items.length===0?<div style={{color:p.textMute,fontSize:12,padding:"20px 0",textAlign:"center"}}>No Storage VMs found</div>:(
      <div>
        {/* Card grid */}
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(240px,1fr))",gap:8,marginBottom:sel?10:0}}>
          {items.map((sv,i)=>{
            const isSel=sv.name===selSvm;
            return(
              <div key={i} onClick={()=>setSelSvm(isSel?null:sv.name)}
                style={{padding:"12px 14px",borderRadius:8,background:isSel?p.panelAlt:p.panel,border:`1px solid ${isSel?"#3b82f6":p.border}`,cursor:"pointer",transition:"border-color .15s"}}>
                <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:6,flexWrap:"wrap"}}>
                  <span style={{fontWeight:800,fontSize:12,color:p.text}}>🗂 {sv.name}</span>
                  {sv.state&&stateChip(sv.state)}
                  {sv.type&&<span style={{fontSize:9,padding:"1px 6px",borderRadius:6,background:p.panelAlt,border:`1px solid ${p.border}`,color:p.textMute,textTransform:"uppercase"}}>{sv.type}</span>}
                </div>
                {sv.protocols&&sv.protocols.length>0&&(
                  <div style={{display:"flex",flexWrap:"wrap",gap:4,marginBottom:6}}>
                    {sv.protocols.map((pr,j)=>(
                      <span key={j} style={{fontSize:9,padding:"2px 7px",borderRadius:6,fontWeight:700,background:"#3b82f615",border:"1px solid #3b82f630",color:"#3b82f6"}}>{pr}</span>
                    ))}
                  </div>
                )}
                <div style={{fontSize:9,color:p.textMute,marginTop:2}}>{isSel?"▲ Click to collapse":"▼ Click for details"}</div>
              </div>
            );
          })}
        </div>
        {/* Detail panel */}
        {sel&&(
          <div style={{border:`1px solid #3b82f6`,borderRadius:10,padding:"14px 16px",background:p.panelAlt,marginTop:4}}>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:12,flexWrap:"wrap"}}>
              <span style={{fontWeight:800,fontSize:13,color:p.text}}>🗂 {sel.name}</span>
              {sel.state&&stateChip(sel.state)}
              {sel.type&&<span style={{fontSize:10,padding:"2px 8px",borderRadius:6,background:p.panel,border:`1px solid ${p.border}`,color:p.textMute,textTransform:"uppercase"}}>{sel.type}</span>}
              {sel.subtype&&<span style={{fontSize:10,padding:"2px 8px",borderRadius:6,background:p.panel,border:`1px solid ${p.border}`,color:"#f59e0b"}}>{sel.subtype}</span>}
              <button onClick={()=>setSelSvm(null)} style={{marginLeft:"auto",padding:"2px 10px",borderRadius:6,border:`1px solid ${p.border}`,background:"none",color:p.textMute,fontSize:11,cursor:"pointer"}}>✕ Close</button>
            </div>
            {sel.protocols&&sel.protocols.length>0&&(
              <div style={{display:"flex",flexWrap:"wrap",gap:5,marginBottom:12}}>
                <span style={{fontSize:10,color:p.textMute,alignSelf:"center",marginRight:4}}>Protocols:</span>
                {sel.protocols.map((pr,j)=>(
                  <span key={j} style={{fontSize:10,padding:"3px 10px",borderRadius:7,fontWeight:700,background:"#3b82f615",border:"1px solid #3b82f630",color:"#3b82f6"}}>{pr}</span>
                ))}
              </div>
            )}
            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(200px,1fr))",gap:6}}>
              {[{l:"UUID",v:sel.uuid,mono:true},{l:"Language",v:sel.language},{l:"IP Space",v:sel.ip_space},
                {l:"Snapshot Policy",v:sel.snapshot_policy},{l:"Comment",v:sel.comment}]
                .filter(r=>r.v)
                .map(({l,v,mono})=>(
                <div key={l} style={{padding:"8px 10px",borderRadius:7,background:p.panel,border:`1px solid ${p.border}`}}>
                  <div style={{fontSize:9,color:p.textMute,marginBottom:3,textTransform:"uppercase",letterSpacing:"0.5px"}}>{l}</div>
                  <div style={{fontSize:11,fontWeight:700,color:p.text,fontFamily:mono?"monospace":undefined,wordBreak:"break-all"}}>{v}</div>
                </div>
              ))}
            </div>
            {(sel.dns_domains?.length||sel.dns_servers?.length)&&(
              <div style={{marginTop:10,padding:"8px 10px",borderRadius:7,background:p.panel,border:`1px solid ${p.border}`}}>
                <div style={{fontSize:9,color:p.textMute,marginBottom:5,textTransform:"uppercase",letterSpacing:"0.5px"}}>DNS</div>
                {sel.dns_servers?.length>0&&(
                  <div style={{marginBottom:4,fontSize:10}}>
                    <span style={{color:p.textMute}}>Servers: </span>
                    {sel.dns_servers.map((s,j)=><span key={j} style={{fontFamily:"monospace",color:"#06b6d4",marginRight:10}}>{s}</span>)}
                  </div>
                )}
                {sel.dns_domains?.length>0&&(
                  <div style={{fontSize:10}}>
                    <span style={{color:p.textMute}}>Domains: </span>
                    {sel.dns_domains.map((d,j)=><span key={j} style={{fontFamily:"monospace",color:p.text,marginRight:10}}>{d}</span>)}
                  </div>
                )}
              </div>
            )}
            {/* Volumes belonging to this SVM */}
            {volList.filter(v=>v.svm===sel.name).length>0&&(
              <div style={{marginTop:10}}>
                <div style={{fontSize:10,color:p.textMute,marginBottom:5}}>Volumes ({volList.filter(v=>v.svm===sel.name).length})</div>
                <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
                  {volList.filter(v=>v.svm===sel.name).map((v,j)=>(
                    <span key={j} style={{fontFamily:"monospace",fontSize:10,padding:"2px 8px",borderRadius:6,background:p.panelAlt,border:`1px solid ${p.border}`,color:p.text}}>{v.name}</span>
                  ))}
                </div>
              </div>
            )}
            {/* LUNs belonging to this SVM */}
            {lunList.filter(l=>l.svm===sel.name).length>0&&(
              <div style={{marginTop:10}}>
                <div style={{fontSize:10,color:p.textMute,marginBottom:5}}>LUNs ({lunList.filter(l=>l.svm===sel.name).length})</div>
                <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
                  {lunList.filter(l=>l.svm===sel.name).map((l,j)=>(
                    <span key={j} style={{fontFamily:"monospace",fontSize:10,padding:"2px 8px",borderRadius:6,background:p.panelAlt,border:`1px solid ${p.border}`,color:p.text}}>{l.name||l.path}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
      </div>
    )
  );}

  // ── Nodes Tab ─────────────────────────────────────────────────────────────────
  function NodesTab(){return(
    <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(260px,1fr))",gap:10}}>
      {(sys?.node_details||[]).map((n,i)=>(
        <div key={i} style={{padding:"12px 14px",borderRadius:8,background:p.panel,border:`1px solid ${p.border}`}}>
          <div style={{fontWeight:800,fontSize:12,color:p.text,marginBottom:8}}>🖧 {n.name}</div>
          {[{l:"Model",v:n.model||"—"},{l:"Serial",v:n.serial||"—"},{l:"State",v:n.state||"—"}].map(({l,v})=>(
            <div key={l} style={{display:"flex",justifyContent:"space-between",marginBottom:4,fontSize:11}}>
              <span style={{color:p.textMute}}>{l}</span>
              <span style={{fontWeight:700,color:p.text,fontFamily:l==="Serial"?"monospace":undefined}}>{v}</span>
            </div>
          ))}
        </div>
      ))}
    </div>
  );}

  return(
    <div style={{border:`1px solid ${p.border}`,borderRadius:10,overflow:"hidden",background:p.panel}}>
      {/* ─ header ─ */}
      <div style={{padding:"12px 16px",display:"flex",alignItems:"center",gap:12,cursor:"pointer",background:`linear-gradient(90deg,${vd.color}10,transparent)`}} onClick={expand}>
        <div title={vd.label+" storage array"} style={{width:36,height:36,borderRadius:8,background:`${vd.color}18`,border:`1px solid ${vd.color}30`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:20,flexShrink:0}}>{vd.icon}</div>
        <div style={{flex:1,minWidth:0}}>
          <div style={{display:"flex",alignItems:"center",gap:7,flexWrap:"wrap"}}>
            <span style={{fontWeight:800,fontSize:13,color:p.text}}>{arr.name}</span>
            <span style={{fontSize:10,padding:"1px 7px",borderRadius:10,background:p.panelAlt,border:`1px solid ${p.border}`,color:p.textMute}}>{arr.vendor}</span>
            <span style={{fontSize:10,padding:"2px 8px",borderRadius:10,
              background:arr.status==="ok"?"#10b98115":arr.status==="error"?"#ef444415":"#f59e0b15",
              border:`1px solid ${arr.status==="ok"?"#10b98135":arr.status==="error"?"#ef444435":"#f59e0b35"}`,
              color:arr.status==="ok"?"#10b981":arr.status==="error"?"#ef4444":"#f59e0b",fontWeight:700}}>
              {arr.status==="ok"?"✓ Connected":arr.status==="error"?"✗ Error":"⏳ Pending"}
            </span>
            {isNetApp&&sys?.version&&<span style={{fontSize:10,color:p.textMute}} title="ONTAP operating system version">ONTAP {sys.version}</span>}
          </div>
          <div style={{fontSize:10,color:p.textMute,marginTop:2}}>{arr.ip}{arr.port?":"+arr.port:""} · {siteLabel}</div>
        </div>
        {cap&&cap.total_bytes>0&&(
          <div style={{width:130,flexShrink:0}}>
            <div style={{display:"flex",justifyContent:"space-between",fontSize:9,marginBottom:3}}>
              <span style={{color:bc,fontWeight:700}}>{used_pct}% used</span>
              <span style={{color:p.textMute}}>{_storFmt(cap.free_bytes)} free</span>
            </div>
            <div style={{height:6,borderRadius:3,background:p.border,overflow:"hidden"}}>
              <div style={{height:"100%",width:used_pct+"%",background:bc,borderRadius:3}}/>
            </div>
            <div style={{display:"flex",justifyContent:"space-between",fontSize:9,color:p.textMute,marginTop:2}}>
              <span>{_storFmt(cap.used_bytes)}</span><span>{_storFmt(cap.total_bytes)}</span>
            </div>
          </div>
        )}
        <span title={open?"Collapse details":"Expand to see live data"} style={{fontSize:10,color:p.textMute,marginLeft:4}}>{open?"▲":"▼"}</span>
      </div>

      {/* ─ expanded body ─ */}
      {open&&(
        <div style={{borderTop:`1px solid ${p.border}`,background:p.panelAlt}}>
          {loading&&<div style={{textAlign:"center",padding:"28px 0",color:p.textMute,fontSize:12}}><div style={{fontSize:26,marginBottom:8,display:"inline-block"}}>⚙️</div><div>Fetching live data…</div></div>}
          {liveErr&&<div style={{margin:"12px 16px",padding:"12px",borderRadius:8,background:"#ef444412",border:"1px solid #ef444430",color:"#ef4444",fontSize:12}}>⚠ {liveErr}</div>}

          {liveData&&!loading&&(
            <>
              {adminMsg.m&&<div style={{margin:"8px 16px 0",padding:"7px 12px",borderRadius:7,background:adminMsg.t==="ok"?"#10b98115":"#ef444415",border:`1px solid ${adminMsg.t==="ok"?"#10b98135":"#ef444435"}`,color:adminMsg.t==="ok"?"#10b981":"#ef4444",fontSize:11,fontWeight:600}}>{adminMsg.m}</div>}

              {/* tab bar */}
              <div style={{display:"flex",gap:0,borderBottom:`1px solid ${p.border}`,paddingLeft:16,overflowX:"auto",flexShrink:0}}>
                {tabs.map(t=>(
                  <button key={t.id} onClick={()=>{setTab(t.id);setAdminOp(null);setSnapVol(null);}}
                    style={{padding:"8px 14px",border:"none",borderBottom:tab===t.id?`2px solid ${vd.color}`:"2px solid transparent",
                      background:"none",color:tab===t.id?vd.color:p.textMute,fontSize:11,fontWeight:tab===t.id?700:500,
                      cursor:"pointer",whiteSpace:"nowrap",flexShrink:0}}>
                    {t.label}
                  </button>
                ))}
              </div>

              <div style={{padding:"14px 16px"}}>
                {tab==="overview"   && <OverviewTab/>}
                {tab==="volumes"    && <VolumesTab/>}
                {tab==="luns"       && <LunsTab/>}
                {tab==="tiers"      && <TiersTab/>}
                {tab==="drives"     && <DrivesTab/>}
                {tab==="hosts"      && <HostsTab/>}
                {tab==="network"    && <NetworkTab/>}
                {tab==="protection" && <ProtectionTab/>}
                {tab==="events"     && <EventsTab/>}
                {tab==="shares"     && <SharesTab/>}
                {tab==="svms"       && <StorageVMsTab/>}
                {tab==="nodes"      && <NodesTab/>}
              </div>
            </>
          )}

          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"6px 16px 12px"}}>
            {liveData&&!loading?<button title="Refresh live data from array" onClick={refresh} style={{padding:"5px 12px",borderRadius:7,border:`1px solid ${p.border}`,background:"none",color:p.textMute,fontSize:10,fontWeight:700,cursor:"pointer"}}>🔄 Refresh</button>:<span/>}
            <button title="Remove this array from the dashboard" onClick={()=>onRemove(arr.id)} style={{padding:"5px 14px",borderRadius:7,border:"1px solid #ef444435",background:"#ef444410",color:"#ef4444",fontSize:11,fontWeight:700,cursor:"pointer"}}>🗑 Remove Array</button>
          </div>
        </div>
      )}
    </div>
  );
}

function StoragePage({p, currentUser}){
  const [arrays,setArrays]   = useState([]);
  const [loadingList,setLL]  = useState(true);
  const [listErr,setListErr] = useState("");
  const [showModal,setModal] = useState(false);
  const [step,setStep]       = useState("form");  // form | testing | confirm | saving
  const [testResult,setTest] = useState(null);    // {ok, message, system_info}
  const [saving,setSaving]   = useState(false);
  const [formErr,setFormErr] = useState("");
  const EMPTY={vendor:"",name:"",ip:"",user:"",pass:"",port:"",site:"dc",capacity_tb:""};
  const [form,setForm]       = useState(EMPTY);

  // Load arrays from backend on mount
  useEffect(()=>{
    fetchStorageArrays()
      .then(setArrays)
      .catch(e=>setListErr(e.message||"Failed to load arrays"))
      .finally(()=>setLL(false));
  },[]);

  function openModal(){setForm(EMPTY);setFormErr("");setStep("form");setTest(null);setModal(true);}
  function closeModal(){if(step==="testing"||saving)return;setModal(false);}
  function setF(k,v){setForm(f=>({...f,[k]:v}));}

  async function handleTest(){
    if(!form.vendor){setFormErr("Please select a vendor.");return;}
    if(!form.name.trim()){setFormErr("Array name is required.");return;}
    if(!form.ip.trim()){setFormErr("Management IP is required.");return;}
    if(!form.user.trim()){setFormErr("Username is required.");return;}
    if(!form.pass.trim()){setFormErr("Password is required.");return;}
    setFormErr("");setStep("testing");
    const result=await testStorageConnection({
      vendor:form.vendor, ip:form.ip.trim(),
      port:form.port.trim(), username:form.user.trim(), password:form.pass.trim()
    });
    setTest(result);
    setStep("confirm");
  }

  async function handleSave(){
    setSaving(true);
    try{
      const arr=await createStorageArray({
        vendor:form.vendor, name:form.name.trim(), ip:form.ip.trim(),
        port:form.port.trim(), username:form.user.trim(), password:form.pass.trim(),
        site:form.site, capacity_tb:form.capacity_tb?parseFloat(form.capacity_tb):0,
      });
      setArrays(prev=>[...prev,arr]);
      setModal(false);
    }catch(e){
      setFormErr(e.message||"Failed to save array.");
      setStep("confirm");
    }finally{setSaving(false);}
  }

  async function handleRemove(id){
    try{
      await deleteStorageArray(id);
      setArrays(prev=>prev.filter(a=>a.id!==id));
    }catch(e){alert("Remove failed: "+e.message);}
  }

  const inputStyle={width:"100%",padding:"8px 11px",borderRadius:7,border:`1px solid ${p.border}`,background:p.panelAlt,color:p.text,fontSize:12,outline:"none",boxSizing:"border-box"};
  const labelStyle={display:"block",fontSize:9,color:p.textMute,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",marginBottom:3};

  return(
    <div className="g-gap">
      {/* page header */}
      <div className="card" style={{padding:"16px 20px",display:"flex",alignItems:"center",gap:14,background:`linear-gradient(135deg,${p.panel},${p.panelAlt})`,border:`1px solid ${p.border}`}}>
        <div style={{width:42,height:42,borderRadius:11,background:"linear-gradient(135deg,#3b82f6,#06b6d4)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,flexShrink:0}}>🗂️</div>
        <div style={{flex:1}}>
          <div style={{fontWeight:900,fontSize:15,letterSpacing:"1.5px",textTransform:"uppercase",background:"linear-gradient(90deg,#3b82f6,#06b6d4)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent"}}>Storage Management</div>
          <div style={{fontSize:11,color:p.textMute,marginTop:1}}>OEM Arrays · Capacity · Volumes · Health · LaaS Portal</div>
        </div>
        {arrays.length>0&&<div style={{fontSize:11,color:p.textMute,marginRight:8}}><strong style={{color:p.text}}>{arrays.length}</strong> array{arrays.length!==1?"s":""}</div>}
        <button onClick={openModal} style={{padding:"8px 18px",borderRadius:9,border:"none",background:"linear-gradient(90deg,#3b82f6,#06b6d4)",color:"#fff",fontSize:12,fontWeight:700,cursor:"pointer",flexShrink:0}}>
          ＋ Register Storage Array
        </button>
      </div>

      {/* list / empty state */}
      {loadingList?(
        <div className="card" style={{padding:"48px",textAlign:"center",color:p.textMute,fontSize:12}}>
          <div style={{fontSize:28,marginBottom:10,animation:"_stor_spin 1s linear infinite",display:"inline-block"}}>⚙️</div>
          <div>Loading arrays…</div>
        </div>
      ):listErr?(
        <div className="card" style={{padding:"32px",textAlign:"center",color:"#ef4444",fontSize:12}}>⚠ {listErr}</div>
      ):arrays.length===0?(
        <div className="card" style={{padding:"64px 24px",textAlign:"center",border:`1px dashed ${p.border}`}}>
          <div style={{fontSize:52,marginBottom:14,opacity:.3}}>🗂️</div>
          <div style={{fontWeight:700,fontSize:15,color:p.text,marginBottom:8}}>No storage arrays registered yet</div>
          <div style={{fontSize:12,color:p.textMute,maxWidth:440,margin:"0 auto",lineHeight:1.8}}>Click <strong style={{color:p.text}}>Register Storage Array</strong> to connect your first array.<br/>You will need the management IP, credentials, and vendor details.</div>
          <button onClick={openModal} style={{marginTop:16,padding:"8px 22px",borderRadius:9,border:"none",background:"linear-gradient(90deg,#3b82f6,#06b6d4)",color:"#fff",fontSize:12,fontWeight:700,cursor:"pointer"}}>＋ Register Storage Array</button>
        </div>
      ):(
        <div style={{display:"flex",flexDirection:"column",gap:10}}>
          {arrays.map(a=><StorageArrayCard key={a.id} arr={a} p={p} onRemove={handleRemove} currentUser={currentUser}/>)}
        </div>
      )}

      {/* ══ MODAL ══ */}
      {showModal&&(
        <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.65)",zIndex:9999,display:"flex",alignItems:"center",justifyContent:"center"}} onClick={closeModal}>
          <div className="card" style={{width:500,padding:0,overflow:"hidden",maxHeight:"92vh",display:"flex",flexDirection:"column"}} onClick={e=>e.stopPropagation()}>

            {/* modal header */}
            <div style={{padding:"14px 18px",background:`linear-gradient(90deg,#3b82f615,#06b6d408)`,borderBottom:`1px solid ${p.border}`,display:"flex",alignItems:"center",gap:12,flexShrink:0}}>
              <div style={{width:34,height:34,borderRadius:8,background:"linear-gradient(135deg,#3b82f6,#06b6d4)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:17}}>🗂️</div>
              <div style={{flex:1}}>
                <div style={{fontWeight:800,fontSize:13,color:p.text}}>Register Storage Array</div>
                <div style={{fontSize:10,color:p.textMute,marginTop:1}}>
                  {step==="form"&&"Fill in credentials — we'll test the connection first"}
                  {step==="testing"&&"Testing connection to array…"}
                  {step==="confirm"&&(testResult?.ok?"Connection successful — review details and save":"Connection failed — check credentials")}
                </div>
              </div>
              {step!=="testing"&&!saving&&(
                <button onClick={closeModal} style={{background:"none",border:"none",fontSize:18,cursor:"pointer",color:p.textMute,lineHeight:1}}>✕</button>
              )}
            </div>

            <div style={{padding:"20px 22px 22px",overflowY:"auto"}}>

              {/* ── FORM ── */}
              {step==="form"&&(
                <div style={{display:"flex",flexDirection:"column",gap:14}}>
                  <div>
                    <label style={labelStyle}>Vendor <span style={{color:"#ef4444"}}>*</span></label>
                    <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8}}>
                      {_STOR_VENDORS.map(v=>(
                        <button key={v.id} onClick={()=>setF("vendor",v.id)}
                          style={{padding:"9px 8px",borderRadius:8,border:`2px solid ${form.vendor===v.id?v.color:p.border}`,background:form.vendor===v.id?`${v.color}14`:p.panelAlt,cursor:"pointer",textAlign:"center",transition:"all .15s"}}
                          onMouseEnter={e=>{if(form.vendor!==v.id){e.currentTarget.style.borderColor=v.color+"80";e.currentTarget.style.background=v.color+"0a";}}}
                          onMouseLeave={e=>{if(form.vendor!==v.id){e.currentTarget.style.borderColor=p.border;e.currentTarget.style.background=p.panelAlt;}}}>
                          <div style={{fontSize:18,marginBottom:2}}>{v.icon}</div>
                          <div style={{fontSize:10,fontWeight:700,color:form.vendor===v.id?v.color:p.text}}>{v.label}</div>
                        </button>
                      ))}
                    </div>
                  </div>
                  <div>
                    <label style={labelStyle}>Array Name <span style={{color:"#ef4444"}}>*</span></label>
                    <input style={inputStyle} placeholder="e.g.  DC-NetApp-Prod-01" value={form.name} onChange={e=>setF("name",e.target.value)}
                      onFocus={e=>e.target.style.borderColor="#3b82f6"} onBlur={e=>e.target.style.borderColor=p.border}/>
                  </div>
                  <div>
                    <label style={labelStyle}>Management IP / Hostname <span style={{color:"#ef4444"}}>*</span></label>
                    <input style={inputStyle} placeholder="e.g.  192.168.10.50  or  array.mgmt.local  (no https://)" value={form.ip}
                      onChange={e=>setF("ip",e.target.value.replace(/^https?:\/\//i,"").replace(/\/+$/,""))}
                      onFocus={e=>e.target.style.borderColor="#3b82f6"} onBlur={e=>e.target.style.borderColor=p.border}/>
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
                    <div>
                      <label style={labelStyle}>Username <span style={{color:"#ef4444"}}>*</span></label>
                      <input style={inputStyle} placeholder="e.g.  admin" value={form.user} onChange={e=>setF("user",e.target.value)}
                        onFocus={e=>e.target.style.borderColor="#3b82f6"} onBlur={e=>e.target.style.borderColor=p.border}/>
                    </div>
                    <div>
                      <label style={labelStyle}>Password <span style={{color:"#ef4444"}}>*</span></label>
                      <input style={inputStyle} type="password" placeholder="••••••••" value={form.pass} onChange={e=>setF("pass",e.target.value)}
                        onFocus={e=>e.target.style.borderColor="#3b82f6"} onBlur={e=>e.target.style.borderColor=p.border}/>
                    </div>
                  </div>
                  <div style={{borderTop:`1px solid ${p.border}`,paddingTop:12}}>
                    <div style={{fontSize:9,color:p.textMute,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",marginBottom:10}}>Optional</div>
                    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:12}}>
                      <div>
                        <label style={labelStyle}>Port</label>
                        <input style={inputStyle} placeholder="443" value={form.port} onChange={e=>setF("port",e.target.value)}
                          onFocus={e=>e.target.style.borderColor="#3b82f6"} onBlur={e=>e.target.style.borderColor=p.border}/>
                      </div>
                      <div>
                        <label style={labelStyle}>Site</label>
                        <select style={{...inputStyle,cursor:"pointer"}} value={form.site} onChange={e=>setF("site",e.target.value)}>
                          <option value="dc">Primary DC</option>
                          <option value="dr">DR Site</option>
                          <option value="other">Other</option>
                        </select>
                      </div>
                      <div>
                        <label style={labelStyle}>Capacity (TB)</label>
                        <input style={inputStyle} type="number" placeholder="e.g. 500" value={form.capacity_tb} onChange={e=>setF("capacity_tb",e.target.value)}
                          onFocus={e=>e.target.style.borderColor="#3b82f6"} onBlur={e=>e.target.style.borderColor=p.border}/>
                      </div>
                    </div>
                  </div>
                  {formErr&&<div style={{padding:"8px 12px",borderRadius:7,background:"#ef444412",border:"1px solid #ef444430",fontSize:11,color:"#ef4444"}}>{formErr}</div>}
                  <div style={{display:"flex",gap:10}}>
                    <button onClick={closeModal} style={{flex:1,padding:"9px",borderRadius:8,border:`1px solid ${p.border}`,background:"none",color:p.textMute,fontSize:12,cursor:"pointer",fontWeight:600}}>Cancel</button>
                    <button onClick={handleTest} style={{flex:2,padding:"9px",borderRadius:8,border:"none",background:"linear-gradient(90deg,#3b82f6,#06b6d4)",color:"#fff",fontSize:12,cursor:"pointer",fontWeight:700}}>Test Connection</button>
                  </div>
                </div>
              )}

              {/* ── TESTING ── */}
              {step==="testing"&&(
                <div style={{textAlign:"center",padding:"32px 0 24px"}}>
                  <div style={{fontSize:42,marginBottom:14,display:"inline-block",animation:"_stor_spin 1s linear infinite"}}>⚙️</div>
                  <div style={{fontWeight:700,fontSize:13,color:p.text,marginBottom:4}}>Connecting to {form.ip}…</div>
                  <div style={{fontSize:11,color:p.textMute}}>Authenticating credentials and probing array management API</div>
                </div>
              )}

              {/* ── CONFIRM ── */}
              {step==="confirm"&&testResult&&(
                <div style={{display:"flex",flexDirection:"column",gap:14}}>
                  {/* Connection result banner */}
                  <div style={{padding:"14px 16px",borderRadius:9,
                    background:testResult.ok?"#10b98112":"#ef444412",
                    border:`1px solid ${testResult.ok?"#10b98135":"#ef444435"}`}}>
                    <div style={{display:"flex",alignItems:"center",gap:9,marginBottom:testResult.system_info?8:0}}>
                      <span style={{fontSize:20}}>{testResult.ok?"✅":"❌"}</span>
                      <div>
                        <div style={{fontWeight:700,fontSize:12,color:testResult.ok?"#10b981":"#ef4444"}}>{testResult.ok?"Connection Successful":"Connection Failed"}</div>
                        <div style={{fontSize:11,color:p.textMute,marginTop:2}}>{testResult.message}</div>
                      </div>
                    </div>
                    {testResult.ok&&testResult.system_info&&(
                      <div style={{display:"grid",gridTemplateColumns:"repeat(2,1fr)",gap:7,marginTop:10}}>
                        {Object.entries(testResult.system_info).filter(([,v])=>v).map(([k,v])=>(
                          <div key={k} style={{padding:"6px 9px",borderRadius:6,background:p.panel,border:`1px solid ${p.border}`}}>
                            <div style={{fontSize:9,color:p.textMute,textTransform:"uppercase",letterSpacing:".4px",marginBottom:1}}>{k.replace(/_/g," ")}</div>
                            <div style={{fontSize:11,fontWeight:700,color:p.text,wordBreak:"break-all"}}>{String(v)}</div>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>

                  <div style={{padding:"10px 14px",borderRadius:8,background:p.panelAlt,border:`1px solid ${p.border}`,fontSize:11,color:p.textMute}}>
                    <strong style={{color:p.text}}>Saving as:</strong> {form.name} · {form.vendor} · {form.ip}
                  </div>

                  {formErr&&<div style={{padding:"8px 12px",borderRadius:7,background:"#ef444412",border:"1px solid #ef444430",fontSize:11,color:"#ef4444"}}>{formErr}</div>}

                  <div style={{display:"flex",gap:10}}>
                    <button onClick={()=>{setStep("form");setTest(null);setFormErr("");}}
                      style={{flex:1,padding:"9px",borderRadius:8,border:`1px solid ${p.border}`,background:"none",color:p.textMute,fontSize:12,cursor:"pointer",fontWeight:600}}>
                      ← Back
                    </button>
                    {testResult.ok?(
                      <button onClick={handleSave} disabled={saving}
                        style={{flex:2,padding:"9px",borderRadius:8,border:"none",background:saving?"#1e3a5f":"linear-gradient(90deg,#3b82f6,#06b6d4)",color:"#fff",fontSize:12,cursor:saving?"not-allowed":"pointer",fontWeight:700}}>
                        {saving?"Saving…":"Save Array"}
                      </button>
                    ):(
                      <button onClick={()=>{setStep("form");setTest(null);setFormErr("");}}
                        style={{flex:2,padding:"9px",borderRadius:8,border:"none",background:"#ef4444",color:"#fff",fontSize:12,cursor:"pointer",fontWeight:700}}>
                        Fix Credentials
                      </button>
                    )}
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      )}
      <style>{`@keyframes _stor_spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}`}</style>
    </div>
  );
}
// ─── RUBRIK FORM INPUT (top-level to avoid remount on rerender) ──────────────
function RubrikFI({label,value,onChange,type,placeholder,p}){
  return(
    <div style={{flex:1,minWidth:160}}>
      <div style={{fontSize:9,color:p.textMute,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",marginBottom:3}}>{label}</div>
      <input type={type||"text"} value={value} onChange={e=>onChange(e.target.value)} placeholder={placeholder||""}
        style={{width:"100%",padding:"7px 10px",borderRadius:7,border:`1px solid ${p.border}`,background:p.panelAlt,color:p.text,fontSize:11,outline:"none",boxSizing:"border-box"}}/>
    </div>
  );
}

// ─── BACKUP PAGE (Rubrik Security Cloud) ─────────────────
function BackupPage({currentUser,p}){
  const [connections, setConns]   = useState([]);
  const [loadingList, setLLst]    = useState(true);
  const [showAdd,  setShowAdd]    = useState(false);
  const [testStep, setTestStep]   = useState(null);
  const [testMsg,  setTestMsg]    = useState("");
  const [form, setForm]           = useState({name:"",url:"https://wipro.my.rubrik.com",username:"",password:""});
  const [saving,   setSaving]     = useState(false);
  const canEdit = currentUser?.role==="admin"||currentUser?.role==="operator";

  useEffect(()=>{ loadList(); },[]);

  async function loadList(){
    setLLst(true);
    try{ const d=await fetchRubrikConnections(); setConns(d||[]); }
    catch(_){}
    finally{ setLLst(false); }
  }
  async function doTest(){
    if(!form.url||!form.username||!form.password) return;
    setTestStep("testing"); setTestMsg("");
    try{
      const r=await testRubrikConnection({url:form.url,username:form.username,password:form.password});
      if(r.ok){ setTestStep("ok"); setTestMsg(r.message||"Connected"); }
      else{ setTestStep("err"); setTestMsg(r.message||"Failed"); }
    }catch(e){ setTestStep("err"); setTestMsg(e.message); }
  }
  async function doSave(){
    setSaving(true);
    try{
      await createRubrikConnection(form);
      setShowAdd(false); setForm({name:"",url:"https://wipro.my.rubrik.com",username:"",password:""});
      setTestStep(null); setTestMsg(""); loadList();
    }catch(e){ setTestMsg(e.message||"Save failed"); }
    finally{ setSaving(false); }
  }
  async function doRemove(id,name){
    if(!window.confirm(`Remove Rubrik connection "${name}"?`)) return;
    try{ await deleteRubrikConnection(id); loadList(); }catch(_){}
  }
  return(
    <div className="g-gap">
      {/* Header */}
      <div className="card" style={{padding:"18px 22px",display:"flex",alignItems:"center",gap:14,background:`linear-gradient(135deg,${p.panel},${p.panelAlt})`,border:`1px solid ${p.border}`}}>
        <div style={{width:44,height:44,borderRadius:11,background:"linear-gradient(135deg,#3b82f6,#8b5cf6)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:24,flexShrink:0}}>☁️</div>
        <div style={{flex:1}}>
          <div style={{fontWeight:900,fontSize:16,letterSpacing:"1.5px",textTransform:"uppercase",background:"linear-gradient(90deg,#3b82f6,#8b5cf6)",WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent"}}>Rubrik Backup</div>
          <div style={{fontSize:11,color:p.textMute,marginTop:2}}>Rubrik Security Cloud · SLA Domains · Protected VMs · Jobs · Capacity</div>
        </div>
        {canEdit&&<button onClick={()=>{setShowAdd(s=>!s);setTestStep(null);setTestMsg("");}} style={{padding:"7px 18px",borderRadius:8,border:"1px solid #3b82f640",background:"#3b82f610",color:"#3b82f6",fontSize:11,fontWeight:700,cursor:"pointer"}}>{showAdd?"✕ Cancel":"＋ Add RSC Connection"}</button>}
      </div>

      {/* Add form */}
      {showAdd&&(
        <div className="card" style={{padding:"16px 20px"}}>
          <div style={{fontWeight:700,fontSize:12,color:p.text,marginBottom:12}}>Connect to Rubrik Security Cloud</div>
          <div style={{display:"flex",flexWrap:"wrap",gap:10,marginBottom:12}}>
            <RubrikFI p={p} label="Connection Name *" value={form.name} onChange={v=>setForm(f=>({...f,name:v}))} placeholder="e.g. Wipro RSC"/>
            <RubrikFI p={p} label="RSC URL *" value={form.url} onChange={v=>setForm(f=>({...f,url:v}))} placeholder="https://org.my.rubrik.com"/>
            <RubrikFI p={p} label="Username *" value={form.username} onChange={v=>setForm(f=>({...f,username:v}))} placeholder="admin@domain.com"/>
            <RubrikFI p={p} label="Password *" value={form.password} onChange={v=>setForm(f=>({...f,password:v}))} type="password" placeholder="••••••••"/>
          </div>
          <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"}}>
            <button disabled={!form.url||!form.username||!form.password||testStep==="testing"}
              onClick={doTest}
              style={{padding:"6px 16px",borderRadius:7,border:"1px solid #06b6d440",background:"#06b6d410",color:"#06b6d4",fontSize:11,fontWeight:700,cursor:"pointer",opacity:testStep==="testing"?0.5:1}}>
              {testStep==="testing"?"Testing…":"🔌 Test Connection"}
            </button>
            <button disabled={testStep!=="ok"||saving||!form.name}
              onClick={doSave}
              style={{padding:"6px 16px",borderRadius:7,border:"none",background:testStep==="ok"&&form.name?"#3b82f6":"#3b82f640",color:"#fff",fontSize:11,fontWeight:700,cursor:testStep==="ok"&&form.name?"pointer":"default",opacity:saving?0.5:1}}>
              {saving?"Saving…":"✓ Save Connection"}
            </button>
            {testMsg&&<span style={{fontSize:11,color:testStep==="ok"?"#10b981":"#ef4444",fontWeight:600}}>{testStep==="ok"?"✓":"✗"} {testMsg}</span>}
          </div>
        </div>
      )}

      {loadingList&&<div style={{textAlign:"center",padding:"40px 0",color:p.textMute,fontSize:13}}>Loading connections…</div>}

      {!loadingList&&connections.length===0&&!showAdd&&(
        <div className="card" style={{padding:"52px 24px",textAlign:"center",border:`1px dashed ${p.border}`}}>
          <div style={{fontSize:52,marginBottom:14,opacity:.35}}>☁️</div>
          <div style={{fontWeight:700,fontSize:15,color:p.text,marginBottom:8}}>No Rubrik RSC connections yet</div>
          <div style={{fontSize:12,color:p.textMute,maxWidth:400,margin:"0 auto",lineHeight:1.7}}>Click "＋ Add RSC Connection" to connect to your Rubrik Security Cloud account and monitor backup jobs, SLA domains, and protected workloads.</div>
        </div>
      )}

      {connections.map(c=>(
        <RubrikCard key={c.id} conn={c} p={p} canEdit={canEdit} onRemove={doRemove}/>
      ))}
    </div>
  );
}

// ─── RUBRIK CARD ──────────────────────────────────────────
function RubrikCard({conn,p,canEdit,onRemove}){
  const [open,    setOpen]    = useState(false);
  const [live,    setLive]    = useState(null);
  const [loading, setLoading] = useState(false);
  const [err,     setErr]     = useState("");
  const [tab,     setTab]     = useState("overview");

  async function expand(){
    const next=!open; setOpen(next);
    if(next&&!live&&!loading){
      setLoading(true); setErr("");
      try{ const d=await fetchRubrikData(conn.id); setLive(d); }
      catch(e){ setErr(e.message||"Failed"); }
      finally{ setLoading(false); }
    }
  }
  async function refresh(){
    setLive(null); setLoading(true); setErr(""); setTab("overview");
    try{ const d=await fetchRubrikData(conn.id); setLive(d); }
    catch(e){ setErr(e.message); }
    finally{ setLoading(false); }
  }

  const s   = live?.summary||{};
  const sla = live?.sla_domains||[];
  const pvm = live?.protected_vms||[];
  const uvm = live?.unprotected_vms||[];
  const jobs= live?.recent_jobs||[];
  const evs = live?.events||[];
  const cls = live?.clusters||[];

  function _fmt(b){ if(!b) return "—"; if(b>=1e12) return (b/1e12).toFixed(2)+" TB"; if(b>=1e9) return (b/1e9).toFixed(2)+" GB"; if(b>=1e6) return (b/1e6).toFixed(1)+" MB"; return b+" B"; }
  function sc(st){ const c=st==="Success"||st==="Succeeded"||st==="Online"||st==="Connected"?"#10b981":st==="Failed"||st==="Failure"||st==="Disconnected"?"#ef4444":st==="Running"||st==="InProgress"?"#3b82f6":"#f59e0b"; return<span style={{padding:"1px 6px",borderRadius:8,fontSize:9,fontWeight:700,background:c+"18",border:`1px solid ${c}35`,color:c}}>{st||"?"}</span>; }
  function TH({c,r}){return<th style={{padding:"5px 8px",textAlign:r?"right":"left",fontSize:9,textTransform:"uppercase",letterSpacing:".4px",color:p.textMute,fontWeight:600,borderBottom:`1px solid ${p.border}`,whiteSpace:"nowrap"}}>{c}</th>;}
  function TD({c,r,color}){return<td style={{padding:"5px 8px",fontSize:11,textAlign:r?"right":"left",color:color||p.text,verticalAlign:"top",borderBottom:`1px solid ${p.border}22`}}>{c}</td>;}

  const tabs=[
    {id:"overview",label:"Overview"},
    ...(sla.length?[{id:"sla",label:`SLA Domains (${sla.length})`}]:[]),
    ...(pvm.length?[{id:"pvms",label:`Protected VMs (${s.protected_count??pvm.length})`}]:[]),
    ...(uvm.length?[{id:"uvms",label:`Unprotected (${s.unprotected_count??uvm.length})`,warn:true}]:[]),
    ...(jobs.length?[{id:"jobs",label:`Recent Jobs (${jobs.length})`}]:[]),
    ...(evs.length?[{id:"events",label:`Events (${evs.length})`}]:[]),
    ...(cls.length?[{id:"clusters",label:`Clusters (${cls.length})`}]:[]),
  ];

  return(
    <div style={{border:`1px solid ${p.border}`,borderRadius:10,overflow:"hidden",background:p.panel}}>
      <div style={{padding:"12px 16px",display:"flex",alignItems:"center",gap:12,cursor:"pointer",background:"linear-gradient(90deg,#3b82f610,transparent)"}} onClick={expand}>
        <div style={{width:36,height:36,borderRadius:8,background:"#3b82f618",border:"1px solid #3b82f630",display:"flex",alignItems:"center",justifyContent:"center",fontSize:20,flexShrink:0}}>☁️</div>
        <div style={{flex:1,minWidth:0}}>
          <div style={{display:"flex",alignItems:"center",gap:7,flexWrap:"wrap"}}>
            <span style={{fontWeight:800,fontSize:13,color:p.text}}>{conn.name}</span>
            <span style={{fontSize:10,padding:"1px 7px",borderRadius:10,background:p.panelAlt,border:`1px solid ${p.border}`,color:p.textMute}}>Rubrik RSC</span>
            <span style={{fontSize:10,padding:"2px 8px",borderRadius:10,background:conn.status==="ok"?"#10b98115":"#f59e0b15",border:`1px solid ${conn.status==="ok"?"#10b98135":"#f59e0b35"}`,color:conn.status==="ok"?"#10b981":"#f59e0b",fontWeight:700}}>{conn.status==="ok"?"✓ Connected":"⏳ Pending"}</span>
          </div>
          <div style={{fontSize:10,color:p.textMute,marginTop:2}}>{conn.url}</div>
        </div>
        {live&&(
          <div style={{display:"flex",gap:14,fontSize:10,flexShrink:0}}>
            <span title="Protected VMs">🛡️ <strong style={{color:"#10b981"}}>{s.protected_count??pvm.length}</strong></span>
            <span title="Unprotected"  >⚠️ <strong style={{color:uvm.length?"#ef4444":"#10b981"}}>{s.unprotected_count??uvm.length}</strong></span>
            <span title="Jobs"         >⚡ <strong style={{color:"#3b82f6"}}>{s.job_count??jobs.length}</strong></span>
          </div>
        )}
        <span style={{fontSize:10,color:p.textMute,marginLeft:4}}>{open?"▲":"▼"}</span>
      </div>

      {open&&(
        <div style={{borderTop:`1px solid ${p.border}`,background:p.panelAlt}}>
          {loading&&<div style={{textAlign:"center",padding:"28px 0",color:p.textMute,fontSize:12}}><div style={{fontSize:26,marginBottom:8}}>☁️</div>Fetching data from Rubrik RSC…</div>}
          {err&&<div style={{margin:"12px 16px",padding:"12px",borderRadius:8,background:"#ef444412",border:"1px solid #ef444430",color:"#ef4444",fontSize:12}}>⚠ {err}</div>}

          {live&&!loading&&(
            <>
              <div style={{display:"flex",gap:0,borderBottom:`1px solid ${p.border}`,paddingLeft:16,overflowX:"auto"}}>
                {tabs.map(t=>(
                  <button key={t.id} onClick={()=>setTab(t.id)}
                    style={{padding:"8px 14px",border:"none",borderBottom:tab===t.id?"2px solid #3b82f6":"2px solid transparent",
                      background:"none",color:tab===t.id?"#3b82f6":t.warn?"#ef4444":p.textMute,
                      fontSize:11,fontWeight:tab===t.id?700:500,cursor:"pointer",whiteSpace:"nowrap"}}>
                    {t.label}
                  </button>
                ))}
              </div>

              <div style={{padding:"14px 16px"}}>

                {tab==="overview"&&(
                  <>
                    <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(140px,1fr))",gap:8,marginBottom:14}}>
                      {[
                        {icon:"🛡️",label:"Protected VMs",  v:s.protected_count??"—",   c:"#10b981"},
                        {icon:"⚠️",label:"Unprotected",    v:s.unprotected_count??"—", c:s.unprotected_count?"#ef4444":"#10b981"},
                        {icon:"📋",label:"SLA Domains",    v:s.sla_count??"—",         c:"#8b5cf6"},
                        {icon:"✅",label:"Jobs OK",         v:s.jobs_ok??"—",           c:"#10b981"},
                        {icon:"❌",label:"Jobs Failed",     v:s.jobs_fail??"—",         c:s.jobs_fail?"#ef4444":"#10b981"},
                        {icon:"⚡",label:"Jobs Running",   v:s.jobs_running??"—",      c:"#3b82f6"},
                        {icon:"🖥️",label:"Clusters",       v:s.cluster_count??"—",     c:"#06b6d4"},
                        {icon:"💾",label:"Used Storage",   v:_fmt(s.used_bytes),        c:"#f59e0b"},
                      ].map(({icon,label,v,c})=>(
                        <div key={label} style={{padding:"10px 8px",borderRadius:8,background:p.panel,border:`1px solid ${p.border}`,textAlign:"center"}}>
                          <div style={{fontSize:15,marginBottom:3}}>{icon}</div>
                          <div style={{fontSize:15,fontWeight:900,color:c,lineHeight:1}}>{v}</div>
                          <div style={{fontSize:9,color:p.textMute,marginTop:3,textTransform:"uppercase",letterSpacing:".4px"}}>{label}</div>
                        </div>
                      ))}
                    </div>
                    {cls.length>0&&(
                      <div style={{marginBottom:12}}>
                        <div style={{fontWeight:700,fontSize:11,color:p.text,marginBottom:8}}>Cluster Capacity</div>
                        {cls.map((c,i)=>{const pct=c.total_bytes?Math.round(c.used_bytes/c.total_bytes*100):0;const bc=pct>80?"#ef4444":pct>60?"#f59e0b":"#10b981";return(
                          <div key={i} style={{marginBottom:8,padding:"10px 12px",borderRadius:8,background:p.panel,border:`1px solid ${p.border}`}}>
                            <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:5,flexWrap:"wrap",gap:6}}>
                              <span style={{fontWeight:700,fontSize:11,color:p.text}}>🖥️ {c.name}</span>
                              {sc(c.status)}<span style={{fontSize:10,color:p.textMute}}>v{c.version}</span>
                              <span style={{fontSize:10,color:bc,fontWeight:700}}>{pct}% used</span>
                            </div>
                            <div style={{height:8,borderRadius:4,background:p.border,overflow:"hidden"}}><div style={{height:"100%",width:pct+"%",background:bc,borderRadius:4}}/></div>
                            <div style={{display:"flex",justifyContent:"space-between",fontSize:9,color:p.textMute,marginTop:3}}>
                              <span>Used {_fmt(c.used_bytes)}</span><span>Free {_fmt(c.free_bytes)}</span><span>Total {_fmt(c.total_bytes)}</span>
                            </div>
                          </div>
                        );})}
                      </div>
                    )}
                    {jobs.length>0&&(
                      <div>
                        <div style={{fontWeight:700,fontSize:11,color:p.text,marginBottom:7}}>Recent Jobs (latest 5)</div>
                        {jobs.slice(0,5).map((j,i)=>(
                          <div key={i} style={{display:"flex",alignItems:"center",gap:8,padding:"6px 8px",borderRadius:7,background:p.panel,marginBottom:4,border:`1px solid ${p.border}44`}}>
                            {sc(j.status)}
                            <span style={{fontWeight:700,fontSize:11,color:p.text,flex:1,minWidth:0,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{j.object_name}</span>
                            <span style={{fontSize:10,color:"#8b5cf6"}}>{j.sla}</span>
                            <span style={{fontSize:9,color:p.textMute,whiteSpace:"nowrap"}}>{j.start?new Date(j.start).toLocaleString():""}</span>
                            {j.data_bytes&&<span style={{fontSize:9,color:"#06b6d4",whiteSpace:"nowrap"}}>{_fmt(j.data_bytes)}</span>}
                          </div>
                        ))}
                      </div>
                    )}
                  </>
                )}

                {tab==="sla"&&(
                  <div style={{overflowX:"auto"}}>
                    <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                      <thead><tr style={{background:p.panel}}><TH c="SLA Name"/><TH c="Object Types"/><TH c="Protected" r/><TH c="Frequency"/><TH c="Retention"/><TH c="Replication"/><TH c="Archival"/></tr></thead>
                      <tbody>{sla.map((s,i)=>(
                        <tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
                          <td style={{padding:"5px 8px",fontWeight:700,color:p.text,borderBottom:`1px solid ${p.border}22`}}>{s.name}</td>
                          <TD c={(s.object_types||[]).join(", ")||"—"} color={p.textMute}/>
                          <TD c={s.protected_count??"—"} r/><TD c={s.frequency||"—"} color={p.textMute}/><TD c={s.retention||"—"} color={p.textMute}/>
                          <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}><span style={{color:s.replication?"#10b981":p.textMute}}>{s.replication?"✓":"—"}</span></td>
                          <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}><span style={{color:s.archival?"#10b981":p.textMute}}>{s.archival?"✓":"—"}</span></td>
                        </tr>
                      ))}</tbody>
                    </table>
                  </div>
                )}

                {tab==="pvms"&&(
                  <div style={{overflowX:"auto"}}>
                    <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                      <thead><tr style={{background:p.panel}}><TH c="VM Name"/><TH c="SLA Domain"/><TH c="Cluster"/><TH c="Power"/><TH c="Last Backup"/><TH c="Status"/><TH c="Oldest Backup"/></tr></thead>
                      <tbody>{pvm.map((v,i)=>(
                        <tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
                          <td style={{padding:"5px 8px",fontWeight:700,color:p.text,borderBottom:`1px solid ${p.border}22`}}>{v.name}</td>
                          <TD c={v.sla_name||"—"} color="#8b5cf6"/><TD c={v.cluster||"—"} color={p.textMute}/>
                          <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}><span style={{fontSize:9,color:v.power==="poweredOn"?"#10b981":p.textMute}}>{v.power||"—"}</span></td>
                          <TD c={v.last_backup?new Date(v.last_backup).toLocaleString():"—"} color={p.textMute}/>
                          <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}>{v.last_status?sc(v.last_status):"—"}</td>
                          <TD c={v.oldest_backup?new Date(v.oldest_backup).toLocaleDateString():"—"} color={p.textMute}/>
                        </tr>
                      ))}</tbody>
                    </table>
                  </div>
                )}

                {tab==="uvms"&&(
                  <>
                    <div style={{padding:"8px 12px",borderRadius:7,background:"#ef444410",border:"1px solid #ef444430",color:"#ef4444",fontSize:11,fontWeight:600,marginBottom:10}}>
                      ⚠ {uvm.length} VM{uvm.length!==1?"s":""} without SLA domain protection
                    </div>
                    <div style={{overflowX:"auto"}}>
                      <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                        <thead><tr style={{background:p.panel}}><TH c="VM Name"/><TH c="Cluster"/><TH c="Power"/><TH c="SLA Assignment"/></tr></thead>
                        <tbody>{uvm.map((v,i)=>(
                          <tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
                            <td style={{padding:"5px 8px",fontWeight:700,color:"#ef4444",borderBottom:`1px solid ${p.border}22`}}>⚠ {v.name}</td>
                            <TD c={v.cluster||"—"} color={p.textMute}/>
                            <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}><span style={{fontSize:9,color:v.power==="poweredOn"?"#10b981":p.textMute}}>{v.power||"—"}</span></td>
                            <TD c={v.sla_assignment||"Unprotected"} color={p.textMute}/>
                          </tr>
                        ))}</tbody>
                      </table>
                    </div>
                  </>
                )}

                {tab==="jobs"&&(
                  <div style={{overflowX:"auto"}}>
                    <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                      <thead><tr style={{background:p.panel}}><TH c="Object"/><TH c="Status"/><TH c="SLA"/><TH c="Cluster"/><TH c="Start"/><TH c="End"/><TH c="Data" r/><TH c="Progress" r/></tr></thead>
                      <tbody>{jobs.map((j,i)=>(
                        <tr key={i} style={{background:i%2===0?p.panel+"88":"transparent"}}>
                          <td style={{padding:"5px 8px",fontWeight:700,color:p.text,borderBottom:`1px solid ${p.border}22`,maxWidth:180,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{j.object_name}</td>
                          <td style={{padding:"5px 8px",borderBottom:`1px solid ${p.border}22`}}>{sc(j.status)}</td>
                          <TD c={j.sla||"—"} color="#8b5cf6"/><TD c={j.cluster||"—"} color={p.textMute}/>
                          <TD c={j.start?new Date(j.start).toLocaleString():"—"} color={p.textMute}/>
                          <TD c={j.end?new Date(j.end).toLocaleString():"—"} color={p.textMute}/>
                          <TD c={j.data_bytes?_fmt(j.data_bytes):"—"} r color="#06b6d4"/>
                          <TD c={j.progress!=null?j.progress+"%":"—"} r/>
                        </tr>
                      ))}</tbody>
                    </table>
                  </div>
                )}

                {tab==="events"&&(
                  <div>{evs.map((ev,i)=>{
                    const c=ev.status==="Success"||ev.status==="Succeeded"?"#10b981":ev.status==="Failed"||ev.status==="Failure"?"#ef4444":"#f59e0b";
                    return(
                      <div key={i} style={{display:"flex",gap:10,padding:"7px 10px",borderRadius:7,background:i%2===0?p.panel:"transparent",marginBottom:3,border:`1px solid ${p.border}44`}}>
                        <span style={{fontSize:10,fontWeight:700,color:c,minWidth:80}}>{ev.action||"—"}</span>
                        {sc(ev.status)}
                        <span style={{fontSize:11,color:p.text,flex:1}}>{ev.object}</span>
                        <span style={{fontSize:10,color:p.textMute}}>{ev.type}</span>
                        <span style={{fontSize:9,color:p.textMute,whiteSpace:"nowrap"}}>{ev.cluster}</span>
                        <span style={{fontSize:9,color:p.textMute,whiteSpace:"nowrap"}}>{ev.time?new Date(ev.time).toLocaleString():""}</span>
                      </div>
                    );
                  })}</div>
                )}

                {tab==="clusters"&&(
                  <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(280px,1fr))",gap:10}}>
                    {cls.map((c,i)=>{const pct=c.total_bytes?Math.round(c.used_bytes/c.total_bytes*100):0;const bc=pct>80?"#ef4444":pct>60?"#f59e0b":"#10b981";return(
                      <div key={i} style={{padding:"12px 14px",borderRadius:9,border:`1px solid ${p.border}`,background:p.panel}}>
                        <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:8}}>
                          <span style={{fontWeight:800,fontSize:12,color:p.text}}>🖥️ {c.name}</span>{sc(c.status)}
                        </div>
                        {[{l:"Version",v:c.version},{l:"Product",v:c.product},{l:"Used",v:_fmt(c.used_bytes)},{l:"Free",v:_fmt(c.free_bytes)},{l:"Total",v:_fmt(c.total_bytes)}].filter(r=>r.v).map(({l,v:val})=>(
                          <div key={l} style={{display:"flex",justifyContent:"space-between",fontSize:10,marginBottom:3}}>
                            <span style={{color:p.textMute}}>{l}</span><span style={{fontWeight:700,color:p.text}}>{val}</span>
                          </div>
                        ))}
                        {c.total_bytes>0&&<>
                          <div style={{height:6,borderRadius:3,background:p.border,overflow:"hidden",marginTop:6}}><div style={{height:"100%",width:pct+"%",background:bc,borderRadius:3}}/></div>
                          <div style={{fontSize:9,color:bc,fontWeight:700,textAlign:"right",marginTop:2}}>{pct}%</div>
                        </>}
                      </div>
                    );})}
                  </div>
                )}

              </div>

              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"6px 16px 12px"}}>
                <button onClick={refresh} style={{padding:"5px 12px",borderRadius:7,border:`1px solid ${p.border}`,background:"none",color:p.textMute,fontSize:10,fontWeight:700,cursor:"pointer"}}>🔄 Refresh</button>
                {canEdit&&<button onClick={()=>onRemove(conn.id,conn.name)} style={{padding:"5px 14px",borderRadius:7,border:"1px solid #ef444435",background:"#ef444410",color:"#ef4444",fontSize:11,fontWeight:700,cursor:"pointer"}}>🗑 Remove</button>}
              </div>
            </>
          )}
        </div>
      )}
    </div>
  );
}

function Sidebar({page,setPage,vcenters,selectedVC,summaries,loading,error,alerts,clock,currentUser,pendingCount,p,ocpData,nutData}){
  ocpData=ocpData||{clusters:[],loading:false,error:null};
  nutData=nutData||{pcs:[],loading:false,error:null};
  const role=currentUser?.role||"viewer";
  const nav=[
    {id:"overview",  label:"Overview",   icon:"🏠", roles:["admin","operator","viewer","requester"]},
    {id:"vms",       label:"VMware", icon:"🖥️", roles:["admin","operator","viewer"]},
    {id:"snapshots", label:"Snapshots",  icon:"📸", roles:["admin","operator","viewer"], sub:true},
    {id:"openshift",  label:"Red Hat OpenShift",icon:"🔴", roles:["admin","operator","viewer"]},
    {id:"nutanix",    label:"Nutanix",           icon:"🟦", roles:["admin","operator","viewer"]},
    {id:"ansible",   label:"Ansible AAP",        icon:"🎛️", roles:["admin","operator","viewer"]},
    {id:"storage",   label:"Storage",             icon:"🗂️", roles:["admin","operator","viewer"]},
    {id:"backup",    label:"Backup",              icon:"🛡️", roles:["admin","operator","viewer"]},
    {id:"project_utilization", label:"Project Utilization", icon:"🏷️", roles:["admin","operator","viewer"]},
    {id:"capacity",  label:"Capacity",   icon:"🗄️", roles:["admin","operator","viewer"]},
    {id:"chargeback",label:"Chargeback",  icon:"💳", roles:["admin","operator","viewer"]},
    {id:"networks",  label:"Networks",   icon:"🌐", roles:["admin","operator","viewer"]},
    {id:"ipam",      label:"IPAM",        icon:"📡", roles:["admin","operator","viewer"]},
    {id:"assets",    label:"Asset Mgmt", icon:"🗃️", roles:["admin","operator","viewer"]},
    {id:"requests",  label:"VM Requests",icon:"📋", roles:["admin","operator","viewer","requester"], badge:pendingCount>0?pendingCount:null},
    {id:"audit",     label:"Audit Log",  icon:"🔍", roles:["admin","operator"]},
    {id:"addns",     label:"AD & DNS",     icon:"🌲", roles:["admin","operator"]},
    {id:"users",     label:"Users & Roles", icon:"👥", roles:["admin"]},
  ].filter(n=>n.roles.includes(role));
  const errCnt=alerts.filter(a=>a.severity==="error").length;
  return(
    <div className="sidebar">
      {/* Portal Header */}
      <div style={{padding:"14px 16px 12px",borderBottom:`1px solid ${p.border}`,background:`linear-gradient(180deg,#0d1829,${p.panel})`}}>
        <div style={{display:"flex",alignItems:"center",gap:11}}>
          <div style={{width:40,height:40,borderRadius:10,background:`linear-gradient(135deg,${p.accent},${p.cyan})`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:20,flexShrink:0,boxShadow:`0 4px 14px ${p.accent}50`}}>⚡</div>
          <div>
            <div style={{fontWeight:800,fontSize:18,lineHeight:1.2,letterSpacing:"-.3px",color:p.text}}>LaaS Portal</div>
            <div style={{fontSize:12,color:p.textMute,marginTop:2,letterSpacing:".4px",fontWeight:500}}>Lab as a Service</div>
          </div>
        </div>
      </div>

      {/* Nav */}
      <nav style={{padding:"10px 8px",flex:1,overflowY:"auto"}}>
        <div className="section-label">Navigation</div>
        {nav.map(n=>(
          <div key={n.id}
            className={`nav-link${page===n.id?" active":""}`}
            onClick={()=>setPage(n.id)}
            style={n.sub?{marginLeft:10,paddingLeft:8,borderLeft:`2px solid ${p.accent}40`}:{}}>
            <span style={{fontSize:n.sub?13:16,width:22,textAlign:"center",flexShrink:0,lineHeight:1}}>{n.icon}</span>
            <span style={{flex:1,fontSize:n.sub?12:undefined,color:n.sub&&page!==n.id?p.textSub:undefined}}>{n.label}</span>
            {n.id==="overview"&&errCnt>0&&<span className="nav-badge" style={{background:`${p.red}20`,color:p.red}}>{errCnt}</span>}
            {n.badge&&n.id!=="overview"&&<span className="nav-badge" style={{background:`${p.accent}20`,color:p.accent}}>{n.badge}</span>}
          </div>
        ))}
      </nav>

      {/* Footer — Analog Clock + Solution Sphere + Multi-Platform Status */}
      <div style={{padding:"12px 14px",borderTop:`1px solid ${p.border}`,background:p.panelAlt}}>
        {/* Analog Clock */}
        {(()=>{
          const H=clock.getHours()%12, M=clock.getMinutes(), S=clock.getSeconds();
          const hDeg=H*30+M*0.5, mDeg=M*6, sDeg=S*6;
          const toXY=(ang,r)=>{const rad=(ang-90)*Math.PI/180;return[50+r*Math.cos(rad),50+r*Math.sin(rad)];};
          const [hx,hy]=toXY(hDeg,20), [mx,my]=toXY(mDeg,28), [sx,sy]=toXY(sDeg,32);
          return(
            <>
              <svg viewBox="0 0 100 100" style={{width:88,height:88,display:"block",margin:"0 auto"}}>
                <circle cx={50} cy={50} r={46} fill={p.panel} stroke={p.accent} strokeWidth={1.5} opacity={.6}/>
                <circle cx={50} cy={50} r={43} fill={p.panelAlt}/>
                {Array.from({length:60},(_,i)=>{
                  const big=i%5===0;
                  const [x1,y1]=toXY(i*6,big?34:37);
                  const [x2,y2]=toXY(i*6,41);
                  return <line key={i} x1={x1} y1={y1} x2={x2} y2={y2}
                    stroke={big?p.accent:p.border} strokeWidth={big?1.8:.7} strokeLinecap="round"/>;
                })}
                {[[0,12],[90,3],[180,6],[270,9]].map(([ang,n])=>{
                  const [tx,ty]=toXY(ang,27);
                  return <text key={n} x={tx} y={ty} textAnchor="middle" dominantBaseline="central"
                    fontSize="7.5" fontWeight="700" fill={p.textMute}>{n}</text>;
                })}
                <line x1={50} y1={50} x2={hx} y2={hy} stroke={p.text} strokeWidth={3} strokeLinecap="round"/>
                <line x1={50} y1={50} x2={mx} y2={my} stroke={p.textSub} strokeWidth={2} strokeLinecap="round"/>
                <line x1={50} y1={50} x2={sx} y2={sy} stroke={p.accent} strokeWidth={1.2} strokeLinecap="round"/>
                <circle cx={50} cy={50} r={3} fill={p.accent}/>
                <circle cx={50} cy={50} r={1.2} fill="#fff"/>
              </svg>
              <div style={{textAlign:"center",marginTop:4,marginBottom:10}}>
                <div style={{fontSize:11,fontWeight:800,color:p.accent,letterSpacing:"1px",textTransform:"uppercase"}}>Solution Sphere</div>
                <div style={{fontSize:10,color:p.textMute,marginTop:1}}>
                  {clock.toLocaleDateString([],{weekday:"short",day:"2-digit",month:"short",year:"numeric"})}
                </div>
              </div>
            </>
          );
        })()}
        <div style={{height:1,background:p.border,marginBottom:8}}/>
        {/* Multi-Platform Live Status */}
        <div style={{display:"flex",flexDirection:"column",gap:4}}>
          {/* VMware */}
          {(()=>{
            const total = vcenters.length;
            const errCnt = summaries.filter(s=>s.status==="error").length;
            const connected = total - errCnt;
            const allErr = total>0 && errCnt===total;
            const someErr = errCnt>0 && !allErr;
            const dotColor = allErr?"#ef4444":someErr?"#f59e0b":loading?"#f59e0b":"#10b981";
            return(
              <div style={{display:"flex",alignItems:"center",gap:6,padding:"3px 0"}}>
                <div style={{width:7,height:7,borderRadius:"50%",flexShrink:0,
                  background:dotColor,boxShadow:"0 0 5px "+dotColor+"90"}}/>
                <span style={{fontSize:11,color:"#60a5fa",fontWeight:600,flex:1}}>🖥️ VMware</span>
                {loading&&total===0
                  ? <span style={{fontSize:10,color:"#f59e0b",fontWeight:500}}>sync</span>
                  : allErr
                    ? <span style={{fontSize:10,color:"#ef4444",fontWeight:600}}>0<span style={{color:"#4b5563"}}>/{total} err</span></span>
                    : someErr
                      ? <span style={{fontSize:10,fontWeight:600}}>
                          <span style={{color:"#10b981"}}>{connected}</span>
                          <span style={{color:"#6b7280"}}>/{total} vC</span>
                        </span>
                      : <span style={{fontSize:10,color:"#10b981",fontWeight:600}}>{total} vC</span>
                }
              </div>
            );
          })()}
          {/* OpenShift */}
          {(()=>{
            const cls=ocpData.clusters||[];
            const ocpErr=ocpData.error;
            const ocpLoad=ocpData.loading;
            const count=cls.length;
            const dotColor=ocpErr?"#ef4444":ocpLoad?"#f59e0b":count?"#10b981":"#4b5563";
            return(
              <div style={{display:"flex",alignItems:"center",gap:6,padding:"3px 0"}}>
                <div style={{width:7,height:7,borderRadius:"50%",flexShrink:0,
                  background:dotColor,boxShadow:"0 0 5px "+dotColor+"90"}}/>
                <span style={{fontSize:11,color:"#f87171",fontWeight:600,flex:1}}>🔴 OpenShift</span>
                {ocpErr
                  ? <span style={{fontSize:10,color:"#ef4444",fontWeight:600}}>error</span>
                  : ocpLoad
                    ? <span style={{fontSize:10,color:"#f59e0b",fontWeight:500}}>sync</span>
                    : count
                      ? <span style={{fontSize:10,fontWeight:600}}>
                          <span style={{color:"#10b981"}}>{count}</span>
                          <span style={{color:"#6b7280"}}> cl</span>
                        </span>
                      : <span style={{fontSize:10,color:"#4b5563"}}>–</span>
                }
              </div>
            );
          })()}
          {/* Nutanix */}
          {(()=>{
            const pcs=nutData.pcs||[];
            const ntErr=nutData.error;
            const ntLoad=nutData.loading;
            const count=pcs.length;
            const dotColor=ntErr?"#ef4444":ntLoad?"#f59e0b":count?"#10b981":"#4b5563";
            return(
              <div style={{display:"flex",alignItems:"center",gap:6,padding:"3px 0"}}>
                <div style={{width:7,height:7,borderRadius:"50%",flexShrink:0,
                  background:dotColor,boxShadow:"0 0 5px "+dotColor+"90"}}/>
                <span style={{fontSize:11,color:"#86efac",fontWeight:600,flex:1}}>🟦 Nutanix</span>
                {ntErr
                  ? <span style={{fontSize:10,color:"#ef4444",fontWeight:600}}>error</span>
                  : ntLoad
                    ? <span style={{fontSize:10,color:"#f59e0b",fontWeight:500}}>sync</span>
                    : count
                      ? <span style={{fontSize:10,fontWeight:600}}>
                          <span style={{color:"#10b981"}}>{count}</span>
                          <span style={{color:"#6b7280"}}> PC</span>
                        </span>
                      : <span style={{fontSize:10,color:"#4b5563"}}>–</span>
                }
              </div>
            );
          })()}
        </div>
      </div>
    </div>
  );
}

