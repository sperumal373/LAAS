// ─── CSS ─────────────────────────────────────────────────────────────────────
const G = (p) => `
  @import url('https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;700&family=Outfit:wght@300;400;500;600;700&display=swap');
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html,body,#root{height:100%;width:100%;overflow:hidden}
  body{background:${p.bg};color:${p.text};font-family:'Outfit',sans-serif;font-size:14px;font-weight:500;line-height:1.6;-webkit-font-smoothing:antialiased}
  ::-webkit-scrollbar{width:10px;height:10px}
  ::-webkit-scrollbar-track{background:${p.panelAlt};border-radius:10px}
  ::-webkit-scrollbar-thumb{background:${p.borderHi};border-radius:10px}
  ::-webkit-scrollbar-thumb:hover{background:${p.textMute}}
  @keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
  @keyframes spin{to{transform:rotate(360deg)}}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
  @keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
  @keyframes ringPop{0%{transform:scale(.7);opacity:1}100%{transform:scale(1.9);opacity:0}}
  .fade-up{animation:fadeUp .3s ease both}
  .spin{animation:spin .8s linear infinite}
  .layout{display:flex;height:100vh;width:100vw;overflow:hidden;background:${p.bg}}
  .sidebar{width:236px;flex-shrink:0;display:flex;flex-direction:column;background:${p.panel};border-right:1px solid ${p.border};height:100%;overflow:hidden}
  .main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
  .topbar{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;gap:10px;padding:0 16px;height:52px;background:${p.panel};border-bottom:1px solid ${p.border}}
  .vcbar{flex-shrink:0;display:flex;align-items:center;gap:0;border-bottom:1px solid ${p.border};background:${p.surface};overflow-x:auto;padding:0 16px;height:42px}
  .ticker{flex-shrink:0;height:26px;overflow:hidden;background:${p.bg};border-bottom:1px solid ${p.border};display:flex;align-items:center}
  .content{flex:1;overflow-y:auto;overflow-x:hidden;padding:14px 16px;min-height:0}
  .card{background:${p.panel};border:1px solid ${p.border};border-radius:10px;overflow:hidden;transition:border-color .2s,box-shadow .2s}
  .card:hover{border-color:${p.borderHi};box-shadow:0 4px 20px rgba(0,0,0,.15)}
  .card-p{padding:14px}
  .card-flat{background:${p.panelAlt};border:1px solid ${p.border};border-radius:8px;padding:10px 12px}
  .card-header{padding:10px 14px;border-bottom:1px solid ${p.border};display:flex;align-items:center;justify-content:space-between;gap:8px;background:${p.panelAlt}}
  .card-title{font-size:13px;font-weight:700;color:${p.text};text-transform:uppercase;letter-spacing:.6px}
  .kpi{background:${p.panel};border:1px solid ${p.border};border-radius:10px;padding:14px 16px;display:flex;flex-direction:column;gap:5px;position:relative;overflow:hidden;transition:border-color .2s,transform .15s,box-shadow .2s;cursor:pointer}
  .kpi:hover{border-color:var(--kc,${p.accent});transform:translateY(-2px);box-shadow:0 6px 24px var(--kc,${p.accent})22}
  .kpi:active{transform:translateY(0)}
  .kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--kc,${p.accent})}
  .btn{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:7px;font-family:inherit;font-size:12px;font-weight:500;cursor:pointer;border:1px solid;transition:all .15s;white-space:nowrap;flex-shrink:0}
  .btn:active{transform:scale(.97)}
  .btn-primary{background:${p.accent}18;border-color:${p.accent}55;color:${p.accent}}
  .btn-primary:hover{background:${p.accent}28;border-color:${p.accent}}
  .btn-success{background:${p.green}15;border-color:${p.green}50;color:${p.green}}
  .btn-success:hover{background:${p.green}25;border-color:${p.green}}
  .btn-ghost{background:transparent;border-color:${p.border};color:${p.textSub}}
  .btn-ghost:hover{border-color:${p.borderHi};color:${p.text};background:${p.panelAlt}}
  .btn-danger{background:${p.red}15;border-color:${p.red}50;color:${p.red}}
  .btn-sm{padding:4px 10px;font-size:11px}
  .vc-tab{display:inline-flex;align-items:center;gap:6px;padding:0 16px;height:42px;cursor:pointer;font-size:13px;font-weight:600;color:${p.textMute};border-bottom:3px solid transparent;white-space:nowrap;transition:all .15s;flex-shrink:0;border-radius:6px 6px 0 0}
  .vc-tab:hover{color:${p.text};background:${p.border}30}
  .vc-tab.active{color:var(--vc-color,${p.accent});border-bottom-color:var(--vc-color,${p.accent});background:var(--vc-color,${p.accent})10}
  .vc-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
  .nav-link{display:flex;align-items:center;gap:9px;padding:9px 12px;border-radius:8px;cursor:pointer;font-size:13.5px;font-weight:500;color:${p.textSub};transition:all .15s;border:1px solid transparent;margin-bottom:2px}
  .nav-link:hover{color:${p.text};background:${p.surface};border-color:${p.border};transform:translateX(2px)}
  .nav-link.active{color:${p.accent};background:${p.accent}15;border-color:${p.accent}35;font-weight:600}
  .nav-badge{margin-left:auto;font-size:10px;font-weight:700;padding:2px 7px;border-radius:10px}
  .badge{display:inline-flex;align-items:center;gap:3px;padding:1px 7px;border-radius:4px;font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;flex-shrink:0;white-space:nowrap}
  .dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;position:relative;display:inline-block}
  .vm-chip{display:inline-flex;align-items:center;gap:4px;padding:2px 6px;border-radius:4px;font-size:10px;font-weight:600;letter-spacing:.3px}
  .dot-live::after{content:'';position:absolute;inset:-3px;border-radius:50%;border:1.5px solid currentColor;animation:ringPop 2s infinite}
  .bar{height:4px;border-radius:2px;background:${p.border};overflow:hidden;flex:1;min-width:30px}
  .bar-fill{height:100%;border-radius:2px;transition:width .9s cubic-bezier(.4,0,.2,1)}
  .bar-lg{height:7px;border-radius:4px;background:${p.border};overflow:hidden}
  .tbl-wrap{overflow-x:auto;overflow-y:auto;width:100%}
  table{width:100%;border-collapse:collapse}
  thead th{padding:7px 8px;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:.7px;color:${p.textSub};border-bottom:1px solid ${p.border};background:${p.panelAlt};white-space:nowrap;position:sticky;top:0;z-index:1;text-align:left}
  tbody td{padding:5px 8px;font-size:12px;font-weight:500;border-bottom:1px solid ${p.border}18;vertical-align:middle;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;line-height:1.3}
  tbody tr:last-child td{border-bottom:none}
  tbody tr:nth-child(even) td{background:${p.bg}40}
  tbody tr:hover td{background:${p.accent}08!important;transition:background .1s}
  input,select{background:${p.panelAlt};border:1px solid ${p.border};border-radius:7px;color:${p.text};padding:7px 10px;font-family:inherit;font-size:13px;width:100%;outline:none;transition:border-color .2s;min-width:0}
  input:focus,select:focus{border-color:${p.accent}80;box-shadow:0 0 0 3px ${p.accent}12}
  select option{background:${p.panel}}
  label{font-size:11px;font-weight:600;color:${p.textSub};display:block;margin-bottom:4px;text-transform:uppercase;letter-spacing:.5px}
  .g2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
  .g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
  .g4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
  .g-gap{display:grid;gap:12px}
  .overlay{position:fixed;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(5px);z-index:200;display:flex;align-items:center;justify-content:center;padding:16px}
  .modal{background:${p.panel};border:1px solid ${p.border};border-radius:14px;padding:24px;width:500px;max-width:100%;animation:fadeUp .2s ease;max-height:90vh;overflow-y:auto}
  .mono{font-family:'Geist Mono',monospace}
  .section-label{font-size:10.5px;font-weight:700;letter-spacing:1.1px;text-transform:uppercase;color:${p.textMute};margin-bottom:7px;padding-left:6px;padding-bottom:4px;border-bottom:1px solid ${p.border}40}
  .divider{height:1px;background:${p.border};margin:8px 0}
  .spinner{width:22px;height:22px;border-radius:50%;border:2px solid ${p.border};border-top-color:${p.accent};animation:spin .7s linear infinite}
  .res-row{display:grid;grid-template-columns:64px 1fr 88px;align-items:center;gap:12px;padding:9px 0;border-bottom:1px solid ${p.border}}
  .res-row:last-child{border-bottom:none}
  .login-bg{height:100vh;width:100vw;display:flex;align-items:center;justify-content:center;background:${p.bg} url('/login-bg.png') center/cover no-repeat;position:relative;overflow:hidden}
  .login-bg::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(10,5,30,.42) 0%,rgba(30,10,60,.32) 50%,rgba(10,5,30,.45) 100%);pointer-events:none;z-index:0}
  @media(max-width:960px){.sidebar{display:none}.g4{grid-template-columns:1fr 1fr}.g3{grid-template-columns:1fr 1fr}}
  @media(max-width:580px){.g4{grid-template-columns:1fr 1fr}.g3{grid-template-columns:1fr}.g2{grid-template-columns:1fr}}
`;

// ─── UTILS ───────────────────────────────────────────────────────────────────
const freeClr = (pct) => pct>=40?"#10b981":pct>=20?"#f59e0b":"#ef4444";
const usedClr = (pct) => freeClr(100-pct);
// Smart storage formatter: shows TB if ≥1000GB, else GB
const fmtGB = (gb) => {
  if(gb===null||gb===undefined||isNaN(gb)) return "—";
  const n=Number(gb);
  if(n>=1000) return (n/1024).toFixed(2).replace(/\.?0+$/,"")+" TB";
  return n%1===0?n+"GB":n.toFixed(1)+"GB";
};

function vcColor(id, vcenters) {
  const idx = vcenters.findIndex(v => v.id === id);
  return VC_COLORS[idx >= 0 ? idx % VC_COLORS.length : 0];
}

function Badge({ children, color }) {
  const MAP = {
    poweredon:"#10b981",running:"#10b981",connected:"#10b981",ok:"#10b981",online:"#10b981",
    poweredoff:"#ef4444",stopped:"#ef4444",error:"#ef4444",disconnected:"#ef4444",notresponding:"#ef4444",unreachable:"#ef4444",
    unknown:"#64748b",
    suspended:"#f59e0b",warn:"#f59e0b",warning:"#f59e0b",maintenance:"#f59e0b",
    info:"#3b82f6",vmware:"#3b82f6",
  };
  const key = String(color||children||"").toLowerCase();
  // Exact match first, then partial — prevents "disconnected".includes("connected") false positive
  const c = MAP[key] ?? (Object.entries(MAP).find(([k])=>key.includes(k))?.[1]) ?? "#64748b";
  const lbl = children==="poweredOn"?"ON":children==="poweredOff"?"OFF":
              children==="notResponding"?"NO RESP":children;
  return <span className="badge" style={{background:`${c}18`,color:c,border:`1px solid ${c}28`}}>{lbl}</span>;
}
function Dot({color,live}){ return <span className={`dot${live?" dot-live":""}`} style={{background:color,color}}/>; }
function Bar({pct,color}){ return <div className="bar"><div className="bar-fill" style={{width:`${Math.min(100,Math.max(0,pct))}%`,background:color||usedClr(pct)}}/></div>; }
function BarLg({pct,color}){ return <div className="bar-lg"><div className="bar-fill" style={{width:`${Math.min(100,Math.max(0,pct))}%`,background:color||usedClr(pct)}}/></div>; }
function M({children,color,size=13}){ return <span className="mono" style={{fontSize:size,color}}>{children}</span>; }
function LoadState({msg}){ return <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:48,gap:14}}><div className="spinner"/><span style={{fontSize:13,color:"#475569"}}>{msg||"Loading…"}</span></div>; }
function ErrState({msg,onRetry}){ return <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:40,gap:12}}><div style={{fontSize:36}}>⚠️</div><div style={{fontWeight:600,color:"#ef4444"}}>Connection Error</div><div style={{fontSize:13,color:"#475569",textAlign:"center",maxWidth:340}}>{msg}</div><button className="btn btn-danger" onClick={onRetry}>↺ Retry</button></div>; }

class PageErrorBoundary extends Component {
  constructor(props){
    super(props);
    this.state = { hasError:false, message:"" };
  }
  static getDerivedStateFromError(error){
    return { hasError:true, message:error?.message || "Unexpected error" };
  }
  componentDidCatch(){ }
  render(){
    if(this.state.hasError){
      return <ErrState msg={`${this.props.page || "Page"} failed to render: ${this.state.message}`} onRetry={()=>this.setState({hasError:false,message:""})}/>;
    }
    return this.props.children;
  }
}

// ─── KPI ─────────────────────────────────────────────────────────────────────
function KPI({label,value,unit,sub,color,icon,onClick}){
  const c=color||"#3b82f6";
  return(
    <div className="kpi fade-up" style={{"--kc":c}} onClick={onClick} title={onClick?"Click to view details":undefined}>
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}>
        <span style={{fontSize:11,color:"#64748b",fontWeight:700,textTransform:"uppercase",letterSpacing:".8px"}}>{label}</span>
        <span style={{fontSize:20,opacity:.75}}>{icon}</span>
      </div>
      <div style={{display:"flex",alignItems:"baseline",gap:4,marginTop:3}}>
        <span className="mono" style={{fontSize:28,fontWeight:700,color:c,lineHeight:1}}>{value}</span>
        {unit&&<span style={{fontSize:12,color:"#64748b",fontWeight:600}}>{unit}</span>}
      </div>
      {sub&&<div style={{fontSize:11.5,color:"#64748b",fontWeight:500,marginTop:3,letterSpacing:".1px"}}>{sub}</div>}
    </div>
  );
}

// ─── RESOURCE ROW ─────────────────────────────────────────────────────────────
function ResRow({label,usedPct,usedVal,freeVal,totalVal,unit}){
  const up=Math.round(usedPct||0); const c=usedClr(up);
  return(
    <div className="res-row">
      <span style={{fontSize:11,fontWeight:700,color:"#475569",textTransform:"uppercase",letterSpacing:".6px"}}>{label}</span>
      <div style={{display:"flex",flexDirection:"column",gap:4}}>
        <BarLg pct={up} color={`linear-gradient(90deg,${c}88,${c})`}/>
        <div style={{display:"flex",justifyContent:"space-between",fontSize:11,color:"#475569"}}>
          <span>Used: <M color={c} size={11}>{usedVal} {unit}</M></span>
          <span>Free: <M color={freeClr(100-up)} size={11}>{freeVal} {unit}</M></span>
        </div>
      </div>
      <div style={{textAlign:"right"}}><M color={c} size={15}>{up}%</M><div style={{fontSize:11,color:"#475569"}}>of {totalVal}{unit}</div></div>
    </div>
  );
}

// ─── VCENTER BAR ─────────────────────────────────────────────────────────────
function VCenterBar({vcenters,selected,onSelect,summaries}){
  return(
    <div className="vcbar">
      <div className={`vc-tab${selected==="all"?" active":""}`} style={{"--vc-color":"#3b82f6"}} onClick={()=>onSelect("all")}>
        <div className="vc-dot" style={{background:"#3b82f6"}}/>
        All vCenters
        <span style={{fontSize:11,color:"#64748b",marginLeft:2}}>({vcenters.length})</span>
      </div>
      <div style={{width:1,height:18,background:"#1a2540",margin:"0 4px",flexShrink:0}}/>
      {vcenters.map((vc,i)=>{
        const c=VC_COLORS[i%VC_COLORS.length];
        const sum=summaries.find(s=>s.vcenter_id===vc.id);
        const err=sum?.status==="error";
        return(
          <div key={vc.id} className={`vc-tab${selected===vc.id?" active":""}`} style={{"--vc-color":c}} onClick={()=>onSelect(vc.id)}>
            <div className="vc-dot" style={{background:err?"#ef4444":c,boxShadow:`0 0 5px ${c}60`}}/>
            {vc.name}
            {err&&<span className="badge" style={{background:"#ef444418",color:"#ef4444",border:"1px solid #ef444428",marginLeft:4}}>ERR</span>}
            {sum&&!err&&<span style={{fontSize:11,color:"#64748b",marginLeft:2}}>{sum.connected_hosts}h · {sum.running_vms}vm</span>}
          </div>
        );
      })}
    </div>
  );
}

// ─── OCP CLUSTER SUMMARY CARD ────────────────────────────────────────────────
function OCPClusterCard({cluster, ov, p}){
  // OCP red used only for the brand strip — semantic health colours drive stat tiles
  const BRAND   = "#ee0000";   // OCP identity accent (header strip only)
  const C_NODES = "#0ea5e9";   // cyan  — Nodes tile label/border
  const C_PODS  = "#8b5cf6";   // violet — Pods tile label/border
  const C_OPS   = "#f59e0b";   // amber — Operators tile label/border
  const health  = !ov ? "unknown"
    : (ov.nodes_summary?.not_ready>0 || ov.operators_summary?.degraded>0) ? "degraded"
    : ov.warnings>5 ? "warning" : "healthy";
  const hc = health==="healthy" ? "#10b981" : health==="degraded" ? "#ef4444" : "#f59e0b";

  // per-tile value colour: health-driven
  const nodeC = ov?.nodes_summary?.not_ready>0      ? "#ef4444" : "#10b981";
  const podC  = ov?.pods_summary?.failed>0          ? "#ef4444"
              : ov?.pods_summary?.pending>0          ? "#f59e0b" : "#10b981";
  const opC   = ov?.operators_summary?.degraded>0   ? "#f97316" : "#10b981";

  return(
    <div style={{background:p.panelAlt,border:`1px solid ${p.border}`,borderRadius:12,overflow:"hidden",
                 transition:"all .22s",cursor:"default",borderTop:`2px solid ${BRAND}60`}}
      onMouseEnter={e=>{e.currentTarget.style.borderTopColor=BRAND;e.currentTarget.style.transform="translateY(-3px)";e.currentTarget.style.boxShadow=`0 10px 28px rgba(0,0,0,.25)`;}}
      onMouseLeave={e=>{e.currentTarget.style.borderTopColor=`${BRAND}60`;e.currentTarget.style.transform="";e.currentTarget.style.boxShadow="";}}>

      {/* Header — neutral dark, brand accent via top border only */}
      <div style={{padding:"12px 16px",background:p.surface,borderBottom:`1px solid ${p.border}`,
                   display:"flex",alignItems:"center",gap:10}}>
        <div style={{width:10,height:10,borderRadius:"50%",background:hc,
                     boxShadow:`0 0 8px ${hc}80`,flexShrink:0,
                     animation:health==="healthy"?"pulse 2s infinite":"none"}}/>
        <div style={{flex:1,minWidth:0}}>
          <div style={{fontWeight:800,fontSize:14,color:p.text,overflow:"hidden",
                       textOverflow:"ellipsis",whiteSpace:"nowrap",letterSpacing:"-.1px"}}>
            {cluster.name}
          </div>
          <div style={{fontSize:10,color:p.textMute,marginTop:2,overflow:"hidden",
                       textOverflow:"ellipsis",whiteSpace:"nowrap"}}>
            {cluster.api_url||"—"}
          </div>
        </div>
        <div style={{display:"flex",flexDirection:"column",alignItems:"flex-end",gap:3}}>
          {/* OCP badge — brand red just for the label text, neutral bg */}
          <span style={{fontSize:10,fontWeight:700,padding:"2px 9px",borderRadius:20,
                        background:`${BRAND}12`,color:BRAND,border:`1px solid ${BRAND}30`,
                        letterSpacing:".2px"}}>OpenShift</span>
          {ov?.version?.version&&(
            <span style={{fontSize:10,color:"#64748b",fontFamily:"monospace"}}>
              {ov.version.version}
            </span>
          )}
        </div>
      </div>

      {!ov ? (
        <div style={{padding:"20px 14px",textAlign:"center"}}>
          <div style={{width:24,height:24,borderRadius:"50%",
                       border:"3px solid #33415540",borderTopColor:"#64748b",
                       animation:"spin 1s linear infinite",margin:"0 auto 8px"}}/>
          <div style={{fontSize:12,color:p.textMute}}>Fetching cluster data...</div>
        </div>
      ) : (
        <div style={{padding:"12px 14px"}}>
          {ov.version?.channel && ov.version?.available_updates>0 && (
            <div style={{display:"flex",alignItems:"center",gap:6,padding:"4px 8px",marginBottom:8,
                         borderRadius:6,background:`${p.yellow}12`,border:`1px solid ${p.yellow}28`}}>
              <span style={{fontSize:10}}>⬆</span>
              <span style={{fontSize:11,color:p.yellow,fontWeight:600}}>
                {ov.version.available_updates} update{ov.version.available_updates!==1?"s":""} available · {ov.version.channel}
              </span>
            </div>
          )}

          {/* Stat tiles — each tile has its own accent colour for label/border,
              but the large number uses semantic health colour */}
          <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:6,marginBottom:8}}>
            {[
              { l:"Nodes",     v:`${ov.nodes_summary.ready}/${ov.nodes_summary.total}`,
                val:nodeC, accent:C_NODES,
                s:`${ov.nodes_summary.not_ready} not ready` },
              { l:"Pods",      v:`${ov.pods_summary.running}/${ov.pods_summary.total}`,
                val:podC,  accent:C_PODS,
                s:`${ov.pods_summary.failed} failed · ${ov.pods_summary.pending} pend` },
              { l:"Operators", v:`${ov.operators_summary.available}/${ov.operators_summary.total}`,
                val:opC,   accent:C_OPS,
                s:`${ov.operators_summary.degraded} degraded` },
            ].map(({l,v,val,accent,s})=>(
              <div key={l} style={{textAlign:"center",padding:"8px 4px",borderRadius:8,
                                   background:`${accent}09`,border:`1px solid ${accent}28`}}>
                <div style={{fontSize:20,fontWeight:800,color:val,lineHeight:1,
                             fontFamily:"'Geist Mono',monospace"}}>{v}</div>
                <div style={{fontSize:9,color:accent,marginTop:3,fontWeight:700,
                             textTransform:"uppercase",letterSpacing:".5px"}}>{l}</div>
                <div style={{fontSize:9,color:"#64748b",marginTop:1,lineHeight:1.4}}>{s}</div>
              </div>
            ))}
          </div>

          {/* Status footer */}
          <div style={{display:"flex",alignItems:"center",gap:6,padding:"5px 8px",borderRadius:6,
                       background:`${hc}09`,border:`1px solid ${hc}22`}}>
            <div style={{width:6,height:6,borderRadius:"50%",background:hc,flexShrink:0}}/>
            <span style={{fontSize:11,color:hc,fontWeight:600}}>
              {health==="healthy"
                ? "All systems healthy"
                : health==="degraded"
                  ? `${ov.nodes_summary.not_ready} node${ov.nodes_summary.not_ready!==1?"s":""} not ready`
                    + (ov.operators_summary.degraded>0
                        ? ` · ${ov.operators_summary.degraded} operator${ov.operators_summary.degraded!==1?"s":""} degraded`
                        : "")
                  : `${ov.warnings} warning event${ov.warnings!==1?"s":""}`}
            </span>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── NUTANIX PC SUMMARY CARD ──────────────────────────────────────────────────
function NutPCCard({pc, ov, p}){
  const NUT="#22c55e"; const NUT2="#16a34a";
  const health=!ov?"unknown":ov.alerts?.critical>0?"critical":ov.alerts?.warning>3?"warning":"healthy";
  const hc=health==="healthy"?"#10b981":health==="critical"?"#ef4444":"#f59e0b";
  return(
    <div style={{background:p.panelAlt,border:`1px solid ${NUT}25`,borderRadius:12,overflow:"hidden",transition:"all .22s",cursor:"default"}}
      onMouseEnter={e=>{e.currentTarget.style.borderColor=`${NUT}55`;e.currentTarget.style.transform="translateY(-3px)";e.currentTarget.style.boxShadow=`0 12px 32px ${NUT}18`;}}
      onMouseLeave={e=>{e.currentTarget.style.borderColor=`${NUT}25`;e.currentTarget.style.transform="";e.currentTarget.style.boxShadow="";}}>
      <div style={{padding:"12px 16px",background:`linear-gradient(135deg,${NUT}15,${NUT}05)`,borderBottom:`1px solid ${NUT}20`,display:"flex",alignItems:"center",gap:10}}>
        <div style={{width:10,height:10,borderRadius:"50%",background:hc,boxShadow:`0 0 8px ${hc}80`,flexShrink:0,animation:health==="healthy"?"pulse 2s infinite":"none"}}/>
        <div style={{flex:1,minWidth:0}}>
          <div style={{fontWeight:800,fontSize:14,color:NUT,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",letterSpacing:"-.1px"}}>{pc.name}</div>
          <div style={{fontSize:10,color:p.textMute,marginTop:2,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{pc.host||"—"}</div>
        </div>
        <div style={{display:"flex",flexDirection:"column",alignItems:"flex-end",gap:3}}>
          <span style={{fontSize:10,fontWeight:700,padding:"2px 8px",borderRadius:20,background:`${NUT}18`,color:NUT,border:`1px solid ${NUT}35`}}>Nutanix PC</span>
          <span style={{fontSize:10,color:p.textMute}}>{pc.site_group||"Primary"}</span>
        </div>
      </div>
      {!ov?(
        <div style={{padding:"20px 14px",textAlign:"center"}}>
          <div style={{width:24,height:24,borderRadius:"50%",border:`3px solid ${NUT}40`,borderTopColor:NUT,animation:"spin 1s linear infinite",margin:"0 auto 8px"}}/>
          <div style={{fontSize:12,color:p.textMute}}>Fetching Prism Central data...</div>
        </div>
      ):(
        <div style={{padding:"12px 14px"}}>
          <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:6,marginBottom:8}}>
            {[
              {l:"VMs",v:`${ov.vms?.running||0}/${ov.vms?.total||0}`,c:"#10b981",s:`${ov.vms?.off||0} powered off`},
              {l:"Hosts",v:`${ov.hosts||0}`,c:"#06b6d4",s:`${ov.total_vcpus||0} vCPUs total`},
              {l:"Clusters",v:`${ov.clusters||0}`,c:NUT,s:"AHV clusters"},
            ].map(({l,v,c,s})=>(
              <div key={l} style={{textAlign:"center",padding:"7px 4px",borderRadius:8,background:`${c}09`,border:`1px solid ${c}22`}}>
                <div style={{fontSize:20,fontWeight:800,color:c,lineHeight:1,fontFamily:"'Geist Mono',monospace"}}>{v}</div>
                <div style={{fontSize:9,color:"#64748b",marginTop:3,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px"}}>{l}</div>
                <div style={{fontSize:9,color:"#64748b",marginTop:1,lineHeight:1.4}}>{s}</div>
              </div>
            ))}
          </div>
          {ov.total_memory_gib>0&&(
            <div style={{display:"flex",alignItems:"center",gap:8,padding:"5px 8px",marginBottom:6,borderRadius:6,background:`${NUT}08`,border:`1px solid ${NUT}20`}}>
              <span style={{fontSize:11,fontWeight:600,color:"#64748b",minWidth:60,flexShrink:0}}>Memory</span>
              <span style={{fontSize:12,fontWeight:800,color:NUT}}>{Math.round(ov.total_memory_gib)} GiB</span>
              <span style={{fontSize:10,color:"#64748b",flex:1}}>total across all hosts</span>
            </div>
          )}
          <div style={{display:"flex",alignItems:"center",gap:6,padding:"5px 8px",borderRadius:6,
            background:ov.alerts?.critical>0?`${p.red}09`:ov.alerts?.warning>0?`${p.yellow}09`:`${p.green}09`,
            border:`1px solid ${ov.alerts?.critical>0?p.red:ov.alerts?.warning>0?p.yellow:p.green}22`}}>
            <div style={{width:6,height:6,borderRadius:"50%",background:hc,flexShrink:0}}/>
            <span style={{fontSize:11,color:hc,fontWeight:600}}>
              {ov.alerts?.critical>0?`${ov.alerts.critical} critical alert${ov.alerts.critical!==1?"s":""}`
               :ov.alerts?.warning>0?`${ov.alerts.warning} warning${ov.alerts.warning!==1?"s":""}`
               :"No active alerts"}
            </span>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── ENVIRONMENT CHARTS PANEL ─────────────────────────────────────────────────
function RingChart({segments, size=120, stroke=14, label, sublabel, centerVal, centerSub, p}){
  const [tooltip,setTooltip]=useState(null);
  const [mousePos,setMousePos]=useState({x:0,y:0});
  const r=(size-stroke)/2; const cx=size/2; const cy=size/2;
  const circ=2*Math.PI*r;
  const total=segments.reduce((a,s)=>a+s.value,0)||1;
  let offset=circ*0.25; // start from top (rotate -90°)
  const arcs=segments.map(seg=>{
    const pct=seg.value/total;
    const dash=pct*circ;
    const arc={...seg,dashArray:`${dash} ${circ-dash}`,dashOffset:-(offset-circ*0.25),pct:Math.round(pct*100)};
    offset+=dash;
    return arc;
  });
  function handleMouseMove(e,seg){
    const rect=e.currentTarget.closest("svg").getBoundingClientRect();
    setMousePos({x:e.clientX-rect.left,y:e.clientY-rect.top});
    setTooltip(seg);
  }
  return(
    <div style={{position:"relative",display:"flex",flexDirection:"column",alignItems:"center",gap:6}}>
      <svg width={size} height={size} style={{overflow:"visible"}}>
        {/* background track */}
        <circle cx={cx} cy={cy} r={r} fill="none" stroke={p.panelAlt} strokeWidth={stroke}/>
        {arcs.map((arc,i)=>(
          <circle key={i} cx={cx} cy={cy} r={r} fill="none"
            stroke={arc.color} strokeWidth={tooltip?.label===arc.label?stroke+4:stroke}
            strokeLinecap="round"
            strokeDasharray={arc.dashArray}
            strokeDashoffset={arc.dashOffset}
            style={{transform:`rotate(-90deg)`,transformOrigin:`${cx}px ${cy}px`,
              transition:"stroke-width .15s,filter .15s",cursor:"pointer",
              filter:tooltip?.label===arc.label?`drop-shadow(0 0 6px ${arc.color}90)`:""}}
            onMouseMove={e=>handleMouseMove(e,arc)}
            onMouseLeave={()=>setTooltip(null)}/>
        ))}
        {/* center text */}
        <text x={cx} y={cy-6} textAnchor="middle" fill={p.text}
          style={{fontSize:20,fontWeight:900,fontFamily:"'Geist Mono',monospace"}}>{centerVal}</text>
        <text x={cx} y={cy+12} textAnchor="middle" fill={p.textMute}
          style={{fontSize:9,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px"}}>{centerSub}</text>
      </svg>
      {tooltip&&(
        <div style={{position:"absolute",left:mousePos.x+12,top:mousePos.y-10,zIndex:999,
          background:p.panel,border:`1.5px solid ${tooltip.color}60`,borderRadius:10,
          padding:"8px 12px",boxShadow:`0 8px 28px rgba(0,0,0,.5),0 0 0 1px ${tooltip.color}25`,
          minWidth:140,pointerEvents:"none",backdropFilter:"blur(4px)"}}>
          <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:4}}>
            <div style={{width:10,height:10,borderRadius:"50%",background:tooltip.color,
              boxShadow:`0 0 8px ${tooltip.color}80`,flexShrink:0}}/>
            <span style={{fontWeight:700,fontSize:12,color:tooltip.color}}>{tooltip.label}</span>
          </div>
          <div style={{fontFamily:"'Geist Mono',monospace",fontSize:20,fontWeight:900,color:p.text,lineHeight:1,marginBottom:2}}>
            {tooltip.value.toLocaleString()}
          </div>
          <div style={{fontSize:11,color:p.textMute}}>{tooltip.pct}% of total</div>
          {tooltip.detail&&<div style={{fontSize:11,color:p.textSub,marginTop:4,paddingTop:4,borderTop:`1px solid ${p.border}`}}>{tooltip.detail}</div>}
        </div>
      )}
      <div style={{textAlign:"center"}}>
        <div style={{fontWeight:800,fontSize:12,color:p.text}}>{label}</div>
        {sublabel&&<div style={{fontSize:10,color:p.textMute,marginTop:1}}>{sublabel}</div>}
      </div>
    </div>
  );
}

function UtilizationGauge({label, usedPct, usedLabel, freeLabel, totalLabel, color, icon, p, extraRows=[]}){
  const [hovered,setHovered]=useState(false);
  const [pos,setPos]=useState({x:0,y:0});
  const clamped=Math.max(0,Math.min(100,usedPct));
  const barColor=clamped>=80?"#ef4444":clamped>=60?"#f59e0b":color;
  const w=200; const h=14;
  return(
    <div style={{position:"relative",display:"flex",flexDirection:"column",gap:4}}
      onMouseMove={e=>{setHovered(true);const r=e.currentTarget.getBoundingClientRect();setPos({x:e.clientX-r.left,y:e.clientY-r.top});}}
      onMouseLeave={()=>setHovered(false)}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
        <span style={{fontSize:11,fontWeight:700,color:p.textSub,letterSpacing:".3px"}}>{icon} {label}</span>
        <span style={{fontFamily:"'Geist Mono',monospace",fontSize:13,fontWeight:900,color:barColor}}>{Math.round(clamped)}%</span>
      </div>
      <svg width="100%" height={h} style={{borderRadius:h/2,overflow:"visible",cursor:"crosshair"}}>
        <defs>
          <linearGradient id={`g-${label}`} x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stopColor={barColor} stopOpacity=".7"/>
            <stop offset="100%" stopColor={barColor}/>
          </linearGradient>
        </defs>
        <rect x={0} y={0} width="100%" height={h} rx={h/2} fill={p.panelAlt}/>
        <rect x={0} y={0} width={`${clamped}%`} height={h} rx={h/2}
          fill={`url(#g-${label})`}
          style={{filter:hovered?`drop-shadow(0 0 4px ${barColor}80)`:""}}/>
        {hovered&&<line x1={`${clamped}%`} y1={-3} x2={`${clamped}%`} y2={h+3} stroke={barColor} strokeWidth={2} strokeDasharray="3 2"/>}
      </svg>
      <div style={{display:"flex",justifyContent:"space-between",fontSize:10,color:p.textMute}}>
        <span style={{color:barColor,fontWeight:600}}>{usedLabel} used</span>
        <span>{freeLabel} free / {totalLabel} total</span>
      </div>
      {hovered&&(
        <div style={{position:"absolute",left:pos.x+10,top:pos.y+10,zIndex:999,
          background:p.panel,border:`1.5px solid ${barColor}60`,borderRadius:10,
          padding:"9px 13px",boxShadow:`0 8px 32px rgba(0,0,0,.55),0 0 0 1px ${barColor}20`,
          minWidth:170,pointerEvents:"none",backdropFilter:"blur(4px)"}}>
          <div style={{display:"flex",alignItems:"center",gap:7,marginBottom:6}}>
            <div style={{width:10,height:10,borderRadius:3,background:barColor,boxShadow:`0 0 8px ${barColor}80`}}/>
            <span style={{fontWeight:800,fontSize:12,color:barColor}}>{icon} {label}</span>
          </div>
          <div style={{display:"flex",flexDirection:"column",gap:3,fontSize:12}}>
            <div style={{display:"flex",justifyContent:"space-between",gap:16}}>
              <span style={{color:p.textMute}}>Used</span>
              <span style={{fontWeight:700,color:barColor}}>{usedLabel} ({Math.round(clamped)}%)</span>
            </div>
            <div style={{display:"flex",justifyContent:"space-between",gap:16}}>
              <span style={{color:p.textMute}}>Free</span>
              <span style={{fontWeight:700,color:"#10b981"}}>{freeLabel}</span>
            </div>
            <div style={{display:"flex",justifyContent:"space-between",gap:16}}>
              <span style={{color:p.textMute}}>Total</span>
              <span style={{fontWeight:700,color:p.text}}>{totalLabel}</span>
            </div>
            {extraRows.map(([k,v])=>(
              <div key={k} style={{display:"flex",justifyContent:"space-between",gap:16,paddingTop:3,borderTop:`1px solid ${p.border}28`}}>
                <span style={{color:p.textMute}}>{k}</span>
                <span style={{fontWeight:600,color:p.textSub}}>{v}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

function EnvironmentChartsPanel({summary, ocpData, nutData, p}){
  // VMware derived
  const vmRunning=summary?.running_vms||0;
  const vmStopped=summary?.stopped_vms||0;
  const vmTotal=summary?.total_vms||0;
  const cpuPct=summary?.cpu?.total_mhz>0?Math.round((summary.cpu.used_mhz/summary.cpu.total_mhz)*100):0;
  const ramPct=summary?.ram?.total_gb>0?Math.round((summary.ram.used_gb/summary.ram.total_gb)*100):0;
  const diskPct=summary?.storage?.total_gb>0?Math.round((summary.storage.used_gb/summary.storage.total_gb)*100):0;
  // OCP derived
  const ocpClusters=(ocpData?.clusters||[]).length;
  const ocpPodsRun=Object.values(ocpData?.overviews||{}).reduce((a,ov)=>a+(ov?.pods_summary?.running||0),0);
  const ocpPodsTot=Object.values(ocpData?.overviews||{}).reduce((a,ov)=>a+(ov?.pods_summary?.total||0),0);
  const ocpNodesTot=Object.values(ocpData?.overviews||{}).reduce((a,ov)=>a+(ov?.nodes_summary?.total||0),0);
  const ocpNodesRdy=Object.values(ocpData?.overviews||{}).reduce((a,ov)=>a+(ov?.nodes_summary?.ready||0),0);
  // Nutanix derived
  const nutPCs=(nutData?.pcs||[]).length;
  const nutVMsRun=Object.values(nutData?.overviews||{}).reduce((a,ov)=>a+(ov?.vms?.running||0),0);
  const nutVMsTot=Object.values(nutData?.overviews||{}).reduce((a,ov)=>a+(ov?.vms?.total||0),0);
  const nutHosts=Object.values(nutData?.overviews||{}).reduce((a,ov)=>a+(ov?.hosts||0),0);
  return(
    <div style={{background:`linear-gradient(135deg,${p.panel},${p.panelAlt})`,border:`1px solid ${p.border}`,
      borderRadius:14,overflow:"hidden",boxShadow:"0 4px 24px rgba(0,0,0,.18)"}}>
      {/* Section header */}
      <div style={{padding:"11px 18px",borderBottom:`1px solid ${p.border}`,
        background:`linear-gradient(90deg,${p.accent}10,${p.cyan}05,transparent)`,
        display:"flex",alignItems:"center",gap:10}}>
        <span style={{fontSize:16}}>📊</span>
        <span style={{fontWeight:900,fontSize:12,letterSpacing:"1.6px",textTransform:"uppercase",
          background:`linear-gradient(90deg,${p.accent},${p.cyan})`,WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent"}}>
          Multi-Platform Resource Overview
        </span>
        <span style={{fontSize:10,color:p.textMute,marginLeft:4}}>· Hover any chart element for details</span>
      </div>
      <div style={{padding:"18px 20px",display:"grid",gridTemplateColumns:"1fr 1fr 1fr 2fr",gap:24,alignItems:"start"}}>
        {/* ── VMware Ring ── */}
        <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:12}}>
          <div style={{fontSize:11,fontWeight:800,letterSpacing:"1.2px",textTransform:"uppercase",color:"#3b82f6",
            padding:"3px 10px",borderRadius:20,background:"#3b82f615",border:"1px solid #3b82f625"}}>🖥️ VMware</div>
          <RingChart p={p} size={130} stroke={16}
            centerVal={vmTotal} centerSub="VMs"
            label={`${summary?.total_hosts||0} Hosts`} sublabel={`${summary?.connected_hosts||0} connected`}
            segments={[
              {label:"Running VMs",value:vmRunning||1,color:"#10b981",detail:`${vmRunning} of ${vmTotal} VMs are powered on`},
              {label:"Stopped VMs",value:vmStopped||0,color:"#ef444450",detail:`${vmStopped} VMs are powered off or suspended`},
            ]}/>
          <div style={{display:"flex",gap:12,fontSize:11}}>
            {[{c:"#10b981",l:`${vmRunning} Running`},{c:"#ef4444",l:`${vmStopped} Stopped`}].map(({c,l})=>(
              <div key={l} style={{display:"flex",alignItems:"center",gap:4,color:p.textSub}}>
                <div style={{width:8,height:8,borderRadius:2,background:c}}/>{l}
              </div>
            ))}
          </div>
        </div>
        {/* ── OpenShift Ring ── */}
        <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:12}}>
          <div style={{fontSize:11,fontWeight:800,letterSpacing:"1.2px",textTransform:"uppercase",color:"#ef4444",
            padding:"3px 10px",borderRadius:20,background:"#ef444415",border:"1px solid #ef444425"}}>🔴 OpenShift</div>
          {ocpClusters===0
            ?<div style={{height:130,display:"flex",alignItems:"center",justifyContent:"center",
                color:p.textMute,fontSize:12,textAlign:"center",opacity:.5}}>
                <div><div style={{fontSize:28,marginBottom:6}}>🔴</div>Not configured</div>
              </div>
            :<RingChart p={p} size={130} stroke={16}
                centerVal={ocpPodsRun} centerSub="Running"
                label={`${ocpClusters} Cluster${ocpClusters!==1?"s":""}`} sublabel={`${ocpNodesTot} nodes total`}
                segments={[
                  {label:"Running Pods",value:ocpPodsRun||1,color:"#ef4444",detail:`${ocpPodsRun} pods running across all clusters`},
                  {label:"Other Pods",value:Math.max(0,ocpPodsTot-ocpPodsRun)||0,color:"#f8717120",detail:`${ocpPodsTot-ocpPodsRun} pods pending/failed`},
                  {label:"Ready Nodes",value:ocpNodesRdy||0,color:"#fb923c",detail:`${ocpNodesRdy}/${ocpNodesTot} nodes ready`},
                ]}/>
          }
          {ocpClusters>0&&<div style={{display:"flex",gap:12,fontSize:11}}>
            {[{c:"#ef4444",l:`${ocpPodsRun} Pods`},{c:"#fb923c",l:`${ocpNodesRdy} Nodes`}].map(({c,l})=>(
              <div key={l} style={{display:"flex",alignItems:"center",gap:4,color:p.textSub}}>
                <div style={{width:8,height:8,borderRadius:2,background:c}}/>{l}
              </div>
            ))}
          </div>}
        </div>
        {/* ── Nutanix Ring ── */}
        <div style={{display:"flex",flexDirection:"column",alignItems:"center",gap:12}}>
          <div style={{fontSize:11,fontWeight:800,letterSpacing:"1.2px",textTransform:"uppercase",color:"#22c55e",
            padding:"3px 10px",borderRadius:20,background:"#22c55e15",border:"1px solid #22c55e25"}}>🟩 Nutanix</div>
          {nutPCs===0
            ?<div style={{height:130,display:"flex",alignItems:"center",justifyContent:"center",
                color:p.textMute,fontSize:12,textAlign:"center",opacity:.5}}>
                <div><div style={{fontSize:28,marginBottom:6}}>🟩</div>Not configured</div>
              </div>
            :<RingChart p={p} size={130} stroke={16}
                centerVal={nutVMsTot} centerSub="AHV VMs"
                label={`${nutPCs} Prism Central${nutPCs!==1?"s":""}`} sublabel={`${nutHosts} AHV hosts`}
                segments={[
                  {label:"Running VMs",value:nutVMsRun||1,color:"#22c55e",detail:`${nutVMsRun} of ${nutVMsTot} VMs powered on`},
                  {label:"Stopped VMs",value:Math.max(0,nutVMsTot-nutVMsRun)||0,color:"#22c55e30",detail:`${nutVMsTot-nutVMsRun} VMs powered off`},
                ]}/>
          }
          {nutPCs>0&&<div style={{display:"flex",gap:12,fontSize:11}}>
            {[{c:"#22c55e",l:`${nutVMsRun} Running`},{c:"#4ade8050",l:`${nutVMsTot-nutVMsRun} Off`}].map(({c,l})=>(
              <div key={l} style={{display:"flex",alignItems:"center",gap:4,color:p.textSub}}>
                <div style={{width:8,height:8,borderRadius:2,background:c}}/>{l}
              </div>
            ))}
          </div>}
        </div>
        {/* ── VMware Resource Gauges ── */}
        <div style={{display:"flex",flexDirection:"column",gap:0,borderLeft:`1px solid ${p.border}`,paddingLeft:24}}>
          <div style={{fontSize:11,fontWeight:800,letterSpacing:"1.2px",textTransform:"uppercase",color:"#3b82f6",
            marginBottom:16,display:"flex",alignItems:"center",gap:8}}>
            <span style={{padding:"3px 10px",borderRadius:20,background:"#3b82f615",border:"1px solid #3b82f625"}}>🖥️ VMware Capacity Utilization</span>
          </div>
          <div style={{display:"flex",flexDirection:"column",gap:18}}>
            <UtilizationGauge p={p} label="CPU" icon="⚡" usedPct={cpuPct}
              usedLabel={`${Math.round((summary?.cpu?.used_mhz||0)/1000)} GHz`}
              freeLabel={`${Math.round((summary?.cpu?.free_mhz||0)/1000)} GHz`}
              totalLabel={`${Math.round((summary?.cpu?.total_mhz||0)/1000)} GHz`}
              color="#3b82f6"
              extraRows={[["Hosts",`${summary?.connected_hosts||0} / ${summary?.total_hosts||0} online`]]}/>
            <UtilizationGauge p={p} label="Memory" icon="🧠" usedPct={ramPct}
              usedLabel={fmtGB(summary?.ram?.used_gb||0)}
              freeLabel={fmtGB(summary?.ram?.free_gb||0)}
              totalLabel={fmtGB(summary?.ram?.total_gb||0)}
              color="#8b5cf6"
              extraRows={[["Running VMs",`${vmRunning} of ${vmTotal}`]]}/>
            <UtilizationGauge p={p} label="Storage" icon="💾" usedPct={diskPct}
              usedLabel={fmtGB(summary?.storage?.used_gb||0)}
              freeLabel={fmtGB(summary?.storage?.free_gb||0)}
              totalLabel={fmtGB(summary?.storage?.total_gb||0)}
              color="#06b6d4"
              extraRows={[["Type","Aggregated across all datastores"]]}/>
          </div>
        </div>
      </div>
    </div>
  );
}

// ─── OVERVIEW ─────────────────────────────────────────────────────────────────
// ─── SDx Lab Topology 3D Modal ────────────────────────────────────────────────
const SDX_VOICEOVER = `
Welcome to the SDx Lab Connectivity Diagram — a secure, segmented network infrastructure spanning two physical sites.

The diagram flows from top to bottom across five layers.

At the top is the Access Layer. Work-from-home users connect through Palo Alto GlobalProtect VPN with multi-factor authentication, forming an encrypted tunnel into the network. They reach the lab via the public Internet, which feeds into an Edge Internet Router acting as the WAN gateway.

Below that is the WAN Switching layer. Traffic from the Internet Router is distributed across two redundant WAN IM Switches — both Layer 2 and Layer 3 capable core switches running in parallel for high availability. A third connection point, the Wipro Backbone external WAN link, is currently shown as Link Down.

Next is the Perimeter Security layer. All inbound and outbound traffic passes through a pair of IMG Firewalls. Firewall 1 is the active unit, and Firewall 2 is in hot standby. Both are in an amber filtering state, meaning active packet inspection is in progress. No traffic reaches the internal lab without passing through this security boundary.

Below the firewalls is the LAN Distribution layer. Traffic is handed off through two 48-port CAT6 Patch Panels, labelled Patch Panel A and Patch Panel B, and two managed access switches — LAN IM Switch 1 and LAN IM Switch 2 — which distribute connectivity into the lab zones.

At the bottom are the two SDx Managed Zones, which are fully isolated, account-managed segments connected to each other via a 10 Gigabit per second Dark Fiber private leased line.

Zone A, located in Building S5F10 B Wing, is the Disaster Recovery site. It contains a patch panel for internal distribution, a Cisco ASA 5500 acting as the LAB Enterprise Core Switch, and a dedicated LAN segment on the 172.16.0.0 slash 16 subnet.

Zone B, located in Building S3F5 A Wing, is the Primary Datacenter. It follows the same structure — patch panel, Cisco ASA 5500 core switch, and its own isolated LAN segment on the 172.17.0.0 slash 16 subnet.

Both zones are completely isolated from each other at the routing level except for the direct dark fiber interconnect, ensuring that DR traffic never crosses the public network. This architecture provides a resilient, multi-layered security posture with physical site separation between the primary datacenter and disaster recovery environments.
`.trim();

function SDxTopologyModal({onClose,p}){
  const [speaking, setSpeaking] = useState(false);
  const [supported] = useState(()=>typeof window!=='undefined'&&'speechSynthesis' in window);
  const synthRef = useRef(null);

  function toggleVoice(){
    if(!supported) return;
    if(speaking){
      window.speechSynthesis.cancel();
      setSpeaking(false);
      return;
    }
    window.speechSynthesis.cancel();
    const utt = new SpeechSynthesisUtterance(SDX_VOICEOVER);
    utt.rate  = 0.92;
    utt.pitch = 1.0;
    utt.volume= 1.0;
    // prefer a natural English voice if available
    const voices = window.speechSynthesis.getVoices();
    const preferred = voices.find(v=>
      v.lang.startsWith('en') && (v.name.includes('Google') || v.name.includes('Natural') || v.name.includes('Neural') || v.name.toLowerCase().includes('english'))
    ) || voices.find(v=>v.lang.startsWith('en')) || voices[0];
    if(preferred) utt.voice = preferred;
    utt.onend   = ()=>setSpeaking(false);
    utt.onerror = ()=>setSpeaking(false);
    synthRef.current = utt;
    setSpeaking(true);
    window.speechSynthesis.speak(utt);
  }

  // stop speech when modal closes
  useEffect(()=>{
    return()=>{ window.speechSynthesis && window.speechSynthesis.cancel(); setSpeaking(false); };
  },[]);

  return(
    <div style={{position:'fixed',inset:0,zIndex:9999,background:'#040810',display:'flex',flexDirection:'column'}}>
      <iframe
        src="/sdx-topo.html"
        style={{flex:1,border:'none',width:'100%',height:'100%'}}
        title="SDx Lab Topology"
        allow="fullscreen"
      />
      {/* Speaker voiceover button — bottom-right overlay (avoids close button) */}
      {supported&&(
        <button
          onClick={toggleVoice}
          title={speaking ? "Stop voiceover" : "▶ Play lab connectivity explanation (~90 sec)"}
          style={{
            position:'fixed', bottom:28, right:22, zIndex:10000,
            width:52, height:52, borderRadius:'50%',
            background: speaking
              ? 'linear-gradient(135deg,#ef4444,#dc2626)'
              : 'linear-gradient(135deg,#0066cc,#0099dd)',
            border: speaking ? '2px solid #ff6b6b' : '2px solid #00d4ff',
            boxShadow: speaking
              ? '0 0 22px rgba(239,68,68,.7), 0 2px 10px rgba(0,0,0,.5)'
              : '0 0 22px rgba(0,180,255,.6), 0 2px 10px rgba(0,0,0,.5)',
            cursor:'pointer',
            display:'flex', alignItems:'center', justifyContent:'center',
            fontSize:24,
            transition:'all .25s',
            animation: speaking ? 'pulse 1s infinite' : 'none',
          }}
          onMouseEnter={e=>{ e.currentTarget.style.transform='scale(1.12)'; }}
          onMouseLeave={e=>{ e.currentTarget.style.transform='scale(1)'; }}
        >
          {speaking ? '⏹' : '🔊'}
        </button>
      )}
      {/* Tooltip label */}
      {supported&&(
        <div style={{
          position:'fixed', bottom:84, right:16, zIndex:10000,
          fontSize:10, color: speaking ? '#ff9999' : '#99ddff',
          fontWeight:700, letterSpacing:'.4px',
          textShadow:'0 1px 4px rgba(0,0,0,.8)',
          pointerEvents:'none',
          textAlign:'center', width:66,
        }}>
          {speaking ? 'TAP TO STOP' : 'VOICEOVER'}
        </div>
      )}
    </div>
  );
}
function Overview({summary,hosts,alerts,summaries,vcenters,selectedVC,onCreateVM,onNavigate,loading,error,onRetry,ocpData,nutData,p}){
  const [ovIpam,setOvIpam]=useState(null);
  const [showTopo,setShowTopo]=useState(false);
  // ── Live banner health: fetched independently so Overview is always accurate ──
  const [liveHealth,setLiveHealth]=useState(null);
  const [lhLoading,setLhLoading]=useState(true);

  useEffect(()=>{
    fetchIPAMSubnets().then(d=>setOvIpam(d)).catch(()=>setOvIpam(null));
  },[]);
  // listen for close message from topology iframe
  useEffect(()=>{
    const handler=e=>{ if(e.data==='close-topo') setShowTopo(false); };
    window.addEventListener('message',handler);
    return()=>window.removeEventListener('message',handler);
  },[]);

  // ── Independent health poll — runs every 60s, never relies on stale props ──
  useEffect(()=>{
    let cancelled=false;
    async function pollHealth(){
      try{
        // VMware
        const vcList = await fetchVCenters().catch(()=>[]);
        const vcSums = await Promise.all((vcList||[]).map(vc=>
          fetchSummary(vc.id).then(s=>({...s,status:"ok"})).catch(()=>({vcenter_id:vc.id,status:"error"}))
        ));
        const vcCount = vcList.length;
        const vcErrorCount = vcSums.filter(s=>s.status==="error").length;
        // Healthy if no errors AND no vcenter has >50% hosts disconnected
        const vcDegraded = vcErrorCount>0 || vcSums.some(s=>
          s.status!=="error" && s.total_hosts>0 && (s.connected_hosts/s.total_hosts)<0.5
        );

        // OCP
        let ocpCount=0, ocpDegraded=false;
        try{
          const clusters = await fetchOCPClusters();
          ocpCount = (clusters||[]).length;
          if(ocpCount>0){
            const ovArr = await Promise.all((clusters||[]).map(c=>fetchOCPOverview(c.id).catch(()=>null)));
            ocpDegraded = ovArr.some(ov=>{
              if(!ov) return false;
              const ns=ov.nodes_summary||{};
              const os=ov.operators_summary||{};
              return (ns.total>0&&ns.not_ready/ns.total>0.25)||(os.total>0&&os.degraded/os.total>0.15);
            });
          }
        }catch(e){}

        // Nutanix
        let nutCount=0, nutDegraded=false;
        try{
          const pcs = await fetchNutanixPCs();
          nutCount = (pcs||[]).length;
          if(nutCount>0){
            const ovArr = await Promise.all((pcs||[]).map(pc=>fetchNutanixOverview(pc.id).catch(()=>null)));
            nutDegraded = ovArr.some(ov=>ov?.alerts?.critical>0);
          }
        }catch(e){}

        if(!cancelled) setLiveHealth({vcCount,vcErrorCount,vcDegraded,ocpCount,ocpDegraded,nutCount,nutDegraded});
      }catch(e){}
      if(!cancelled) setLhLoading(false);
    }
    pollHealth();
    const t=setInterval(pollHealth,60000);
    return()=>{ cancelled=true; clearInterval(t); };
  },[]);

  if(loading) return <LoadState msg="Loading environment summary…"/>;
  if(error)   return <ErrState msg={error} onRetry={onRetry}/>;
  if(!summary) return null;
  const {cpu,ram,storage}=summary;
  const cpuPct  = cpu.total_mhz   >0?Math.round((cpu.used_mhz   /cpu.total_mhz)  *100):0;
  const ramPct  = ram.total_gb    >0?Math.round((ram.used_gb    /ram.total_gb)   *100):0;
  const diskPct = storage.total_gb>0?Math.round((storage.used_gb/storage.total_gb)*100):0;
  const errA=alerts.filter(a=>a.severity==="error").length;
  const warnA=alerts.filter(a=>a.severity==="warn").length;
  const sortedH=[...hosts].filter(h=>h.status==="connected").sort((a,b)=>b.ram_free_pct-a.ram_free_pct);
  return(
    <div className="g-gap">
      {showTopo&&<SDxTopologyModal onClose={()=>setShowTopo(false)} p={p}/>}
      {/* ────── GLOBAL INFRASTRUCTURE BANNER ────── */}
      {(()=>{
        // Always use live-fetched counts when available, fall back to props
        const totalVMware = liveHealth ? liveHealth.vcCount : vcenters.length;
        const totalOCP    = liveHealth ? liveHealth.ocpCount : (ocpData?.clusters||[]).length;
        const totalNut    = liveHealth ? liveHealth.nutCount : (nutData?.pcs||[]).length;
        const nutVMsRun = Object.values(nutData?.overviews||{}).reduce((a,ov)=>a+(ov?.vms?.running||0),0);
        const nutVMsTot = Object.values(nutData?.overviews||{}).reduce((a,ov)=>a+(ov?.vms?.total||0),0);
        const nutHosts  = Object.values(nutData?.overviews||{}).reduce((a,ov)=>a+(ov?.hosts||0),0);
        const ocpNodes  = Object.values(ocpData?.overviews||{}).reduce((a,ov)=>a+(ov?.nodes_summary?.total||0),0);
        const ocpPods   = Object.values(ocpData?.overviews||{}).reduce((a,ov)=>a+(ov?.pods_summary?.running||0),0);
        const vmTotal=(summary?.total_vms||0)+(nutVMsTot);
        const vmRunning=(summary?.running_vms||0)+(nutVMsRun);
        const hostTotal=(summary?.total_hosts||0)+(ocpNodes)+(nutHosts);
        const vcConnected = liveHealth ? (liveHealth.vcCount - (liveHealth.vcErrorCount||0)) : (totalVMware - summaries.filter(s=>s.status==="error").length);
        const platforms=[
          {label:"VMware vCenter", color:"#3b82f6",
           count:`${totalVMware} vCenter${totalVMware!==1?"s":""}`,
           connCount: vcConnected, totalCount: totalVMware, unitLabel:"vCenter",
           icon:"🖥️",
           status: lhLoading&&!liveHealth ? "loading"
                 : liveHealth ? (liveHealth.vcDegraded?"degraded":"healthy")
                 : (summaries.some(s=>s.status==="error")?"degraded":"healthy")},
          {label:"Red Hat OpenShift", color:"#ef4444", count:totalOCP===0?"Not configured":`${totalOCP} cluster${totalOCP!==1?"s":""}`,
           connCount:totalOCP, totalCount:totalOCP, unitLabel:"cluster",
           icon:"🔴",
           status: (lhLoading&&!liveHealth) ? "loading"
                 : totalOCP===0 ? "none"
                 : liveHealth ? (liveHealth.ocpDegraded?"degraded":"healthy")
                 : ocpData?.loading ? "loading"
                 : (()=>{
                     const ovs=Object.values(ocpData?.overviews||{});
                     const bad=ovs.some(ov=>{
                       const ns=ov?.nodes_summary||{};
                       const os=ov?.operators_summary||{};
                       return (ns.total>0&&ns.not_ready/ns.total>0.25)||(os.total>0&&os.degraded/os.total>0.15);
                     });
                     return bad?"degraded":"healthy";
                   })()},
          {label:"Nutanix AHV", color:"#22c55e", count:totalNut===0?"Not configured":`${totalNut} Prism Central${totalNut!==1?"s":""}`,
           connCount:totalNut, totalCount:totalNut, unitLabel:"Prism Central",
           icon:"🟩",
           status: (lhLoading&&!liveHealth) ? "loading"
                 : totalNut===0 ? "none"
                 : liveHealth ? (liveHealth.nutDegraded?"critical":"healthy")
                 : nutData?.loading ? "loading"
                 : (Object.values(nutData?.overviews||{}).some(ov=>ov?.alerts?.critical>0)?"critical":"healthy")},
        ];
        const globalHealth=platforms.some(p=>p.status==="degraded"||p.status==="critical")?"degraded":"healthy";
        const ghColor=globalHealth==="healthy"?"#10b981":"#f59e0b";
        return(
          <div style={{background:`linear-gradient(135deg,${p.panel},${p.panelAlt})`,border:`1px solid ${p.border}`,borderRadius:14,overflow:"hidden",boxShadow:"0 4px 24px rgba(0,0,0,.2)"}}>
            {/* Banner header */}
            <div style={{padding:"14px 20px",background:`linear-gradient(135deg,${p.accent}20,${p.cyan}10,${p.panel})`,borderBottom:`1px solid ${p.border}`,display:"flex",alignItems:"center",gap:14}}>
              <div style={{display:"flex",alignItems:"center",justifyContent:"center",width:38,height:38,borderRadius:10,background:`linear-gradient(135deg,${p.accent},${p.cyan})`,fontSize:18,flexShrink:0}}>⚡</div>
              <div style={{flex:1}}>
                <div style={{fontWeight:900,fontSize:15,letterSpacing:"1.5px",textTransform:"uppercase",background:`linear-gradient(90deg,${p.accent},${p.cyan})`,WebkitBackgroundClip:"text",WebkitTextFillColor:"transparent"}}>
                  SDx Infrastructure Overview
                </div>
                <div style={{fontSize:11,color:p.textMute,marginTop:2}}>Unified view across all managed platforms · LaaS Portal</div>
              </div>
              <div style={{display:"flex",alignItems:"center",gap:12,flexShrink:0}}>
                <button
                  onClick={()=>setShowTopo(true)}
                  style={{display:"flex",alignItems:"center",gap:8,padding:"8px 18px",
                    background:"linear-gradient(135deg,#0066cc,#0099dd)",
                    border:"2px solid #00d4ff",borderRadius:10,cursor:"pointer",
                    fontSize:13,fontWeight:800,color:"#ffffff",letterSpacing:".8px",
                    boxShadow:"0 0 18px rgba(0,180,255,.5),0 2px 8px rgba(0,0,0,.4)",
                    transition:"all .2s",whiteSpace:"nowrap",textShadow:"0 0 10px rgba(0,220,255,.8)"}}
                  onMouseEnter={e=>{e.currentTarget.style.background="linear-gradient(135deg,#0088ee,#00bbff)";e.currentTarget.style.boxShadow="0 0 28px rgba(0,200,255,.7),0 2px 8px rgba(0,0,0,.4)";e.currentTarget.style.transform="scale(1.04)";}}
                  onMouseLeave={e=>{e.currentTarget.style.background="linear-gradient(135deg,#0066cc,#0099dd)";e.currentTarget.style.boxShadow="0 0 18px rgba(0,180,255,.5),0 2px 8px rgba(0,0,0,.4)";e.currentTarget.style.transform="scale(1)";}}
                >
                  <span style={{fontSize:16}}>🌐</span> SDx Lab Topology
                </button>
                <div style={{width:8,height:8,borderRadius:"50%",background:ghColor,boxShadow:`0 0 8px ${ghColor}80`,animation:"pulse 2s infinite",flexShrink:0}}/>
                <span style={{fontSize:12,fontWeight:700,color:ghColor,whiteSpace:"nowrap"}}>{globalHealth==="healthy"?"All Platforms Healthy":"Attention Required"}</span>
              </div>
            </div>
            {/* Platform pills row */}
            <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:0,borderBottom:`1px solid ${p.border}`}}>
              {platforms.map((pl,i)=>{
                const sc=pl.status==="healthy"?"#10b981":pl.status==="degraded"||pl.status==="critical"?"#ef4444":pl.status==="loading"?"#f59e0b":"#64748b";
                return(
                  <div key={i} style={{padding:"14px 18px",borderRight:i<2?`1px solid ${p.border}`:"none",display:"flex",alignItems:"center",gap:10}}>
                    <div style={{display:"flex",alignItems:"center",justifyContent:"center",width:34,height:34,borderRadius:8,background:`${pl.color}18`,border:`1px solid ${pl.color}30`,fontSize:16,flexShrink:0}}>{pl.icon}</div>
                    <div style={{flex:1,minWidth:0}}>
                      <div style={{fontWeight:700,fontSize:12,color:p.text,marginBottom:2}}>{pl.label}</div>
                      {pl.totalCount!=null&&pl.totalCount>0
                        ? <div style={{fontSize:11,fontWeight:600,lineHeight:1.2}}>
                            <span style={{color: pl.connCount===pl.totalCount?"#10b981":pl.connCount>0?"#10b981":"#ef4444"}}>{pl.connCount}</span>
                            {pl.connCount!==pl.totalCount&&<span style={{color:p.textMute}}>/{pl.totalCount}</span>}
                            <span style={{color:p.textMute,fontWeight:400}}> {pl.unitLabel}{pl.totalCount!==1?"s":""}</span>
                          </div>
                        : <div style={{fontSize:11,color:pl.count==="Not configured"?p.textMute:pl.color,fontWeight:pl.count==="Not configured"?400:600}}>{pl.count}</div>
                      }
                    </div>
                    <div style={{display:"flex",flexDirection:"column",alignItems:"flex-end",gap:2}}>
                      <div style={{width:8,height:8,borderRadius:"50%",background:sc,boxShadow:`0 0 6px ${sc}70`,animation:pl.status==="healthy"?"pulse 2s infinite":"none"}}/>
                      <span style={{fontSize:9,color:sc,fontWeight:700,textTransform:"uppercase"}}>{pl.status==="loading"?"sync":pl.status==="none"?"—":pl.status}</span>
                    </div>
                  </div>
                );
              })}
            </div>
            {/* Aggregate KPIs */}
            <div style={{display:"grid",gridTemplateColumns:"repeat(5,1fr)",gap:0}}>
              {[
                {label:"Total VMs",value:vmTotal,sub:`${vmRunning} running`,color:p.green,icon:"💻"},
                {label:"ESXi Hosts",value:summary?.total_hosts||"—",sub:`${summary?.connected_hosts||0} connected`,color:p.accent,icon:"🗄️"},
                {label:"OCP Nodes",value:ocpNodes||"—",sub:`${Object.values(ocpData?.overviews||{}).reduce((a,ov)=>a+(ov?.nodes_summary?.ready||0),0)} ready`,color:"#ef4444",icon:"🔴"},
                {label:"Nutanix Hosts",value:nutHosts||"—",sub:`${nutVMsTot} VMs managed`,color:"#22c55e",icon:"🟩"},
                {label:"OCP Pods",value:ocpPods||"—",sub:"running containers",color:p.cyan,icon:"📦"},
              ].map(({label,value,sub,color,icon},i)=>(
                <div key={i} style={{padding:"12px 16px",borderRight:i<4?`1px solid ${p.border}`:"none",textAlign:"center"}}>
                  <div style={{fontSize:10,marginBottom:4}}>{icon}</div>
                  <div style={{fontWeight:900,fontSize:22,color,fontFamily:"'Geist Mono',monospace",lineHeight:1}}>{value}</div>
                  <div style={{fontSize:10,fontWeight:700,color:p.textMute,marginTop:3,textTransform:"uppercase",letterSpacing:".4px"}}>{label}</div>
                  <div style={{fontSize:10,color:p.textMute,marginTop:1}}>{sub}</div>
                </div>
              ))}
            </div>
          </div>
        );
      })()}
      {/* ────── MULTI-PLATFORM CHARTS ────── */}
      <EnvironmentChartsPanel summary={summary} ocpData={ocpData} nutData={nutData} p={p}/>
      {selectedVC==="all"&&summaries.length>1&&(
        <div className="g-gap">
          <div style={{textTransform:"uppercase",letterSpacing:"2px",fontWeight:800,fontSize:13,color:p.accent,padding:"4px 0 8px",display:"flex",alignItems:"center",gap:8}}>⬡ <span>VCENTER SUMMARY</span></div>
          <div className="g2">
            {summaries.map((s,i)=>{
              const c=VC_COLORS[i%VC_COLORS.length]; const err=s.status==="error";
              return(
                <div key={s.vcenter_id} className="card fade-up"
                  style={{borderColor:`${c}30`,cursor:"pointer",transition:"all .2s"}}
                  onClick={()=>onNavigate("capacity")}
                  onMouseEnter={e=>{e.currentTarget.style.borderColor=c;e.currentTarget.style.transform="translateY(-2px)";e.currentTarget.style.boxShadow=`0 8px 24px ${c}25`;}}
                  onMouseLeave={e=>{e.currentTarget.style.borderColor=`${c}30`;e.currentTarget.style.transform="";e.currentTarget.style.boxShadow="";}}>
                  <div style={{padding:"13px 16px",display:"flex",alignItems:"center",gap:10,borderBottom:`1px solid ${p.border}`}}>
                    <div style={{width:10,height:10,borderRadius:"50%",background:err?"#ef4444":c,boxShadow:`0 0 6px ${c}60`}}/>
                    <span style={{fontWeight:800,fontSize:16,color:err?"#ef4444":c}}>{s.vcenter_name}</span>
                    <M color="#475569" size={11}>{s.vcenter_host}</M>
                    {err&&<Badge color="error">ERROR</Badge>}
                  </div>
                  {!err&&(
                    <div style={{padding:"10px 14px"}}>
                      {/* Row 1 — Hosts · VMs · Storage */}
                      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8,marginBottom:10}}>
                        {[
                          ["Hosts",   `${s.connected_hosts}/${s.total_hosts}`, c,       `${s.total_hosts-s.connected_hosts} issues`],
                          ["VMs",     `${s.running_vms}/${s.total_vms||"?"}`,  p.green, `${(s.total_vms||0)-s.running_vms} off`],
                          ["Storage", `${Math.round(100-(s.storage?.free_pct??0))}%`,
                            (s.storage?.free_pct??100)<20?p.red:(s.storage?.free_pct??100)<40?p.yellow:p.green,
                            `${fmtGB(s.storage?.free_gb??0)} free`],
                        ].map(([l,v,vc,sub])=>(
                          <div key={l} style={{textAlign:"center",padding:"6px 4px",borderRadius:7,background:`${vc}08`,border:`1px solid ${vc}20`}}>
                            <div className="mono" style={{fontSize:24,fontWeight:800,color:vc,lineHeight:1}}>{v}</div>
                            <div style={{fontSize:10,color:"#475569",marginTop:3,fontWeight:600,textTransform:"uppercase",letterSpacing:".4px"}}>{l}</div>
                            <div style={{fontSize:10,color:"#475569",marginTop:1}}>{sub}</div>
                          </div>
                        ))}
                      </div>
                      {/* Row 2 — CPU / RAM / Storage with bars */}
                      <div style={{display:"flex",flexDirection:"column",gap:6}}>
                        {[
                          ["⚡ CPU",     s.cpu?.free_pct??0,   `${Math.round(s.cpu?.free_mhz/1000||0)} GHz free`,  `/ ${Math.round(s.cpu?.total_mhz/1000||0)} GHz`],
                          ["🧠 RAM",     s.ram?.free_pct??0,   `${fmtGB(s.ram?.free_gb??0)} free`,`/ ${fmtGB(s.ram?.total_gb??0)}`],
                          ["💾 Storage", s.storage?.free_pct??0,`${fmtGB(s.storage?.free_gb??0)} free`,`/ ${fmtGB(s.storage?.total_gb??0)}`],
                        ].map(([l,freePct,freeVal,totalVal])=>{
                          const clr=freeClr(freePct);
                          const usedPct=Math.round(100-freePct);
                          return(
                            <div key={l} style={{display:"flex",alignItems:"center",gap:8}}>
                              <span style={{fontSize:10,fontWeight:600,color:"#64748b",minWidth:62,flexShrink:0}}>{l}</span>
                              <div style={{flex:1,height:6,borderRadius:3,background:"#1a254050",overflow:"hidden"}}>
                                <div style={{height:"100%",width:`${usedPct}%`,borderRadius:3,background:clr,transition:"width .8s"}}/>
                              </div>
                              <span style={{fontSize:10,fontWeight:600,color:clr,minWidth:60,textAlign:"right",flexShrink:0}}>{freeVal}</span>
                              <span style={{fontSize:10,color:"#475569",minWidth:48,flexShrink:0}}>{totalVal}</span>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      )}
      <div className="g4">
        <KPI icon="🖥️" label="Running VMs"  value={summary.running_vms}  color={p.green}  sub={`${summary.stopped_vms} stopped · ${summary.total_vms} total`} onClick={()=>onNavigate("vms")}/>
        <KPI icon="🗄️" label="ESXi Hosts"   value={`${summary.connected_hosts}/${summary.total_hosts}`} color={p.accent} sub={`${summary.total_hosts-summary.connected_hosts} disconnected`} onClick={()=>onNavigate("capacity")}/>
        <KPI icon="🔔" label="Active Alerts" value={errA+warnA} color={errA>0?p.red:warnA>0?p.yellow:p.green} sub={`${errA} errors · ${warnA} warnings`} onClick={()=>onNavigate("overview")}/>
        <KPI icon="💾" label="Storage Free"  value={storage.free_pct} unit="%" color={freeClr(storage.free_pct)} sub={`${fmtGB(storage.free_gb)} available`} onClick={()=>onNavigate("capacity")}/>
      </div>
      <div className="g2">
        <div className="card">
          <div className="card-header">
            <span className="card-title">{selectedVC==="all"?"All vCenters — Aggregated":summary.vcenter_host} — Capacity</span>
          </div>
          <div className="card-p">
            <ResRow label="CPU"     usedPct={cpuPct}  usedVal={Math.round(cpu.used_mhz/1000)}    freeVal={Math.round(cpu.free_mhz/1000)}  totalVal={Math.round(cpu.total_mhz/1000)}  unit="GHz"/>
            <ResRow label="Memory"  usedPct={ramPct}  usedVal={fmtGB(ram.used_gb)} freeVal={fmtGB(ram.free_gb)} totalVal={fmtGB(ram.total_gb)} unit=""/>
            <ResRow label="Storage" usedPct={diskPct} usedVal={fmtGB(storage.used_gb)} freeVal={fmtGB(storage.free_gb)} totalVal={fmtGB(storage.total_gb)} unit=""/>
            <div style={{display:"flex",gap:14,marginTop:10,paddingTop:8,borderTop:`1px solid ${p.border}`}}>
              {[["#10b981","≥40% free"],["#f59e0b","20–39% free"],["#ef4444","<20% free"]].map(([c,l])=>(
                <div key={l} style={{display:"flex",alignItems:"center",gap:5,fontSize:11,color:"#475569"}}>
                  <div style={{width:8,height:8,borderRadius:2,background:c}}/>{l}
                </div>
              ))}
            </div>
          </div>
        </div>
        <div className="card">
          <div className="card-header">
            <span className="card-title">Host Free Space Ranking</span>
            <div style={{display:"flex",gap:10,fontSize:11,color:"#475569"}}>
              <span><span style={{color:"#10b981"}}>●</span> ≥40%</span>
              <span><span style={{color:"#f59e0b"}}>●</span> 20–39%</span>
              <span><span style={{color:"#ef4444"}}>●</span> &lt;20%</span>
            </div>
          </div>
          <div style={{maxHeight:240,overflowY:"auto",padding:"6px 10px"}}>
            {sortedH.map((h,i)=>{
              const rc=freeClr(h.ram_free_pct); const cc=freeClr(h.cpu_free_pct);
              const ramP=h.ram_total_gb>0?Math.round((h.ram_used_gb/h.ram_total_gb)*100):0;
              const vcDot=vcColor(h.vcenter_id,vcenters);
              return(
                <div key={i} style={{display:"flex",alignItems:"center",gap:8,padding:"7px 6px",borderRadius:7,background:`${rc}06`,border:`1px solid ${rc}20`,marginBottom:4}}>
                  <span style={{fontSize:11,color:"#475569",width:16,textAlign:"center"}}>{i+1}</span>
                  <div style={{width:8,height:8,borderRadius:"50%",background:rc,boxShadow:`0 0 5px ${rc}50`,flexShrink:0}}/>
                  {vcenters.length>1&&<div className="dot" style={{background:vcDot,width:5,height:5,flexShrink:0}} title={h.vcenter_name}/>}
                  <M size={11} color={p.text}>{h.name}</M>
                  <div style={{flex:1,display:"grid",gridTemplateColumns:"1fr 1fr",gap:6}}>
                    <div>
                      <div style={{fontSize:10,color:"#475569",marginBottom:2}}>MEM FREE</div>
                      <div style={{display:"flex",alignItems:"center",gap:4}}><Bar pct={ramP} color={rc}/><M color={rc} size={10}>{fmtGB(h.ram_free_gb)}</M></div>
                    </div>
                    <div>
                      <div style={{fontSize:10,color:"#475569",marginBottom:2}}>CPU</div>
                      <div style={{display:"flex",alignItems:"center",gap:4}}><Bar pct={Math.round(100-h.cpu_free_pct)} color={cc}/><M color={cc} size={10}>{Math.round(100-h.cpu_free_pct)}%</M></div>
                    </div>
                  </div>
                  <Badge color={h.status}>{h.status}</Badge>
                </div>
              );
            })}
          </div>
        </div>
      </div>
      {/* ────── RED HAT OPENSHIFT ────── */}
      <div>
        <div style={{display:"flex",alignItems:"center",gap:10,padding:"6px 0 10px",borderBottom:`2px solid #ef444420`,marginBottom:12}}>
          <div style={{width:26,height:26,borderRadius:7,background:"linear-gradient(135deg,#ef444420,#ef444408)",border:"1px solid #ef444430",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13}}>🔴</div>
          <div>
            <div style={{fontWeight:900,fontSize:12,letterSpacing:"1.8px",textTransform:"uppercase",color:"#ef4444"}}>Red Hat OpenShift</div>
            <div style={{fontSize:10,color:"#f87171",marginTop:1,fontWeight:500}}>Container Platform · Kubernetes Orchestration</div>
          </div>
          <div style={{flex:1}}/>
          {ocpData?.loading?(
            <span style={{fontSize:11,color:p.yellow,fontWeight:600,display:"flex",alignItems:"center",gap:5}}>
              <div style={{width:10,height:10,borderRadius:"50%",border:`2px solid #f59e0b40`,borderTopColor:"#f59e0b",animation:"spin 1s linear infinite"}}/>Fetching...
            </span>
          ):(
            <span style={{fontSize:11,color:p.textMute}}>{(ocpData?.clusters||[]).length} cluster{(ocpData?.clusters||[]).length!==1?"s":""} registered</span>
          )}
        </div>
        {(ocpData?.clusters||[]).length===0&&!ocpData?.loading?(
          <div style={{textAlign:"center",padding:"28px 20px",background:p.panelAlt,border:`1px dashed #ef444428`,borderRadius:12,color:p.textMute,fontSize:13}}>
            <div style={{fontSize:28,marginBottom:8,opacity:.4}}>🔴</div>
            <div style={{fontWeight:600,marginBottom:4}}>No OpenShift clusters configured</div>
            <div style={{fontSize:12}}>Add a cluster via the OpenShift page to see live data here</div>
          </div>
        ):(
          <div className="g2">
            {(ocpData?.clusters||[]).map(c=>(
              <OCPClusterCard key={c.id} cluster={c} ov={ocpData?.overviews?.[c.id]} p={p}/>
            ))}
            {ocpData?.loading&&[...(ocpData?.clusters?.length?[]:[1,2])].map(i=>(
              <div key={i} style={{background:p.panelAlt,border:"1px solid rgba(239,68,68,.15)",borderRadius:12,height:140,animation:"pulse 1.5s ease-in-out infinite",opacity:.5}}/>
            ))}
          </div>
        )}
      </div>

      {/* ────── NUTANIX PRISM CENTRAL ────── */}
      <div>
        <div style={{display:"flex",alignItems:"center",gap:10,padding:"6px 0 10px",borderBottom:`2px solid #22c55e20`,marginBottom:12}}>
          <div style={{width:26,height:26,borderRadius:7,background:"linear-gradient(135deg,#22c55e20,#22c55e08)",border:"1px solid #22c55e30",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13}}>🟩</div>
          <div>
            <div style={{fontWeight:900,fontSize:12,letterSpacing:"1.8px",textTransform:"uppercase",color:"#22c55e"}}>Nutanix AHV</div>
            <div style={{fontSize:10,color:p.textMute,marginTop:1}}>Prism Central · Hyper-Converged Infrastructure</div>
          </div>
          <div style={{flex:1}}/>
          {nutData?.loading?(
            <span style={{fontSize:11,color:p.yellow,fontWeight:600,display:"flex",alignItems:"center",gap:5}}>
              <div style={{width:10,height:10,borderRadius:"50%",border:`2px solid #f59e0b40`,borderTopColor:"#f59e0b",animation:"spin 1s linear infinite"}}/>Fetching...
            </span>
          ):(
            <span style={{fontSize:11,color:p.textMute}}>{(nutData?.pcs||[]).length} Prism Central{(nutData?.pcs||[]).length!==1?"s":""} registered</span>
          )}
        </div>
        {(nutData?.pcs||[]).length===0&&!nutData?.loading?(
          <div style={{textAlign:"center",padding:"28px 20px",background:p.panelAlt,border:`1px dashed #22c55e28`,borderRadius:12,color:p.textMute,fontSize:13}}>
            <div style={{fontSize:28,marginBottom:8,opacity:.4}}>🟩</div>
            <div style={{fontWeight:600,marginBottom:4}}>No Nutanix Prism Centrals configured</div>
            <div style={{fontSize:12}}>Add a Prism Central via the Nutanix page to see live data here</div>
          </div>
        ):(
          <div className="g2">
            {(nutData?.pcs||[]).map(pc=>(
              <NutPCCard key={pc.id} pc={pc} ov={nutData?.overviews?.[pc.id]} p={p}/>
            ))}
            {nutData?.loading&&[...(nutData?.pcs?.length?[]:[1,2])].map(i=>(
              <div key={i} style={{background:p.panelAlt,border:"1px solid rgba(34,197,94,.15)",borderRadius:12,height:140,animation:"pulse 1.5s ease-in-out infinite",opacity:.5}}/>
            ))}
          </div>
        )}
      </div>

      {/* ────── IPAM OVERVIEW ────── */}
      <div>
        <div style={{display:"flex",alignItems:"center",gap:10,padding:"6px 0 10px",borderBottom:`2px solid #06b6d420`,marginBottom:12}}>
          <div style={{width:26,height:26,borderRadius:7,background:"linear-gradient(135deg,#06b6d420,#06b6d408)",border:"1px solid #06b6d430",display:"flex",alignItems:"center",justifyContent:"center",fontSize:13}}>📡</div>
          <div>
            <div style={{fontWeight:900,fontSize:12,letterSpacing:"1.8px",textTransform:"uppercase",color:"#06b6d4"}}>IPAM</div>
            <div style={{fontSize:10,color:p.textMute,marginTop:1}}>IP Address Management · SolarWinds Integration</div>
          </div>
          <div style={{flex:1}}/>
          {ovIpam?.summary&&(
            <span style={{fontSize:11,color:p.textMute}}>{ovIpam.summary.total_subnets||0} subnet{(ovIpam.summary.total_subnets||0)!==1?"s":""} · {Math.round(ovIpam.summary.percent_used||0)}% utilised</span>
          )}
        </div>
        {!ovIpam?(  
          <div style={{textAlign:"center",padding:"22px 20px",background:p.panelAlt,border:`1px dashed #06b6d428`,borderRadius:12,color:p.textMute,fontSize:12}}>
            <span style={{marginRight:8}}>📡</span>IPAM data unavailable — check SolarWinds connectivity
          </div>
        ):ovIpam.error?(
          <div style={{padding:"12px 16px",borderRadius:8,fontSize:12,color:"#ef4444",background:"#ef444410",border:"1px solid #ef444430"}}>
            ⚠️ IPAM error: {ovIpam.error}
          </div>
        ):(
          <>
            <div style={{display:"grid",gridTemplateColumns:"repeat(6,1fr)",gap:10,marginBottom:12}}>            {[{icon:"📡",label:"Subnets",value:ovIpam.summary.total_subnets||0,color:"#06b6d4"},{icon:"🌐",label:"Total IPs",value:(ovIpam.summary.total_ips||0).toLocaleString(),color:"#3b82f6"},{icon:"🔴",label:"Used",value:(ovIpam.summary.used_ips||0).toLocaleString(),color:"#ef4444"},{icon:"🟢",label:"Available",value:(ovIpam.summary.available_ips||0).toLocaleString(),color:"#10b981"},{icon:"🔒",label:"Reserved",value:(ovIpam.summary.reserved_ips||0).toLocaleString(),color:"#a855f7"},{icon:"📊",label:"Used %",value:`${Math.round(ovIpam.summary.percent_used||0)}%`,color:(ovIpam.summary.percent_used||0)>=80?"#ef4444":(ovIpam.summary.percent_used||0)>=60?"#f59e0b":"#10b981"}].map(k=>(
              <KPI key={k.label} icon={k.icon} label={k.label} value={k.value} color={k.color}/>
            ))}
            </div>
            {/* Top 6 high-utilisation subnets */}
            {(()=>{
              const top=[...(ovIpam.subnets||[])].sort((a,b)=>(b.percent_used||0)-(a.percent_used||0)).slice(0,6);
              if(top.length===0) return null;
              return(
                <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:10,overflow:"hidden"}}>
                  <div style={{padding:"10px 14px",borderBottom:`1px solid ${p.border}`,fontSize:11,fontWeight:700,color:"#06b6d4",letterSpacing:"1px",textTransform:"uppercase"}}>Top Utilised Subnets</div>
                  <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:0}}>
                    {top.map((s,i)=>{
                      const pct=Math.round(s.percent_used||0);
                      const bc=pct>=80?"#ef4444":pct>=60?"#f59e0b":"#10b981";
                      return(
                        <div key={i} style={{padding:"10px 14px",borderRight:i%3<2?`1px solid ${p.border}`:"none",borderBottom:i<3?`1px solid ${p.border}`:"none"}}>
                          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:4}}>
                            <span style={{fontSize:11,fontWeight:600,color:p.text,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",maxWidth:"70%"}}>{s.name||s.address_cidr}</span>
                            <span style={{fontSize:12,fontWeight:800,color:bc}}>{pct}%</span>
                          </div>
                          <div style={{height:4,borderRadius:2,background:p.panelAlt,overflow:"hidden"}}>
                            <div style={{height:"100%",width:`${pct}%`,background:bc,borderRadius:2,transition:"width .8s"}}/>
                          </div>
                          <div style={{fontSize:10,color:p.textMute,marginTop:3}}>{s.address_cidr} · {s.available||0} free</div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              );
            })()}
          </>
        )}
      </div>
    </div>
  );
}

// ─── VMs ─────────────────────────────────────────────────────────────────────
// ─── VM COST BADGE (uses pricing from localStorage cache or default) ──────────
const PRICE_CACHE = { data: null, fetched: false };
async function ensurePricing(){
  if(PRICE_CACHE.fetched) return;
  PRICE_CACHE.fetched = true;
  try{ PRICE_CACHE.data = await fetchPricing(); }catch{ PRICE_CACHE.data = DEFAULT_PRICING; }
}
function detectLicType(str){
  const s=(str||"").toLowerCase();
  if(s.includes("windows")||s.includes("win server")||s.includes("winserver")) return "windows";
  if(s.includes("red hat")||s.includes("rhel")) return "rhel";
  return "";
}

function calcVMCost(vm, pr){
  if(!pr) return null;
  const dsName = ((vm.datastores||[])[0]||"").toLowerCase();
  const diskType = dsName.includes("ssd") ? "SSD" : "HDD";
  const diskRate = diskType==="SSD" ? (pr.ssd_per_gb_month_inr||15) : (pr.hdd_per_gb_month_inr||pr.disk_per_gb_month_inr||8);
  const licType = detectLicType(vm.guest_os||"");
  const licRate = licType==="windows"?(pr.windows_license_month_inr||12500):licType==="rhel"?(pr.rhel_license_month_inr||10000):0;
  const monthly=(vm.cpu||0)*(pr.cpu_per_core_month_inr||500)+(vm.ram_gb||0)*(pr.ram_per_gb_month_inr||200)+(vm.disk_gb||0)*diskRate+licRate;
  return {monthly, daily:monthly/30, yearly:monthly*12, usd:pr.usd_rate||83.5, diskType, licType, licRate};
}

// ─── VMWARE UNIFIED PAGE ─────────────────────────────────────────────────────
function VMwarePage({vms,snapshots,vcenters,selectedVC,summaries,hosts,datastores,
    onCreateVM,onOpenModal,onRefresh,loading,error,onRetry,p,currentUser,initSearch}){
  const [vmTab,setVmTab]=useState("vcenters");
  // ESXi host action state (full parity with CapacityPage)
  const [hostActionState,setHostActionState]=useState({});
  const [selectedHosts,setSelectedHosts]=useState(new Set());
  const [bulkBusy,setBulkBusy]=useState(false);
  const [bulkMsg,setBulkMsg]=useState(null);
  const [topoTarget,setTopoTarget]=useState(null);
  const canAct=currentUser?.role==="admin"||currentUser?.role==="operator";

  function toggleHost(name){ setSelectedHosts(s=>{ const n=new Set(s); n.has(name)?n.delete(name):n.add(name); return n; }); }
  function toggleAllHosts(){ setSelectedHosts(s=>s.size===hosts.length?new Set():new Set(hosts.map(h=>h.name))); }

  async function doHostAction(h, action){
    const k=h.name;
    setHostActionState(s=>({...s,[k]:{status:"loading",action}}));
    try{
      await hostAction(h.vcenter_id, h.name, action);
      setHostActionState(s=>({...s,[k]:{status:"ok",action}}));
      setTimeout(()=>setHostActionState(s=>{const n={...s};delete n[k];return n;}),3000);
    }catch(e){
      setHostActionState(s=>({...s,[k]:{status:"err",msg:e.message}}));
      setTimeout(()=>setHostActionState(s=>{const n={...s};delete n[k];return n;}),4000);
    }
  }

  async function doBulkHostAction(action){
    if(selectedHosts.size===0) return;
    setBulkBusy(true); setBulkMsg(null);
    const sel=hosts.filter(h=>selectedHosts.has(h.name)).map(h=>({vcenter_id:h.vcenter_id,host_name:h.name}));
    try{
      await bulkHostAction(sel,action);
      setBulkMsg({ok:true,text:`${action} sent to ${sel.length} hosts`});
      setSelectedHosts(new Set());
      setTimeout(()=>setBulkMsg(null),4000);
    }catch(e){ setBulkMsg({ok:false,text:e.message}); }
    setBulkBusy(false);
  }

  const tD=datastores.reduce((s,d)=>s+d.total_gb,0);
  const fD=datastores.reduce((s,d)=>s+d.free_gb,0);
  const tR=hosts.reduce((s,h)=>s+h.ram_total_gb,0);
  const fR=hosts.reduce((s,h)=>s+h.ram_free_gb,0);

  const isAdmin=currentUser?.role==="admin";
  const canAct2=currentUser?.role==="admin"||currentUser?.role==="operator"||currentUser?.role==="requester";
  const tabs=[
    {id:"vcenters",    label:"vCenters",           icon:"🏢", color:"#3b82f6",
     sub:`${vcenters.length} connected`},
    {id:"vms",         label:"Virtual Machines",    icon:"💻", color:"#06b6d4",
     sub:`${vms.filter(v=>v.status==="poweredOn").length} running · ${vms.length} total`},
    {id:"hypervisors", label:"Hypervisors (ESXi)",  icon:"🗄️", color:"#8b5cf6",
     sub:`${hosts.filter(h=>h.status==="connected").length} online · ${hosts.length} total`},
    {id:"datastores",  label:"Datastores",           icon:"💾", color:"#f59e0b",
     sub:`${datastores.length} datastore${datastores.length!==1?"s":""} · ${fmtGB(fD)} free`},
    ...(canAct2?[{id:"actions", label:"VM Actions", icon:"🚀", color:"#10b981",
     sub:"Create · Request · Quick actions"}]:[]),
    ...(isAdmin?[{id:"manage", label:"Manage vCenters", icon:"⚙️", color:"#a78bfa",
     sub:`${vcenters.length} vCenter${vcenters.length!==1?"s":""} configured`}]:[]),
  ];
  return(
    <div className="g-gap">
      {topoTarget&&<TopologyModal target={topoTarget} onClose={()=>setTopoTarget(null)} p={p}/>}

      {/* ── Header + Sub-tab bar ── */}
      <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,overflow:"hidden"}}>
        <div style={{padding:"12px 18px",borderBottom:`1px solid ${p.border}`,
          background:`linear-gradient(135deg,#3b82f614,${p.panel})`,display:"flex",alignItems:"center",gap:10}}>
          <div style={{width:30,height:30,borderRadius:8,background:"linear-gradient(135deg,#3b82f6,#06b6d4)",
            display:"flex",alignItems:"center",justifyContent:"center",fontSize:14,flexShrink:0}}>🖥️</div>
          <div>
            <div style={{fontWeight:800,fontSize:13,color:p.text,letterSpacing:"-.1px"}}>VMware Infrastructure</div>
            <div style={{fontSize:10,color:p.textMute,marginTop:1}}>
              {vcenters.length} vCenter{vcenters.length!==1?"s":""} · {hosts.length} ESXi Host{hosts.length!==1?"s":""} · {vms.length} VM{vms.length!==1?"s":""} · {datastores.length} Datastore{datastores.length!==1?"s":""}
            </div>
          </div>
        </div>
        <div style={{display:"grid",gridTemplateColumns:`repeat(${tabs.length},1fr)`}}>
          {tabs.map((t,i)=>{
            const active=vmTab===t.id;
            return(
              <button key={t.id} onClick={()=>setVmTab(t.id)}
                style={{padding:"13px 14px",border:"none",
                  borderRight:i<tabs.length-1?`1px solid ${p.border}`:"none",
                  background:active?`${t.color}14`:"transparent",
                  cursor:"pointer",transition:"all .15s",
                  borderBottom:active?`3px solid ${t.color}`:`3px solid transparent`,
                  textAlign:"left"}}>
                <div style={{display:"flex",alignItems:"center",gap:8}}>
                  <span style={{fontSize:16}}>{t.icon}</span>
                  <div>
                    <div style={{fontWeight:700,fontSize:12,color:active?t.color:p.text}}>{t.label}</div>
                    <div style={{fontSize:10,color:p.textMute,marginTop:1}}>{t.sub}</div>
                  </div>
                </div>
              </button>
            );
          })}
        </div>
      </div>

      {/* ── vCenters tab ── */}
      {vmTab==="vcenters"&&(
        loading?<LoadState msg="Loading vCenter data…"/>:
        error?<ErrState msg={error} onRetry={onRetry}/>:
        summaries.length===0?(
          <div style={{textAlign:"center",padding:"48px 20px",background:p.panelAlt,
            border:`1px dashed #3b82f628`,borderRadius:12,color:p.textMute}}>
            <div style={{fontSize:32,marginBottom:10,opacity:.4}}>🏢</div>
            <div style={{fontWeight:700,fontSize:15,marginBottom:6}}>No vCenters Connected</div>
            <div style={{fontSize:12}}>Go to Settings → vCenter Manager to add a vCenter connection.</div>
          </div>
        ):(
          <div className="g2">
            {summaries.map((s,i)=>{
              const c=VC_COLORS[i%VC_COLORS.length]; const err=s.status==="error";
              return(
                <div key={s.vcenter_id} className="card fade-up" style={{borderColor:`${c}30`}}>
                  <div style={{padding:"13px 16px",display:"flex",alignItems:"center",gap:10,
                    borderBottom:`1px solid ${p.border}`,
                    background:`linear-gradient(135deg,${c}10,${p.panel})`}}>
                    <div style={{width:10,height:10,borderRadius:"50%",background:err?"#ef4444":c,
                      boxShadow:`0 0 6px ${c}60`}}/>
                    <span style={{fontWeight:800,fontSize:16,color:err?"#ef4444":c}}>{s.vcenter_name}</span>
                    <span style={{fontSize:11,color:p.textMute,marginLeft:4}}>{s.vcenter_host}</span>
                    <span style={{marginLeft:"auto",fontSize:10,fontWeight:700,
                      color:err?"#ef4444":"#10b981",
                      background:err?"#ef444415":"#10b98115",
                      border:`1px solid ${err?"#ef444430":"#10b98130"}`,
                      borderRadius:5,padding:"2px 8px"}}>{err?"ERROR":"ONLINE"}</span>
                  </div>
                  {!err&&(
                    <div style={{padding:"12px 16px",display:"flex",flexDirection:"column",gap:12}}>
                      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:8}}>
                        {[
                          ["ESXi Hosts",`${s.connected_hosts}/${s.total_hosts}`,c,`${s.total_hosts-s.connected_hosts} issue${s.total_hosts-s.connected_hosts!==1?"s":""}`],
                          ["VMs",`${s.running_vms}/${s.total_vms||"?"}`,p.green,`${(s.total_vms||0)-s.running_vms} off`],
                          ["Storage",`${Math.round(100-(s.storage?.free_pct??0))}%`,
                            (s.storage?.free_pct??100)<20?"#ef4444":(s.storage?.free_pct??100)<40?"#f59e0b":"#10b981",
                            `${fmtGB(s.storage?.free_gb??0)} free`],
                        ].map(([l,v,vc2,sub])=>(
                          <div key={l} style={{textAlign:"center",padding:"8px 4px",borderRadius:7,
                            background:`${vc2}08`,border:`1px solid ${vc2}20`}}>
                            <div className="mono" style={{fontSize:22,fontWeight:800,color:vc2,lineHeight:1}}>{v}</div>
                            <div style={{fontSize:10,color:p.textMute,marginTop:3,fontWeight:600,
                              textTransform:"uppercase",letterSpacing:".4px"}}>{l}</div>
                            <div style={{fontSize:10,color:p.textMute,marginTop:1}}>{sub}</div>
                          </div>
                        ))}
                      </div>
                      <div style={{display:"flex",flexDirection:"column",gap:5}}>
                        {[
                          ["⚡ CPU",s.cpu?.free_pct??0,`${Math.round((s.cpu?.free_mhz||0)/1000)} GHz free`,`/ ${Math.round((s.cpu?.total_mhz||0)/1000)} GHz`],
                          ["🧠 RAM",s.ram?.free_pct??0,`${fmtGB(s.ram?.free_gb??0)} free`,`/ ${fmtGB(s.ram?.total_gb??0)}`],
                          ["💾 Storage",s.storage?.free_pct??0,`${fmtGB(s.storage?.free_gb??0)} free`,`/ ${fmtGB(s.storage?.total_gb??0)}`],
                        ].map(([l,freePct,freeVal,totalVal])=>{
                          const clr=freeClr(freePct); const usedPct=Math.round(100-freePct);
                          return(
                            <div key={l} style={{display:"flex",alignItems:"center",gap:8}}>
                              <span style={{fontSize:10,fontWeight:600,color:p.textMute,minWidth:66,flexShrink:0}}>{l}</span>
                              <div style={{flex:1,height:6,borderRadius:3,background:"#1a254050",overflow:"hidden"}}>
                                <div style={{height:"100%",width:`${usedPct}%`,borderRadius:3,background:clr,transition:"width .8s"}}/>
                              </div>
                              <span style={{fontSize:10,fontWeight:600,color:clr,minWidth:64,textAlign:"right",flexShrink:0}}>{freeVal}</span>
                              <span style={{fontSize:10,color:p.textMute,minWidth:50,flexShrink:0}}>{totalVal}</span>
                            </div>
                          );
                        })}
                      </div>
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        )
      )}

      {/* ── Virtual Machines tab ── */}
      {vmTab==="vms"&&(
        <VMsPage vms={vms} snapshots={snapshots||[]} vcenters={vcenters} selectedVC={selectedVC}
          currentUser={currentUser} onCreateVM={onCreateVM} onRefresh={onRefresh}
          loading={loading} error={error} onRetry={onRetry} p={p} initSearch={initSearch||""}/>
      )}

      {/* ── Hypervisors (ESXi) tab — full parity with Capacity page ── */}
      {vmTab==="hypervisors"&&(
        loading?<LoadState msg="Loading host data…"/>:
        error?<ErrState msg={error} onRetry={onRetry}/>:(
          <>
            <div className="g4">
              <KPI icon="&#128476;&#65039;" label="Total Hosts"  value={hosts.length}        color={p.accent}/>
              <KPI icon="&#129504;" label="Memory Free"          value={fmtGB(fR)} color={freeClr((fR/tR)*100)} sub={`of ${fmtGB(tR)}`}/>
              <KPI icon="✅" label="Connected"                   value={hosts.filter(h=>h.status==="connected").length} color="#10b981" sub="hosts online"/>
              <KPI icon="🔧" label="Maintenance / Issues"        value={hosts.filter(h=>h.status!=="connected").length} color={hosts.filter(h=>h.status!=="connected").length>0?"#f59e0b":"#10b981"} sub="not connected"/>
            </div>
            {canAct&&selectedHosts.size>0&&(
              <div style={{display:"flex",gap:8,alignItems:"center",padding:"10px 14px",
                background:p.panelAlt,borderRadius:8,border:`1px solid ${p.orange}40`}}>
                <span style={{fontSize:12,fontWeight:600,color:p.orange}}>{selectedHosts.size} host{selectedHosts.size>1?"s":""} selected</span>
                <div style={{flex:1}}/>
                {bulkBusy?<span style={{fontSize:12,color:p.textMute}}>&#9203; Processing…</span>:<>
                  <button className="btn btn-sm" style={{background:`${p.yellow}15`,border:`1px solid ${p.yellow}40`,color:p.yellow}} onClick={()=>doBulkHostAction("maintenance")}>&#128295; Maintenance Mode</button>
                  <button className="btn btn-sm" style={{background:`${p.cyan}15`,border:`1px solid ${p.cyan}40`,color:p.cyan}} onClick={()=>doBulkHostAction("exit_maintenance")}>&#9989; Exit Maintenance</button>
                  <button className="btn btn-sm" style={{background:`${p.orange}15`,border:`1px solid ${p.orange}40`,color:p.orange}} onClick={()=>doBulkHostAction("reboot")}>&#8634; Reboot</button>
                  <button className="btn btn-danger btn-sm" onClick={()=>doBulkHostAction("shutdown")}>&#9210; Shutdown</button>
                  <button className="btn btn-ghost btn-sm" onClick={()=>setSelectedHosts(new Set())}>&#10005; Clear</button>
                </>}
              </div>
            )}
            {bulkMsg&&<div style={{padding:"10px 14px",borderRadius:8,fontSize:13,fontWeight:500,
              background:bulkMsg.ok?`${p.green}15`:`${p.red}15`,border:`1px solid ${bulkMsg.ok?p.green:p.red}40`,
              color:bulkMsg.ok?p.green:p.red}}>{bulkMsg.ok?"&#10003;":"&#10007;"} {bulkMsg.text}</div>}
            <div className="card" style={{overflow:"hidden"}}>
              <div className="card-header">
                <span className="card-title">ESXi Host Capacity</span>
                <button className="btn btn-success btn-sm" onClick={()=>downloadCSV("hosts",selectedVC)}>&#8595; CSV</button>
              </div>
              {hosts.length===0?(
                <div style={{padding:"40px 20px",textAlign:"center",color:p.textMute,fontSize:13}}>
                  <div style={{fontSize:28,marginBottom:8,opacity:.4}}>🗄️</div>
                  <div>No ESXi hosts found for selected scope.</div>
                </div>
              ):(
                <div className="tbl-wrap" style={{maxHeight:480}}>
                  <table><thead><tr>
                    {canAct&&<th style={{width:36,paddingLeft:14}}>
                      <input type="checkbox" checked={selectedHosts.size===hosts.length&&hosts.length>0}
                        onChange={toggleAllHosts} style={{cursor:"pointer",accentColor:p.accent}}/>
                    </th>}
                    <th style={{width:16}}></th>
                    {vcenters.length>1&&<th style={{width:90}}>VCENTER</th>}
                    <th style={{minWidth:140}}>HOST</th><th style={{minWidth:120}}>CLUSTER</th>
                    <th style={{width:100}}>STATUS</th><th style={{width:50}}>CORES</th>
                    <th style={{minWidth:130}}>CPU USED</th><th style={{width:70}}>RAM USED</th>
                    <th style={{width:70}}>RAM FREE</th><th style={{width:70}}>TOTAL</th>
                    {canAct&&<th style={{width:220,textAlign:"center"}}>ACTIONS</th>}
                  </tr></thead>
                  <tbody>{hosts.map((h,i)=>{
                    const cp=Math.round(100-h.cpu_free_pct);
                    const rp=h.ram_total_gb>0?Math.round((h.ram_used_gb/h.ram_total_gb)*100):0;
                    const vc=vcColor(h.vcenter_id,vcenters);
                    const isSel=selectedHosts.has(h.name);
                    const as=hostActionState[h.name];
                    return(<tr key={i} style={{background:isSel?`${p.orange}08`:""}}>
                      {canAct&&<td style={{paddingLeft:14}}>
                        <input type="checkbox" checked={isSel} onChange={()=>toggleHost(h.name)}
                          style={{cursor:"pointer",accentColor:p.accent}}/>
                      </td>}
                      <td><Dot color={h.status==="connected"?p.green:h.status==="maintenance"?p.yellow:/disconnected|notresponding|unreachable/i.test(h.status)?p.red:"#64748b"} live={h.status==="connected"}/></td>
                      {vcenters.length>1&&<td><span style={{fontSize:11,color:vc,fontWeight:600}}>{h.vcenter_name}</span></td>}
                      <td>
                        <div style={{display:"flex",alignItems:"center",gap:6}}>
                          <M color={p.accent} size={12}>{h.name}</M>
                          <button title="View Host Topology Map" onClick={()=>setTopoTarget({type:"host",vcenter_id:h.vcenter_id,vcenter_name:h.vcenter_name,name:h.name})}
                            style={{background:`${p.cyan}18`,border:`1px solid ${p.cyan}35`,borderRadius:4,padding:"1px 4px",cursor:"pointer",fontSize:10,color:p.cyan,flexShrink:0}}>🗺️</button>
                        </div>
                      </td>
                      <td>
                        {h.cluster_name&&h.cluster_name!=="—"
                          ?<span style={{display:"inline-flex",alignItems:"center",gap:4,fontSize:11,fontWeight:600,color:p.purple,background:`${p.purple}14`,border:`1px solid ${p.purple}35`,borderRadius:5,padding:"2px 7px",whiteSpace:"nowrap"}}>⚙️ {h.cluster_name}</span>
                          :<span style={{fontSize:11,color:p.textMute}}>— Standalone</span>}
                      </td>
                      <td><Badge color={h.status}>{h.status}</Badge></td>
                      <td><M size={12}>{h.cpu_cores}</M></td>
                      <td><div style={{display:"flex",alignItems:"center",gap:6}}><Bar pct={cp}/><M color={usedClr(cp)} size={11}>{cp}%</M></div></td>
                      <td><M size={12}>{fmtGB(h.ram_used_gb)}</M></td>
                      <td><M color={freeClr(100-rp)} size={12}>{fmtGB(h.ram_free_gb)}</M></td>
                      <td><M color={p.textMute} size={12}>{fmtGB(h.ram_total_gb)}</M></td>
                      {canAct&&<td style={{textAlign:"center",padding:"3px 4px"}}>
                        {as?.status==="loading"
                          ?<span style={{fontSize:11,color:p.textMute}}>&#9203; {as.action}…</span>
                          :as?.status==="ok"
                          ?<span style={{fontSize:11,color:p.green}}>&#10003; Done</span>
                          :as?.status==="err"
                          ?<span style={{fontSize:10,color:p.red}}>&#10007; Failed</span>
                          :<div style={{display:"flex",gap:2,justifyContent:"center"}}>
                            <button title="Enter Maintenance Mode" onClick={()=>doHostAction(h,"maintenance")}
                              style={{background:`${p.yellow}18`,border:`1px solid ${p.yellow}44`,borderRadius:5,padding:"2px 5px",cursor:"pointer",fontSize:10,color:p.yellow}}>&#128295; Maint</button>
                            <button title="Exit Maintenance Mode" onClick={()=>doHostAction(h,"exit_maintenance")}
                              style={{background:`${p.cyan}18`,border:`1px solid ${p.cyan}44`,borderRadius:5,padding:"2px 5px",cursor:"pointer",fontSize:10,color:p.cyan}}>&#9989; Exit</button>
                            <button title="Reboot Host" onClick={()=>doHostAction(h,"reboot")}
                              style={{background:`${p.orange}18`,border:`1px solid ${p.orange}44`,borderRadius:5,padding:"2px 5px",cursor:"pointer",fontSize:10,color:p.orange}}>&#8634; Reboot</button>
                            <button title="Shutdown Host" onClick={()=>doHostAction(h,"shutdown")}
                              style={{background:`${p.red}18`,border:`1px solid ${p.red}44`,borderRadius:5,padding:"2px 5px",cursor:"pointer",fontSize:10,color:p.red}}>&#9210; Off</button>
                          </div>
                        }
                      </td>}
                    </tr>);
                  })}</tbody></table>
                </div>
              )}
            </div>
          </>
        )
      )}

      {/* ── VM Actions tab ── */}
      {vmTab==="actions"&&canAct2&&(
        <div style={{display:"flex",flexDirection:"column",gap:16}}>
          {/* Action cards row */}
          <div className="g2">
            {/* Request VM card */}
            <div className="card" style={{border:`1px solid #10b98130`,borderTop:`3px solid #10b981`}}>
              <div style={{padding:"16px 18px"}}>
                <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:12}}>
                  <div style={{width:36,height:36,borderRadius:9,background:"#10b98118",border:"1px solid #10b98130",display:"flex",alignItems:"center",justifyContent:"center",fontSize:18,flexShrink:0}}>📋</div>
                  <div>
                    <div style={{fontWeight:800,fontSize:14,color:"#10b981"}}>Request VM</div>
                    <div style={{fontSize:11,color:p.textMute,marginTop:1}}>Submit a provisioning request for approval</div>
                  </div>
                </div>
                <div style={{fontSize:12,color:p.textMute,marginBottom:14,padding:"8px 10px",background:`#10b98108`,borderRadius:6,border:`1px solid #10b98120`}}>
                  Fill out the full VM specification form — OS, resources, vCenter target, owner, justification. Request goes to admin approval queue.
                </div>
                <button className="btn btn-success" style={{width:"100%",fontWeight:700}}
                  onClick={()=>onCreateVM&&onCreateVM()}>
                  📋 Open Request VM Form
                </button>
              </div>
            </div>
            {/* Quick Create VM card */}
            <div className="card" style={{border:`1px solid ${p.accent}30`,borderTop:`3px solid ${p.accent}`}}>
              <div style={{padding:"16px 18px"}}>
                <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:12}}>
                  <div style={{width:36,height:36,borderRadius:9,background:`${p.accent}18`,border:`1px solid ${p.accent}30`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:18,flexShrink:0}}>⚡</div>
                  <div>
                    <div style={{fontWeight:800,fontSize:14,color:p.accent}}>Quick Create VM</div>
                    <div style={{fontSize:11,color:p.textMute,marginTop:1}}>3-step guided VM creation wizard</div>
                  </div>
                </div>
                <div style={{fontSize:12,color:p.textMute,marginBottom:14,padding:"8px 10px",background:`${p.accent}08`,borderRadius:6,border:`1px solid ${p.accent}20`}}>
                  Fast 3-step wizard — set VM name, OS, vCPU/RAM/Disk resources, then submit. Ideal for quick ad-hoc requests.
                </div>
                <button className="btn btn-primary" style={{width:"100%",fontWeight:700}}
                  onClick={()=>onOpenModal&&onOpenModal()}>
                  ⚡ Open VM Creation Wizard
                </button>
              </div>
            </div>
          </div>
          {/* Summary of current VMware footprint */}
          <div className="card">
            <div className="card-header">
              <span className="card-title">Current VMware Footprint</span>
            </div>
            <div style={{padding:"12px 16px"}}>
              <div className="g4">
                <KPI icon="💻" label="Total VMs"      value={vms.length}                                      color={p.cyan}   sub={`${vms.filter(v=>v.status==="poweredOn").length} powered on`}/>
                <KPI icon="⏹️" label="Powered Off"    value={vms.filter(v=>v.status!=="poweredOn").length}    color={p.textMute} sub="stopped VMs"/>
                <KPI icon="🗄️" label="ESXi Hosts"     value={hosts.length}                                    color={p.accent} sub={`${hosts.filter(h=>h.status==="connected").length} connected`}/>
                <KPI icon="💾" label="Datastores"      value={datastores.length}                               color={p.purple} sub={`${fmtGB(fD)} free`}/>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* ── Manage vCenters tab (admin only) ── */}
      {vmTab==="manage"&&isAdmin&&(
        <div style={{display:"flex",flexDirection:"column",gap:16}}>
          <div style={{padding:"10px 14px",borderRadius:8,fontSize:12,color:"#a78bfa",
            background:"#a78bfa12",border:"1px solid #a78bfa30",display:"flex",alignItems:"center",gap:8}}>
            <span style={{fontSize:15}}>⚙️</span>
            <span><b>Admin only.</b> Add, test, or remove vCenter connections. Changes update .env and take effect immediately.</span>
          </div>
          <VCenterManager p={p} onReload={onRefresh}/>
        </div>
      )}

      {/* ── Datastores tab ── */}
      {vmTab==="datastores"&&(
        loading?<LoadState msg="Loading datastore data…"/>:
        error?<ErrState msg={error} onRetry={onRetry}/>:(
          <>
            <div className="g4">
              <KPI icon="&#128190;" label="Total Datastores" value={datastores.length}        color={p.purple}/>
              <KPI icon="&#128230;" label="Storage Free"     value={fmtGB(fD)} color={freeClr((fD/tD)*100)} sub={`of ${fmtGB(tD)}`}/>
              <KPI icon="✅"        label="Accessible"       value={datastores.filter(d=>d.accessible).length}   color="#10b981" sub="online"/>
              <KPI icon="⚠️"       label="Offline"          value={datastores.filter(d=>!d.accessible).length}  color={datastores.filter(d=>!d.accessible).length>0?"#ef4444":"#10b981"} sub="not accessible"/>
            </div>
            <div className="card" style={{overflow:"hidden"}}>
              <div className="card-header">
                <span className="card-title">Datastore Usage</span>
                <button className="btn btn-success btn-sm" onClick={()=>downloadCSV("datastores",selectedVC)}>&#8595; CSV</button>
              </div>
              {datastores.length===0?(
                <div style={{padding:"40px 20px",textAlign:"center",color:p.textMute,fontSize:13}}>
                  <div style={{fontSize:28,marginBottom:8,opacity:.4}}>💾</div>
                  <div>No datastores found for selected scope.</div>
                </div>
              ):(
                <div className="tbl-wrap" style={{maxHeight:520}}>
                  <table><thead><tr>
                    {vcenters.length>1&&<th style={{width:90}}>VCENTER</th>}
                    <th style={{minWidth:160}}>DATASTORE</th>
                    <th style={{width:60}}>TYPE</th>
                    <th style={{minWidth:140}}>USAGE</th>
                    <th style={{width:70}}>USED</th>
                    <th style={{width:70}}>FREE</th>
                    <th style={{width:70}}>TOTAL</th>
                    <th style={{width:70}}>STATUS</th>
                  </tr></thead>
                  <tbody>{datastores.map((d,i)=>{
                    const fc=freeClr(100-d.used_pct); const vc=vcColor(d.vcenter_id,vcenters);
                    return(<tr key={i}>
                      {vcenters.length>1&&<td><span style={{fontSize:11,color:vc,fontWeight:600}}>{d.vcenter_name}</span></td>}
                      <td><M color={p.accent} size={12}>{d.name}</M></td>
                      <td><span className="badge" style={{background:`${p.border}55`,color:p.textMute}}>{d.type}</span></td>
                      <td><div style={{display:"flex",alignItems:"center",gap:6}}><Bar pct={d.used_pct} color={fc}/><M color={fc} size={11}>{d.used_pct}%</M></div></td>
                      <td><M size={12}>{d.used_gb}GB</M></td>
                      <td><M color={fc} size={12}>{d.free_gb}GB</M></td>
                      <td><M color={p.textMute} size={12}>{d.total_gb}GB</M></td>
                      <td><Badge color={d.accessible?"connected":"error"}>{d.accessible?"OK":"OFFLINE"}</Badge></td>
                    </tr>);
                  })}</tbody></table>
                </div>
              )}
            </div>
          </>
        )
      )}
    </div>
  );
}

function VMsPage({vms,snapshots=[],vcenters,selectedVC,onCreateVM,onRefresh,loading,error,onRetry,p,currentUser,initSearch=""}){
  const [activeAction, setActiveAction] = useState(null);
  const [snapDeleteTarget, setSnapDeleteTarget] = useState(null);
  const [q,setQ]=useState(initSearch||""); const [st,setSt]=useState("All"); const [osF,setOsF]=useState("All");
  const [actionState,setActionState]=useState({});
  const [selected,setSelected]=useState(new Set());
  const [bulkBusy,setBulkBusy]=useState(false);
  const [bulkMsg,setBulkMsg]=useState(null);
  const [reconfigTarget,setReconfigTarget]=useState(null);
  const [deleteTarget,setDeleteTarget]=useState(null);
  const [topoTarget,setTopoTarget]=useState(null);
  const canAct = currentUser?.role==="admin"||currentUser?.role==="operator";

  const osList=["All",...Array.from(new Set(vms.map(v=>v.guest_os&&v.guest_os.trim()?v.guest_os.includes("Windows")?"Windows":v.guest_os.includes("Linux")||v.guest_os.includes("Ubuntu")||v.guest_os.includes("CentOS")||v.guest_os.includes("Red Hat")?"Linux":"Other":"Unknown"))).sort()];
  const list=vms.filter(v=>(st==="All"||v.status===st)&&(osF==="All"||(osF==="Windows"&&v.guest_os?.includes("Windows"))||(osF==="Linux"&&(v.guest_os?.includes("Linux")||v.guest_os?.includes("Ubuntu")||v.guest_os?.includes("CentOS")||v.guest_os?.includes("Red Hat")))||(osF==="Other"&&v.guest_os&&!v.guest_os.includes("Windows")&&!v.guest_os.includes("Linux")&&!v.guest_os.includes("Ubuntu")&&!v.guest_os.includes("CentOS")&&!v.guest_os.includes("Red Hat"))||(osF==="Unknown"&&(!v.guest_os||!v.guest_os.trim())))&&[v.name,v.host,v.guest_os,v.ip].some(s=>s?.toLowerCase().includes(q.toLowerCase())));

  function toggleSelect(name){ setSelected(s=>{ const n=new Set(s); n.has(name)?n.delete(name):n.add(name); return n; }); }
  function toggleAll(){ setSelected(s=>s.size===list.length?new Set():new Set(list.map(v=>v.name))); }

  // Fix #3: correct status colours
  function vmStatusColor(status){
    if(status==="poweredOn")  return p.green;
    if(status==="suspended")  return p.yellow;
    return p.red;
  }

  async function doAction(vm, action) {
    const key=vm.name;
    setActionState(s=>({...s,[key]:{status:"loading",action}}));
    try {
      await vmPowerAction(vm.vcenter_id, vm.name, action);
      setActionState(s=>({...s,[key]:{status:"ok",action}}));
      setTimeout(()=>setActionState(s=>{const n={...s};delete n[key];return n;}),3000);
    } catch(e) {
      setActionState(s=>({...s,[key]:{status:"err",msg:e.message}}));
      setTimeout(()=>setActionState(s=>{const n={...s};delete n[key];return n;}),4000);
    }
  }

  async function doBulk(action){
    if(selected.size===0) return;
    setBulkBusy(true); setBulkMsg(null);
    const selVMs=list.filter(v=>selected.has(v.name)).map(v=>({vcenter_id:v.vcenter_id,vm_name:v.name}));
    try{
      const r=await bulkVMAction(selVMs,action);
      setBulkMsg({ok:true,text:`${action} sent to ${selVMs.length} VMs`});
      setSelected(new Set());
      setTimeout(()=>{ setBulkMsg(null); onRefresh&&onRefresh(); },4000);
    }catch(e){ setBulkMsg({ok:false,text:e.message}); }
    setBulkBusy(false);
  }

  if(loading) return <LoadState msg="Loading virtual machines…"/>;
  if(error)   return <ErrState msg={error} onRetry={onRetry}/>;
  return(
    <div className="g-gap">
      {activeAction&&(
        <VMActionModal vm={activeAction.vm} action={activeAction.action}
          vcenters={vcenters} onClose={()=>setActiveAction(null)}
          onDone={()=>{ setActiveAction(null); onRefresh&&onRefresh(); }} p={p}/>
      )}
      {reconfigTarget&&(
        <ReconfigModal vm={reconfigTarget} onClose={()=>setReconfigTarget(null)}
          onDone={()=>{ setReconfigTarget(null); onRefresh&&onRefresh(); }} p={p}/>
      )}
      {deleteTarget&&(
        <DeleteVMModal vm={deleteTarget} onClose={()=>setDeleteTarget(null)}
          onDone={()=>{ setDeleteTarget(null); onRefresh&&onRefresh(); }} p={p}/>
      )}
      {snapDeleteTarget&&(
        <SnapshotDeleteModal vm={snapDeleteTarget} snapshots={snapshots}
          onClose={()=>setSnapDeleteTarget(null)}
          onDone={()=>{ setSnapDeleteTarget(null); onRefresh&&onRefresh(); }} p={p}/>
      )}
      {topoTarget&&<TopologyModal target={topoTarget} onClose={()=>setTopoTarget(null)} p={p}/>}
      <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"}}>
        <input style={{maxWidth:240,flex:"1 1 160px"}} placeholder="Search VM, host, OS, IP…" value={q} onChange={e=>setQ(e.target.value)}/>
        <select style={{width:150,flex:"none"}} value={st} onChange={e=>setSt(e.target.value)}>
          <option value="All">All Statuses</option>
          <option value="poweredOn">Powered On</option>
          <option value="poweredOff">Powered Off</option>
          <option value="suspended">Suspended</option>
        </select>
        <select style={{width:130,flex:"none"}} value={osF} onChange={e=>setOsF(e.target.value)}>
          <option value="All">All OS</option>
          <option value="Windows">🪟 Windows</option>
          <option value="Linux">🐧 Linux</option>
          <option value="Other">Other</option>
          <option value="Unknown">Unknown</option>
        </select>
        <span style={{fontSize:12,color:p.textMute}}>{list.length}/{vms.length} VMs</span>
        <div style={{flex:1}}/>
        <button className="btn btn-success btn-sm" onClick={()=>downloadCSV("vms",selectedVC)}>&#8595; CSV</button>
      </div>
      {canAct&&selected.size>0&&(
        <div style={{display:"flex",gap:8,alignItems:"center",padding:"10px 14px",
          background:p.panelAlt,borderRadius:8,border:`1px solid ${p.accent}40`}}>
          <span style={{fontSize:12,fontWeight:600,color:p.accent}}>{selected.size} VM{selected.size>1?"s":""} selected</span>
          <div style={{flex:1}}/>
          {bulkBusy?<span style={{fontSize:12,color:p.textMute}}>&#9203; Processing…</span>:<>
            <button className="btn btn-success btn-sm" onClick={()=>doBulk("start")}>&#9654; Start All</button>
            <button className="btn btn-danger btn-sm"  onClick={()=>doBulk("stop")}>&#9632; Stop All</button>
            <button className="btn btn-sm" style={{background:`${p.yellow}15`,border:`1px solid ${p.yellow}40`,color:p.yellow}} onClick={()=>doBulk("restart")}>&#8634; Restart All</button>
            <button className="btn btn-ghost btn-sm" onClick={()=>setSelected(new Set())}>&#10005; Clear</button>
          </>}
        </div>
      )}
      {bulkMsg&&(
        <div style={{padding:"10px 14px",borderRadius:8,fontSize:13,fontWeight:500,
          background:bulkMsg.ok?`${p.green}15`:`${p.red}15`,
          border:`1px solid ${bulkMsg.ok?p.green:p.red}40`,color:bulkMsg.ok?p.green:p.red}}>
          {bulkMsg.ok?"&#10003;":"&#10007;"} {bulkMsg.text}
        </div>
      )}
      <div className="card" style={{overflow:"hidden"}}>
        <div className="tbl-wrap" style={{maxHeight:"calc(100vh - 240px)"}}>
          <table>
            <thead><tr>
              {canAct&&<th style={{width:32,paddingLeft:10}}>
                <input type="checkbox" checked={selected.size===list.length&&list.length>0}
                  onChange={toggleAll} style={{cursor:"pointer",accentColor:p.accent}}/>
              </th>}
              {vcenters.length>1&&<th style={{width:80}}>VCENTER</th>}
              <th style={{minWidth:160}}>VM NAME</th>
              <th style={{width:70}}>STATUS</th>
              <th style={{width:38}}>CPU</th><th style={{width:52}}>RAM</th><th style={{width:56}}>DISK</th>
              <th style={{minWidth:110}}>HOST</th>
              <th style={{width:60}}>SNAPS</th><th style={{width:100}}>IP</th>
              <th style={{minWidth:130,textAlign:"center"}}>OS</th>
              <th style={{width:canAct?148:50,textAlign:"center"}}>ACTIONS</th>
            </tr></thead>
            <tbody>
              {list.map((v,i)=>{
                const sc=vmStatusColor(v.status);
                const vc=vcColor(v.vcenter_id,vcenters);
                const isSel=selected.has(v.name);
                return(
                  <tr key={i} style={{background:isSel?`${p.accent}10`:""}}>
                    {canAct&&<td style={{paddingLeft:10}}>
                      <input type="checkbox" checked={isSel} onChange={()=>toggleSelect(v.name)}
                        style={{cursor:"pointer",accentColor:p.accent}}/>
                    </td>}
                    {vcenters.length>1&&<td><span style={{fontSize:10,color:vc,fontWeight:700}}>{v.vcenter_name}</span></td>}
                    <td>
                      <div style={{display:"flex",alignItems:"center",gap:6}}>
                        <Dot color={sc} live={v.status==="poweredOn"}/>
                        <span style={{fontWeight:600,color:p.text,fontSize:12,fontFamily:"'Geist Mono',monospace"}}>{v.name}</span>
                        <button title="View Topology Map" onClick={()=>setTopoTarget({type:"vm",vcenter_id:v.vcenter_id,vcenter_name:v.vcenter_name,name:v.name})}
                          style={{background:`${p.cyan}18`,border:`1px solid ${p.cyan}35`,borderRadius:4,padding:"1px 4px",cursor:"pointer",fontSize:10,color:p.cyan,flexShrink:0}}>🗺️</button>
                      </div>
                    </td>
                    <td>
                      <span className="vm-chip" style={{
                        background:sc+"18",color:sc,border:`1px solid ${sc}35`}}>
                        {v.status==="poweredOn"?"ON":v.status==="poweredOff"?"OFF":v.status==="suspended"?"SUSP":"?"}
                      </span>
                    </td>
                    <td><span style={{fontFamily:"monospace",fontSize:11,color:p.textSub}}>{v.cpu}c</span></td>
                    <td><span style={{fontFamily:"monospace",fontSize:11,color:p.textSub}}>{v.ram_gb}G</span></td>
                    <td><span style={{fontFamily:"monospace",fontSize:11,color:p.textSub}}>{v.disk_gb}G</span></td>
                    <td style={{fontSize:11,color:p.textMute,maxWidth:110,overflow:"hidden",textOverflow:"ellipsis"}}>{v.host}</td>
                    <td>{v.snapshot_count>0
                      ?<div style={{display:"flex",alignItems:"center",gap:4}}>
                        <span className="badge" style={{background:`${p.yellow}20`,color:p.yellow,border:`1px solid ${p.yellow}35`,cursor:currentUser?.role==="admin"?"pointer":"default"}}
                          onClick={currentUser?.role==="admin"||currentUser?.role==="operator"?()=>setSnapDeleteTarget(v):undefined}
                          title={currentUser?.role==="admin"||currentUser?.role==="operator"?"Click to delete a snapshot":undefined}>
                          📸 {v.snapshot_count}
                        </span>
                        {currentUser?.role==="admin"||currentUser?.role==="operator"&&<button title="Delete a snapshot" onClick={()=>setSnapDeleteTarget(v)}
                          style={{background:`${p.red}15`,border:`1px solid ${p.red}35`,borderRadius:4,padding:"1px 4px",cursor:"pointer",fontSize:10,color:p.red}}>✕</button>}
                      </div>
                      :<span style={{color:p.border}}>—</span>}
                    </td>
                    <td><span style={{fontFamily:"monospace",fontSize:11,color:p.textMute}}>{v.ip||"—"}</span></td>
                    <td style={{fontSize:11,color:p.textMute,overflow:"hidden",textOverflow:"ellipsis",maxWidth:130}} title={v.guest_os}>{v.guest_os||"—"}</td>
                    <td style={{textAlign:"center",padding:"4px 4px"}}>
                      {!canAct
                        ? <span style={{fontSize:11,color:p.textMute}}>—</span>
                        : actionState[v.name]?.status==="loading"
                        ? <span style={{fontSize:11,color:p.textMute}}>&#9203;</span>
                        : actionState[v.name]?.status==="ok"
                        ? <span style={{fontSize:11,color:p.green}}>&#10003;</span>
                        : actionState[v.name]?.status==="err"
                        ? <span style={{fontSize:10,color:p.red}}>&#10007;</span>
                        : <div style={{display:"flex",gap:2,justifyContent:"center",flexWrap:"wrap"}}>
                            {v.status!=="poweredOn"&&<button title="Start" onClick={()=>doAction(v,"start")} style={{background:`${p.green}18`,border:`1px solid ${p.green}44`,borderRadius:5,padding:"2px 5px",cursor:"pointer",fontSize:12,color:p.green}}>&#9654;</button>}
                            {v.status==="poweredOn"&&<button title="Stop"  onClick={()=>doAction(v,"stop")}  style={{background:`${p.red}18`,border:`1px solid ${p.red}44`,borderRadius:5,padding:"2px 5px",cursor:"pointer",fontSize:12,color:p.red}}>&#9632;</button>}
                            {v.status==="poweredOn"&&<button title="Restart" onClick={()=>doAction(v,"restart")} style={{background:`${p.yellow}18`,border:`1px solid ${p.yellow}44`,borderRadius:5,padding:"2px 5px",cursor:"pointer",fontSize:12,color:p.yellow}}>&#8634;</button>}
                            <div style={{width:1,height:16,background:p.border,margin:"0 1px"}}/>
                            <button title="Snapshot" onClick={()=>setActiveAction({vm:v,action:"snapshot"})} style={{background:`${p.cyan}18`,border:`1px solid ${p.cyan}44`,borderRadius:5,padding:"2px 4px",cursor:"pointer",fontSize:11,color:p.cyan}}>&#128248;</button>
                            <button title="Clone VM" onClick={()=>setActiveAction({vm:v,action:"clone"})}    style={{background:`${p.purple}18`,border:`1px solid ${p.purple}44`,borderRadius:5,padding:"2px 4px",cursor:"pointer",fontSize:11,color:p.purple}}>&#128203;</button>
                            <button title="Migrate VM (vMotion / Storage vMotion / Cross-vCenter)" onClick={()=>setActiveAction({vm:v,action:"migrate"})} style={{background:`${p.orange}18`,border:`1px solid ${p.orange}44`,borderRadius:5,padding:"2px 4px",cursor:"pointer",fontSize:11,color:p.orange}}>&#128640;</button>
                            <button title="Reconfig CPU/RAM/Disk" onClick={()=>setReconfigTarget(v)} style={{background:`${p.textMute}18`,border:`1px solid ${p.textMute}44`,borderRadius:5,padding:"2px 4px",cursor:"pointer",fontSize:11,color:p.textMute}}>&#9881;&#65039;</button>
                            {currentUser?.role==="admin"&&<button title="Delete VM from Disk (Admin)" onClick={()=>setDeleteTarget(v)} style={{background:`${p.red}18`,border:`1px solid ${p.red}55`,borderRadius:5,padding:"2px 4px",cursor:"pointer",fontSize:11,color:p.red,fontWeight:700}}>&#128465;</button>}
                          </div>
                      }
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}

// ─── RECONFIG MODAL ───────────────────────────────────────────────────────────

// ─── VCENTER MANAGER COMPONENT (Admin Settings Tab) ───────────────────────────
function VCenterManager({p, onReload}){
  const [vcs, setVcs]       = useState([]);
  const [busy, setBusy]     = useState(false);
  const [msg, setMsg]       = useState(null);
  const [showAdd, setShowAdd] = useState(false);
  // Add form
  const [host, setHost]     = useState("");
  const [name, setName]     = useState("");
  const [user, setUser]     = useState("administrator@vsphere.local");
  const [pwd,  setPwd]      = useState("");
  const [port, setPort]     = useState(443);
  const [testing, setTesting] = useState(false);
  const [testResult, setTestResult] = useState(null);
  // Delete confirm
  const [delTarget, setDelTarget] = useState(null);
  const [delConfirm, setDelConfirm] = useState("");

  useEffect(()=>{
    fetchVCenters().then(setVcs).catch(()=>{});
  },[]);

  async function doTest(){
    if(!host||!user||!pwd) return;
    setTesting(true); setTestResult(null);
    try{ const r=await testVCenter({host,name:name||host,user,password:pwd,port}); setTestResult(r); }
    catch(e){ setTestResult({success:false,message:e.message}); }
    setTesting(false);
  }

  async function doAdd(){
    if(!host||!name||!user||!pwd){ setMsg({ok:false,text:"All fields required"}); return; }
    setBusy(true); setMsg(null);
    try{
      await addVCenter({host,name,user,password:pwd,port});
      await reloadVCenters();
      const updated = await fetchVCenters();
      setVcs(updated);
      setMsg({ok:true,text:`vCenter ${name} added successfully`});
      setShowAdd(false); setHost(""); setName(""); setPwd(""); setTestResult(null);
      onReload&&onReload();
    }catch(e){ setMsg({ok:false,text:e.message}); }
    setBusy(false);
  }

  async function doDelete(vc){
    if(delConfirm!==vc.host){ return; }
    setBusy(true); setMsg(null);
    try{
      await deleteVCenter(vc.id);
      await reloadVCenters();
      const updated = await fetchVCenters();
      setVcs(updated);
      setMsg({ok:true,text:`vCenter ${vc.name} removed`});
      setDelTarget(null); setDelConfirm("");
      onReload&&onReload();
    }catch(e){ setMsg({ok:false,text:e.message}); }
    setBusy(false);
  }

  return(
    <div style={{display:"flex",flexDirection:"column",gap:12}}>
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between"}}>
        <div style={{fontSize:12,color:p.textMute}}>Manage vCenter connections. Changes update .env and take effect immediately.</div>
        <button className="btn btn-primary btn-sm" onClick={()=>setShowAdd(s=>!s)}>
          {showAdd?"✕ Cancel":"＋ Add vCenter"}
        </button>
      </div>

      {msg&&<div style={{padding:"8px 12px",borderRadius:7,fontSize:12,fontWeight:500,
        background:msg.ok?`${p.green}15`:`${p.red}15`,border:`1px solid ${msg.ok?p.green:p.red}40`,
        color:msg.ok?p.green:p.red}}>{msg.ok?"✅":"✗"} {msg.text}</div>}

      {/* Existing vCenters list */}
      <div style={{display:"flex",flexDirection:"column",gap:6}}>
        {vcs.map((vc,i)=>(
          <div key={vc.id} style={{padding:"10px 12px",background:p.panelAlt,borderRadius:8,
            border:`1px solid ${p.border}`,display:"flex",alignItems:"center",gap:10}}>
            <div style={{width:8,height:8,borderRadius:"50%",background:p.green,flexShrink:0}}/>
            <div style={{flex:1}}>
              <div style={{fontWeight:600,fontSize:13}}>{vc.name}</div>
              <div style={{fontSize:11,color:p.textMute}}>{vc.host}</div>
            </div>
            {delTarget?.id===vc.id
              ? <div style={{display:"flex",gap:6,alignItems:"center",flexWrap:"wrap"}}>
                  <input value={delConfirm} onChange={e=>setDelConfirm(e.target.value)}
                    placeholder={vc.host} style={{width:160,fontSize:11}}/>
                  <button className="btn btn-danger btn-sm" onClick={()=>doDelete(vc)} disabled={delConfirm!==vc.host||busy}>
                    {busy?"⏳":"Confirm Delete"}
                  </button>
                  <button className="btn btn-ghost btn-sm" onClick={()=>{setDelTarget(null);setDelConfirm("");}}>Cancel</button>
                </div>
              : <button className="btn btn-danger btn-sm" onClick={()=>{setDelTarget(vc);setDelConfirm("");}}>
                  ✕ Remove
                </button>
            }
          </div>
        ))}
      </div>

      {/* Add vCenter form */}
      {showAdd&&(
        <div style={{padding:"14px",background:p.panelAlt,borderRadius:8,border:`1px solid ${p.border}`,
          display:"flex",flexDirection:"column",gap:10}}>
          <div style={{fontWeight:600,fontSize:13}}>Add New vCenter</div>
          <div className="g2">
            <div><label style={{fontSize:11}}>vCenter IP / Hostname *</label>
              <input value={host} onChange={e=>setHost(e.target.value)} placeholder="172.17.x.x"/>
            </div>
            <div><label style={{fontSize:11}}>Display Name *</label>
              <input value={name} onChange={e=>setName(e.target.value)} placeholder="Production"/>
            </div>
          </div>
          <div className="g2">
            <div><label style={{fontSize:11}}>Username *</label>
              <input value={user} onChange={e=>setUser(e.target.value)}/>
            </div>
            <div><label style={{fontSize:11}}>Password *</label>
              <input type="password" value={pwd} onChange={e=>setPwd(e.target.value)} placeholder="•••••••"/>
            </div>
          </div>
          <div style={{width:120}}><label style={{fontSize:11}}>Port</label>
            <input type="number" value={port} onChange={e=>setPort(Number(e.target.value))}/>
          </div>
          {testResult&&<div style={{fontSize:12,color:testResult.success?p.green:p.red,padding:"6px 10px",
            background:testResult.success?`${p.green}15`:`${p.red}15`,borderRadius:6,
            border:`1px solid ${testResult.success?p.green:p.red}40`}}>
            {testResult.success?"✅":"✗"} {testResult.message}
          </div>}
          <div style={{display:"flex",gap:8}}>
            <button className="btn btn-ghost btn-sm" onClick={doTest} disabled={testing||!host||!user||!pwd}>
              {testing?"⏳ Testing…":"🔌 Test Connection"}
            </button>
            <button className="btn btn-primary btn-sm" onClick={doAdd} disabled={busy||!host||!name||!user||!pwd}>
              {busy?"⏳ Adding…":"＋ Add vCenter"}
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── PRICING MANAGER (Admin Settings Tab) ────────────────────────────────────
const DEFAULT_PRICING = {
  // ── VMware vCenter ──
  cpu_per_core_month_inr:500,
  ram_per_gb_month_inr:200,
  ssd_per_gb_month_inr:15,
  hdd_per_gb_month_inr:8,
  disk_per_gb_month_inr:8,
  windows_license_month_inr:12500,
  rhel_license_month_inr:10000,
  internet_per_vm_month_inr:1500,
  // ── OpenShift ──
  ocp_cpu_per_core_month_inr:600,     // container CPU/core/month
  ocp_ram_per_gb_month_inr:220,       // container RAM/GB/month
  ocp_storage_per_gb_month_inr:12,    // persistent storage/GB/month
  ocp_pod_base_month_inr:200,         // fixed overhead per pod/month
  ocp_route_per_month_inr:300,        // ingress route per month
  ocp_windows_license_month_inr:8000, // Windows container OS license/month
  ocp_rhel_license_month_inr:7000,    // RHEL container OS license/month
  // ── Nutanix AHV ──
  nut_cpu_per_core_month_inr:480,     // Nutanix vCPU/core/month
  nut_ram_per_gb_month_inr:190,       // Nutanix RAM/GB/month
  nut_ssd_per_gb_month_inr:14,        // Nutanix SSD/GB/month
  nut_hdd_per_gb_month_inr:7,         // Nutanix HDD/GB/month
  nut_windows_license_month_inr:12500,
  nut_rhel_license_month_inr:10000,
  nut_internet_per_vm_month_inr:1500,
  usd_rate:83.5
};

function PricingManager({p, readOnly=false}){
  const [pr, setPr]     = useState(null);
  const [editing, setEditing] = useState({});
  const [saved, setSaved]     = useState(false);
  const [err, setErr]         = useState(null);

  useEffect(()=>{
    fetchPricing().then(d=>{ setPr(d); setEditing(d); }).catch(()=>{ setPr(DEFAULT_PRICING); setEditing(DEFAULT_PRICING); });
  },[]);

  async function doSave(){
    try{
      await savePricing(editing);
      setPr({...editing});
      setSaved(true); setErr(null);
      setTimeout(()=>setSaved(false),2500);
    }catch(e){ setErr(e.message); }
  }

  if(!pr) return <div style={{color:p.textMute,fontSize:12}}>Loading pricing…</div>;

  const fields=[
    {key:"cpu_per_core_month_inr",       label:"CPU — per core / month",                   icon:"⚡", unit:"₹"},
    {key:"ram_per_gb_month_inr",         label:"RAM — per GB / month",                    icon:"🧠", unit:"₹"},
    {key:"ssd_per_gb_month_inr",         label:"Disk (SSD) — per GB / month",             icon:"🟦", unit:"₹"},
    {key:"hdd_per_gb_month_inr",         label:"Disk (HDD) — per GB / month",             icon:"🟫", unit:"₹"},
    {key:"windows_license_month_inr",    label:"OS License — Windows Server / VM / month",icon:"🪟", unit:"₹"},
    {key:"rhel_license_month_inr",       label:"OS License — RHEL / VM / month",          icon:"🎩", unit:"₹"},
    {key:"internet_per_vm_month_inr",    label:"Internet Access — per VM / month",        icon:"🌐", unit:"₹"},
    {key:"usd_rate",                     label:"USD Exchange Rate (1 USD =)",             icon:"💱", unit:"₹"},
  ];

  return(
    <div style={{display:"flex",flexDirection:"column",gap:14}}>
      <div style={{fontSize:12,color:p.textMute,padding:"8px 12px",background:p.panelAlt,
        borderRadius:7,border:`1px solid ${p.border}`}}>
        💰 On-premises internal pricing. Used in VM Request cost estimation and Project Utilization chargeback.
        {pr.updated_by&&<span style={{marginLeft:8,color:p.textMute}}>Last updated by <b>{pr.updated_by}</b></span>}
      </div>
      <div style={{fontSize:11,padding:"7px 12px",background:`#0ea5e910`,borderRadius:7,
        border:`1px solid #0ea5e940`,color:"#0ea5e9"}}>
        🟦 <b>SSD</b> — Flash/solid-state datastores (higher IOPS, faster). Datastore names containing <b>"ssd"</b> auto-use this rate.<br/>
        🟫 <b>HDD</b> — Spinning disk datastores (standard). All other datastores use this rate.
      </div>
      <div style={{fontSize:11,padding:"7px 12px",background:`#7c3aed10`,borderRadius:7,
        border:`1px solid #7c3aed40`,color:"#7c3aed"}}>
        🪟 <b>Windows Server</b> (SPLA on-prem) &amp; 🎩 <b>RHEL</b> (subscription on-prem) — charged per VM per month automatically
        based on the VM's OS as reported by VMware Tools. Ubuntu, CentOS, Debian: <b>₹0</b> (open-source, no fee).
      </div>
      <div style={{fontSize:11,padding:"7px 12px",background:`#0891b210`,borderRadius:7,
        border:`1px solid #0891b240`,color:"#0891b2"}}>
        🌐 <b>Internet Access</b> — on-prem corporate internet circuit allocated per VM per month.
        Applies to all <b>powered-on</b> VMs by default. Admin can enable/disable per VM from Project Utilization.
      </div>
      {fields.map(({key,label,icon,unit})=>(
        <div key={key}>
          <label>{icon} {label}</label>
          <div style={{display:"flex",alignItems:"center",gap:8}}>
            <span style={{color:p.textMute,fontSize:13}}>{unit}</span>
            <input type="number" min={0} step={key==="usd_rate"?0.1:1}
              value={editing[key]||0} onChange={e=>setEditing(v=>({...v,[key]:Number(e.target.value)}))}
              style={{maxWidth:120}}/>
            {key!=="usd_rate"&&<span style={{fontSize:11,color:p.textMute}}>
              = ${((editing[key]||0)/(editing.usd_rate||83.5)).toFixed(2)} USD/month
            </span>}
          </div>
        </div>
      ))}
      {err&&<div style={{color:p.red,fontSize:12}}>✗ {err}</div>}
      <button className={`btn ${saved?"btn-success":"btn-primary"}`}
        onClick={doSave} style={{alignSelf:"flex-start"}}>
        {saved?"✅ Pricing Saved!":"💾 Save Pricing"}
      </button>
    </div>
  );
}

// ─── CHARGEBACK PAGE ────────────────────────────────────────────────────────
function ChargebackPage({currentUser, p}){
  const [cbTab,setCbTab]=useState("vmware");
  const isAdmin=currentUser?.role==="admin";
  const isOp=currentUser?.role==="operator";
  const canEdit=isAdmin;

  const platforms=[
    {id:"vmware",   label:"VMware vCenter", icon:"🖥️", color:"#3b82f6"},
    {id:"openshift",label:"OpenShift",       icon:"🔴", color:"#ef4444"},
    {id:"nutanix",  label:"Nutanix AHV",     icon:"🟩", color:"#22c55e"},
  ];

  return(
    <div className="g-gap">
      {/* Header */}
      <div style={{background:`linear-gradient(135deg,${p.panel},${p.panelAlt})`,border:`1px solid ${p.border}`,borderRadius:14,padding:"20px 24px",display:"flex",alignItems:"center",gap:16}}>
        <div style={{width:48,height:48,borderRadius:12,background:"linear-gradient(135deg,#f59e0b,#d97706)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,flexShrink:0,boxShadow:"0 4px 16px rgba(245,158,11,.35)"}}>💳</div>
        <div style={{flex:1}}>
          <div style={{fontWeight:900,fontSize:18,color:p.text,letterSpacing:"-.3px"}}>Infrastructure Chargeback</div>
          <div style={{fontSize:12,color:p.textMute,marginTop:3}}>Platform Pricing Configuration — Rates used for VM Request cost estimation &amp; Project Utilization chargeback</div>
        </div>
        {!canEdit&&<div style={{padding:"5px 12px",borderRadius:20,background:"#f59e0b15",border:"1px solid #f59e0b40",fontSize:11,color:"#f59e0b",fontWeight:600}}>👁 View Only — Operator mode</div>}
        {canEdit&&<div style={{padding:"5px 12px",borderRadius:20,background:"#10b98115",border:"1px solid #10b98140",fontSize:11,color:"#10b981",fontWeight:600}}>✏️ Edit enabled — Admin</div>}
      </div>

      {/* Platform Tab Selector */}
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10}}>
        {platforms.map(pl=>{
          const active=cbTab===pl.id;
          return(
            <div key={pl.id} onClick={()=>setCbTab(pl.id)}
              style={{padding:"16px 18px",borderRadius:12,cursor:"pointer",transition:"all .15s",
                background:active?`${pl.color}15`:p.panel,
                border:`2px solid ${active?pl.color:p.border}`,
                boxShadow:active?`0 0 0 3px ${pl.color}15`:"none"}}>
              <div style={{display:"flex",alignItems:"center",gap:12}}>
                <span style={{fontSize:26}}>{pl.icon}</span>
                <div>
                  <div style={{fontWeight:800,fontSize:14,color:active?pl.color:p.text}}>{pl.label}</div>
                  <div style={{fontSize:11,color:p.textMute,marginTop:2}}>Click to configure rates</div>
                </div>
                {active&&<div style={{marginLeft:"auto",width:8,height:8,borderRadius:"50%",background:pl.color,boxShadow:`0 0 8px ${pl.color}`}}/>}
              </div>
            </div>
          );
        })}
      </div>

      {/* VMware Pricing */}
      {cbTab==="vmware"&&<VMwarePricingPanel p={p} readOnly={!canEdit}/>}
      {/* OpenShift Pricing */}
      {cbTab==="openshift"&&<OCPPricingPanel p={p} readOnly={!canEdit}/>}
      {/* Nutanix Pricing */}
      {cbTab==="nutanix"&&<NutanixPricingPanel p={p} readOnly={!canEdit}/>}
    </div>
  );
}

// shared hook for pricing load/save
function usePricingEditor(){
  const [pr,setPr]=useState(null);
  const [editing,setEditing]=useState({});
  const [saved,setSaved]=useState(false);
  const [err,setErr]=useState(null);
  useEffect(()=>{
    fetchPricing().then(d=>{setPr(d);setEditing(d);}).catch(()=>{setPr(DEFAULT_PRICING);setEditing(DEFAULT_PRICING);});
  },[]);
  async function doSave(){
    try{
      await savePricing(editing);
      setPr({...editing});
      setSaved(true);setErr(null);
      setTimeout(()=>setSaved(false),2500);
    }catch(e){setErr(e.message);}
  }
  return {pr,editing,setEditing,saved,err,doSave};
}

function PricingFieldRow({icon,label,fieldKey,editing,setEditing,usdRate,readOnly,unit="₹",step=1,note}){
  const val=editing[fieldKey]??0;
  return(
    <div style={{display:"flex",alignItems:"center",gap:12,padding:"10px 14px",borderRadius:8,background:`rgba(255,255,255,.025)`,border:`1px solid rgba(255,255,255,.06)`}}>
      <span style={{fontSize:18,flexShrink:0}}>{icon}</span>
      <div style={{flex:1,minWidth:0}}>
        <div style={{fontSize:12,fontWeight:600,color:"#94a3b8",marginBottom:1}}>{label}</div>
        {note&&<div style={{fontSize:10,color:"#64748b"}}>{note}</div>}
      </div>
      <div style={{display:"flex",alignItems:"center",gap:8,flexShrink:0}}>
        {fieldKey!=="usd_rate"&&<span style={{fontSize:13,color:"#10b981",fontWeight:800,minWidth:72,textAlign:"right",fontFamily:"monospace"}}>
          ${((val)/(usdRate||83.5)).toFixed(2)}/mo
        </span>}
        <span style={{fontSize:11,color:"#64748b"}}>{unit}</span>
        <input type="number" min={0} step={step}
          value={val}
          readOnly={readOnly}
          onChange={e=>!readOnly&&setEditing(v=>({...v,[fieldKey]:Number(e.target.value)}))}
          style={{width:100,textAlign:"right",borderColor:readOnly?"transparent":undefined,
            background:readOnly?"rgba(255,255,255,.03)":undefined,
            cursor:readOnly?"default":undefined}}/>
        {fieldKey==="usd_rate"&&<span style={{fontSize:11,color:"#64748b",minWidth:50}}>₹ / $1</span>}
      </div>
    </div>
  );
}

function PlatformPricingHeader({icon,color,label,sub,p}){
  return(
    <div style={{display:"flex",alignItems:"center",gap:12,padding:"12px 16px",borderRadius:10,
      background:`${color}10`,border:`1px solid ${color}25`,marginBottom:4}}>
      <span style={{fontSize:24}}>{icon}</span>
      <div>
        <div style={{fontWeight:800,fontSize:15,color}}>{label} Pricing</div>
        <div style={{fontSize:11,color:p.textMute,marginTop:1}}>{sub}</div>
      </div>
    </div>
  );
}

function VMwarePricingPanel({p,readOnly}){
  const {pr,editing,setEditing,saved,err,doSave}=usePricingEditor();
  if(!pr) return <div style={{color:p.textMute,fontSize:12,padding:16}}>⏳ Loading…</div>;
  const usd=editing.usd_rate||83.5;
  const groups=[
    {
      title:"Compute", color:"#3b82f6",
      fields:[
        {icon:"⚡",label:"CPU — per vCore / month",     key:"cpu_per_core_month_inr",     note:"Applied per allocated vCPU"},
        {icon:"🧠",label:"RAM — per GB / month",        key:"ram_per_gb_month_inr",      note:"Applied per allocated RAM GB"},
      ]
    },
    {
      title:"Storage", color:"#8b5cf6",
      fields:[
        {icon:"🟦",label:"Disk (SSD) — per GB / month", key:"ssd_per_gb_month_inr",      note:"Datastores with 'ssd' in name auto-use this rate"},
        {icon:"🟫",label:"Disk (HDD) — per GB / month", key:"hdd_per_gb_month_inr",      note:"All other datastores use HDD rate"},
      ]
    },
    {
      title:"OS Licensing", color:"#7c3aed",
      fields:[
        {icon:"🪟",label:"Windows Server SPLA — per VM / month", key:"windows_license_month_inr", note:"Auto-applied when VMware Tools reports Windows OS"},
        {icon:"🎩",label:"RHEL Subscription — per VM / month",   key:"rhel_license_month_inr",   note:"Auto-applied for Red Hat VMs. Ubuntu/Debian: ₹0"},
      ]
    },
    {
      title:"Network & Access", color:"#0891b2",
      fields:[
        {icon:"🌐",label:"Internet Access — per VM / month",  key:"internet_per_vm_month_inr", note:"Corporate internet circuit allocation per powered-on VM"},
      ]
    },
    {
      title:"Currency", color:"#f59e0b",
      fields:[
        {icon:"💱",label:"USD Exchange Rate (1 USD = ₹)",     key:"usd_rate", note:"Used to display USD equivalent costs",step:0.1},
      ]
    },
  ];
  return(
    <div style={{display:"flex",flexDirection:"column",gap:16}}>
      <PlatformPricingHeader icon="🖥️" color="#3b82f6" label="VMware vCenter" sub="On-premises ESXi virtual machine resource chargeback rates" p={p}/>
      <div style={{padding:"8px 14px",borderRadius:8,background:"#3b82f610",border:"1px solid #3b82f630",fontSize:11,color:"#60a5fa"}}>
        💡 These rates apply to all VMware VMs appearing in the <b>Project Utilization</b> page and in the <b>VM Request</b> cost estimator.
      </div>
      {groups.map(g=>(
        <div key={g.title} style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,overflow:"hidden"}}>
          <div style={{padding:"10px 14px",borderBottom:`1px solid ${p.border}`,background:`${g.color}0A`,display:"flex",alignItems:"center",gap:8}}>
            <div style={{width:4,height:18,borderRadius:2,background:g.color,flexShrink:0}}/>
            <span style={{fontWeight:800,fontSize:11,color:g.color,textTransform:"uppercase",letterSpacing:"1.2px"}}>{g.title}</span>
          </div>
          <div style={{padding:"10px 10px",display:"flex",flexDirection:"column",gap:6}}>
            {g.fields.map(f=>(
              <PricingFieldRow key={f.key} icon={f.icon} label={f.label} fieldKey={f.key}
                editing={editing} setEditing={setEditing} usdRate={usd}
                readOnly={readOnly} step={f.step||1} note={f.note}/>
            ))}
          </div>
        </div>
      ))}
      {err&&<div style={{color:p.red,fontSize:12,padding:"8px 12px",background:`${p.red}10`,borderRadius:7}}>✗ {err}</div>}
      {!readOnly&&(
        <button className={`btn ${saved?"btn-success":"btn-primary"}`} onClick={doSave}
          style={{alignSelf:"flex-start",padding:"8px 20px",fontWeight:700}}>
          {saved?"✅ Saved!":"💾 Save VMware Pricing"}
        </button>
      )}
    </div>
  );
}

function OCPPricingPanel({p,readOnly}){
  const {pr,editing,setEditing,saved,err,doSave}=usePricingEditor();
  if(!pr) return <div style={{color:p.textMute,fontSize:12,padding:16}}>⏳ Loading…</div>;
  const usd=editing.usd_rate||83.5;
  const groups=[
    {
      title:"Container Compute", color:"#ef4444",
      fields:[
        {icon:"⚡",label:"CPU — per vCore / month",      key:"ocp_cpu_per_core_month_inr",  note:"Applied per CPU core requested in container spec"},
        {icon:"🧠",label:"Memory — per GB / month",      key:"ocp_ram_per_gb_month_inr",   note:"Applied per GB memory request in container spec"},
        {icon:"📦",label:"Pod Base Rate — per pod / month",key:"ocp_pod_base_month_inr",  note:"Fixed overhead per running pod (scheduling, infra)"},
      ]
    },
    {
      title:"Persistent Storage", color:"#f97316",
      fields:[
        {icon:"💾",label:"Persistent Volume — per GB / month",key:"ocp_storage_per_gb_month_inr",note:"Applied per GB in PersistentVolumeClaims (all storage classes)"},
      ]
    },
    {
      title:"Networking", color:"#0891b2",
      fields:[
        {icon:"🔀",label:"Ingress Route — per route / month",key:"ocp_route_per_month_inr",note:"Per OpenShift Route / Ingress resource, per month"},
      ]
    },
    {
      title:"OS Licensing", color:"#7c3aed",
      fields:[
        {icon:"🪟",label:"Windows Container License — per workload / month",key:"ocp_windows_license_month_inr",note:"Windows-based container images (SPLA)"},
        {icon:"🎩",label:"RHEL Container License — per workload / month",   key:"ocp_rhel_license_month_inr",   note:"RHEL-based container images (UBI paid tiers)"},
      ]
    },
  ];
  return(
    <div style={{display:"flex",flexDirection:"column",gap:16}}>
      <PlatformPricingHeader icon="🔴" color="#ef4444" label="Red Hat OpenShift" sub="Container workload resource chargeback rates — namespace &amp; project billing" p={p}/>
      <div style={{padding:"8px 14px",borderRadius:8,background:"#ef444410",border:"1px solid #ef444430",fontSize:11,color:"#fca5a5"}}>
        💡 Rates apply per requested resources (CPU/memory at <b>request</b> values, not limits). These feed into OCP namespace-level chargeback reports.
      </div>
      {groups.map(g=>(
        <div key={g.title} style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,overflow:"hidden"}}>
          <div style={{padding:"10px 14px",borderBottom:`1px solid ${p.border}`,background:`${g.color}0A`,display:"flex",alignItems:"center",gap:8}}>
            <div style={{width:4,height:18,borderRadius:2,background:g.color,flexShrink:0}}/>
            <span style={{fontWeight:800,fontSize:11,color:g.color,textTransform:"uppercase",letterSpacing:"1.2px"}}>{g.title}</span>
          </div>
          <div style={{padding:"10px 10px",display:"flex",flexDirection:"column",gap:6}}>
            {g.fields.map(f=>(
              <PricingFieldRow key={f.key} icon={f.icon} label={f.label} fieldKey={f.key}
                editing={editing} setEditing={setEditing} usdRate={usd}
                readOnly={readOnly} step={f.step||1} note={f.note}/>
            ))}
          </div>
        </div>
      ))}
      {err&&<div style={{color:p.red,fontSize:12,padding:"8px 12px",background:`${p.red}10`,borderRadius:7}}>✗ {err}</div>}
      {!readOnly&&(
        <button className={`btn ${saved?"btn-success":"btn-primary"}`} onClick={doSave}
          style={{alignSelf:"flex-start",padding:"8px 20px",fontWeight:700,background:"#ef4444",borderColor:"#ef444480"}}>
          {saved?"✅ Saved!":"🔴 Save OpenShift Pricing"}
        </button>
      )}
    </div>
  );
}

