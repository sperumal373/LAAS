      </div>
      {groups.map(g=>(
        <div key={g.title} style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,overflow:"hidden"}}>
          <div style={{padding:"10px 14px",borderBottom:`1px solid ${p.border}`,background:`${g.color}0A`,display:"flex",alignItems:"center",gap:8}}>
            <div style={{width:4,height:18,borderRadius:2,background:g.color,flexShrink:0}}/>
            <span style={{fontWeight:800,fontSize:11,color:g.color,textTransform:"uppercase",letterSpacing:"1.2px"}}>{g.title}</span>
          </div>
          <div style={{padding:"10px 10px",display:"flex",flexDirection:"column",gap:6}}>
            {g.fields.map(f=>(
              <PricingFieldRow key={f.key} icon={f.icon} label={f.label} fieldKey={f.key}
                editing={editing} setEditing={setEditing} usdRate={usd}
                readOnly={readOnly} step={f.step||1} note={f.note}/>
            ))}
          </div>
        </div>
      ))}
      {err&&<div style={{color:p.red,fontSize:12,padding:"8px 12px",background:`${p.red}10`,borderRadius:7}}>✗ {err}</div>}
      {!readOnly&&(
        <button className={`btn ${saved?"btn-success":"btn-primary"}`} onClick={doSave}
          style={{alignSelf:"flex-start",padding:"8px 20px",fontWeight:700,background:"#22c55e",borderColor:"#22c55e80",color:"#fff"}}>
          {saved?"✅ Saved!":"🟩 Save Nutanix Pricing"}
        </button>
      )}
    </div>
  );
}

function ReconfigModal({vm, onClose, onDone, p}){
  const [cpu,  setCpu]  = useState(vm.cpu||2);
  const [ram,  setRam]  = useState(vm.ram_gb||4);
  const [disk, setDisk] = useState(vm.disk_gb||50);
  const [busy, setBusy] = useState(false);
  const [result,setResult]=useState(null);
  async function apply(){
    setBusy(true);
    try{
      await reconfigVM(vm.vcenter_id, vm.name, cpu, ram, disk);
      setResult({ok:true,msg:"Reconfigured successfully."});
      setTimeout(()=>{ onDone(); onClose(); },2500);
    }catch(e){ setResult({ok:false,msg:e.message}); }
    setBusy(false);
  }
  return(
    <div className="overlay" onClick={onClose}>
      <div className="modal" style={{width:420}} onClick={e=>e.stopPropagation()}>
        <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:16}}>
          <div>
            <div style={{fontWeight:700,fontSize:15,color:p.orange}}>&#9881;&#65039; Reconfigure VM</div>
            <div style={{fontSize:12,color:p.textMute,marginTop:2}}>{vm.name}</div>
          </div>
          <button className="btn btn-ghost btn-sm" onClick={onClose}>&#10005;</button>
        </div>
        <div style={{padding:"10px 12px",background:`${p.yellow}10`,borderRadius:7,
          border:`1px solid ${p.yellow}30`,fontSize:12,color:p.textMute,marginBottom:14}}>
          &#9888;&#65039; VM is <b>{vm.status==="poweredOn"?"POWERED ON — CPU/RAM changes need restart":"POWERED OFF"}</b>. Disk increase applies immediately.
        </div>
        <div style={{display:"flex",flexDirection:"column",gap:14}}>
          {[
            {label:"CPU Cores", val:cpu,  set:setCpu,  opts:[1,2,4,8,16,32],        unit:"vCPUs", cur:vm.cpu},
            {label:"RAM (GB)",  val:ram,  set:setRam,  opts:[1,2,4,8,16,32,64,128], unit:"GB",    cur:vm.ram_gb},
            {label:"Disk (GB)", val:disk, set:setDisk, opts:[20,40,50,80,100,200,500,1000],unit:"GB",cur:vm.disk_gb},
          ].map(({label,val,set,opts,unit,cur})=>(
            <div key={label}>
              <label>{label} <span style={{color:p.textMute,fontWeight:400,textTransform:"none"}}>current: {cur} {unit}</span></label>
              <select value={val} onChange={e=>set(Number(e.target.value))}>
                {opts.map(n=><option key={n} value={n}>{n} {unit}</option>)}
              </select>
              {val>cur&&<div style={{fontSize:10,color:p.green,marginTop:3}}>&#8679; {cur} → {val} {unit}</div>}
              {val<cur&&<div style={{fontSize:10,color:p.red,marginTop:3}}>&#8681; Reducing may cause issues</div>}
            </div>
          ))}
        </div>
        {result&&<div style={{marginTop:14,padding:"10px 12px",borderRadius:7,fontSize:12,
          background:result.ok?`${p.green}15`:`${p.red}15`,border:`1px solid ${result.ok?p.green:p.red}40`,
          color:result.ok?p.green:p.red}}>{result.ok?"&#10003;":"&#10007;"} {result.msg}</div>}
        <div style={{display:"flex",gap:8,justifyContent:"flex-end",marginTop:20,paddingTop:16,borderTop:`1px solid ${p.border}`}}>
          <button className="btn btn-ghost" onClick={onClose} disabled={busy}>Cancel</button>
          <button className="btn btn-primary" onClick={apply} disabled={busy}>{busy?"Applying…":"Apply Changes"}</button>
        </div>
      </div>
    </div>
  );
}

// ─── CAPACITY ────────────────────────────────────────────summaries,─────────────────────
function CapacityPage({hosts,datastores,vcenters,selectedVC,currentUser,onRefresh,loading,error,onRetry,ocpData,nutData,p}){
  const [hostActionState,setHostActionState]=useState({});
  const [selectedHosts,setSelectedHosts]=useState(new Set());
  const [bulkBusy,setBulkBusy]=useState(false);
  const [bulkMsg,setBulkMsg]=useState(null);
  const [topoTarget,setTopoTarget]=useState(null);
  const [platTab,setPlatTab]=useState("vmware");
  const canAct=currentUser?.role==="admin"||currentUser?.role==="operator";

  const [ipamData,setIpamData]=useState(null);
  const [ipamLoading,setIpamLoading]=useState(false);
  useEffect(()=>{
    setIpamLoading(true);
    fetchIPAMSubnets().then(d=>setIpamData(d)).catch(()=>setIpamData(null)).finally(()=>setIpamLoading(false));
  },[]);

  if(loading) return <LoadState msg="Loading capacity data…"/>;
  if(error)   return <ErrState msg={error} onRetry={onRetry}/>;

  const tR=hosts.reduce((s,h)=>s+h.ram_total_gb,0);
  const fR=hosts.reduce((s,h)=>s+h.ram_free_gb,0);
  const tD=datastores.reduce((s,d)=>s+d.total_gb,0);
  const fD=datastores.reduce((s,d)=>s+d.free_gb,0);

  // ONLY "connected" → green. Everything else gets an explicit colour.
  function hostStatusColor(status){
    const s=(status||"").toLowerCase().trim();
    if(s==="connected")                          return p.green;
    if(s==="maintenance")                        return p.yellow;
    if(s==="poweredon")                          return p.green;    // edge case
    if(s==="disconnected"||s==="notresponding"
       ||s==="unreachable"||s==="notreachable")  return p.red;
    // unknown / "" → grey
    return "#64748b";
  }

  function toggleHost(name){ setSelectedHosts(s=>{ const n=new Set(s); n.has(name)?n.delete(name):n.add(name); return n; }); }
  function toggleAllHosts(){ setSelectedHosts(s=>s.size===hosts.length?new Set():new Set(hosts.map(h=>h.name))); }

  async function doHostAction(h, action){
    const k=h.name;
    setHostActionState(s=>({...s,[k]:{status:"loading",action}}));
    try{
      await hostAction(h.vcenter_id, h.name, action);
      setHostActionState(s=>({...s,[k]:{status:"ok",action}}));
      setTimeout(()=>setHostActionState(s=>{const n={...s};delete n[k];return n;}),3000);
    }catch(e){
      setHostActionState(s=>({...s,[k]:{status:"err",msg:e.message}}));
      setTimeout(()=>setHostActionState(s=>{const n={...s};delete n[k];return n;}),4000);
    }
  }

  async function doBulkHostAction(action){
    if(selectedHosts.size===0) return;
    setBulkBusy(true); setBulkMsg(null);
    const sel=hosts.filter(h=>selectedHosts.has(h.name)).map(h=>({vcenter_id:h.vcenter_id,host_name:h.name}));
    try{
      await bulkHostAction(sel,action);
      setBulkMsg({ok:true,text:`${action} sent to ${sel.length} hosts`});
      setSelectedHosts(new Set());
      setTimeout(()=>setBulkMsg(null),4000);
    }catch(e){ setBulkMsg({ok:false,text:e.message}); }
    setBulkBusy(false);
  }

  return(
    <div className="g-gap">
      {topoTarget&&<TopologyModal target={topoTarget} onClose={()=>setTopoTarget(null)} p={p}/>}

      {/* ────── PLATFORM CAPACITY SELECTOR ────── */}
      {(()=>{
        const tabs=[
          {id:"vmware",  label:"VMware vCenter",      icon:"🖥️", color:"#3b82f6",  count:"Resource Utilization Summary"},
          {id:"openshift",label:"Red Hat OpenShift",  icon:"🔴", color:"#ef4444",  count:`${(ocpData?.clusters||[]).length} Cluster${(ocpData?.clusters||[]).length!==1?"s":""}`},
          {id:"nutanix", label:"Nutanix AHV",          icon:"🟩", color:"#22c55e",  count:`${(nutData?.pcs||[]).length} Prism Central${(nutData?.pcs||[]).length!==1?"s":""}`},
          {id:"ipam",   label:"IPAM",                 icon:"📡", color:"#06b6d4",  count:ipamData?`${ipamData.summary?.total_subnets||0} Subnet${(ipamData.summary?.total_subnets||0)!==1?"s":""}`:(ipamLoading?"Loading…":"Not connected")},
        ];
        return(
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,overflow:"hidden"}}>
            {/* Header */}
            <div style={{padding:"12px 18px",borderBottom:`1px solid ${p.border}`,background:`linear-gradient(135deg,${p.accent}14,${p.panel})`,display:"flex",alignItems:"center",gap:10}}>
              <div style={{width:30,height:30,borderRadius:8,background:`linear-gradient(135deg,${p.accent},${p.cyan})`,display:"flex",alignItems:"center",justifyContent:"center",fontSize:14}}>📊</div>
              <div>
                <div style={{fontWeight:800,fontSize:13,color:p.text,letterSpacing:"-.1px"}}>Infrastructure Capacity</div>
                <div style={{fontSize:10,color:p.textMute,marginTop:1}}>All Platforms · Resource Utilization Overview</div>
              </div>
            </div>
            {/* Tab buttons */}
            <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr 1fr"}}>
              {tabs.map((t,i)=>{
                const active=platTab===t.id;
                return(
                  <button key={t.id} onClick={()=>setPlatTab(t.id)}
                    style={{padding:"14px 18px",border:"none",borderRight:i<3?`1px solid ${p.border}`:"none",
                      background:active?`${t.color}14`:"transparent",cursor:"pointer",transition:"all .15s",
                      borderBottom:active?`3px solid ${t.color}`:`3px solid transparent`,textAlign:"left"}}>
                    <div style={{display:"flex",alignItems:"center",gap:8}}>
                      <span style={{fontSize:18}}>{t.icon}</span>
                      <div>
                        <div style={{fontWeight:700,fontSize:13,color:active?t.color:p.text}}>{t.label}</div>
                        <div style={{fontSize:11,color:p.textMute,marginTop:1}}>{t.count}</div>
                      </div>
                    </div>
                  </button>
                );
              })}
            </div>
          </div>
        );
      })()}

      {/* ────── VMWARE TAB ────── */}
      {platTab==="vmware"&&(
        <>
          <d{(()=>{
              const totalCPU=hosts.reduce((s,h)=>s+(h.cpu_total_mhz||0),0);
              const usedCPU=hosts.reduce((s,h)=>s+(h.cpu_used_mhz||0),0);
              const cpuFreePct=totalCPU>0?Math.round(((totalCPU-usedCPU)/totalCPU)*100):0;
              const totalVMs=summaries?summaries.reduce((s,v)=>s+(v.total_vms||0),0):0;
              const runVMs=summaries?summaries.reduce((s,v)=>s+(v.running_vms||0),0):0;
              return(<>
                <KPI icon="&#128476;&#65039;" label="Total Hosts"  value={hosts.length} color={p.accent}/>
                <KPI icon="&#129504;" label="Memory Free"  value={fmtGB(fR)} color={freeClr((fR/tR)*100)} sub={`of ${fmtGB(tR)}`}/>
                <KPI icon="&#128190;" label="Datastores"   value={datastores.length} color={p.purple}/>
                <KPI icon="&#128230;" label="Storage Free" value={fmtGB(fD)} color={freeClr((fD/tD)*100)} sub={`of ${fmtGB(tD)}`}/>
                {totalVMs>0&&<KPI icon="🖥️" label="VMs (On/Total)" value={`${runVMs}/${totalVMs}`} color={p.cyan} sub={`${totalVMs-runVMs} off`}/>}
                {totalCPU>0&&<KPI icon="⚡" label="CPU Free" value={`${cpuFreePct}%`} color={freeClr(cpuFreePct)} sub={`${Math.round(usedCPU/1000)}/${Math.round(totalCPU/1000)} GHz`}/>}
              </>);
            })()}
            <KPI icon="&#128230;" label="Storage Free"         value={fmtGB(fD)} color={freeClr((fD/tD)*100)} sub={`of ${fmtGB(tD)}`}/>
          </div>
          <div style={{padding:"14px 18px",borderRadius:10,fontSize:13,color:"#3b82f6",background:"#3b82f608",border:"1px solid #3b82f630",display:"flex",alignItems:"center",gap:12}}>
            <span style={{fontSize:20,flexShrink:0}}>ℹ️</span>
            <div>
              <div style={{fontWeight:700,marginBottom:3}}>ESXi Hosts &amp; Datastores moved</div>
              <div style={{fontSize:12,color:"#60a5fa"}}>Full ESXi Host management and Datastore usage tables are now available in the <b>VMware</b> page under the <b>Hypervisors</b> and <b>Datastores</b> sub-tabs — including all actions, bulk operations, and topology maps.</div>
            </div>
          </div>
        </>
      )}

      {/* ────── OPENSHIFT CAPACITY TAB ────── */}
      {platTab==="openshift"&&(
        <div style={{display:"flex",flexDirection:"column",gap:16}}>
          {/* Aggregate OCP KPIs */}
          {(()=>{
            const clusters=ocpData?.clusters||[];
            const ovs=Object.values(ocpData?.overviews||{});
            const totNodes=ovs.reduce((a,ov)=>a+(ov?.nodes_summary?.total||0),0);
            const rdyNodes=ovs.reduce((a,ov)=>a+(ov?.nodes_summary?.ready||0),0);
            const totPods=ovs.reduce((a,ov)=>a+(ov?.pods_summary?.total||0),0);
            const runPods=ovs.reduce((a,ov)=>a+(ov?.pods_summary?.running||0),0);
            const totOps=ovs.reduce((a,ov)=>a+(ov?.operators_summary?.total||0),0);
            const okOps=ovs.reduce((a,ov)=>a+(ov?.operators_summary?.available||0),0);
            const totWarn=ovs.reduce((a,ov)=>a+(ov?.warnings||0),0);
            return(
              <>
                <div className="g4">
                  <KPI icon="🔴" label="OCP Clusters"   value={clusters.length} color="#ef4444"/>
                  <KPI icon="🖥️" label="Nodes"          value={`${rdyNodes}/${totNodes}`} color={rdyNodes<totNodes?"#ef4444":"#10b981"} sub={`${totNodes-rdyNodes} not ready`}/>
                  <KPI icon="📦" label="Pods Running"   value={`${runPods}/${totPods}`} color="#06b6d4" sub={`of ${totPods} total`}/>
                  <KPI icon="⚙️" label="Operators OK"   value={`${okOps}/${totOps}`} color={okOps<totOps?"#f97316":"#10b981"} sub={`${totOps-okOps} degraded`}/>
                </div>
                {totWarn>0&&(
                  <div style={{display:"flex",alignItems:"center",gap:10,padding:"10px 16px",borderRadius:8,background:`${p.yellow}10`,border:`1px solid ${p.yellow}28`}}>
                    <span style={{fontSize:14}}>⚠️</span>
                    <span style={{fontSize:13,color:p.yellow,fontWeight:600}}>{totWarn} warning event{totWarn!==1?"s":""} across all OpenShift clusters</span>
                  </div>
                )}
              </>
            );
          })()}

          {/* Per-cluster capacity detail */}
          {(ocpData?.clusters||[]).length===0?(
            <div style={{textAlign:"center",padding:"40px 20px",background:p.panelAlt,border:`1px dashed #ef444428`,borderRadius:12,color:p.textMute,fontSize:13}}>
              <div style={{fontSize:32,marginBottom:10,opacity:.4}}>🔴</div>
              <div style={{fontWeight:700,fontSize:15,marginBottom:6}}>No OpenShift Clusters Configured</div>
              <div style={{fontSize:12}}>Navigate to the OpenShift page and add a cluster to monitor capacity here</div>
            </div>
          ):(
            <div style={{display:"flex",flexDirection:"column",gap:10}}>
              <div style={{fontWeight:800,fontSize:11,color:"#ef4444",letterSpacing:"1.5px",textTransform:"uppercase",padding:"4px 0"}}>Per-Cluster Breakdown</div>
              {(ocpData?.clusters||[]).map(cl=>{
                const ov=ocpData?.overviews?.[cl.id];
                const nReady=ov?.nodes_summary?.ready||0;
                const nTotal=ov?.nodes_summary?.total||0;
                const nNotReady=ov?.nodes_summary?.not_ready||0;
                const pRun=ov?.pods_summary?.running||0;
                const pTot=ov?.pods_summary?.total||0;
                const pFail=ov?.pods_summary?.failed||0;
                const pPend=ov?.pods_summary?.pending||0;
                const oAvail=ov?.operators_summary?.available||0;
                const oTot=ov?.operators_summary?.total||0;
                const oDeg=ov?.operators_summary?.degraded||0;
                const health=!ov?"unknown":nNotReady>0||oDeg>0?"degraded":(ov?.warnings||0)>5?"warning":"healthy";
                const hc=health==="healthy"?"#10b981":health==="degraded"?"#ef4444":"#f59e0b";
                return(
                  <div key={cl.id} style={{background:p.panelAlt,border:`1px solid #ef444420`,borderLeft:`4px solid ${hc}`,borderRadius:12,overflow:"hidden",padding:"14px 18px"}}>
                    <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:12}}>
                      <div style={{width:10,height:10,borderRadius:"50%",background:hc,boxShadow:`0 0 8px ${hc}80`,flexShrink:0}}/>
                      <div style={{flex:1}}>
                        <div style={{fontWeight:800,fontSize:14,color:"#ef4444"}}>{cl.name}</div>
                        <div style={{fontSize:10,color:p.textMute,marginTop:1}}>{cl.api_url||"—"}
                          {ov?.version?.version&&<span style={{marginLeft:8,color:p.cyan,fontWeight:600}}>{ov.version.version}</span>}
                        </div>
                      </div>
                      <span style={{fontSize:11,fontWeight:700,padding:"3px 10px",borderRadius:20,
                        background:hc==="healthy"?`${hc}15`:hc==="degraded"?`#ef444415`:`${p.yellow}15`,
                        color:hc,border:`1px solid ${hc}35`}}>
                        {health}
                      </span>
                    </div>
                    <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8}}>
                      {[
                        {label:"Node Readiness",used:nNotReady,free:nReady,total:nTotal,
                         pct:nTotal>0?Math.round((nNotReady/nTotal)*100):0,
                         color:nNotReady>0?"#ef4444":"#10b981",
                         sub:`${nReady} ready · ${nNotReady} not ready`},
                        {label:"Pod Health",used:pFail+pPend,free:pRun,total:pTot,
                         pct:pTot>0?Math.round(((pFail+pPend)/pTot)*100):0,
                         color:pFail>0?"#ef4444":pPend>0?"#f59e0b":"#10b981",
                         sub:`${pRun} run · ${pFail} fail · ${pPend} pend`},
                        {label:"Operator Health",used:oDeg,free:oAvail,total:oTot,
                         pct:oTot>0?Math.round((oDeg/oTot)*100):0,
                         color:oDeg>0?"#f97316":"#10b981",
                         sub:`${oAvail} ok · ${oDeg} degraded`},
                      ].map(({label,used,free,pct,color,sub,total})=>(
                        <div key={label} style={{padding:"10px 12px",borderRadius:8,background:`${color}08`,border:`1px solid ${color}20`}}>
                          <div style={{fontSize:10,fontWeight:700,color:p.textMute,textTransform:"uppercase",letterSpacing:".5px",marginBottom:6}}>{label}</div>
                          <div style={{height:5,borderRadius:3,background:`${p.border}`,overflow:"hidden",marginBottom:6}}>
                            <div style={{height:"100%",width:`${pct}%`,background:color,borderRadius:3,transition:"width .8s"}}/>
                          </div>
                          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                            <span style={{fontSize:10,color:p.textMute}}>{sub}</span>
                            <span style={{fontSize:14,fontWeight:800,color,fontFamily:"monospace"}}>{total}</span>
                          </div>
                        </div>
                      ))}
                    </div>
                    {(ov?.warnings||0)>0&&(
                      <div style={{display:"flex",alignItems:"center",gap:6,marginTop:8,padding:"5px 8px",borderRadius:6,background:`${p.yellow}10`,border:`1px solid ${p.yellow}25`}}>
                        <span style={{fontSize:11}}>⚠</span>
                        <span style={{fontSize:11,color:p.yellow,fontWeight:600}}>{ov.warnings} warning event{ov.warnings!==1?"s":""} active</span>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      )}

      {/* ────── NUTANIX CAPACITY TAB ────── */}
      {platTab==="nutanix"&&(
        <div style={{display:"flex",flexDirection:"column",gap:16}}>
          {/* Aggregate Nutanix KPIs */}
          {(()=>{
            const pcs=nutData?.pcs||[];
            const ovs=Object.values(nutData?.overviews||{});
            const totVMs=ovs.reduce((a,ov)=>a+(ov?.vms?.total||0),0);
            const runVMs=ovs.reduce((a,ov)=>a+(ov?.vms?.running||0),0);
            const totHosts=ovs.reduce((a,ov)=>a+(ov?.hosts||0),0);
            const totClusters=ovs.reduce((a,ov)=>a+(ov?.clusters||0),0);
            const totMem=ovs.reduce((a,ov)=>a+(ov?.total_memory_gib||0),0);
            const critAlerts=ovs.reduce((a,ov)=>a+(ov?.alerts?.critical||0),0);
            const warnAlerts=ovs.reduce((a,ov)=>a+(ov?.alerts?.warning||0),0);
            return(
              <>
                <div className="g4">
                  <KPI icon="🟩" label="Prism Centrals" value={pcs.length} color="#22c55e"/>
                  <KPI icon="💻" label="VMs Running"     value={`${runVMs}/${totVMs}`} color="#10b981" sub={`${totVMs-runVMs} powered off`}/>
                  <KPI icon="🖥️" label="AHV Hosts"       value={totHosts} color="#06b6d4" sub={`${totClusters} AHV clusters`}/>
                  <KPI icon="🧠" label="Total Memory"    value={`${Math.round(totMem)} GiB`} color="#a855f7" sub="across all hosts"/>
                </div>
                {(critAlerts>0||warnAlerts>0)&&(
                  <div style={{display:"flex",alignItems:"center",gap:10,padding:"10px 16px",borderRadius:8,
                    background:critAlerts>0?`${p.red}10`:`${p.yellow}10`,
                    border:`1px solid ${critAlerts>0?p.red:p.yellow}28`}}>
                    <span style={{fontSize:14}}>⚠️</span>
                    <span style={{fontSize:13,color:critAlerts>0?p.red:p.yellow,fontWeight:600}}>
                      {critAlerts>0?`${critAlerts} critical alert${critAlerts!==1?"s":""}`:""}{critAlerts>0&&warnAlerts>0?" · ":""}{warnAlerts>0?`${warnAlerts} warning${warnAlerts!==1?"s":""}`:""} across all Nutanix environments
                    </span>
                  </div>
                )}
              </>
            );
          })()}

          {/* Per-PC capacity detail */}
          {(nutData?.pcs||[]).length===0?(
            <div style={{textAlign:"center",padding:"40px 20px",background:p.panelAlt,border:`1px dashed #22c55e28`,borderRadius:12,color:p.textMute,fontSize:13}}>
              <div style={{fontSize:32,marginBottom:10,opacity:.4}}>🟩</div>
              <div style={{fontWeight:700,fontSize:15,marginBottom:6}}>No Nutanix Prism Centrals Configured</div>
              <div style={{fontSize:12}}>Navigate to the Nutanix page and add a Prism Central to monitor capacity here</div>
            </div>
          ):(
            <div style={{display:"flex",flexDirection:"column",gap:10}}>
              <div style={{fontWeight:800,fontSize:11,color:"#22c55e",letterSpacing:"1.5px",textTransform:"uppercase",padding:"4px 0"}}>Per Prism Central Breakdown</div>
              {(nutData?.pcs||[]).map(pc=>{
                const ov=nutData?.overviews?.[pc.id];
                const vmRun=ov?.vms?.running||0;
                const vmTot=ov?.vms?.total||0;
                const vmOff=ov?.vms?.off||0;
                const crit=ov?.alerts?.critical||0;
                const warn=ov?.alerts?.warning||0;
                const memGiB=Math.round(ov?.total_memory_gib||0);
                const health=!ov?"unknown":crit>0?"critical":warn>3?"warning":"healthy";
                const hc=health==="healthy"?"#10b981":health==="critical"?"#ef4444":"#f59e0b";
                const vmRunPct=vmTot>0?Math.round((vmRun/vmTot)*100):0;
                return(
                  <div key={pc.id} style={{background:p.panelAlt,border:`1px solid #22c55e20`,borderLeft:`4px solid ${hc}`,borderRadius:12,overflow:"hidden",padding:"14px 18px"}}>
                    <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:12}}>
                      <div style={{width:10,height:10,borderRadius:"50%",background:hc,boxShadow:`0 0 8px ${hc}80`,flexShrink:0}}/>
                      <div style={{flex:1}}>
                        <div style={{fontWeight:800,fontSize:14,color:"#22c55e"}}>{pc.name}</div>
                        <div style={{fontSize:10,color:p.textMute,marginTop:1}}>
                          {pc.host||"—"}
                          {pc.site_group&&<span style={{marginLeft:8,color:"#06b6d4",fontWeight:600}}>{pc.site_group}</span>}
                        </div>
                      </div>
                      <span style={{fontSize:11,fontWeight:700,padding:"3px 10px",borderRadius:20,
                        background:`${hc}18`,color:hc,border:`1px solid ${hc}35`}}>{health}</span>
                    </div>
                    <div style={{display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:8}}>
                      {[
                        {label:"VM State",pct:vmRunPct,color:vmRunPct>90?"#10b981":vmRunPct>50?"#f59e0b":"#64748b",
                         sub:`${vmRun} on · ${vmOff} off`,total:vmTot},
                        {label:"AHV Hosts",pct:0,color:"#06b6d4",sub:`${ov?.total_vcpus||0} vCPUs total`,total:ov?.hosts||0,noBar:true},
                        {label:"AHV Clusters",pct:0,color:"#22c55e",sub:`${memGiB} GiB total mem`,total:ov?.clusters||0,noBar:true},
                      ].map(({label,pct,color,sub,total,noBar})=>(
                        <div key={label} style={{padding:"10px 12px",borderRadius:8,background:`${color}08`,border:`1px solid ${color}20`}}>
                          <div style={{fontSize:10,fontWeight:700,color:p.textMute,textTransform:"uppercase",letterSpacing:".5px",marginBottom:6}}>{label}</div>
                          {!noBar&&<div style={{height:5,borderRadius:3,background:`${p.border}`,overflow:"hidden",marginBottom:6}}>
                            <div style={{height:"100%",width:`${pct}%`,background:color,borderRadius:3,transition:"width .8s"}}/>
                          </div>}
                          <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginTop:noBar?8:0}}>
                            <span style={{fontSize:10,color:p.textMute}}>{sub}</span>
                            <span style={{fontSize:18,fontWeight:900,color,fontFamily:"monospace"}}>{total}</span>
                          </div>
                        </div>
                      ))}
                    </div>
                    {(crit>0||warn>0)&&(
                      <div style={{display:"flex",alignItems:"center",gap:6,marginTop:8,padding:"5px 8px",borderRadius:6,
                        background:crit>0?`${p.red}10`:`${p.yellow}10`,
                        border:`1px solid ${crit>0?p.red:p.yellow}25`}}>
                        <span style={{fontSize:11}}>⚠</span>
                        <span style={{fontSize:11,color:crit>0?p.red:p.yellow,fontWeight:600}}>
                          {crit>0?`${crit} critical alert${crit!==1?"s":""}`:""}{crit>0&&warn>0?" · ":""}{warn>0?`${warn} warning${warn!==1?"s":""}`:""} active
                        </span>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          )}
        </div>
      )}

      {/* ────── IPAM TAB ────── */}
      {platTab==="ipam"&&(()=>{
        const barColor=pct=>pct>=80?"#ef4444":pct>=60?"#f59e0b":"#10b981";
        const summary=ipamData?.summary||{};
        const subnets=ipamData?.subnets||[];
        if(ipamLoading) return <LoadState msg="Loading IPAM data…"/>;
        if(!ipamData||ipamData.error)return(
          <div style={{textAlign:"center",padding:"48px 20px",background:p.panelAlt,border:`1px dashed #06b6d428`,borderRadius:12,color:p.textMute,fontSize:13}}>
            <div style={{fontSize:36,marginBottom:10,opacity:.4}}>📡</div>
            <div style={{fontWeight:700,fontSize:15,marginBottom:6}}>IPAM Data Unavailable</div>
            <div style={{fontSize:12}}>{ipamData?.error||"Unable to reach SolarWinds IPAM. Check backend connectivity."}</div>
          </div>
        );
        return(
          <div style={{display:"flex",flexDirection:"column",gap:16}}>
            {/* IPAM KPI row */}
            <div style={{display:"grid",gridTemplateColumns:"repeat(6,1fr)",gap:10}}>
              {[
                {icon:"📡",label:"Total Subnets",  value:summary.total_subnets||0,    color:"#06b6d4"},
                {icon:"🌐",label:"Total IPs",      value:(summary.total_ips||0).toLocaleString(), color:p.accent},
                {icon:"🔴",label:"Used IPs",       value:(summary.used_ips||0).toLocaleString(),  color:"#ef4444"},
                {icon:"🟢",label:"Available IPs",  value:(summary.available_ips||0).toLocaleString(), color:"#10b981"},
                {icon:"🔒",label:"Reserved IPs",   value:(summary.reserved_ips||0).toLocaleString(),  color:"#a855f7"},
                {icon:"📊",label:"Overall Used %", value:`${Math.round(summary.percent_used||0)}%`, color:barColor(summary.percent_used||0)},
              ].map(k=>(
                <KPI key={k.label} icon={k.icon} label={k.label} value={k.value} color={k.color}/>
              ))}
            </div>
            {/* Usage bar */}
            <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,padding:"14px 18px"}}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:8}}>
                <span style={{fontWeight:700,fontSize:12,color:p.text}}>Overall IP Address Utilisation</span>
                <div style={{display:"flex",gap:14,fontSize:11,color:p.textMute}}>
                  <span style={{color:"#ef4444",fontWeight:600}}>Used: {(summary.used_ips||0).toLocaleString()}</span>
                  <span style={{color:"#10b981",fontWeight:600}}>Free: {(summary.available_ips||0).toLocaleString()}</span>
                  <span style={{color:"#a855f7",fontWeight:600}}>Reserved: {(summary.reserved_ips||0).toLocaleString()}</span>
                </div>
              </div>
              <div style={{display:"flex",height:14,borderRadius:7,overflow:"hidden",background:p.panelAlt,border:`1px solid ${p.border}`}}>
                <div style={{width:`${(summary.used_ips||0)/(summary.total_ips||1)*100}%`,background:barColor(summary.percent_used||0),transition:"width .8s"}}/>
                <div style={{width:`${(summary.reserved_ips||0)/(summary.total_ips||1)*100}%`,background:"#a855f780"}}/>
              </div>
              {ipamData.cached_at&&(
                <div style={{fontSize:10,color:p.textMute,marginTop:6}}>Data cached at: {new Date(ipamData.cached_at*1000).toLocaleString()}</div>
              )}
            </div>
            {/* Subnet table */}
            <div className="card" style={{overflow:"hidden"}}>
              <div className="card-header">
                <span className="card-title">📡 IP Subnets</span>
                <span style={{fontSize:11,color:p.textMute,marginLeft:8}}>{subnets.length} subnets</span>
              </div>
              <div className="tbl-wrap" style={{maxHeight:400}}>
                <table><thead><tr>
                  <th style={{width:60}}>VLAN</th>
                  <th style={{minWidth:130}}>CIDR</th>
                  <th style={{minWidth:160}}>NAME</th>
                  <th style={{width:110}}>LOCATION</th>
                  <th style={{minWidth:130}}>USAGE</th>
                  <th style={{width:65}}>TOTAL</th>
                  <th style={{width:65}}>USED</th>
                  <th style={{width:65}}>FREE</th>
                  <th style={{width:65}}>RESERVED</th>
                  <th style={{width:70}}>STATUS</th>
                </tr></thead>
                <tbody>{subnets.map((s,i)=>{
                  const bc=barColor(s.percent_used||0);
                  return(<tr key={i}>
                    <td><M size={11} color="#06b6d4">{s.vlan||"—"}</M></td>
                    <td><M size={11} color={p.accent}>{s.address_cidr||"—"}</M></td>
                    <td><span style={{fontSize:11,fontWeight:600,color:p.text}}>{s.name||"—"}</span></td>
                    <td><span style={{fontSize:11,color:p.textMute}}>{s.location||"—"}</span></td>
                    <td><div style={{display:"flex",alignItems:"center",gap:6}}><Bar pct={s.percent_used||0} color={bc}/><M color={bc} size={11}>{Math.round(s.percent_used||0)}%</M></div></td>
                    <td><M size={11}>{s.total||0}</M></td>
                    <td><M size={11} color="#ef4444">{s.used||0}</M></td>
                    <td><M size={11} color="#10b981">{s.available||0}</M></td>
                    <td><M size={11} color="#a855f7">{s.reserved||0}</M></td>
                    <td><Badge color={(s.status||"active")==="active"?"connected":"error"}>{(s.status||"active").toUpperCase()}</Badge></td>
                  </tr>);
                })}</tbody></table>
              </div>
            </div>
          </div>
        );
      })()}
    </div>
  );
}
// ─── SNAPSHOTS ────────────────────────────────────────────────────────────────
function SnapshotsPage({snapshots,vcenters,onRefresh,loading,error,onRetry,p}){
  const [q,setQ]=useState("");
  const [selected,setSelected]=useState(new Set());
  const [deleting,setDeleting]=useState({});
  const [bulkBusy,setBulkBusy]=useState(false);
  const [msg,setMsg]=useState(null);

  if(loading) return <LoadState msg="Loading snapshots…"/>;
  if(error)   return <ErrState msg={error} onRetry={onRetry}/>;

  const list=snapshots.filter(s=>!q||[s.vm_name,s.snapshot_name].some(x=>x?.toLowerCase().includes(q.toLowerCase())));
  const key=(s)=>`${s.vcenter_id}::${s.vm_name}::${s.snapshot_name}`;

  function toggleSelect(s){ const k=key(s); setSelected(prev=>{ const n=new Set(prev); n.has(k)?n.delete(k):n.add(k); return n; }); }
  function toggleAll(){ setSelected(prev=>prev.size===list.length?new Set():new Set(list.map(key))); }

  async function doDelete(s){
    const k=key(s);
    setDeleting(d=>({...d,[k]:true}));
    try{
      await deleteSnapshot(s.vcenter_id, s.vm_name, s.snapshot_name);
      setMsg({ok:true,text:`Deleted snapshot "${s.snapshot_name}" from ${s.vm_name}`});
      setTimeout(()=>{ setMsg(null); onRefresh&&onRefresh(); },3000);
    }catch(e){ setMsg({ok:false,text:e.message}); }
    setDeleting(d=>({...d,[k]:false}));
  }

  async function doBulkDelete(){
    if(selected.size===0) return;
    setBulkBusy(true); setMsg(null);
    const toDelete=list.filter(s=>selected.has(key(s)));
    let ok=0, fail=0;
    for(const s of toDelete){
      try{ await deleteSnapshot(s.vcenter_id, s.vm_name, s.snapshot_name); ok++; }
      catch{ fail++; }
    }
    setBulkBusy(false);
    setMsg({ok:fail===0,text:`Deleted ${ok} snapshot${ok!==1?"s":""}${fail>0?`, ${fail} failed`:""}`});
    setSelected(new Set());
    setTimeout(()=>{ setMsg(null); onRefresh&&onRefresh(); },4000);
  }

  // Compute per-snapshot age in days
  function snapAge(created){
    if(!created) return null;
    const ms=Date.now()-new Date(created.replace(" ","T")+"Z").getTime();
    return Math.max(0,Math.floor(ms/86400000));
  }

  const deletingCount=Object.keys(deleting).filter(k=>deleting[k]).length;
  const oldCount=snapshots.filter(s=>(snapAge(s.created)||0)>30).length;
  const staleCount=snapshots.filter(s=>(snapAge(s.created)||0)>7).length;

  if(snapshots.length===0) return(
    <div className="card" style={{textAlign:"center",padding:40}}>
      <div style={{fontSize:36,marginBottom:10}}>&#10003;</div>
      <div style={{fontWeight:600,marginBottom:6}}>No Snapshots Found</div>
      <div style={{fontSize:13,color:p.textMute}}>Environment is clean.</div>
    </div>
  );

  return(
    <div className="g-gap">
      {/* ── Summary Tiles ── */}
      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fit,minmax(130px,1fr))",gap:10}}>
        {[
          {label:"Total Snapshots",value:snapshots.length,color:"#3b82f6",icon:"📸"},
          {label:"Stale (>7 days)",value:staleCount,color:staleCount>0?"#f59e0b":"#10b981",icon:"⏰"},
          {label:"Old (>30 days)",value:oldCount,color:oldCount>0?"#ef4444":"#10b981",icon:"⚠️"},
          {label:"Deleting Now",value:deletingCount,color:deletingCount>0?"#f97316":"#64748b",icon:"🗑️"},
        ].map(t=>(
          <div key={t.label} style={{background:"rgba(255,255,255,.03)",border:`1px solid ${t.color}30`,borderRadius:10,padding:"10px 14px",display:"flex",flexDirection:"column",gap:3}}>
            <div style={{fontSize:10,color:"#64748b",fontWeight:700,textTransform:"uppercase",letterSpacing:".4px"}}>{t.icon} {t.label}</div>
            <div style={{fontSize:22,fontWeight:800,color:t.color}}>{t.value}</div>
          </div>
        ))}
      </div>
      <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"}}>
        <input style={{maxWidth:280,flex:1}} placeholder="Search VM or snapshot…" value={q} onChange={e=>setQ(e.target.value)}/>
        <span style={{fontSize:12,color:p.textMute}}>{list.length} snapshots</span>
        <div style={{flex:1}}/>
        {selected.size>0&&(
          <button className="btn btn-danger btn-sm" onClick={doBulkDelete} disabled={bulkBusy}>
            {bulkBusy?"⏳ Deleting…":`&#128465; Delete ${selected.size} selected`}
          </button>
        )}
      </div>
      {msg&&<div style={{padding:"10px 14px",borderRadius:8,fontSize:13,fontWeight:500,
        background:msg.ok?`${p.green}15`:`${p.red}15`,border:`1px solid ${msg.ok?p.green:p.red}40`,
        color:msg.ok?p.green:p.red}}>{msg.ok?"&#10003;":"&#10007;"} {msg.text}</div>}
      <div className="card" style={{overflow:"hidden"}}>
        <div className="tbl-wrap" style={{maxHeight:"calc(100vh - 200px)"}}>
          <table><thead><tr>
            <th style={{width:36,paddingLeft:14}}>
              <input type="checkbox" checked={selected.size===list.length&&list.length>0}
                onChange={toggleAll} style={{cursor:"pointer",accentColor:p.accent}}/>
            </th>
            {vcenters.length>1&&<th style={{width:90}}>VCENTER</th>}
            <th style={{minWidth:140}}>VM NAME</th><th style={{minWidth:140}}>SNAPSHOT</th>
            <th style={{minWidth:160}}>DESCRIPTION</th><th style={{width:140}}>CREATED</th>
            <th style={{width:65,textAlign:"center"}}>AGE</th>
            <th style={{width:90}}>TAKEN BY</th>
            <th style={{width:80}}>STATE</th><th style={{width:80,textAlign:"center"}}>DELETE</th>
          </tr></thead>
          <tbody>{list.map((s,i)=>{
            const vc=vcColor(s.vcenter_id,vcenters);
            const k=key(s);
            const isSel=selected.has(k);
            return(<tr key={i} style={{background:isSel?`${p.red}06`:""}}>
              <td style={{paddingLeft:14}}>
                <input type="checkbox" checked={isSel} onChange={()=>toggleSelect(s)}
                  style={{cursor:"pointer",accentColor:p.accent}}/>
              </td>
              {vcenters.length>1&&<td><span style={{fontSize:11,color:vc,fontWeight:600}}>{s.vcenter_name}</span></td>}
              <td><M color={p.accent} size={12}>{s.vm_name}</M></td>
              <td style={{fontWeight:600}}>{s.snapshot_name}</td>
              <td style={{textAlign:"center"}}>
                {(()=>{const d=snapAge(s.created);if(d===null)return<span style={{color:p.textMute}}>—</span>;const c=d>30?"#ef4444":d>7?"#f59e0b":"#10b981";return<span style={{fontSize:11,fontWeight:700,color:c,fontFamily:"monospace"}}>{d}d</span>;})()}
              </td>
              <td style={{color:p.textMute,fontSize:11}}>—</td>
              <td style={{color:p.textMute,fontSize:12}}>{s.description||"—"}</td>
              <td><M color={p.textMute} size={11}>{s.created}</M></td>
              <td><Badge color={s.state}>{s.state}</Badge></td>
              <td style={{textAlign:"center"}}>
                {deleting[k]
                  ?<span style={{fontSize:11,color:p.textMute}}>⏳</span>
                  :<button onClick={()=>doDelete(s)}
                    style={{background:`${p.red}15`,border:`1px solid ${p.red}40`,borderRadius:5,
                      padding:"2px 8px",cursor:"pointer",fontSize:11,color:p.red,fontWeight:600}}>
                    &#128465; Del
                  </button>
                }
              </td>
            </tr>);
          })}</tbody></table>
        </div>
      </div>
    </div>
  );
}
// ─── NETWORKS ─────────────────────────────────────────────────────────────────
function NetworksPage({networks,vcenters,loading,error,onRetry,p}){
  if(loading) return <LoadState msg="Loading port groups…"/>;
  if(error)   return <ErrState msg={error} onRetry={onRetry}/>;
  return(
    <div className="card" style={{overflow:"hidden"}}>
      <div className="card-header">
        <span className="card-title">Network Port Groups</span>
        <span style={{fontSize:12,color:"#475569"}}>{networks.length} networks</span>
      </div>
      <div className="tbl-wrap" style={{maxHeight:"calc(100vh - 180px)"}}>
        <table><thead><tr>
          {vcenters.length>1&&<th style={{width:90}}>VCENTER</th>}
          <th style={{minWidth:180}}>PORT GROUP</th><th style={{width:80}}>HOSTS</th><th style={{width:110}}>VMs</th><th style={{width:75}}>STATUS</th>
        </tr></thead>
        <tbody>{networks.map((n,i)=>{
          const vc=vcColor(n.vcenter_id,vcenters);
          return(<tr key={i}>
            {vcenters.length>1&&<td><span style={{fontSize:11,color:vc,fontWeight:600}}>{n.vcenter_name}</span></td>}
            <td><M color={p.accent} size={12}>{n.name}</M></td>
            <td><M size={12}>{n.hosts_connected}</M></td>
            <td><M size={12}>{n.vms_connected}</M></td>
            <td><Badge color={n.accessible!==false?"connected":"error"}>{n.accessible!==false?"OK":"OFFLINE"}</Badge></td>
          </tr>);
        })}</tbody></table>
      </div>
    </div>
  );
}

// ─── CREATE VM ────────────────────────────────────────────────────────────────
function CreateVM({onClose,p}){
  const [step,setStep]=useState(1); const [done,setDone]=useState(false);
  const [f,setF]=useState({name:"",cpu:"2",ram:"8",disk:"100",os:"RHEL 9",owner:""});
  const set=(k,v)=>setF(prev=>({...prev,[k]:v}));
  const STEPS=["Details","Resources","Review"];
  if(done) return(
    <div className="overlay"><div className="modal" style={{textAlign:"center"}}>
      <div style={{fontSize:52,marginBottom:12}}>✅</div>
      <div style={{fontWeight:700,fontSize:18,marginBottom:6,color:p.green}}>Request Submitted!</div>
      <div style={{fontSize:13,color:"#475569",marginBottom:20}}><strong>{f.name}</strong> — {f.cpu} vCPU · {f.ram}GB RAM · {f.disk}GB · {f.os}</div>
      <button className="btn btn-primary" onClick={onClose} style={{margin:"auto"}}>← Back</button>
    </div></div>
  );
  return(
    <div className="overlay" onClick={onClose}>
      <div className="modal" onClick={e=>e.stopPropagation()}>
        <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:20}}>
          <div>
            <div style={{fontWeight:700,fontSize:16}}>Create Virtual Machine</div>
            <div style={{fontSize:12,color:"#475569",marginTop:2}}>Step {step} of 3 — {STEPS[step-1]}</div>
          </div>
          <button className="btn btn-ghost btn-sm" onClick={onClose} style={{fontSize:18,lineHeight:1,padding:"2px 8px"}}>×</button>
        </div>
        <div style={{display:"flex",gap:4,marginBottom:20}}>
          {STEPS.map((n,i)=>(
            <div key={n} style={{flex:1,display:"flex",flexDirection:"column",gap:3}}>
              <div style={{height:3,borderRadius:2,background:i+1<=step?p.accent:p.border,transition:"background .3s"}}/>
              <span style={{fontSize:9,color:i+1<=step?p.accent:"#475569",textAlign:"center"}}>{n}</span>
            </div>
          ))}
        </div>
        {step===1&&(
          <div className="g-gap">
            <div><label>VM NAME *</label><input value={f.name} onChange={e=>set("name",e.target.value)} placeholder="e.g. prod-web-03"/></div>
            <div><label>OPERATING SYSTEM</label>
              <select value={f.os} onChange={e=>set("os",e.target.value)}>
                {["RHEL 9","RHEL 8","Ubuntu 22.04 LTS","Ubuntu 20.04 LTS","Windows Server 2022","Windows Server 2019"].map(o=><option key={o}>{o}</option>)}
              </select>
            </div>
            <div><label>REQUESTER EMAIL</label><input value={f.owner} onChange={e=>set("owner",e.target.value)} placeholder="team@company.com"/></div>
          </div>
        )}
        {step===2&&(
          <div className="g-gap">
            <div className="g3">
              {[{l:"vCPU CORES",k:"cpu",opts:["1","2","4","8","16","32"]},
                {l:"RAM (GB)",k:"ram",opts:["4","8","16","32","64","128","256"]},
                {l:"DISK (GB)",k:"disk",opts:["50","100","200","500","1000","2000"]}].map(({l,k,opts})=>(
                <div key={k}><label>{l}</label>
                  <select value={f[k]} onChange={e=>set(k,e.target.value)}>{opts.map(o=><option key={o}>{o}</option>)}</select>
                </div>
              ))}
            </div>
            <div className="card-flat" style={{display:"grid",gap:8}}>
              {[["vCPU",f.cpu,32,"cores"],["RAM",f.ram,256,"GB"],["Disk",f.disk,2000,"GB"]].map(([l,v,max,u])=>(
                <div key={l} style={{display:"grid",gridTemplateColumns:"40px 1fr 60px",alignItems:"center",gap:8}}>
                  <span style={{fontSize:11,color:"#475569"}}>{l}</span>
                  <BarLg pct={Math.round((Number(v)/max)*100)} color={p.accent}/>
                  <M color={p.accent} size={12}>{v} {u}</M>
                </div>
              ))}
            </div>
          </div>
        )}
        {step===3&&(
          <div className="card-flat g-gap">
            {[["VM Name",f.name||"—"],["OS",f.os],["Resources",`${f.cpu} vCPU · ${f.ram}GB RAM · ${f.disk}GB Disk`],["Requested By",f.owner||"—"]].map(([k,v])=>(
              <div key={k} style={{display:"flex",justifyContent:"space-between",alignItems:"center",padding:"7px 0",borderBottom:`1px solid ${p.border}`}}>
                <span style={{fontSize:12,color:"#475569",fontWeight:500}}>{k}</span>
                <M color={p.accent} size={12}>{v}</M>
              </div>
            ))}
          </div>
        )}
        <div style={{display:"flex",gap:8,marginTop:20}}>
          {step>1&&<button className="btn btn-ghost" onClick={()=>setStep(s=>s-1)}>← Back</button>}
          <div style={{flex:1}}/>
          <button className="btn btn-primary" disabled={step===1&&!f.name.trim()} onClick={()=>step<3?setStep(s=>s+1):setDone(true)}>
            {step===3?"🚀 Submit Request":"Next →"}
          </button>
        </div>
      </div>
    </div>
  );
  const [addModal,   setAddModal]   = useState(false);
  const [addModal,   setAddModal]   = useState(false);
  const [editEntry,  setEditEntry]  = useState(null);
  const [subnetForm, setSubnetForm] = useState({vlan:"",address_cidr:"",name:"",location:"",comments:"",status:"Up"});
  const [subnetBusy, setSubnetBusy] = useState(false);
  const [subnetMsg,  setSubnetMsg]  = useState(null);

  const load = async () => {
    setLoading(true); setError(null);
    try { setData(await fetchIPAMSubnets()); }
    catch(e) { setError(e.message); }
    finally { setLoading(false); }
  };
  useEffect(() => { load(); }, []);

  const handleRefresh = async () => {
    setRefreshing(true);
    try { await refreshIPAMCache(); await load(); }
    catch(e) { setError(e.message); }
  const canManage  = role === "admin";
  const [addModal,   setAddModal]   = useState(false);
  const [editEntry,  setEditEntry]  = useState(null);
  const [subnetForm, setSubnetForm] = useState({vlan:"",address_cidr:"",name:"",location:"",comments:"",status:"Up"});
  const [subnetBusy, setSubnetBusy] = useState(false);
  const [subnetMsg,  setSubnetMsg]  = useState(null);
  async function handleAddSubnet(){
    if(!subnetForm.address_cidr) return;
    setSubnetBusy(true); setSubnetMsg(null);
    try{ await addIPAMManualSubnet(subnetForm); setSubnetMsg({ok:true,text:"Subnet added"}); setAddModal(false); setSubnetForm({vlan:"",address_cidr:"",name:"",location:"",comments:"",status:"Up"}); await load(); }catch(e){ setSubnetMsg({ok:false,text:e.message}); }
    setSubnetBusy(false);
