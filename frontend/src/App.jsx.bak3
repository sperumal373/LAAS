function ContactUs({ p }) {
  const [open, setOpen] = useState(false);
  const [copiedEmail, setCopiedEmail] = useState(null);
  const ref = useRef(null);

  useEffect(() => {
    function handleClick(e) {
      if (ref.current && !ref.current.contains(e.target)) setOpen(false);
    }
    if (open) document.addEventListener("mousedown", handleClick);
    return () => document.removeEventListener("mousedown", handleClick);
  }, [open]);

  function copyEmail(email) {
    navigator.clipboard.writeText(email).then(() => {
      setCopiedEmail(email);
      setTimeout(() => setCopiedEmail(null), 2000);
    });
  }

  return (
    <div ref={ref} style={{ position: "relative" }}>
      <button
        className="btn btn-sm"
        onClick={() => setOpen(o => !o)}
        style={{
          background: open ? `${p.cyan}20` : p.panelAlt,
          border: `1px solid ${open ? p.cyan : p.border}`,
          color: open ? p.cyan : p.textSub,
          fontWeight: 600, gap: 5,
          transition: "all .2s",
        }}
      >
        📞 Support
      </button>

      {open && (
        <div style={{
          position: "absolute", right: 0, top: "calc(100% + 8px)",
          width: 500, background: p.panel, border: `1px solid ${p.border}`,
          borderRadius: 14, boxShadow: "0 20px 60px rgba(0,0,0,.6)",
          zIndex: 600, animation: "fadeUp .15s ease", overflow: "hidden",
          maxHeight: "85vh", display: "flex", flexDirection: "column",
        }}>
          {/* Header */}
          <div style={{
            padding: "12px 16px", borderBottom: `1px solid ${p.border}`,
            background: `linear-gradient(135deg,${p.accent}18,${p.cyan}10)`,
            display: "flex", alignItems: "center", gap: 10, flexShrink: 0,
          }}>
            <div style={{width:34,height:34,borderRadius:9,
              background:`linear-gradient(135deg,${p.accent},${p.cyan})`,
              display:"flex",alignItems:"center",justifyContent:"center",fontSize:17,flexShrink:0}}>📞</div>
            <div style={{flex:1}}>
              <div style={{fontWeight:800,fontSize:14,color:p.text}}>Support Escalation Matrix</div>
              <div style={{fontSize:11,color:p.textMute}}>Wipro CaaS Platform · LaaS Engineering</div>
            </div>
            <button onClick={()=>setOpen(false)} style={{background:"none",border:"none",color:p.textMute,cursor:"pointer",fontSize:16,lineHeight:1,padding:4}}>✕</button>
          </div>

          {/* Escalation flow banner */}
          <div style={{padding:"7px 16px",borderBottom:`1px solid ${p.border}`,
            background:`linear-gradient(90deg,${p.panelAlt},${p.panel})`,
            display:"flex",alignItems:"center",gap:5,flexShrink:0,flexWrap:"wrap"}}>
            <span style={{fontSize:9,fontWeight:700,color:p.textMute,textTransform:"uppercase",letterSpacing:".8px",marginRight:2}}>Escalation Path</span>
            {[
              {label:"Domain Team",  color:"#06b6d4"},
              {label:"Domain Lead",  color:"#8b5cf6"},
              {label:"Eng Head",     color:"#f59e0b"},
              {label:"ADH",          color:"#ef4444"},
            ].map(({label,color},i,arr)=>(
              <span key={label} style={{display:"inline-flex",alignItems:"center",gap:4}}>
                <span style={{
                  fontSize:10,fontWeight:700,padding:"2px 8px",borderRadius:20,
                  background:`${color}18`,color,border:`1px solid ${color}35`,
                }}>{label}</span>
                {i<arr.length-1&&<span style={{color:p.textMute,fontSize:11}}>›</span>}
              </span>
            ))}
          </div>

          {/* Scrollable body */}
          <div style={{overflowY:"auto",flex:1}}>

            {/* ── Leadership ── */}
            <div style={{padding:"10px 14px 6px"}}>
              <div style={{fontSize:9,fontWeight:800,textTransform:"uppercase",letterSpacing:"1.2px",
                color:p.textMute,marginBottom:8,display:"flex",alignItems:"center",gap:6}}>
                <span style={{height:1,flex:1,background:p.border}}/>
                <span>Leadership</span>
                <span style={{height:1,flex:1,background:p.border}}/>
              </div>
              <div style={{display:"flex",flexDirection:"column",gap:4}}>
                {SUPPORT_MATRIX.leadership.map((person,i)=>(
                  <div key={i}>
                    <div style={{
                      display:"flex",alignItems:"center",gap:10,
                      padding:"8px 10px",borderRadius:9,
                      background:`${person.color}10`,border:`1px solid ${person.color}30`,
                    }}>
                      <div style={{width:32,height:32,borderRadius:8,
                        background:`linear-gradient(135deg,${person.color}30,${person.color}15)`,
                        border:`1px solid ${person.color}40`,
                        display:"flex",alignItems:"center",justifyContent:"center",fontSize:16,flexShrink:0}}>
                        {person.icon}
                      </div>
                      <div style={{flex:1,minWidth:0}}>
                        <div style={{fontWeight:700,fontSize:12,color:p.text}}>{person.name}</div>
                        <div style={{fontSize:11,color:person.color,fontWeight:600}}>
                          {person.designation}
                          {person.abbrev&&<span style={{marginLeft:5,opacity:.75,fontSize:10}}>({person.abbrev})</span>}
                        </div>
                      </div>
                      {person.email&&(
                        <div style={{display:"flex",gap:4,flexShrink:0}}>
                          <button title="Copy email" onClick={()=>copyEmail(person.email)} style={{
                            background:copiedEmail===person.email?`${p.green}20`:`${p.border}40`,
                            border:`1px solid ${copiedEmail===person.email?p.green:p.border}`,
                            color:copiedEmail===person.email?p.green:p.textSub,
                            borderRadius:6,padding:"3px 7px",cursor:"pointer",fontSize:10,fontWeight:600,transition:"all .2s",
                          }}>
                            {copiedEmail===person.email?"✓":"📋"}
                          </button>
                          <a href={`mailto:${person.email}`} title={person.email} style={{
                            background:`${p.accent}15`,border:`1px solid ${p.accent}40`,
                            color:p.accent,borderRadius:6,padding:"3px 7px",
                            fontSize:10,fontWeight:600,textDecoration:"none",display:"inline-flex",alignItems:"center",
                          }}>✉️</a>
                        </div>
                      )}
                    </div>
                    {i<SUPPORT_MATRIX.leadership.length-1&&(
                      <div style={{display:"flex",justifyContent:"center",margin:"2px 0"}}>
                        <span style={{color:p.textMute,fontSize:13}}>↓</span>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </div>

            {/* ── Domain Teams ── */}
            <div style={{padding:"2px 14px 14px"}}>
              <div style={{fontSize:9,fontWeight:800,textTransform:"uppercase",letterSpacing:"1.2px",
                color:p.textMute,marginBottom:10,marginTop:6,display:"flex",alignItems:"center",gap:6}}>
                <span style={{height:1,flex:1,background:p.border}}/>
                <span>Domain Teams (Report to Engineering Head)</span>
                <span style={{height:1,flex:1,background:p.border}}/>
              </div>
              <div style={{display:"flex",flexDirection:"column",gap:10}}>
                {SUPPORT_MATRIX.domains.map(domain=>(
                  <div key={domain.id} style={{
                    border:`1px solid ${domain.color}30`,borderRadius:10,overflow:"hidden",
                    background:`${domain.color}05`,
                  }}>
                    {/* Domain header */}
                    <div style={{
                      padding:"7px 12px",
                      background:`linear-gradient(90deg,${domain.color}22,${domain.color}08)`,
                      borderBottom:`1px solid ${domain.color}25`,
                      display:"flex",alignItems:"center",gap:8,
                    }}>
                      <span style={{fontSize:15}}>{domain.icon}</span>
                      <span style={{fontWeight:800,fontSize:12,color:domain.color,letterSpacing:".2px"}}>{domain.label}</span>
                    </div>
                    {/* Team hierarchy */}
                    <div style={{padding:"6px 10px 8px",display:"flex",flexDirection:"column",gap:3}}>
                      {domain.team.map((member,mi)=>(
                        <div key={mi} style={{
                          display:"flex",alignItems:"flex-start",gap:6,
                          paddingLeft:mi===0?0:mi===1?10:20,
                        }}>
                          {mi>0&&(
                            <span style={{color:p.textMute,fontSize:12,marginTop:7,lineHeight:1,flexShrink:0}}>↳</span>
                          )}
                          <div style={{
                            flex:1,display:"flex",alignItems:"center",gap:8,
                            padding:"6px 9px",borderRadius:8,
                            background:p.panelAlt,
                            border:`1px solid ${mi===0?domain.color+"28":p.border}`,
                            minWidth:0,
                          }}>
                            <div style={{flex:1,minWidth:0}}>
                              <div style={{display:"flex",alignItems:"center",gap:6,flexWrap:"wrap"}}>
                                <span style={{fontWeight:700,fontSize:11,color:p.text}}>{member.name}</span>
                                <span style={{
                                  fontSize:9,fontWeight:700,padding:"1px 6px",borderRadius:10,
                                  background:`${member.tierColor}20`,color:member.tierColor,
                                  border:`1px solid ${member.tierColor}30`,whiteSpace:"nowrap",flexShrink:0,
                                }}>{member.tier}</span>
                              </div>
                              <div style={{fontSize:10,color:p.textSub,marginTop:1}}>{member.designation}</div>
                              <div style={{fontSize:10,color:domain.color,marginTop:1,fontWeight:500,display:"flex",alignItems:"center",gap:3}}>
                                <span>🔧</span><span>{member.tech}</span>
                              </div>
                            </div>
                            {member.email?(
                              <div style={{display:"flex",gap:3,flexShrink:0}}>
                                <button title="Copy email" onClick={()=>copyEmail(member.email)} style={{
                                  background:copiedEmail===member.email?`${p.green}20`:`${p.border}40`,
                                  border:`1px solid ${copiedEmail===member.email?p.green:p.border}`,
                                  color:copiedEmail===member.email?p.green:p.textSub,
                                  borderRadius:5,padding:"2px 6px",cursor:"pointer",fontSize:10,fontWeight:600,transition:"all .2s",
                                }}>
                                  {copiedEmail===member.email?"✓":"📋"}
                                </button>
                                <a href={`mailto:${member.email}`} title={member.email} style={{
                                  background:`${p.accent}15`,border:`1px solid ${p.accent}40`,
                                  color:p.accent,borderRadius:5,padding:"2px 6px",
                                  fontSize:10,fontWeight:600,textDecoration:"none",display:"inline-flex",alignItems:"center",
                                }}>✉️</a>
                              </div>
                            ):(
                              <span style={{fontSize:9,color:p.textMute,fontStyle:"italic",flexShrink:0}}>Team</span>
                            )}
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          {/* Footer */}
          <div style={{
            padding:"7px 14px",borderTop:`1px solid ${p.border}`,flexShrink:0,
            background:p.panelAlt,display:"flex",alignItems:"center",justifyContent:"space-between",
          }}>
            <span style={{fontSize:10,color:p.textMute}}>📋 Copy email · ✉️ Open mail client</span>
            <span style={{fontSize:10,color:p.textMute}}>Wipro LaaS Platform</span>
          </div>
        </div>
      )}
    </div>
  );
}

// ─── ABOUT LAAS MODAL ────────────────────────────────────────────────────────
function AboutCaaSModal({onClose,p}){
  const [tab,setTab]=useState("whats_new");
  const tabs=[
    {id:"whats_new", label:"✨ What's New"},
    {id:"what",      label:"What is LaaS"},
    {id:"features",  label:"Features"},
    {id:"howto",     label:"How To Use"},
    {id:"roles",     label:"Access & Roles"},
  ];
  const accent=p.accent||"#3b82f6";

  const OEM_LOGOS=[
    {name:"VMware",    url:"https://logo.clearbit.com/vmware.com",   bg:"#1a1a2e", border:"#3b82f6"},
    {name:"OpenShift", url:"https://logo.clearbit.com/redhat.com",   bg:"#1a0a0a", border:"#ef4444"},
    {name:"Nutanix",   url:"https://logo.clearbit.com/nutanix.com",  bg:"#0a1a0e", border:"#22c55e"},
    {name:"Ansible",   url:"https://logo.clearbit.com/ansible.com",  bg:"#1a0d00", border:"#f97316"},
  ];

  const Check=({color,children})=>(
    <div style={{display:"flex",alignItems:"flex-start",gap:7,fontSize:12,color:p.textSub,lineHeight:1.7}}>
      <span style={{color,fontWeight:800,flexShrink:0,marginTop:1}}>✓</span><span>{children}</span>
    </div>
  );

  const FeatCard=({icon,title,points,color})=>(
    <div style={{background:p.panelAlt,border:`1px solid ${p.border}`,borderLeft:`3px solid ${color}`,borderRadius:10,padding:"13px 15px"}}>
      <div style={{display:"flex",alignItems:"center",gap:9,marginBottom:8}}>
        <span style={{fontSize:19,background:`${color}18`,border:`1px solid ${color}28`,borderRadius:7,padding:"4px 8px",flexShrink:0}}>{icon}</span>
        <span style={{fontWeight:700,fontSize:13,color:p.text}}>{title}</span>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"3px 16px"}}>
        {points.map((pt,j)=><Check key={j} color={color}>{pt}</Check>)}
      </div>
    </div>
  );

  const PlatformHeader=({logo,fallback,label,color})=>(
    <div style={{fontWeight:800,fontSize:12,color,letterSpacing:".4px",
      padding:"10px 0 4px",borderBottom:`1px solid ${color}30`,marginBottom:6,
      display:"flex",alignItems:"center",gap:8}}>
      <img src={logo} alt={label} onError={e=>e.target.style.display="none"}
        style={{width:18,height:18,objectFit:"contain",background:"#fff",borderRadius:3,padding:2}}/>
      {label}
    </div>
  );

  const NewBadge=({label="NEW",color="#10b981"})=>(
    <span style={{fontSize:9,fontWeight:800,padding:"2px 6px",borderRadius:20,
      background:`${color}20`,color,border:`1px solid ${color}40`,marginLeft:6,
      verticalAlign:"middle",letterSpacing:".3px"}}>{label}</span>
  );

  return(
    <div style={{position:"fixed",inset:0,background:"rgba(0,0,0,.70)",zIndex:3000,
      display:"flex",alignItems:"center",justifyContent:"center",padding:16,backdropFilter:"blur(6px)"}}
      onClick={e=>{if(e.target===e.currentTarget)onClose();}}>
      <div style={{background:p.panel,borderRadius:16,width:"100%",maxWidth:1100,maxHeight:"93vh",
        display:"flex",flexDirection:"column",boxShadow:"0 28px 90px rgba(0,0,0,.7)",
        border:`1px solid ${p.border}`,overflow:"hidden"}}>

        {/* ── Header ── */}
        <div style={{background:"linear-gradient(135deg,#0f172a,#1e3a5f,#1e40af)",
          padding:"18px 24px",position:"relative",flexShrink:0}}>
          <div style={{display:"flex",alignItems:"center",gap:14}}>
            <div style={{background:"rgba(255,255,255,.15)",borderRadius:12,padding:"8px 14px",
              fontSize:26,letterSpacing:"-1px",fontWeight:900,color:"#fff",fontFamily:"'Geist Mono',monospace"}}>
              L<span style={{color:"#93c5fd",fontWeight:400,fontSize:18}}>aaS</span>
            </div>
            <div>
              <div style={{fontSize:22,fontWeight:900,color:"#fff",letterSpacing:"-.4px"}}>
                LaaS Dashboard
                <span style={{fontSize:11,fontWeight:500,opacity:.65,marginLeft:8,
                  background:"rgba(255,255,255,.15)",borderRadius:10,padding:"2px 8px"}}>v6.0</span>
              </div>
              <div style={{fontSize:12,color:"rgba(255,255,255,.7)",marginTop:3}}>
                Lab as a Service &nbsp;·&nbsp; Unified Multi-Platform Infrastructure Portal &nbsp;·&nbsp; Wipro SDX INFRA &amp; DC
              </div>
            </div>
            <div style={{flex:1}}/>
            {/* Right corner: OEM logos + IPAM & Asset shortcuts */}
            <div style={{display:"flex",gap:8,alignItems:"center"}}>
              {OEM_LOGOS.map(oem=>(
                <div key={oem.name} title={oem.name} style={{display:"flex",flexDirection:"column",
                  alignItems:"center",gap:3,background:"rgba(0,0,0,.35)",
                  border:`1px solid ${oem.border}40`,borderRadius:9,padding:"5px 8px",minWidth:56}}>
                  <img src={oem.url} alt={oem.name}
                    onError={e=>{e.target.style.display="none";e.target.nextSibling.style.display="flex";}}
                    style={{width:28,height:28,objectFit:"contain",borderRadius:5,background:"#fff",padding:2}}/>
                  <div style={{display:"none",width:28,height:28,alignItems:"center",justifyContent:"center",
                    background:"rgba(255,255,255,.15)",borderRadius:5,fontSize:15}}>
                    {oem.name==="VMware"?"🖥️":oem.name==="OpenShift"?"🔴":oem.name==="Nutanix"?"🟩":"🎛️"}
                  </div>
                  <span style={{fontSize:9,fontWeight:700,color:"rgba(255,255,255,.75)",letterSpacing:".1px"}}>{oem.name}</span>
                </div>
              ))}
              {/* IPAM tile */}
              <div title="IPAM &amp; Network Management" style={{display:"flex",flexDirection:"column",
                alignItems:"center",gap:3,background:"rgba(0,0,0,.35)",
                border:"1px solid #06b6d440",borderRadius:9,padding:"5px 8px",minWidth:56}}>
                <div style={{width:28,height:28,borderRadius:5,background:"#06b6d420",
                  display:"flex",alignItems:"center",justifyContent:"center",fontSize:16}}>📡</div>
                <span style={{fontSize:9,fontWeight:700,color:"rgba(255,255,255,.75)",letterSpacing:".1px"}}>IPAM</span>
              </div>
              {/* Asset Management tile */}
              <div title="Asset Management &amp; Rack Topology" style={{display:"flex",flexDirection:"column",
                alignItems:"center",gap:3,background:"rgba(0,0,0,.35)",
                border:"1px solid #8b5cf640",borderRadius:9,padding:"5px 8px",minWidth:56}}>
                <div style={{width:28,height:28,borderRadius:5,background:"#8b5cf620",
                  display:"flex",alignItems:"center",justifyContent:"center",fontSize:16}}>🗃️</div>
                <span style={{fontSize:9,fontWeight:700,color:"rgba(255,255,255,.75)",letterSpacing:".1px"}}>Assets</span>
              </div>
            </div>
          </div>
          <button onClick={onClose} style={{position:"absolute",top:14,right:16,
            background:"rgba(255,255,255,.18)",border:"none",borderRadius:6,color:"#fff",
            cursor:"pointer",fontSize:16,padding:"4px 10px",fontWeight:700}}>&times;</button>
        </div>

        {/* ── Tab Bar ── */}
        <div style={{display:"flex",borderBottom:`1px solid ${p.border}`,background:p.panelAlt,flexShrink:0,overflowX:"auto"}}>
          {tabs.map(t=>(
            <button key={t.id} onClick={()=>setTab(t.id)} style={{
              flex:1,padding:"12px 8px",border:"none",background:"transparent",
              borderBottom:`3px solid ${tab===t.id?accent:"transparent"}`,
              color:tab===t.id?accent:p.textMute,fontWeight:tab===t.id?700:500,
              fontSize:12,cursor:"pointer",transition:"all .15s",whiteSpace:"nowrap",
              letterSpacing:".1px"}}>{t.label}</button>
          ))}
        </div>

        {/* ── Tab Content ── */}
        <div style={{overflowY:"auto",padding:"22px 26px",flex:1}}>

          {/* ══════════════ WHAT'S NEW ══════════════ */}
          {tab==="whats_new"&&(
            <div style={{display:"flex",flexDirection:"column",gap:10}}>
              <div style={{fontSize:13,color:p.textMute,marginBottom:6}}>
                Recent additions and improvements to the LaaS Dashboard — v6.0, March 2026
              </div>
              {[
                {v:"v6.0",date:"Mar 2026",color:"#10b981",icon:"✨",title:"Universal Global Search",
                  items:["Search VMs, hosts, datastores, snapshots, networks, OCP clusters, Nutanix PCs, Ansible jobs, alerts and all 17 pages","Grouped results with keyboard navigation (↑↓ Enter ESC)","Support contacts searchable by name, role and technology","Clicking a contact result copies their email — no extra steps"]},
                {v:"v6.0",date:"Mar 2026",color:"#3b82f6",icon:"📊",title:"Multi-Platform Resource Overview Charts",
                  items:["Interactive SVG donut rings on Overview showing VMware / OCP / Nutanix VM distribution","Hover any arc segment for a rich tooltip with exact counts and percentages","Animated VMware capacity gauges — CPU, RAM and Storage with colour-coded thresholds","Hover any bar for a floating tooltip with used / free / total values and extra context"]},
                {v:"v6.0",date:"Mar 2026",color:"#8b5cf6",icon:"📞",title:"Revamped Support Escalation Matrix",
                  items:["Full org hierarchy — ADH → Engineering Head → 3 domain teams","DC & VMware, OpenShift & AI, Storage & Nutanix domains each with lead + engineers","Full names, designations, technology areas and Wipro email IDs","Click ✉️ to open mail · 📋 to copy email address"]},
                {v:"v5.9",date:"Feb 2026",color:"#f97316",icon:"🤖",title:"Ansible Automation Platform (AAP)",
                  items:["Browse all job templates, inventories and credentials across AAP instances","Launch job templates with extra-vars from the portal","Live job execution status and stdout log streaming","Activity stream for audit trail of automation runs"]},
                {v:"v5.9",date:"Feb 2026",color:"#ef4444",icon:"🔴",title:"Multi-Platform VM Request Wizard",
                  items:["Single '+ Request VM' button with platform picker: VMware / OpenShift / Nutanix","OpenShift: 3-step form — cluster, namespace, workload type, container image dropdown","Nutanix: live image fetch from Prism Central — no manual image name typing","Reviews page with platform tabs: VMware · OpenShift · Nutanix filter"]},
                {v:"v5.8",date:"Jan 2026",color:"#06b6d4",icon:"📡",title:"IPAM & Chargeback Pages",
                  items:["IPAM page: subnet grid, utilization bars, IP search, SolarWinds integration","Chargeback page: VMware, OCP and Nutanix pricing panels with per-resource rates","IPAM overview section on the main Overview dashboard","Configurable pricing rates saved server-side"]},
                {v:"v5.7",date:"Dec 2025",color:"#22c55e",icon:"🟩",title:"Nutanix AHV Full Integration",
                  items:["Multi-site DC/DR Prism Central grouping","VM power actions and snapshots via Prism Central v3 API","Live images dropdown in VM request wizard fetched from selected PC","Storage containers, AHV hosts, network subnets and live alerts"]},
                {v:"v5.6",date:"Nov 2025",color:"#a78bfa",icon:"🎨",title:"Theme & UX Improvements",
                  items:["Three themes: Dark, Light, and Wipro Wings (purple/indigo)","Animated multi-platform ticker in the notification bar","Topology diagrams for OCP clusters and VMware vCenter","AI Chatbot with live data awareness for natural-language queries"]},
              ].map((entry,i)=>(
                <div key={i} style={{background:p.panelAlt,border:`1px solid ${entry.color}30`,
                  borderLeft:`4px solid ${entry.color}`,borderRadius:10,padding:"13px 15px"}}>
                  <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:8,flexWrap:"wrap"}}>
                    <span style={{fontSize:18}}>{entry.icon}</span>
                    <span style={{fontWeight:800,fontSize:13,color:p.text}}>{entry.title}</span>
                    <span style={{fontSize:10,fontWeight:700,padding:"2px 7px",borderRadius:10,
                      background:`${entry.color}20`,color:entry.color,
                      border:`1px solid ${entry.color}35`}}>{entry.v}</span>
                    <span style={{fontSize:10,color:p.textMute}}>{entry.date}</span>
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"3px 18px"}}>
                    {entry.items.map((it,j)=><Check key={j} color={entry.color}>{it}</Check>)}
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* ══════════════ WHAT IS LAAS ══════════════ */}
          {tab==="what"&&(
            <div style={{display:"flex",flexDirection:"column",gap:14}}>
              <div style={{background:`${accent}0f`,border:`1px solid ${accent}28`,
                borderRadius:10,padding:"18px 20px",lineHeight:1.9,fontSize:14,color:p.text}}>
                <span style={{fontWeight:900,color:accent}}>LaaS (Lab as a Service)</span> is a unified
                self-service portal for your team to view, manage, and request virtual infrastructure across&nbsp;
                <strong>VMware vCenter</strong>, <strong>Red Hat OpenShift</strong>, <strong>Nutanix Prism Central</strong>,
                and <strong>Ansible Automation Platform</strong> — from a single browser window, without needing
                direct access to any underlying platform.
              </div>
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:10}}>
                {[
                  {icon:"🖥️",color:"#3b82f6",title:"VMware vCenter",desc:"Full VM lifecycle — power, clone, migrate, snapshots, reconfigure, bulk actions and chargeback across all vCenters."},
                  {icon:"🔴",color:"#ef4444",title:"Red Hat OpenShift",desc:"Live cluster monitoring — nodes, pods, namespaces, operators, routes, storage, topology, events and RHOAI."},
                  {icon:"🟩",color:"#22c55e",title:"Nutanix Prism Central",desc:"Multi-site AHV — VMs, hosts, clusters, storage, networks, alerts, provisioning via Prism Central v3 API."},
                  {icon:"🤖",color:"#f97316",title:"Ansible Automation Platform",desc:"AAP job templates, inventories, credentials, job execution with stdout streaming and activity stream."},
                  {icon:"📡",color:"#06b6d4",title:"IPAM (SolarWinds)",desc:"IP Address Management — subnet grid, utilization tracking, IP search, and overview integration."},
                  {icon:"🗂️",color:"#8b5cf6",title:"Active Directory & DNS",desc:"Create and manage AD users, groups and DNS records via LDAP — no WinRM or PowerShell agent required."},
                  {icon:"📋",color:"#f59e0b",title:"VM Request Workflow",desc:"Self-service provisioning for VMware, OpenShift workloads and Nutanix VMs with admin approval workflow."},
                  {icon:"💳",color:"#ec4899",title:"Chargeback & Pricing",desc:"Per-platform pricing (VMware, OCP, Nutanix), monthly INR/USD cost breakdown and project-level billing."},
                  {icon:"🏷️",color:"#14b8a6",title:"Asset Inventory",desc:"Physical and logical asset tracking with search, filters, inline editing and CSV export."},
                  {icon:"🔍",color:"#a78bfa",title:"Universal Search",desc:"Instant search across VMs, hosts, clusters, pods, contacts, alerts and all 17 pages with keyboard navigation."},
                  {icon:"🤖",color:"#7c3aed",title:"AI Assistant",desc:"Ask plain-English questions about your infrastructure. Fully offline, powered by live portal data."},
                  {icon:"🔐",color:"#64748b",title:"Role-Based Access",desc:"Four roles — Admin, Operator, Viewer, Requester — each with precisely scoped permissions."},
                ].map((c,i)=>(
                  <div key={i} style={{background:p.panelAlt,border:`1px solid ${p.border}`,
                    borderLeft:`3px solid ${c.color}`,borderRadius:9,padding:"13px 15px",
                    display:"flex",gap:11,alignItems:"flex-start"}}>
                    <span style={{fontSize:20,flexShrink:0}}>{c.icon}</span>
                    <div>
                      <div style={{fontWeight:700,fontSize:13,color:p.text,marginBottom:4}}>{c.title}</div>
                      <div style={{fontSize:12,color:p.textSub,lineHeight:1.7}}>{c.desc}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* ══════════════ FEATURES ══════════════ */}
          {tab==="features"&&(
            <div style={{display:"flex",flexDirection:"column",gap:8}}>

              <PlatformHeader logo="https://logo.clearbit.com/vmware.com" label="VMware vCenter" color="#60a5fa"/>
              {[
                {icon:"💻",title:"Virtual Machine Management",color:"#3b82f6",points:["Live power state, CPU, RAM & disk across all vCenters","Power On / Off / Restart from the portal","Clone VMs and vMotion live migration","Reconfigure CPU, RAM and disk size","Full-text search by name, OS, IP, host","Bulk VM power and clone actions"]},
                {icon:"📈",title:"Capacity & Host Monitoring",color:"#3b82f6",points:["ESXi host CPU and memory utilisation charts","Datastore usage with colour-coded free space","Host ranking — identify most overloaded nodes","Per-vCenter breakdown for multi-site setups","VMware resource overview gauges with hover tooltips"]},
                {icon:"💰",title:"Project Chargeback",color:"#3b82f6",points:["VM costs aggregated by VMware tag / project","Monthly chargeback in INR and USD","Owner and email mapped to each project tag","Configurable pricing rates per CPU, RAM and disk","PDF export for billing and planning"]},
                {icon:"📸",title:"Snapshot Management",color:"#3b82f6",points:["View all snapshots across vCenters","Create and delete snapshots from portal","Snapshot age and size tracking","Identify VMs with excessive snapshots"]},
              ].map((f,i)=><FeatCard key={i} {...f}/>)}

              <PlatformHeader logo="https://logo.clearbit.com/redhat.com" label="Red Hat OpenShift" color="#f87171"/>
              {[
                {icon:"🗺️",title:"Cluster Topology",color:"#ef4444",points:["Interactive topology diagram per cluster","Nodes with CPU/RAM bars and pod counts","Namespace swim-lanes with health status","Operator health overlay on topology view"]},
                {icon:"🖥️",title:"Node Management",color:"#ef4444",points:["Live nodes with role, status, CPU and RAM","Cordon, Uncordon and Drain nodes","Full describe: OS, kernel, kubelet version","Node age and Kubernetes version display"]},
                {icon:"📦",title:"Pod & Namespace Monitoring",color:"#ef4444",points:["All pods with namespace, node, phase and age","Log streaming with container selection","Namespaces with pod/service/deployment counts","PVC usage and resource quota visibility"]},
                {icon:"🚀",title:"Routes, Operators & Storage",color:"#ef4444",points:["All Routes with clickable HTTPS/HTTP URLs","TLS termination type and backend service","All cluster operators — Available / Degraded","Storage classes, provisioner and reclaim policy"]},
                {icon:"🔬",title:"OpenShift AI (RHOAI)",color:"#ef4444",points:["Direct link to RHOAI dashboard per cluster","Configurable RHOAI URL via Edit Cluster","One-click launch from the cluster info bar","Purple badge visible when RHOAI URL is set"]},
              ].map((f,i)=><FeatCard key={i} {...f}/>)}

              <PlatformHeader logo="https://logo.clearbit.com/nutanix.com" label="Nutanix Prism Central" color="#34d399"/>
              {[
                {icon:"🏢",title:"Multi-Site DC / DR Management",color:"#22c55e",points:["Separate DC and DR Prism Central grouping","Add multiple Prism Centrals per site","Per-PC status indicator and test connectivity","Live overview KPIs per Prism Central"]},
                {icon:"💻",title:"VM & Host Monitoring",color:"#22c55e",points:["All AHV VMs with power state, vCPUs, RAM, IPs","VM power actions: on, off, reset","On-demand snapshots via Prism Central API","AHV hosts with CPU, RAM and IPMI / CVM IPs"]},
                {icon:"🌐",title:"Storage, Networks & Alerts",color:"#22c55e",points:["Storage containers with usage and free space","All subnets with VLAN ID and IP pool ranges","Live alerts with severity: Critical / Warning","Network type: VLAN or overlay"]},
                {icon:"🚀",title:"VM Provisioning Wizard",color:"#22c55e",points:["3-step guided form: Basics → Resources → Confirm","Live image dropdown fetched from selected PC","Select cluster, container, NIC and disk type","Provisions via Prism Central v3 API post-approval"]},
              ].map((f,i)=><FeatCard key={i} {...f}/>)}

              <PlatformHeader logo="https://logo.clearbit.com/ansible.com" label="Ansible Automation Platform" color="#fb923c"/>
              {[
                {icon:"📋",title:"Templates, Inventories & Jobs",color:"#f97316",points:["Browse all job templates across AAP instances","View inventories and credentials","Launch templates with extra-vars via portal","Job execution with live stdout streaming"]},
                {icon:"📜",title:"Activity Stream & Audit",color:"#f97316",points:["Full automation activity stream per instance","Filter by event type and timestamp","Track who launched what and when","Correlates with the portal-wide audit log"]},
              ].map((f,i)=><FeatCard key={i} {...f}/>)}

              <PlatformHeader logo="https://logo.clearbit.com/microsoft.com" label="Active Directory & DNS" color="#c084fc"/>
              {[
                {icon:"🌲",title:"AD User & Group Management",color:"#a78bfa",points:["Browse all AD users with OU and account status","Create users with password policy & group copy","Enable / Disable / Unlock / Delete accounts","Reset passwords without domain access","Manage group membership: add and remove","Pure LDAP — no WinRM or PowerShell"]},
                {icon:"🌐",title:"DNS Zone & Record Management",color:"#a78bfa",points:["Browse AD-integrated DNS zones","A, CNAME, MX, PTR, SRV, NS, TXT records","Add and delete DNS records","Flush entire DNS server cache","MS-DNSP protocol via LDAP — no WinRM"]},
              ].map((f,i)=><FeatCard key={i} {...f}/>)}

              <PlatformHeader logo="" label="Platform-Wide Capabilities" color="#94a3b8"/>
              {[
                {icon:"🔍",title:"Universal Global Search",color:"#64748b",points:["Search VMs, hosts, snapshots, networks, datastores","OpenShift clusters, Nutanix PCs, Ansible jobs","All 17 navigation pages by name and description","Support contacts by name, role and email","Keyboard navigation: ↑↓ Enter ESC","Grouped results with per-category headers","Clicking a contact copies their email to clipboard"]},
                {icon:"📡",title:"IPAM & Asset Inventory",color:"#06b6d4",points:["Subnet grid with % utilisation and IP counts","IP search within subnets","Top utilised subnets on the Overview page","Physical/virtual asset tracking with inline editing","CSV export of asset inventory"]},
                {icon:"💬",title:"AI Assistant & Notifications",color:"#7c3aed",points:["Ask natural-language questions about infrastructure","Powered entirely by live portal data — offline-safe","Configurable scrolling ticker for custom notices","Live alert severity chips in notification bar"]},
                {icon:"🎨",title:"Themes, Charts & Audit",color:"#f59e0b",points:["Dark · Light · Wipro Wings (purple) themes","Multi-platform donut charts on Overview with hover tooltips","VMware capacity gauges with animated fill bars","Full portal audit log — every action recorded","Exportable audit data for compliance"]},
              ].map((f,i)=><FeatCard key={i} {...f}/>)}
            </div>
          )}

          {/* ══════════════ HOW TO USE ══════════════ */}
          {tab==="howto"&&(
            <div style={{display:"flex",flexDirection:"column",gap:10}}>
              {[
                {step:1,color:"#3b82f6",icon:"🔑",title:"Log In",
                  desc:"Use your Wipro Active Directory credentials or a local portal account. Open a browser and navigate to the LaaS Dashboard URL provided by your admin."},
                {step:2,color:"#06b6d4",icon:"🧭",title:"Pick Your Platform",
                  desc:"Use the left sidebar to switch between VMware, OCP, Nutanix, Ansible, AD/DNS, IPAM, Assets, Chargeback, or VM Requests. Each platform has its own tabs and live data."},
                {step:3,color:"#10b981",icon:"🔄",title:"Explore Live Data",
                  desc:"All data is fetched live. Use the refresh selector (top right) to set auto-refresh from 30s to 1h. A countdown and last-sync time are shown in the top bar."},
                {step:4,color:"#f59e0b",icon:"🔍",title:"Search Anything",
                  desc:"Type in the global search bar to instantly find VMs, clusters, nodes, contacts, pages and more. Use ↑↓ to navigate results and Enter to jump — or press ESC to close."},
                {step:5,color:"#ef4444",icon:"📋",title:"Request a VM",
                  desc:"Click '+ Request VM' in the top bar. Pick your platform (VMware / OpenShift / Nutanix) and follow the step-by-step wizard. Admins and Operators review requests under VM Requests."},
                {step:6,color:"#8b5cf6",icon:"🤖",title:"Ask the AI Assistant",
                  desc:"Click '🤖 Ask AI' for natural-language answers about your infrastructure. Ask things like 'which host has the most free RAM?' or 'how many pods are running in cluster A?'"},
                {step:7,color:"#f97316",icon:"💳",title:"View Chargeback",
                  desc:"Go to Chargeback to see per-VM costs broken down by platform, with VMware tag-based project grouping, INR and USD totals, and configurable pricing rates."},
                {step:8,color:"#ec4899",icon:"📞",title:"Contact the Team",
                  desc:"Click '📞 Support' in the top bar to open the escalation matrix. All Wipro contacts are listed with designation, tech area, and direct email. Click ✉️ to email or 📋 to copy."},
              ].map((s,i)=>(
                <div key={i} style={{display:"flex",gap:14,alignItems:"flex-start",
                  background:p.panelAlt,border:`1px solid ${p.border}`,
                  borderLeft:`3px solid ${s.color}`,borderRadius:10,padding:"14px 16px"}}>
                  <div style={{background:`linear-gradient(135deg,${s.color},${s.color}cc)`,color:"#fff",
                    borderRadius:"50%",width:34,height:34,display:"flex",alignItems:"center",
                    justifyContent:"center",fontWeight:900,fontSize:14,flexShrink:0}}>{s.step}</div>
                  <div>
                    <div style={{fontWeight:700,fontSize:13,color:p.text,marginBottom:4}}>
                      {s.icon} {s.title}
                    </div>
                    <div style={{fontSize:12,color:p.textSub,lineHeight:1.75}}>{s.desc}</div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* ══════════════ ACCESS & ROLES ══════════════ */}
          {tab==="roles"&&(
            <div style={{display:"flex",flexDirection:"column",gap:12}}>
              <div style={{fontSize:13,color:p.textMute,marginBottom:2}}>
                Access levels are assigned by an Administrator. Each role has precisely scoped permissions across all platforms.
              </div>
              {[
                {role:"Admin",color:"#c2410c",bg:"#fff7ed",border:"#fed7aa",
                  desc:"Full control of all platforms and portal settings.",caps:[
                  "All VMware, OpenShift, Nutanix, Ansible, AD/DNS tabs","Add / edit / delete vCenters, clusters, Prism Centrals, AAP instances",
                  "Approve or decline VM provisioning requests (all platforms)","Create and manage portal users and role assignments",
                  "Create / delete AD users, groups, OUs and DNS records","Manage pricing rates for VMware, OCP and Nutanix",
                  "Configure thresholds, notifications and ticker messages","View and export full portal audit log",
                ]},
                {role:"Operator",color:"#1d4ed8",bg:"#eff6ff",border:"#bfdbfe",
                  desc:"Day-to-day operations and provisioning approvals.",caps:[
                  "All VMware VM actions: power, clone, migrate, snapshot","OpenShift: view nodes, pods, namespaces, operators, routes, events",
                  "OpenShift: cordon / uncordon / drain nodes","Nutanix: all monitoring tabs + VM power actions and snapshots",
                  "Approve or decline VM requests (VMware & Nutanix)","Create and manage AD users, groups and DNS records",
                  "Launch Ansible job templates","View IPAM, assets, chargeback and audit logs",
                ]},
                {role:"Viewer",color:"#6d28d9",bg:"#f5f3ff",border:"#ddd6fe",
                  desc:"Read-only visibility across all platforms.",caps:[
                  "VMware: Overview, VMs, Capacity, Snapshots, Networks","OpenShift: all monitoring tabs (no cordon/drain/delete)",
                  "Nutanix: all tabs — clusters, VMs, hosts, storage, alerts","IPAM, Asset Inventory and Chargeback (read-only)",
                  "Ansible: view templates, inventories, jobs (no launch)","View VM requests list (no approve/decline action)",
                  "No ability to perform any write actions or submit requests","Full audit log access (view only)",
                ]},
                {role:"Requester",color:"#15803d",bg:"#f0fdf4",border:"#bbf7d0",
                  desc:"Self-service VM provisioning requests only.",caps:[
                  "Submit VMware VM provisioning requests","Submit OpenShift workload requests (Deployment, StatefulSet, etc.)",
                  "Submit Nutanix AHV VM requests via guided wizard","View and track status of own submitted requests",
                  "View personal audit history","No access to infrastructure monitoring dashboards",
                ]},
              ].map((r,i)=>(
                <div key={i} style={{border:`1px solid ${r.border}`,borderLeft:`4px solid ${r.color}`,
                  borderRadius:10,padding:"14px 16px",background:r.bg}}>
                  <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:10}}>
                    <span style={{background:r.color,color:"#fff",borderRadius:6,
                      padding:"3px 14px",fontSize:12,fontWeight:800,letterSpacing:".3px"}}>{r.role}</span>
                    <span style={{fontSize:12,color:r.color,fontWeight:600}}>{r.desc}</span>
                  </div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"4px 16px"}}>
                    {r.caps.map((c,j)=>(
                      <div key={j} style={{display:"flex",alignItems:"flex-start",gap:7,
                        fontSize:12,color:"#374151",lineHeight:1.7}}>
                        <span style={{color:r.color,fontWeight:700,flexShrink:0,marginTop:2}}>✓</span><span>{c}</span>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          )}

        </div>

        {/* ── Footer ── */}
        <div style={{borderTop:`1px solid ${p.border}`,padding:"10px 24px",
          display:"flex",justifyContent:"space-between",alignItems:"center",
          background:p.panelAlt,flexShrink:0}}>
          <div style={{fontSize:11,color:p.textMute,display:"flex",alignItems:"center",gap:10}}>
            <span style={{fontWeight:700,color:p.textSub}}>LaaS Dashboard v6.0</span>
            <span style={{opacity:.4}}>·</span>
            <span>Wipro · SDX INFRA &amp; DC Operations</span>
            <span style={{opacity:.4}}>·</span>
            <div style={{display:"flex",gap:5,alignItems:"center"}}>
              {OEM_LOGOS.map(oem=>(
                <img key={oem.name} src={oem.url} alt={oem.name} title={oem.name}
                  onError={e=>e.target.style.display="none"}
                  style={{width:16,height:16,objectFit:"contain",background:"#fff",
                    borderRadius:3,padding:1,opacity:.8}}/>
              ))}
            </div>
          </div>
          <button onClick={onClose} style={{background:`linear-gradient(135deg,${accent},#06b6d4)`,
            color:"#fff",border:"none",borderRadius:7,padding:"8px 26px",
            fontWeight:700,fontSize:13,cursor:"pointer",
            boxShadow:`0 2px 8px ${accent}40`}}>Close</button>
        </div>

      </div>
    </div>
  );
}








// ─── APP ──────────────────────────────────────────────────────────────────────
export default function App(){
  const [loggedIn,setLoggedIn]=useState(false);
  const [currentUser, setCurrentUser]=useState(null);
  const [page,    setPageRaw] =useState(getSavedPage()||"overview");
  const [modal,   setModal]   =useState(false);
  const [vmReqModal,setVmReqModal]=useState(false);
  const [vmReqVmwareOnly,setVmReqVmwareOnly]=useState(false);
  const [theme,   setTheme]   =useState(()=>{ const t=localStorage.getItem("caas_theme"); return (t==="dark"||t==="light"||t==="wings")?t:"dark"; });
  const dark = theme==="dark";
  const [pendingCount,setPendingCount]=useState(0);
  const [refresh, setRefresh] =useState(3600);
  const [cdwn,    setCdwn]    =useState(3600);
  const [clock,   setClock]   =useState(new Date());
  const [selectedVC,setSelectedVC]=useState("all");
  const [authChecked,setAuthChecked]=useState(false);
  // Manual notifications
  const [manualNotifs,setManualNotifs]=useState([]);
  const [notifEditorOpen,setNotifEditorOpen]=useState(false);
  useEffect(()=>{
    if(loggedIn) fetchNotifications().then(setManualNotifs).catch(()=>{});
  },[loggedIn]);
  // Fix 4: global search
  const [globalQ,setGlobalQ]=useState("");
  const [searchOpen,setSearchOpen]=useState(false);
  const [searchIdx,setSearchIdx]=useState(-1);
  const searchRef=useRef(null);
  const [searchHL,setSearchHL]=useState(null); // {page,term} passed to target page
  // Fix 5: chatbot
  const [chatOpen,setChatOpen]=useState(false);
  // About LaaS modal
  const [aboutOpen,setAboutOpen]=useState(false);
  const [portalSpeaking,setPortalSpeaking]=useState(false);
  const portalSynthRef=useRef(null);

  const PORTAL_VOICEOVER=`Welcome to the LaaS Portal — Lab as a Service, built by Wipro SDX Infrastructure and Data Centre team.

LaaS is a unified self-service portal that brings together four enterprise platforms — VMware vSphere, Red Hat OpenShift, Nutanix AHV, and Ansible Automation Platform — into a single browser-based interface. Engineers and managers no longer need direct access to individual consoles. Everything is available here, governed by role-based access control.

Starting with VMware. The portal connects to multiple vCenter instances and gives you full VM lifecycle management — power on, off, reset, clone, migrate, reconfigure CPU and memory, manage snapshots, and view network and datastore inventory. Bulk actions let you operate on multiple VMs at once. A topology map shows the relationship between VMs and their ESXi hosts.

For Red Hat OpenShift, the portal monitors all clusters — node health, CPU and memory utilisation, namespace inventory, running pods, deployed operators, storage persistent volumes, routes, and RHOAI AI platform components. Cluster topology diagrams are available per cluster.

The Nutanix integration connects to Prism Central instances across multiple sites. You can browse AHV VMs, host clusters, storage containers, network subnets, and cluster-level capacity — all without Prism Central access.

Ansible Automation Platform integration lets operators browse job templates, inventories and credentials, and launch playbooks directly from the portal with custom extra variables. Live job output and activity streams are streamed in real time.

Storage Management covers Pure Storage FlashArrays, HPE Alletra and Primera, Dell EMC PowerStore, and NetApp ONTAP — all via native REST APIs. Volumes, LUNs, drives, hosts, shares and capacity are visible in one place.

Backup visibility is provided through Rubrik Security Cloud and Cohesity DataProtect. Every SLA domain, protected and unprotected workload, backup job status, and cluster capacity is surfaced without opening a backup console.

Supporting services include Active Directory and DNS management via LDAP, SolarWinds IPAM for subnet and IP tracking, a VM request and approval workflow for self-service provisioning, and a chargeback engine that calculates monthly costs per project across all three virtualisation platforms.

The portal includes a Universal Search that finds VMs, hosts, OCP clusters, Nutanix PCs, Ansible jobs, alerts, and team contacts instantly. There is also an AI Assistant for natural-language infrastructure queries.

Access is controlled by four roles — Admin, Operator, Viewer, and Requester — with a full audit log of every action. This portal replaces over six separate management consoles, reducing access risk, improving governance, and accelerating operations across the entire Wipro lab environment.`.trim();

  function togglePortalVoice(){
    if(!('speechSynthesis' in window)) return;
    if(portalSpeaking){
      window.speechSynthesis.cancel();
      setPortalSpeaking(false);
      return;
    }
    window.speechSynthesis.cancel();
    const utt=new SpeechSynthesisUtterance(PORTAL_VOICEOVER);
    utt.rate=0.90; utt.pitch=1.0; utt.volume=1.0;
    const voices=window.speechSynthesis.getVoices();
    const pick=voices.find(v=>v.lang.startsWith('en')&&(v.name.includes('Google')||v.name.includes('Natural')||v.name.includes('Neural')))
      ||voices.find(v=>v.lang==='en-US')||voices.find(v=>v.lang.startsWith('en'))||voices[0];
    if(pick) utt.voice=pick;
    utt.onend=()=>setPortalSpeaking(false);
    utt.onerror=()=>setPortalSpeaking(false);
    portalSynthRef.current=utt;
    setPortalSpeaking(true);
    window.speechSynthesis.speak(utt);
  }

  const [vcenters,   setVcenters]  =useState([]);
  const [summaries,  setSummaries] =useState([]);
  const [summary,    setSummary]   =useState(null);
  const [vms,        setVMs]       =useState([]);
  const [hosts,      setHosts]     =useState([]);
  const [datastores, setDatastores]=useState([]);
  const [networks,   setNetworks]  =useState([]);
  const [snapshots,  setSnapshots] =useState([]);
  const [alerts,     setAlerts]    =useState([]);
  const [loading,    setLoading]   =useState(true);
  const [error,      setError]     =useState(null);
  const [lastSync,   setLastSync]  =useState(null);

  // Cross-platform summary data (for Overview + Capacity)
  const [ocpData, setOcpData]=useState({clusters:[],overviews:{},loading:false,error:null});
  const [nutData, setNutData]=useState({pcs:[],overviews:{},loading:false,error:null});

  const p=theme==="wings"?WINGS:theme==="dark"?DARK:LIGHT;

  // Save page whenever it changes
  function setPage(pg){ setPageRaw(pg); savePage(pg); }

  // Fix #10: on mount, try to restore session from sessionStorage
  useEffect(()=>{
    verifySession().then(user=>{
      if(user){ setCurrentUser(user); setLoggedIn(true); }
      setAuthChecked(true);
    });
  },[]);

  // Save theme preference
  useEffect(()=>{ localStorage.setItem("caas_theme", theme); },[theme]);

  const load=useCallback(async(vcid)=>{
    const vid=vcid??selectedVC;
    setLoading(true); setError(null);
    try{
      const [vcList,s,v,h,d,n,sn,a]=await Promise.all([
        fetchVCenters(),fetchSummary(vid),fetchVMs(vid),fetchHosts(vid),
        fetchDatastores(vid),fetchNetworks(vid),fetchSnapshots(vid),fetchAlerts(vid),
      ]);
      setVcenters(vcList||[]);
      const perVC=await Promise.all((vcList||[]).map(vc=>fetchSummary(vc.id).catch(()=>({vcenter_id:vc.id,status:"error"}))));
      setSummaries(perVC);
      setSummary(s); setVMs(v||[]); setHosts(h||[]);
      setDatastores(d||[]); setNetworks(n||[]); setSnapshots(sn||[]); setAlerts(a||[]);
      setLastSync(new Date()); setCdwn(refresh);
    }catch(e){ setError(e.message||"API unavailable"); }
    setLoading(false);
  },[selectedVC,refresh]);

  useEffect(()=>{ if(loggedIn) load(); },[loggedIn]);

  // Load OpenShift + Nutanix overview data for global overview/capacity pages
  const loadPlatformSummaries=useCallback(async()=>{
    setOcpData(d=>({...d,loading:true,error:null}));
    try{
      const clusters=await fetchOCPClusters();
      setOcpData(d=>({...d,clusters:clusters||[]}));
      const ovArr=await Promise.all((clusters||[]).map(c=>fetchOCPOverview(c.id).catch(()=>null)));
      const ovMap={};
      (clusters||[]).forEach((c,i)=>{ ovMap[c.id]=ovArr[i]; });
      setOcpData({clusters:clusters||[],overviews:ovMap,loading:false,error:null});
    }catch(e){ setOcpData({clusters:[],overviews:{},loading:false,error:e.message}); }
    setNutData(d=>({...d,loading:true,error:null}));
    try{
      const pcs=await fetchNutanixPCs();
      setNutData(d=>({...d,pcs:pcs||[]}));
      const ovArr=await Promise.all((pcs||[]).map(pc=>fetchNutanixOverview(pc.id).catch(()=>null)));
      const ovMap={};
      (pcs||[]).forEach((pc,i)=>{ ovMap[pc.id]=ovArr[i]; });
      setNutData({pcs:pcs||[],overviews:ovMap,loading:false,error:null});
    }catch(e){ setNutData({pcs:[],overviews:{},loading:false,error:e.message}); }
  },[]);
  useEffect(()=>{ if(loggedIn) loadPlatformSummaries(); },[loggedIn]);
  useEffect(()=>{
    if(!loggedIn) return;
    const t=setInterval(()=>load(),refresh*1000);
    return()=>clearInterval(t);
  },[loggedIn,refresh]);
  useEffect(()=>{
    const t=setInterval(()=>{ setCdwn(c=>c<=1?refresh:c-1); setClock(new Date()); },1000);
    return()=>clearInterval(t);
  },[refresh]);

  function handleVCSelect(id){ setSelectedVC(id); load(id); }

  // Show blank while checking saved session to avoid flash
  if(!authChecked) return <><style>{G(p)}</style><div style={{height:"100vh",display:"flex",alignItems:"center",justifyContent:"center"}}><div className="spinner"/></div></>;

  if(!loggedIn) return <><style>{G(p)}</style><Login onLogin={(u)=>{setCurrentUser(u);setLoggedIn(true);}} p={p}/></>;

  const navLabels={overview:"Overview",vms:"VMware",project_utilization:"Project Utilization",capacity:"Capacity",snapshots:"Snapshots",networks:"Networks",ipam:"IPAM",requests:"VM Requests",audit:"Audit Log",users:"User Management",storage:"Storage",backup:"Backup"};

  // Fix 6: notification ticker — only show real alerts/events, not resource stats
  const notifItems = [
    ...alerts.filter(a=>a.severity==="error").map(a=>`🔴 CRITICAL · ${a.resource||""} · ${a.message}`),
    ...alerts.filter(a=>a.severity==="warn"||a.severity==="warning").map(a=>`🟡 WARNING · ${a.resource||""} · ${a.message}`),
    ...(summary?.running_vms!==undefined?[`✅ ${summary.running_vms} VMs running across ${vcenters.length} vCenter${vcenters.length!==1?"s":""}`]:[]),
    ...(hosts.filter(h=>h.status!=="connected").length>0?[`⚠️ ${hosts.filter(h=>h.status!=="connected").length} host(s) not connected`]:[]),
    ...(snapshots.length>50?[`📸 ${snapshots.length} snapshots detected — consider cleanup`]:[]),
    ...(vcenters.length===0?["🔄 Connecting to vCenters…"]:[]),
  ].filter(Boolean);
  const tickItems = notifItems.length>0 ? notifItems : ["✅ All systems normal — no active alerts"];

  // Global search — all data sources
  const _gq=globalQ.trim().toLowerCase();
  const _NAV_PAGES=[
    {id:"overview",   label:"Overview",           icon:"🏠", desc:"Infrastructure overview & platform health"},
    {id:"vms",        label:"VMware VMs",          icon:"🖥️", desc:"Virtual machines · snapshots · actions"},
    {id:"capacity",   label:"Capacity",            icon:"🗄️", desc:"ESXi host & datastore capacity"},
    {id:"openshift",  label:"Red Hat OpenShift",   icon:"🔴", desc:"Container platform · pods · nodes · operators"},
    {id:"nutanix",    label:"Nutanix AHV",         icon:"🟩", desc:"AHV VMs · clusters · Prism Central"},
    {id:"ansible",    label:"Ansible AAP",         icon:"🤖", desc:"Automation · playbooks · job templates"},
    {id:"requests",   label:"VM Requests",         icon:"📋", desc:"VM provisioning requests & approvals"},
    {id:"snapshots",  label:"Snapshots",           icon:"📸", desc:"VM snapshot management & cleanup"},
    {id:"networks",   label:"Networks",            icon:"🌐", desc:"Port groups & network inventory"},
    {id:"ipam",       label:"IPAM",               icon:"📡", desc:"IP address management · subnets"},
    {id:"assets",     label:"Asset Inventory",     icon:"🖥️", desc:"Physical & logical asset tracking"},
    {id:"chargeback", label:"Chargeback",          icon:"💳", desc:"Cost breakdown · pricing · billing"},
    {id:"capacity",   label:"Capacity IPAM",       icon:"📊", desc:"IPAM capacity & subnet utilization"},
    {id:"addns",      label:"AD & DNS",            icon:"🗂️", desc:"Active Directory users · DNS records"},
    {id:"audit",      label:"Audit Log",           icon:"📝", desc:"Activity history & change tracking"},
    {id:"users",      label:"Users",               icon:"👥", desc:"User management & role assignment"},
    {id:"project_utilization",label:"Project Utilization",icon:"📊",desc:"Team & project VM utilization charts"},
  ];
  const _allPeople=[...SUPPORT_MATRIX.leadership,...SUPPORT_MATRIX.domains.flatMap(d=>d.team.filter(m=>m.email))];
  const globalResults = _gq.length<2 ? [] : [
    // Navigate to page
    ..._NAV_PAGES.filter(pg=>[pg.label,pg.desc].some(s=>s.toLowerCase().includes(_gq)))
      .map(pg=>({grp:"Navigate",grpIcon:"🚀",type:pg.id,label:pg.label,sub:pg.desc,page:pg.id,color:"#64748b",icon:pg.icon,navOnly:true})).slice(0,4),
    // vCenters
    ...vcenters.filter(v=>[v.name,v.host].some(s=>s?.toLowerCase().includes(_gq)))
      .map(v=>({grp:"VMware",grpIcon:"🖥️",type:"vCenter",label:v.name,sub:`vCenter · ${v.host}`,page:"vms",color:"#3b82f6",icon:"📡"})).slice(0,3),
    // Virtual Machines
    ...vms.filter(v=>[v.name,v.host,v.guest_os,v.ip,v.vcenter_name].some(s=>s?.toLowerCase().includes(_gq)))
      .map(v=>({grp:"VMware",grpIcon:"🖥️",type:"VM",label:v.name,sub:`${v.status==="poweredOn"?"🟢 On":"🔴 Off"} · ${v.host||""} · ${v.ip||"no IP"}`,page:"vms",color:v.status==="poweredOn"?"#10b981":"#ef4444",icon:"🖥️"})).slice(0,6),
    // ESXi Hosts
    ...hosts.filter(h=>[h.name,h.vcenter_name,h.model,h.manufacturer,h.status].some(s=>s?.toLowerCase().includes(_gq)))
      .map(h=>({grp:"VMware",grpIcon:"🖥️",type:"Host",label:h.name,sub:`${h.status} · CPU ${Math.round(100-h.cpu_free_pct||0)}% · RAM ${Math.round(100-(h.ram_free_pct||0))}%`,page:"capacity",color:"#3b82f6",icon:"🗄️"})).slice(0,4),
    // Datastores
    ...datastores.filter(d=>[d.name,d.type,d.vcenter_name].some(s=>s?.toLowerCase().includes(_gq)))
      .map(d=>({grp:"VMware",grpIcon:"🖥️",type:"Datastore",label:d.name,sub:`${d.used_pct||0}% used · ${fmtGB(d.free_gb||0)} free`,page:"capacity",color:"#06b6d4",icon:"💾"})).slice(0,4),
    // Snapshots
    ...snapshots.filter(s=>[s.vm_name,s.snapshot_name,s.description].some(x=>x?.toLowerCase().includes(_gq)))
      .map(s=>({grp:"Snapshots",grpIcon:"📸",type:"Snapshot",label:s.snapshot_name,sub:`VM: ${s.vm_name}${s.created_at?" · "+s.created_at.slice(0,10):""}`,page:"snapshots",color:"#f59e0b",icon:"📸"})).slice(0,4),
    // Networks
    ...networks.filter(n=>[n.name,n.type,n.vcenter_name].some(s=>s?.toLowerCase().includes(_gq)))
      .map(n=>({grp:"Networks",grpIcon:"🌐",type:"Network",label:n.name,sub:`${n.type||""} · ${n.vcenter_name||""}`.trim().replace(/^·\s*|\s*·\s*$/,""),page:"networks",color:"#8b5cf6",icon:"🌐"})).slice(0,4),
    // Alerts
    ...alerts.filter(a=>[a.message,a.resource,a.severity].some(s=>s?.toLowerCase().includes(_gq)))
      .map(a=>({grp:"Alerts",grpIcon:"🔔",type:a.severity==="error"?"Critical":"Warning",label:a.resource||"Alert",sub:a.message,page:"overview",color:a.severity==="error"?"#ef4444":"#f59e0b",icon:a.severity==="error"?"🔴":"🟡"})).slice(0,4),
    // OpenShift clusters
    ...(ocpData?.clusters||[]).filter(c=>[c.name,c.host,c.api_url].some(s=>s?.toLowerCase().includes(_gq)))
      .map(c=>({grp:"OpenShift",grpIcon:"🔴",type:"OCP Cluster",label:c.name,sub:`OpenShift · ${c.host||c.api_url||""}`,page:"openshift",color:"#ef4444",icon:"🔴"})),
    // Nutanix Prism Centrals
    ...(nutData?.pcs||[]).filter(pc=>[pc.name,pc.host].some(s=>s?.toLowerCase().includes(_gq)))
      .map(pc=>({grp:"Nutanix",grpIcon:"🟩",type:"Prism Central",label:pc.name,sub:`Nutanix AHV · ${pc.host||""}`,page:"nutanix",color:"#22c55e",icon:"🟩"})),
    // Support contacts
    ..._allPeople.filter(person=>[person.name,person.designation,person.tech,person.email].some(s=>s?.toLowerCase().includes(_gq)))
      .map(person=>({grp:"People",grpIcon:"👤",type:"Contact",label:person.name,sub:`${person.designation}${person.tech?" · "+person.tech:""}`,page:null,color:"#06b6d4",icon:"👤",email:person.email,isContact:true})),
  ];

  const cp={loading,error,onRetry:()=>load(),p};

  return(
    <>
      <style>{G(p)}</style>
      {modal&&<CreateVM onClose={()=>setModal(false)} p={p}/>}
      {vvmwareOnly={vmReqVmwareOnly}
        onClose={()=>{ setVmReqModal(false); setVmReqVmwareOnly(false); }}
        onSubmitted={()=>{ setVmReqModal(false); setVmReqVmwareOnly)}
        onSubmitted={()=>{ setVmReqModal(false); setPage("requests"); }}/>}
      {chatOpen&&<CaaSChatbot vms={vms} hosts={hosts} datastores={datastores} snapshots={snapshots}
        networks={networks} summary={summary} vcenters={vcenters} alerts={alerts}
        currentUser={currentUser} onClose={()=>setChatOpen(false)} p={p}/>}
      <div className="layout">
        <Sidebar page={page} setPage={setPage} vcenters={vcenters} selectedVC={selectedVC}
          summaries={summaries} loading={loading} error={error} alerts={alerts} clock={clock}
          currentUser={currentUser} pendingCount={pendingCount} p={p}
          ocpData={ocpData} nutData={nutData}/>
        <div className="main">
          <div className="topbar">
            <div>
              <div style={{fontWeight:700,fontSize:16}}>{navLabels[page]||page}</div>
              <div style={{fontSize:11,color:p.textMute}}>
                {lastSync?`Synced ${lastSync.toLocaleTimeString()}`:"Connecting…"}
                {" · "}Next in <M color={p.accent} size={11}>{cdwn}s</M>
              </div>
            </div>
            <div style={{display:"flex",gap:6,alignItems:"center"}}>
              {/* About LaaS Button */}
              <button onClick={()=>setAboutOpen(true)} style={{display:"flex",alignItems:"center",gap:6,padding:"5px 13px",background:`linear-gradient(135deg,${p.accent},${p.purple||"#7c3aed"})`,border:"none",borderRadius:8,cursor:"pointer",fontSize:12,fontWeight:700,color:"#fff",letterSpacing:".2px",boxShadow:`0 2px 8px ${p.accent}44`,whiteSpace:"nowrap"}}>
                <span style={{fontSize:14}}>&#9432;</span> About LaaS
              </button>
              {/* Portal Voiceover Speaker Button */}
              {'speechSynthesis' in window&&(
                <button
                  onClick={togglePortalVoice}
                  title={portalSpeaking?"Stop voiceover":"▶ Hear about LaaS Portal features (~2 min)"}
                  style={{display:"flex",alignItems:"center",justifyContent:"center",
                    width:32,height:32,borderRadius:"50%",border:"none",cursor:"pointer",
                    fontSize:16,flexShrink:0,transition:"all .2s",
                    background:portalSpeaking
                      ?"linear-gradient(135deg,#ef4444,#dc2626)"
                      :`linear-gradient(135deg,${p.accent}cc,${p.purple||"#7c3aed"})`,
                    boxShadow:portalSpeaking
                      ?"0 0 14px rgba(239,68,68,.6)"
                      :`0 0 10px ${p.accent}55`,
                    animation:portalSpeaking?"pulse 1s infinite":"none",
                  }}
                  onMouseEnter={e=>{e.currentTarget.style.transform="scale(1.15)";}}
                  onMouseLeave={e=>{e.currentTarget.style.transform="scale(1)";}}
                >{portalSpeaking?"⏹":"🔊"}</button>
              )}
              {/* Global Search Bar */}
              <div style={{position:"relative"}} ref={searchRef}>
                <div style={{display:"flex",alignItems:"center",gap:6,padding:"5px 10px",
                  background:p.panelAlt,border:`1px solid ${searchOpen||globalQ?p.accent:p.border}`,
                  borderRadius:8,width:240,transition:"all .2s",
                  boxShadow:searchOpen?`0 0 0 3px ${p.accent}20`:"none"}}>
                  <span style={{fontSize:13,color:searchOpen?p.accent:p.textMute,flexShrink:0,transition:"color .2s"}}>🔍</span>
                  <input
                    value={globalQ}
                    onChange={e=>{setGlobalQ(e.target.value);setSearchOpen(true);setSearchIdx(-1);}}
                    onFocus={()=>setSearchOpen(true)}
                    onBlur={()=>setTimeout(()=>{setSearchOpen(false);setSearchIdx(-1);},200)}
                    onKeyDown={e=>{
                      if(!searchOpen||globalResults.length===0) return;
                      if(e.key==="ArrowDown"){e.preventDefault();setSearchIdx(i=>Math.min(i+1,globalResults.length-1));}
                      else if(e.key==="ArrowUp"){e.preventDefault();setSearchIdx(i=>Math.max(i-1,-1));}
                      else if(e.key==="Enter"&&searchIdx>=0){
                        const r=globalResults[searchIdx];
                        if(r.isContact&&r.email){navigator.clipboard.writeText(r.email).catch(()=>{});}
                        else if(r.page){setPage(r.page);setSearchHL({page:r.page,term:r.label});}
                        setGlobalQ("");setSearchOpen(false);setSearchIdx(-1);
                      } else if(e.key==="Escape"){setGlobalQ("");setSearchOpen(false);setSearchIdx(-1);}
                    }}
                    placeholder="Search VMs, hosts, clusters, people…"
                    style={{background:"transparent",border:"none",padding:0,fontSize:12,width:"100%",outline:"none",color:p.text}}
                  />
                  {globalQ
                    ?<span onClick={()=>{setGlobalQ("");setSearchOpen(false);setSearchIdx(-1);}}
                        style={{cursor:"pointer",color:p.textMute,fontSize:14,flexShrink:0,lineHeight:1}}>✕</span>
                    :<span style={{fontSize:10,color:p.textMute,flexShrink:0,whiteSpace:"nowrap",letterSpacing:".2px",opacity:.6}}>⌘K</span>
                  }
                </div>
                {searchOpen&&globalQ.trim().length>=2&&(()=>{
                  const groups=[...new Set(globalResults.map(r=>r.grp))];
                  const grpIcon={Navigate:"🚀",VMware:"🖥️",Snapshots:"📸",Networks:"🌐",Alerts:"🔔",OpenShift:"🔴",Nutanix:"🟩",People:"👤"};
                  let flatIdx=0;
                  return(
                    <div style={{position:"absolute",right:0,top:"calc(100% + 6px)",width:460,
                      background:p.panel,border:`1px solid ${p.border}`,borderRadius:12,
                      boxShadow:"0 16px 48px rgba(0,0,0,.55),0 0 0 1px rgba(255,255,255,.04)",
                      zIndex:500,overflow:"hidden",animation:"fadeUp .15s ease",
                      maxHeight:"70vh",display:"flex",flexDirection:"column"}}>
                      {/* Header */}
                      <div style={{padding:"8px 14px",borderBottom:`1px solid ${p.border}`,
                        background:`linear-gradient(90deg,${p.accent}10,transparent)`,
                        display:"flex",alignItems:"center",justifyContent:"space-between",flexShrink:0}}>
                        <span style={{fontSize:11,fontWeight:700,color:p.textMute,textTransform:"uppercase",letterSpacing:".8px"}}>
                          {globalResults.length} result{globalResults.length!==1?"s":""} · ↑↓ navigate · ↵ select
                        </span>
                        <span style={{fontSize:10,color:p.textMute}}>ESC to close</span>
                      </div>
                      {/* Results */}
                      {globalResults.length===0
                        ?<div style={{padding:"24px 16px",fontSize:13,color:p.textMute,textAlign:"center"}}>
                            <div style={{fontSize:28,marginBottom:8,opacity:.3}}>🔍</div>
                            No results for <b style={{color:p.text}}>"{globalQ}"</b>
                          </div>
                        :<div style={{overflowY:"auto",flex:1}}>
                          {groups.map(grp=>{
                            const grpItems=globalResults.filter(r=>r.grp===grp);
                            return(
                              <div key={grp}>
                                {/* Group header */}
                                <div style={{padding:"5px 14px 3px",fontSize:9,fontWeight:800,
                                  textTransform:"uppercase",letterSpacing:"1px",color:p.textMute,
                                  background:p.panelAlt,borderBottom:`1px solid ${p.border}22`,
                                  display:"flex",alignItems:"center",gap:5}}>
                                  <span>{grpIcon[grp]||"📁"}</span><span>{grp}</span>
                                  <span style={{marginLeft:"auto",fontWeight:600,color:p.border}}>{grpItems.length}</span>
                                </div>
                                {grpItems.map(r=>{
                                  const idx=flatIdx++;
                                  const isActive=idx===searchIdx;
                                  return(
                                    <div key={idx}
                                      onMouseEnter={()=>setSearchIdx(idx)}
                                      onClick={()=>{
                                        if(r.isContact&&r.email){navigator.clipboard.writeText(r.email).catch(()=>{});}
                                        else if(r.page){setPage(r.page);setSearchHL({page:r.page,term:r.label});}
                                        setGlobalQ("");setSearchOpen(false);setSearchIdx(-1);
                                      }}
                                      style={{display:"flex",alignItems:"center",gap:10,padding:"8px 14px",
                                        cursor:"pointer",borderBottom:`1px solid ${p.border}18`,
                                        background:isActive?`${r.color}12`:"transparent",
                                        borderLeft:isActive?`3px solid ${r.color}`:"3px solid transparent",
                                        transition:"background .08s"}}>
                                      {/* Type icon */}
                                      <div style={{width:28,height:28,borderRadius:7,flexShrink:0,
                                        background:`${r.color}18`,border:`1px solid ${r.color}30`,
                                        display:"flex",alignItems:"center",justifyContent:"center",fontSize:13}}>
                                        {r.icon}
                                      </div>
                                      {/* Main content */}
                                      <div style={{flex:1,minWidth:0}}>
                                        <div style={{display:"flex",alignItems:"center",gap:6,marginBottom:1}}>
                                          <span style={{fontSize:12,fontWeight:700,color:isActive?r.color:p.text,
                                            overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",flex:1}}>{r.label}</span>
                                          <span style={{fontSize:9,fontWeight:700,padding:"1px 5px",borderRadius:4,
                                            background:`${r.color}20`,color:r.color,border:`1px solid ${r.color}30`,
                                            flexShrink:0,whiteSpace:"nowrap"}}>{r.type}</span>
                                        </div>
                                        {r.sub&&<div style={{fontSize:11,color:p.textMute,overflow:"hidden",summaries={summaries} 
                                          textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.sub}</div>}
                                        {r.isContact&&r.email&&(
                                          <div style={{fontSize:10,color:p.accent,marginTop:1,
                                            overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{r.email}</div>
                                        )}
                                      </div>
                                      {/* Right action hint */}
                                      <span style={{fontSize:10,color:p.textMute,flexShrink:0,opacity:.6}}>
                                        {r.isContact?"📋 copy":r.navOnly?"↵ go":"↵ view"}
                                      </span>
                                    </div>
                                  );
                                })}
                              </div>
                            );
                          })}
                        </div>
                      }
                      {/* Footer hint */}
                      <div style={{padding:"5px 14px",borderTop:`1px solid ${p.border}`,flexShrink:0,
                        background:p.panelAlt,display:"flex",alignItems:"center",gap:12,flexWrap:"wrap"}}>
                        {[{k:"↵",v:"Select"},{k:"↑↓",v:"Navigate"},{k:"ESC",v:"Close"}].map(({k,v})=>(
                          <span key={k} style={{fontSize:10,color:p.textMute,display:"flex",alignItems:"center",gap:4}}>
                            <kbd style={{padding:"1px 5px",borderRadius:4,background:p.panel,
                              border:`1px solid ${p.border}`,fontSize:9,fontWeight:700,color:p.textSub}}>{k}</kbd>
                            <span>{v}</span>
                          </span>
                        ))}
                        <span style={{marginLeft:"auto",fontSize:10,color:p.textMute}}>📋 Contact = copy email</span>
                      </div>
                    </div>
                  );
                })()}
              </div>

              <select style={{width:"auto",fontSize:12,padding:"4px 8px"}} value={refresh} onChange={e=>setRefresh(Number(e.target.value))}>
                <option value={30}>↻ 30s</option>
                <option value={60}>↻ 1m</option>
                <option value={300}>↻ 5m</option>
                <option value={600}>↻ 10m</option>
                <option value={1800}>↻ 30m</option>
                <option value={3600}>↻ 1h</option>
              </select>

              {/* Contact Us */}
              <ContactUs p={p}/>

              {/* Fix 5: AI Chatbot button */}
              <button className="btn btn-sm" onClick={()=>setChatOpen(true)}
                style={{background:`linear-gradient(135deg,${p.purple}25,${p.accent}20)`,
                  border:`1px solid ${p.purple}50`,color:p.purple,fontWeight:600,gap:5}}>
                🤖 Ask AI
              </button>

              <UserProfile user={currentUser?.username||"admin"} dark={dark} theme={theme} currentUser={currentUser} onLogout={async()=>{await logout();setCurrentUser(null);setLoggedIn(false);}} onToggleTheme={()=>setTheme(t=>t==="dark"?"light":"dark")} onSetTheme={setTheme} p={p}/>
              <button className="btn btn-ghost btn-sm" onClick={()=>load()}>↺</button>
              {currentUser?.role!=="viewer"&&<button className="btn btn-primary btn-sm" onClick={()=>setVmReqModal(true)}>＋ Request VM</button>}
            </div>
          </div>
          {vcenters.length>0&&page==="vms"&&<VCenterBar vcenters={vcenters} selected={selectedVC} onSelect={handleVCSelect} summaries={summaries}/>}

          {/* Notification bar: static system alerts + slow-scrolling info ticker */}
          {(()=>{
            const infoParts  = manualNotifs.length>0 ? manualNotifs.map(n=>n.text) : ["✅ All systems normal"];
            return(
              <div style={{display:"flex",alignItems:"center",flexShrink:0,minHeight:36,
                background:p.bg,borderBottom:`1px solid ${p.border}`,overflow:"hidden",position:"relative"}}>
                {/* Scrolling ticker only — no alert chips */}
                <div style={{flex:1,overflow:"hidden",height:36,display:"flex",alignItems:"center",minWidth:120}}>
                  <div style={{display:"inline-block",animation:"ticker 90s linear infinite",whiteSpace:"nowrap",paddingLeft:"100%"}}>
                    {[...infoParts,...infoParts].map((t,i)=>(
                      <span key={i} style={{marginRight:120,fontSize:13,fontWeight:500,color:manualNotifs.length>0?p.cyan:p.textMute}}>
                        <span style={{marginRight:10,fontSize:10,color:manualNotifs.length>0?p.cyan:p.green}}>◆</span>
                        {manualNotifs.length>0?"📢 ":""}{t}
                      </span>
                    ))}
                  </div>
                </div>
                {currentUser?.role==="admin"&&(
                  <button onClick={()=>setNotifEditorOpen(o=>!o)}
                    title="Manage Notifications"
                    style={{flexShrink:0,padding:"3px 10px",background:notifEditorOpen?`${p.cyan}25`:`${p.panelAlt}`,
                      border:`1px solid ${notifEditorOpen?p.cyan:p.border}`,borderRadius:5,
                      cursor:"pointer",fontSize:10,color:notifEditorOpen?p.cyan:p.textMute,
                      marginRight:6,whiteSpace:"nowrap",fontWeight:600}}>
                    📢 {manualNotifs.length>0?manualNotifs.length+" active":"Notify"}
                  </button>
                )}
              </div>
            );
          })()}
          {notifEditorOpen&&currentUser?.role==="admin"&&(
            <NotifEditor notifs={manualNotifs} onSave={async ns=>{
              setManualNotifs(ns);
              try{ await saveNotifications(ns); }catch(e){ console.error("Failed to save notifications",e); }
              setNotifEditorOpen(false);
            }} onClose={()=>setNotifEditorOpen(false)} p={p}/>
          )}
          {aboutOpen&&<AboutCaaSModal onClose={()=>setAboutOpen(false)} p={p}/>}

          <div className="content">{ setVmReqVmwareOnly(true); setVmReqModal(true); }
            {page==="overview"  &&<Overview summary={summary} hosts={hosts} alerts={alerts} summaries={summaries} vcenters={vcenters} selectedVC={selectedVC} onCreateVM={()=>setVmReqModal(true)} onNavigate={setPage} ocpData={ocpData} nutData={nutData} {...cp}/>}
            {page==="vms"       &&<VMwarePage vms={vms} snapshots={snapshots} vcenters={vcenters} selectedVC={selectedVC} summaries={summaries} hosts={hosts} datastores={datastores} currentUser={currentUser} onCreateVM={()=>setVmReqModal(true)} onOpenModal={()=>setModal(true)} onRefresh={load} initSearch={searchHL?.page==="vms"?searchHL.term:""} {...cp}/>}
            {page==="openshift" &&<PageErrorBoundary page="Red Hat OpenShift"><Suspense fallback={<div style={{padding:48,textAlign:"center",color:"#64748b",fontSize:14}}>⏳ Loading OpenShift…</div>}><OpenShiftPage currentUser={currentUser} p={p}/></Suspense></PageErrorBoundary>}
            {page==="nutanix"   &&<PageErrorBoundary page="Nutanix"><Suspense fallback={<div style={{padding:48,textAlign:"center",color:"#64748b",fontSize:14}}>⏳ Loading Nutanix…</div>}><NutanixPage currentUser={currentUser} p={p}/></Suspense></PageErrorBoundary>}
            {page==="ansible"   &&<PageErrorBoundary page="Ansible AAP"><Suspense fallback={<div style={{padding:48,textAlign:"center",color:"#64748b",fontSize:14}}>⏳ Loading Ansible AAP…</div>}><AnsiblePage currentUser={currentUser} p={p}/></Suspense></PageErrorBoundary>}
            {page==="storage"   &&<PageErrorBoundary page="Storage"><StoragePage currentUser={currentUser} p={p}/></PageErrorBoundary>}
            {page==="backup"    &&<PageErrorBoundary page="Backup"><BackupPage  currentUser={currentUser} p={p}/></PageErrorBoundary>}
            {page==="project_utilization" &&<PageErrorBoundary page="Project Utilization"><ProjectUtilizationPage selectedVC={selectedVC} currentUser={currentUser} p={p}/></PageErrorBoundary>}
            {page==="capacity"  &&<CapacityPage hosts={hosts} datastores={datastores} vcenters={vcenters} selectedVC={selectedVC} currentUser={currentUser} onRefresh={load} ocpData={ocpData} nutData={nutData} initSearch={searchHL?.page==="capacity"?searchHL.term:""} {...cp}/>}
            {page==="chargeback" &&<ChargebackPage currentUser={currentUser} p={p}/>}
            {page==="snapshots" &&<SnapshotsPage snapshots={snapshots} vcenters={vcenters} onRefresh={load} initSearch={searchHL?.page==="snapshots"?searchHL.term:""} {...cp}/>}
            {page==="networks"  &&<NetworksPage networks={networks} vcenters={vcenters} initSearch={searchHL?.page==="networks"?searchHL.term:""} {...cp}/>}
            {page==="ipam"      &&<IPAMPage currentUser={currentUser} p={p}/>}
            {page==="assets"    &&<AssetManagementPage currentUser={currentUser} p={p}/>}
            {page==="requests"  &&<RequestsPage currentUser={currentUser} vcenters={vcenters} p={p}/>}
            {page==="addns"     &&<ADDNSPage currentUser={currentUser} p={p}/>}
            {page==="audit"     &&<AuditPage currentUser={currentUser} p={p}/>}
            {page==="users"     &&<UsersPage currentUser={currentUser} p={p}/>}
          </div>
        </div>
      </div>
    </>
  );
}
