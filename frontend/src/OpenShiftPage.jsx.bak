import { useState, useEffect, useCallback, useRef } from "react";
import {
  fetchOCPClusters, createOCPCluster, updateOCPCluster, deleteOCPCluster,
  testOCPCluster, fetchOCPOverview, fetchOCPLiveNodes, fetchOCPPods,
  fetchOCPNamespaces, fetchOCPOperators, fetchOCPEvents, ocpNodeAction,
  fetchOCPPodDetail, fetchOCPNamespaceDetail, fetchOCPPodLogs,
  fetchOCPStorageClasses, fetchOCPRoutes,
  fetchOCPPVs, fetchOCPPVCs,
  fetchOCPDescribeSC, fetchOCPDescribePV, fetchOCPDescribePVC,
  fetchOCPPVEvents, fetchOCPPVCEvents,
  deleteOCPSC, deleteOCPPV, deleteOCPPVC, createOCPPVC,
  fetchOCPDeployments, fetchOCPDeploymentConfigs, fetchOCPStatefulSets,
  fetchOCPDaemonSets, fetchOCPReplicaSets, fetchOCPSecrets, fetchOCPConfigMaps,
  fetchOCPWorkloadDescribe, deleteOCPWorkload, fetchOCPWorkloadLogs,
  createOCPVMRequest, fetchOCPVMRequests, fetchOCPVMRequest, reviewOCPVMRequest,
} from "./api";

// --- RED HAT OPENSHIFT PAGE ---------------------------------------------------
function LoadState({msg}){ return <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:48,gap:14}}><div className="spinner"/><span style={{fontSize:13,color:"#475569"}}>{msg||"Loading…"}</span></div>; }
function ErrState({msg,onRetry}){ return <div style={{display:"flex",flexDirection:"column",alignItems:"center",justifyContent:"center",padding:40,gap:12}}><div style={{fontSize:36}}>??</div><div style={{fontWeight:600,color:"#ef4444"}}>Connection Error</div><div style={{fontSize:13,color:"#475569",textAlign:"center",maxWidth:340}}>{msg}</div><button className="btn btn-danger" onClick={onRetry}>? Retry</button></div>; }
function _ocpAge(iso){
  if(!iso) return "—";
  const d=Math.floor((Date.now()-new Date(iso))/864e5);
  if(d<1) return "<1d"; if(d<30) return `${d}d`;
  return `${Math.floor(d/30)}mo`;
}
function _ocpMem(gi){ return gi>0?`${gi} GiB`:"—"; }
function OcpBar({pct,color}){
  const c=pct>85?"#ef4444":pct>60?"#f59e0b":"#10b981";
  return(<div style={{display:"flex",alignItems:"center",gap:5}}>
    <div style={{width:70,height:6,borderRadius:4,background:"#1e293b",overflow:"hidden",flexShrink:0}}>
      <div style={{width:`${Math.min(100,pct||0)}%`,height:"100%",background:color||c,borderRadius:4}}/>
    </div>
    <span style={{fontSize:11,color:color||c,fontWeight:600,minWidth:32}}>{pct||0}%</span>
  </div>);
}
function OcpHealthBadge({health}){
  const map={Available:{bg:"#10b98118",color:"#10b981"},Degraded:{bg:"#ef444418",color:"#ef4444"},
    Unavailable:{bg:"#ef444418",color:"#ef4444"},Progressing:{bg:"#f59e0b18",color:"#f59e0b"},
    Unknown:{bg:"#64748b18",color:"#64748b"},NotReady:{bg:"#ef444418",color:"#ef4444"},
    Ready:{bg:"#10b98118",color:"#10b981"},connected:{bg:"#10b98118",color:"#10b981"},
    error:{bg:"#ef444418",color:"#ef4444"},unknown:{bg:"#64748b18",color:"#64748b"}};
  const s=map[health]||map["Unknown"];
  return <span style={{fontSize:11,fontWeight:700,padding:"2px 8px",borderRadius:5,background:s.bg,color:s.color}}>{health||"—"}</span>;
}

export default function OpenShiftPage({currentUser,p}){
  const role=currentUser?.role||"viewer";
  const canAct=role==="admin"||role==="operator";
  const isAdmin=role==="admin";

  const [clusters,setClusters]=useState([]);
  const [selCluster,setSelCluster]=useState(null);
  const [tab,setTab]=useState("overview");
  const [loading,setLoading]=useState(true);
  const [tabLoading,setTabLoading]=useState(false);
  const [err,setErr]=useState(null);
  const [tabErr,setTabErr]=useState(null);

  // Tab data
  const [overview,setOverview]=useState(null);
  const [nodes,setNodes]=useState([]);
  const [pods,setPods]=useState([]);
  const [namespaces,setNamespaces]=useState([]);
  const [operators,setOperators]=useState([]);
  const [events,setEvents]=useState([]);

  // Filters
  const [podNs,setPodNs]=useState("");
  const [podQ,setPodQ]=useState("");
  const [nsQ,setNsQ]=useState("");
  const [nodeQ,setNodeQ]=useState("");
  const [evtTypeFilter,setEvtTypeFilter]=useState("all");

  // Node action state
  const [nodeActState,setNodeActState]=useState({});
  const [nodeActMsg,setNodeActMsg]=useState(null);

  // Add cluster modal
  const [showAdd,setShowAdd]=useState(false);
  const [addForm,setAddForm]=useState({name:"",api_url:"",username:"",password:"",console_url:"",ai_url:"",description:""});
  const [addBusy,setAddBusy]=useState(false);
  const [addErr,setAddErr]=useState(null);

  // Edit cluster modal
  const [showEdit,setShowEdit]=useState(false);
  const [editForm,setEditForm]=useState({});
  const [editBusy,setEditBusy]=useState(false);
  const [editErr,setEditErr]=useState(null);

  // Test connection
  const [testBusy,setTestBusy]=useState(false);
  const [testResult,setTestResult]=useState(null);

  // Detail modals
  const [selPod,setSelPod]=useState(null);
  const [selNsDetail,setSelNsDetail]=useState(null);
  const [copiedId,setCopiedId]=useState(false);

  // Export all
  const [exportAllBusy,setExportAllBusy]=useState(false);

  // Rich detail modal state (fetched from backend)
  const [podDetail,setPodDetail]=useState(null);
  const [podDetailLoading,setPodDetailLoading]=useState(false);
  const [nsDetail,setNsDetail]=useState(null);
  const [nsDetailLoading,setNsDetailLoading]=useState(false);

  // Pod modal tabs & logs
  const [podModalTab,setPodModalTab]=useState("detail");
  const [podLogs,setPodLogs]=useState(null);
  const [podLogsLoading,setPodLogsLoading]=useState(false);
  const [podLogsContainer,setPodLogsContainer]=useState("");

  // Storage classes
  const [storageClasses,setStorageClasses]=useState([]);
  // Storage sub-tab & PVs/PVCs
  const [storageSubTab,setStorageSubTab]=useState("sc"); // sc | pv | pvc
  const [pvs,setPvs]=useState([]);
  const [pvcs,setPvcs]=useState([]);
  const [pvQ,setPvQ]=useState("");
  const [pvcQ,setPvcQ]=useState("");
  const [pvcNsFilter,setPvcNsFilter]=useState("all");
  // Storage describe modal
  const [storeDesc,setStoreDesc]=useState(null); // {title, data}
  const [storeDescLoading,setStoreDescLoading]=useState(false);
  // Storage events modal
  const [storeEvts,setStoreEvts]=useState(null); // {title, events:[]}
  const [storeEvtsLoading,setStoreEvtsLoading]=useState(false);
  // Storage delete confirm
  const [storeDelTarget,setStoreDelTarget]=useState(null); // {type,name,namespace}
  const [storeDelBusy,setStoreDelBusy]=useState(false);
  const [storeDelErr,setStoreDelErr]=useState(null);
  // Create PVC modal
  const [showCreatePVC,setShowCreatePVC]=useState(false);
  const [createPVCForm,setCreatePVCForm]=useState({name:"",namespace:"default",storage:"1Gi",access_mode:"ReadWriteOnce",storage_class:"",volume_mode:"Filesystem"});
  const [createPVCBusy,setCreatePVCBusy]=useState(false);
  const [createPVCErr,setCreatePVCErr]=useState(null);

  // Workloads tab
  const [wlSubTab,setWlSubTab]=useState("deployments");
  const [wlData,setWlData]=useState({deployments:[],deploymentconfigs:[],statefulsets:[],daemonsets:[],replicasets:[],secrets:[],configmaps:[],pods:[]});
  const [wlLoading,setWlLoading]=useState(false);
  const [wlNsFilter,setWlNsFilter]=useState("all");
  const [wlQ,setWlQ]=useState("");
  const [wlDesc,setWlDesc]=useState(null);           // {title,data}
  const [wlDescLoading,setWlDescLoading]=useState(false);
  const [wlLogs,setWlLogs]=useState(null);           // {title,pod,containers,logs}
  const [wlLogsLoading,setWlLogsLoading]=useState(false);
  const [wlLogsContainer,setWlLogsContainer]=useState("");
  const [wlDelTarget,setWlDelTarget]=useState(null); // {kind,namespace,name}
  const [wlDelBusy,setWlDelBusy]=useState(false);
  const [wlDelErr,setWlDelErr]=useState(null);

  // Applications (Routes)
  const [routes,setRoutes]=useState([]);
  const [routeQ,setRouteQ]=useState("");
  const [routeNsF,setRouteNsF]=useState("all");

  // Topology
  const [topoData,setTopoData]=useState(null);
  const [topoExpandNode,setTopoExpandNode]=useState({});

  // -- OCP VM Request Wizard --
  const OCP_OS_TEMPLATES=[
    {id:"rhel9",   label:"RHEL 9",              color:"#ee0000",icon:"??",desc:"Red Hat Enterprise Linux 9",cpu_cores:2,memory_gi:4,boot:"30Gi"},
    {id:"rhel8",   label:"RHEL 8",              color:"#cc0000",icon:"??",desc:"Red Hat Enterprise Linux 8",cpu_cores:2,memory_gi:4,boot:"20Gi"},
    {id:"rhel7",   label:"RHEL 7",              color:"#aa0000",icon:"??",desc:"Red Hat Enterprise Linux 7",cpu_cores:2,memory_gi:4,boot:"20Gi"},
    {id:"win2k22", label:"Windows Server 2022", color:"#0078d4",icon:"??",desc:"Windows Server 2022 Datacenter",cpu_cores:4,memory_gi:8,boot:"60Gi"},
    {id:"win2k19", label:"Windows Server 2019", color:"#005a9e",icon:"??",desc:"Windows Server 2019 Datacenter",cpu_cores:4,memory_gi:8,boot:"60Gi"},
    {id:"win10",   label:"Windows 10",          color:"#0067b8",icon:"??",desc:"Windows 10 Enterprise",cpu_cores:2,memory_gi:4,boot:"40Gi"},
    {id:"centos9", label:"CentOS Stream 9",     color:"#262577",icon:"??",desc:"CentOS Stream 9",cpu_cores:2,memory_gi:4,boot:"20Gi"},
    {id:"ubuntu22",label:"Ubuntu 22.04 LTS",    color:"#e95420",icon:"??",desc:"Canonical Ubuntu 22.04 LTS",cpu_cores:2,memory_gi:4,boot:"20Gi"},
    {id:"fedora",  label:"Fedora",              color:"#51a2da",icon:"??",desc:"Fedora Latest",cpu_cores:2,memory_gi:2,boot:"15Gi"},
    {id:"custom",  label:"Custom",              color:"#64748b",icon:"??",desc:"Custom / Blank disk configuration",cpu_cores:2,memory_gi:4,boot:"20Gi"},
  ];
  const OCP_DISK_SIZES=["5Gi","10Gi","15Gi","20Gi","30Gi","40Gi","50Gi","60Gi","80Gi","100Gi","150Gi","200Gi","500Gi","1Ti"];
  const OCP_MEM_OPTIONS=[1,2,4,8,16,32,64,128];
  const OCP_DEFAULTS={cluster_id:null,cluster_name:"",namespace:"default",vm_name:"",description:"",
    os_template:"rhel9",cpu_sockets:1,cpu_cores:2,cpu_threads:1,memory_gi:4,
    boot_disk_size:"30Gi",boot_disk_sc:"",boot_disk_interface:"virtio",
    additional_disks:[],network_type:"masquerade",network_interface:"virtio",
    network_name:"Pod Networking",cloud_init_enabled:true,ssh_public_key:"",
    root_password:"",start_on_create:true,notes:""};
  const _vmNameClean=(v)=>v.split("").filter(c=>"abcdefghijklmnopqrstuvwxyz0123456789-".includes(c)).join("");
  const [showVMReq,setShowVMReq]=useState(false);
  const [vmReqStep,setVmReqStep]=useState(0);
  const [vmReqForm,setVmReqForm]=useState({...OCP_DEFAULTS});
  const [vmReqBusy,setVmReqBusy]=useState(false);
  const [vmReqErr,setVmReqErr]=useState(null);
  const [vmReqNs,setVmReqNs]=useState([]);
  const [vmReqScs,setVmReqScs]=useState([]);
  const [vmReqNsLoading,setVmReqNsLoading]=useState(false);
  // Admin VM requests queue
  const [showVMRequests,setShowVMRequests]=useState(false);
  const [vmRequests,setVmRequests]=useState([]);
  const [vmReqsLoading,setVmReqsLoading]=useState(false);
  const [vmReqReviewTarget,setVmReqReviewTarget]=useState(null);
  const [vmReqReviewForm,setVmReqReviewForm]=useState({decision:"approved",review_notes:""});
  const [vmReqReviewBusy,setVmReqReviewBusy]=useState(false);
  const [vmReqPendingCount,setVmReqPendingCount]=useState(0);

  async function loadVMRequests(){
    setVmReqsLoading(true);
    try{ const list=await fetchOCPVMRequests(); setVmRequests(list||[]); setVmReqPendingCount((list||[]).filter(r=>r.status==="pending").length); }catch{}
    setVmReqsLoading(false);
  }

  async function loadWizardClusterData(clusterId){
    setVmReqNsLoading(true);
    try{
      const [ns,scs]=await Promise.all([fetchOCPNamespaces(clusterId),fetchOCPStorageClasses(clusterId)]);
      setVmReqNs(ns||[]);
      setVmReqScs(scs||[]);
      setVmReqForm(f=>({...f,namespace:(ns&&ns.length>0?ns[0].name:"default"),boot_disk_sc:(scs&&scs.length>0?scs.find(s=>s.is_default)?.name||scs[0].name:"")}));
    }catch{ setVmReqNs([]); setVmReqScs([]); }
    setVmReqNsLoading(false);
  }

  async function submitVMRequest(){
    if(!vmReqForm.vm_name.trim()){ setVmReqErr("VM name is required"); return; }
    setVmReqBusy(true); setVmReqErr(null);
    try{
      await createOCPVMRequest(vmReqForm);
      setShowVMReq(false);
      setVmReqStep(0);
      setVmReqForm({...OCP_DEFAULTS});
      if(isAdmin||role==="operator") loadVMRequests();
    }catch(e){ setVmReqErr(e.message); }
    setVmReqBusy(false);
  }

  async function doReviewVMReq(){
    if(!vmReqReviewTarget) return;
    setVmReqReviewBusy(true);
    try{
      await reviewOCPVMRequest(vmReqReviewTarget.id,vmReqReviewForm);
      setVmReqReviewTarget(null);
      loadVMRequests();
    }catch(e){ alert(e.message); }
    setVmReqReviewBusy(false);
  }

  async function loadClusters(){
    setLoading(true); setErr(null);
    try{
      const list=await fetchOCPClusters();
      setClusters(list||[]);
      if(!selCluster && list?.length>0){
        setSelCluster(list[0]);
      } else if(selCluster){
        const fresh=list?.find(c=>c.id===selCluster.id);
        if(fresh) setSelCluster(fresh);
      }
    }catch(e){ setErr(e.message); }
    setLoading(false);
  }

  useEffect(()=>{ loadClusters(); loadVMRequests(); },[]);

  useEffect(()=>{
    if(selCluster) loadTab(tab);
  },[selCluster,tab]);

  async function loadTab(t){
    if(!selCluster) return;
    setTabLoading(true); setTabErr(null);
    try{
      if(t==="overview")    setOverview(await fetchOCPOverview(selCluster.id));
      else if(t==="nodes")  setNodes(await fetchOCPLiveNodes(selCluster.id));
      else if(t==="pods")   setPods(await fetchOCPPods(selCluster.id,""));
      else if(t==="ns")     setNamespaces(await fetchOCPNamespaces(selCluster.id));
      else if(t==="ops")    setOperators(await fetchOCPOperators(selCluster.id));
      else if(t==="events") setEvents(await fetchOCPEvents(selCluster.id));
      else if(t==="storage"){
        const [sc,pv_,pvc_,ns_]=await Promise.all([
          fetchOCPStorageClasses(selCluster.id),
          fetchOCPPVs(selCluster.id),
          fetchOCPPVCs(selCluster.id),
          fetchOCPNamespaces(selCluster.id),
        ]);
        setStorageClasses(sc||[]);
        setPvs(pv_||[]);
        setPvcs(pvc_||[]);
        setNamespaces(ns_||[]);
      }
      else if(t==="apps")    setRoutes(await fetchOCPRoutes(selCluster.id));
      else if(t==="workloads"){
        setWlLoading(true);
        const [dep,dc,ss,ds,rs,sec,cm,pd]=await Promise.all([
          fetchOCPDeployments(selCluster.id),
          fetchOCPDeploymentConfigs(selCluster.id),
          fetchOCPStatefulSets(selCluster.id),
          fetchOCPDaemonSets(selCluster.id),
          fetchOCPReplicaSets(selCluster.id),
          fetchOCPSecrets(selCluster.id),
          fetchOCPConfigMaps(selCluster.id),
          fetchOCPPods(selCluster.id,""),
        ]);
        setWlData({
          deployments:dep||[], deploymentconfigs:dc||[],
          statefulsets:ss||[], daemonsets:ds||[],
          replicasets:rs||[], secrets:sec||[],
          configmaps:cm||[], pods:pd||[],
        });
        setWlLoading(false);
      }
      else if(t==="topology"){
        const [tn,tp,tns,top,tov,tr,sc,pv_,pvc_,dep,dc,ss,ds,rs,sec,cm,evts]=await Promise.all([
          fetchOCPLiveNodes(selCluster.id),
          fetchOCPPods(selCluster.id,""),
          fetchOCPNamespaces(selCluster.id),
          fetchOCPOperators(selCluster.id),
          fetchOCPOverview(selCluster.id),
          fetchOCPRoutes(selCluster.id),
          fetchOCPStorageClasses(selCluster.id),
          fetchOCPPVs(selCluster.id),
          fetchOCPPVCs(selCluster.id),
          fetchOCPDeployments(selCluster.id),
          fetchOCPDeploymentConfigs(selCluster.id),
          fetchOCPStatefulSets(selCluster.id),
          fetchOCPDaemonSets(selCluster.id),
          fetchOCPReplicaSets(selCluster.id),
          fetchOCPSecrets(selCluster.id),
          fetchOCPConfigMaps(selCluster.id),
          fetchOCPEvents(selCluster.id),
        ]);
        setTopoData({
          nodes:tn||[],pods:tp||[],namespaces:tns||[],operators:top||[],overview:tov||{},
          routes:tr||[],storageClasses:sc||[],pvs:pv_||[],pvcs:pvc_||[],
          workloads:{deployments:dep||[],deploymentconfigs:dc||[],statefulsets:ss||[],
                     daemonsets:ds||[],replicasets:rs||[],secrets:sec||[],configmaps:cm||[]},
          events:evts||[],
        });
      }
    }catch(e){ setTabErr(e.message); }
    setTabLoading(false);
  }

  async function doTest(){
    if(!selCluster) return;
    setTestBusy(true); setTestResult(null);
    try{
      const r=await testOCPCluster(selCluster.id);
      setTestResult(r);
      loadClusters();
    }catch(e){ setTestResult({reachable:false,message:e.message}); }
    setTestBusy(false);
  }

  async function doNodeAction(nodeName,action){
    if(!selCluster) return;
    setNodeActState(s=>({...s,[nodeName]:{status:"loading",action}}));
    setNodeActMsg(null);
    try{
      const r=await ocpNodeAction(selCluster.id,nodeName,action);
      setNodeActState(s=>({...s,[nodeName]:{status:"ok",action}}));
      setNodeActMsg({ok:true,text:r.message});
      setTimeout(()=>{ setNodeActMsg(null); loadTab("nodes"); },3000);
    }catch(e){
      setNodeActState(s=>({...s,[nodeName]:{status:"err",action}}));
      setNodeActMsg({ok:false,text:e.message});
    }
  }

  async function doAddCluster(){
    if(!addForm.name||!addForm.api_url||!addForm.username||!addForm.password){
      setAddErr("Name, API URL, username and password are required"); return;
    }
    setAddBusy(true); setAddErr(null);
    try{
      await createOCPCluster(addForm);
      setShowAdd(false);
      setAddForm({name:"",api_url:"",username:"",password:"",console_url:"",ai_url:"",description:""});
      await loadClusters();
    }catch(e){ setAddErr(e.message); }
    setAddBusy(false);
  }

  async function doDelCluster(c){
    if(!window.confirm(`Delete cluster '${c.name}'? This cannot be undone.`)) return;
    try{ await deleteOCPCluster(c.id); await loadClusters(); if(selCluster?.id===c.id) setSelCluster(null); }
    catch(e){ alert(e.message); }
  }

  async function doEditCluster(){
    if(!editForm.name||!editForm.api_url){ setEditErr("Name and API URL are required."); return; }
    setEditBusy(true); setEditErr(null);
    try{
      // exclude empty password so existing credential is preserved
      const payload={...editForm};
      if(!payload.password) delete payload.password;
      await updateOCPCluster(selCluster.id, payload);
      setShowEdit(false);
      await loadClusters();
    }catch(e){ setEditErr(e.message); }
    setEditBusy(false);
  }

  if(loading) return <LoadState msg="Loading OpenShift clusters…"/>;

  /* -- Export helpers -- */
  async function exportAllClustersPDF(){
    if(!clusters.length) return;
    setExportAllBusy(true);
    try{
      // fetch overview for every cluster in parallel
      const results=await Promise.all(
        clusters.map(c=>fetchOCPOverview(c.id).then(ov=>({cluster:c,ov:ov||{}})).catch(()=>({cluster:c,ov:{}})))
      );
      const exported=new Date().toLocaleString();
      function statusDot(s){ const c=s==="connected"?"#10b981":s==="error"?"#ef4444":"#94a3b8"; return `<span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:${c};margin-right:5px"></span>`; }
      function kpi(label,val,color){ return `<div class="kpi"><div class="kv" style="color:${color||'#1e293b'}">${val}</div><div class="kl">${label}</div></div>`; }
      function clusterBlock({cluster:c,ov}){
        const v=ov.version||{};
        const ns=ov.nodes_summary||{total:0,ready:0,not_ready:0};
        const ps=ov.pods_summary||{total:0,running:0,failed:0,pending:0};
        const os=ov.operators_summary||{total:0,available:0,degraded:0};
        const warns=ov.warnings??0;
        const stColor=c.status==="connected"?"#10b981":c.status==="error"?"#ef4444":"#94a3b8";
        return `<div class="cluster-block">
          <div class="cluster-title">
            <div style="display:flex;align-items:center;gap:10">
              <div style="width:12px;height:12px;border-radius:50%;background:${stColor};flex-shrink:0"></div>
              <div>
                <div style="font-size:17px;font-weight:800;color:#1e293b">${c.name}</div>
                <div style="font-size:11px;color:#64748b;margin-top:2px">${c.api_url||""}</div>
              </div>
            </div>
            <span style="font-size:11px;font-weight:700;padding:3px 10px;border-radius:5px;background:${stColor}18;color:${stColor}">${c.status||"unknown"}</span>
          </div>
          <div class="meta-grid">
            ${v.version?`<div class="meta-item"><div class="ml">OCP Version</div><div class="mv" style="color:#0ea5e9">${v.version}</div></div>`:""}
            ${v.channel?`<div class="meta-item"><div class="ml">Channel</div><div class="mv" style="color:#f59e0b">${v.channel}</div></div>`:""}
            ${v.cluster_id?`<div class="meta-item" style="grid-column:1/-1"><div class="ml">Cluster ID</div><div class="mv" style="font-family:monospace;font-size:12px">${v.cluster_id}</div></div>`:""}
            ${c.console_url?`<div class="meta-item" style="grid-column:1/-1"><div class="ml">Console URL</div><div class="mv"><a href="${c.console_url}" style="color:#3b82f6">${c.console_url}</a></div></div>`:""}
            ${c.description?`<div class="meta-item" style="grid-column:1/-1"><div class="ml">Description</div><div class="mv">${c.description}</div></div>`:""}
          </div>
          <div class="kpi-row">
            ${kpi("Nodes (Ready)",`${ns.ready}/${ns.total}`,ns.not_ready>0?"#ef4444":"#10b981")}
            ${kpi("Pods Running",`${ps.running}/${ps.total}`,ps.failed>0?"#ef4444":"#10b981")}
            ${kpi("Pods Failed",ps.failed,ps.failed>0?"#ef4444":"#64748b")}
            ${kpi("Pods Pending",ps.pending,ps.pending>0?"#f59e0b":"#64748b")}
            ${kpi("Operators",`${os.available}/${os.total}`,os.degraded>0?"#ef4444":"#10b981")}
            ${kpi("Degraded Ops",os.degraded,os.degraded>0?"#ef4444":"#64748b")}
            ${kpi("Warnings",warns,warns>0?"#f59e0b":"#64748b")}
          </div>
        </div>`;
      }
      const html=`<!DOCTYPE html><html><head><meta charset="utf-8"/>
<title>OpenShift Clusters Report</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Segoe UI',Arial,sans-serif;background:#f8fafc;color:#1e293b;padding:28px}
  h1{font-size:22px;font-weight:800;margin-bottom:4px}
  p.sub{font-size:12px;color:#64748b;margin-bottom:24px}
  .print-btn{margin-bottom:24px;padding:8px 18px;background:#ee0000;color:#fff;border:none;border-radius:7px;font-size:13px;cursor:pointer;font-weight:600}
  .cluster-block{background:#fff;border:1.5px solid #e2e8f0;border-radius:12px;padding:20px 22px;margin-bottom:24px;page-break-inside:avoid}
  .cluster-title{display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:8px;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid #f1f5f9}
  .meta-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px;margin-bottom:14px}
  .meta-item{background:#f8fafc;border:1px solid #e2e8f0;border-radius:7px;padding:8px 12px}
  .ml{font-size:10px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px}
  .mv{font-size:13px;font-weight:600;word-break:break-all}
  .kpi-row{display:flex;flex-wrap:wrap;gap:10}
  .kpi{background:#f8fafc;border:1px solid #e2e8f0;border-radius:7px;padding:10px 14px;min-width:90px;text-align:center}
  .kv{font-size:22px;font-weight:800;line-height:1}
  .kl{font-size:10px;color:#64748b;margin-top:4px}
  @media print{.print-btn{display:none}}
</style></head>
<body>
  <button class="print-btn" onclick="window.print()">??? Print / Save as PDF</button>
  <h1>?? OpenShift Clusters Report</h1>
  <p class="sub">${results.length} cluster${results.length!==1?"s":""} &nbsp;|&nbsp; Generated: ${exported}</p>
  ${results.map(clusterBlock).join("")}
</body></html>`;
      const w=window.open("","_blank"); w.document.write(html); w.document.close();
    }catch(e){ alert("Export failed: "+e.message); }
    setExportAllBusy(false);
  }
  function _csvBlob(rows){
    const csv=rows.map(r=>r.map(v=>`"${String(v==null?"":v).replace(/"/g,'""')}"`).join(",")).join("\r\n");
    return URL.createObjectURL(new Blob([csv],{type:"text/csv"}));
  }
  function _dlCSV(url,name){ const a=document.createElement("a"); a.href=url; a.download=name; a.click(); }
  function _openPDF(title,cluster,bodyRows){
    const trs=bodyRows.map(([k,v])=>`<tr><td>${k}</td><td>${String(v==null?"—":v)}</td></tr>`).join("");
    const html=`<!DOCTYPE html><html><head><meta charset="utf-8"/><title>${title}</title>
<style>body{font-family:Arial,sans-serif;padding:24px;color:#111}h2{margin-bottom:4px}p{font-size:12px;color:#555;margin-bottom:16px}
table{border-collapse:collapse;width:100%}td,th{border:1px solid #ddd;padding:8px 12px;font-size:13px;text-align:left}
th{background:#f4f4f4;font-weight:700;width:200px}@media print{.nobtn{display:none}}</style></head>
<body><button class="nobtn" onclick="window.print()" style="margin-bottom:16px;padding:6px 14px;cursor:pointer">??? Print / Save as PDF</button>
<h2>${title}</h2><p>Cluster: ${selCluster?.name||"—"} &nbsp;|&nbsp; Exported: ${new Date().toLocaleString()}</p>
<table><thead><tr><th>Field</th><th>Value</th></tr></thead><tbody>${trs}</tbody></table></body></html>`;
    const w=window.open("","_blank"); w.document.write(html); w.document.close();
  }
  function exportPodCSV(pod){
    _dlCSV(_csvBlob([["Field","Value"],["Name",pod.name],["Namespace",pod.namespace],["Phase",pod.phase],
      ["Ready",pod.ready],["Restarts",pod.restarts],["Node",pod.node||""],["Pod IP",pod.pod_ip||""],
      ["Host IP",pod.host_ip||""],["QoS Class",pod.qos_class||""],["Start Time",pod.start_time||""]]),`pod-${pod.name}.csv`);
  }
  function exportPodPDF(pod){
    _openPDF(`Pod: ${pod.name}`,selCluster,[["Name",pod.name],["Namespace",pod.namespace],["Phase",pod.phase],
      ["Ready",pod.ready],["Restarts",pod.restarts],["Node",pod.node||"—"],["Pod IP",pod.pod_ip||"—"],
      ["Host IP",pod.host_ip||"—"],["QoS Class",pod.qos_class||"—"],["Start Time",pod.start_time||"—"]]);
  }
  function exportNsCSV(ns){
    _dlCSV(_csvBlob([["Field","Value"],["Name",ns.name],["Display Name",ns.display_name||ns.name],
      ["Phase",ns.phase||"Active"],["Requester",ns.requester||""],["Description",ns.description||""],["Created At",ns.created_at||""]]),`namespace-${ns.name}.csv`);
  }
  function exportNsPDF(ns){
    _openPDF(`Namespace: ${ns.name}`,selCluster,[["Name",ns.name],["Display Name",ns.display_name||ns.name],
      ["Phase",ns.phase||"Active"],["Requester",ns.requester||"—"],["Description",ns.description||"—"],["Created At",ns.created_at||"—"]]);
  }

  /* -- Open Full Topology Page in new tab -- */
  function openTopologyPage(){
    if(!topoData||!selCluster) return;
    const {nodes:tnodes,pods:tpods,namespaces:tns,operators:tops,overview:tov,
           routes:troutes=[],storageClasses:tscs=[],pvs:tpvs=[],pvcs:tpvcs=[],
           workloads:twl={},events:tevts=[]}=topoData;
    const exported=new Date().toLocaleString();
    const clName=selCluster.name||"—";
    const clAPI=selCluster.api_url||"—";
    const clConsole=selCluster.console_url||"";
    const version=tov?.version?.version||""; const channel=tov?.version?.channel||""; const clusterId=tov?.version?.cluster_id||"";
    const cpNodes=tnodes.filter(n=>n.role.includes("master")||n.role.includes("control"));
    const wkNodes=tnodes.filter(n=>!n.role.includes("master")&&!n.role.includes("control"));
    const podsByNode={};
    tpods.forEach(pod=>{ const nd=pod.node||"(unscheduled)"; if(!podsByNode[nd]) podsByNode[nd]=[]; podsByNode[nd].push(pod); });
    const totalPods=tpods.length; const runPods=tpods.filter(p=>p.phase==="Running").length;
    const failPods=tpods.filter(p=>p.phase==="Failed").length;
    const availOps=tops.filter(o=>o.health==="Available").length;
    const degOps=tops.filter(o=>o.health==="Degraded").length;
    const boundPVCs=tpvcs.filter(v=>v.status==="Bound").length;
    const warnEvts=(tevts||[]).filter(e=>e.type==="Warning");
    const deps=twl.deployments||[]; const ssets=twl.statefulsets||[]; const dsets=twl.daemonsets||[]; const rsets=twl.replicasets||[];
    const secrets=twl.secrets||[]; const cms=twl.configmaps||[]; const dcs=twl.deploymentconfigs||[];

    function nodeCard(n){
      const sc=n.status==="Ready"?"#10b981":"#ef4444";
      const plist=(podsByNode[n.name]||[]);
      const podRows=plist.map(pod=>{
        const pc=pod.phase==="Running"?"#10b981":pod.phase==="Failed"?"#ef4444":pod.phase==="Pending"?"#f59e0b":"#64748b";
        return `<tr><td style="font-size:11px;color:#334155;word-break:break-all">${pod.name}</td>
          <td style="font-size:11px;color:#0ea5e9">${pod.namespace}</td>
          <td><span style="font-size:10px;font-weight:700;color:${pc};background:${pc}18;padding:1px 6px;border-radius:4px">${pod.phase}</span></td>
          <td style="font-size:11px;color:#64748b">${pod.pod_ip||"—"}</td></tr>`;
      }).join("");
      return `<div class="node-card" style="border-left:3px solid ${sc}">
        <div class="node-header">
          <div style="display:flex;align-items:center;gap:10">
            <div style="width:10px;height:10px;border-radius:50%;background:${sc};flex-shrink:0"></div>
            <div>
              <div style="font-weight:700;font-size:14px;color:#1e293b">${n.name}</div>
              <div style="font-size:11px;color:#64748b">IP: ${n.ip||"—"} &nbsp;|&nbsp; ${n.os_image||"—"} &nbsp;|&nbsp; ${n.container_runtime||"—"}</div>
            </div>
          </div>
          <div style="display:flex;gap:10;flex-wrap:wrap;align-items:center">
            <span class="badge" style="background:#6366f118;color:#6366f1">${n.role}</span>
            <span class="badge" style="background:${sc}18;color:${sc}">${n.status}</span>
            ${n.unschedulable?'<span class="badge" style="background:#f59e0b18;color:#f59e0b">Cordoned</span>':""}
            <span style="font-size:11px;color:#64748b">CPU: ${n.cpu_allocatable||"—"} &nbsp;|&nbsp; Mem: ${n.mem_allocatable_gi?n.mem_allocatable_gi.toFixed(1)+" GiB":"—"} &nbsp;|&nbsp; ${plist.length} pod${plist.length!==1?"s":""}</span>
          </div>
        </div>
        <details style="margin-top:8px">
          <summary style="cursor:pointer;font-size:12px;color:#3b82f6;padding:4px 0">? Show ${plist.length} pod${plist.length!==1?"s":""} on this node</summary>
          <div style="overflow-x:auto;margin-top:8px">
            <table><thead><tr><th>Pod Name</th><th>Namespace</th><th>Phase</th><th>Pod IP</th></tr></thead>
            <tbody>${podRows||"<tr><td colspan=4 style='color:#64748b;text-align:center'>No pods</td></tr>"}</tbody></table>
          </div>
        </details>
      </div>`;
    }
    function nsRow(ns){
      const ac=ns.phase==="Active"; const sc=ac?"#10b981":"#ef4444";
      return `<tr><td style="font-weight:600;color:#334155">${ns.name}</td>
        <td>${ns.display_name||ns.name}</td>
        <td><span style="font-size:11px;font-weight:700;color:${sc};background:${sc}18;padding:1px 6px;border-radius:4px">${ns.phase||"Active"}</span></td>
        <td style="color:#64748b">${ns.requester||"—"}</td>
        <td style="color:#64748b;font-size:11px">${ns.created_at?ns.created_at.slice(0,10):"—"}</td></tr>`;
    }
    function opRow(op){
      const hc=op.health==="Available"?"#10b981":op.health==="Degraded"?"#ef4444":"#f59e0b";
      return `<tr><td style="font-weight:600;color:#334155">${op.name}</td>
        <td><span style="font-size:11px;font-weight:700;color:${hc};background:${hc}18;padding:1px 6px;border-radius:4px">${op.health}</span></td>
        <td style="color:${op.available==="True"?"#10b981":"#ef4444"}">${op.available||"—"}</td>
        <td style="color:${op.degraded==="True"?"#ef4444":"#64748b"}">${op.degraded||"—"}</td>
        <td style="font-size:11px;color:#64748b;word-break:break-all">${op.degraded_msg||"—"}</td></tr>`;
    }
    function routeRow(r){
      const tls=r.tls_termination?"??":"??";
      return `<tr>
        <td style="font-weight:600;color:#334155">${r.name}</td>
        <td style="color:#0ea5e9">${r.namespace}</td>
        <td><a href="${r.url||"#"}" target="_blank" style="color:#3b82f6;font-size:12px">${r.host||"—"}</a></td>
        <td>${r.service||"—"}</td>
        <td>${tls} ${r.tls_termination||"none"}</td>
        <td><span style="font-size:10px;font-weight:700;${r.admitted?"color:#10b981;background:#10b98118":"color:#ef4444;background:#ef444418"};padding:1px 6px;border-radius:4px">${r.admitted?"Admitted":"Rejected"}</span></td>
      </tr>`;
    }
    function wlCard(label,icon,count,color){
      return `<div class="kpi" style="border:1px solid ${color}30">
        <div class="kv" style="color:${color};font-size:26px">${count}</div>
        <div class="kl">${icon} ${label}</div>
      </div>`;
    }
    function pvcRow(v){
      const sc=v.status==="Bound"?"#10b981":"#ef4444";
      return `<tr><td style="font-weight:600;color:#334155;word-break:break-all">${v.name}</td>
        <td style="color:#0ea5e9">${v.namespace||"—"}</td>
        <td><span style="font-size:10px;font-weight:700;color:${sc};background:${sc}18;padding:1px 6px;border-radius:4px">${v.status||"—"}</span></td>
        <td>${v.storage_class||"—"}</td>
        <td>${v.capacity||"—"}</td>
        <td>${v.access_mode||"—"}</td></tr>`;
    }
    function evtRow(e){
      const ec=e.type==="Warning"?"#ef4444":"#64748b";
      return `<tr>
        <td><span style="font-size:10px;font-weight:700;color:${ec};background:${ec}18;padding:1px 6px;border-radius:4px">${e.type}</span></td>
        <td style="color:#0ea5e9">${e.namespace||"—"}</td>
        <td style="font-weight:600;color:#334155;word-break:break-all">${e.name||"—"}</td>
        <td style="color:#64748b">${e.reason||"—"}</td>
        <td style="font-size:11px;color:#475569;max-width:300px;word-break:break-word">${e.message||"—"}</td>
        <td style="font-size:11px;color:#64748b;white-space:nowrap">${e.count||1}x</td>
        <td style="font-size:11px;color:#64748b;white-space:nowrap">${e.last_time?new Date(e.last_time).toLocaleString("en-GB",{dateStyle:"short",timeStyle:"short"}):"—"}</td>
      </tr>`;
    }

    const html=`<!DOCTYPE html><html><head><meta charset="utf-8"/>
<title>OCP Topology — ${clName}</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Segoe UI',Arial,sans-serif;background:#f8fafc;color:#1e293b;padding:28px}
  h1{font-size:22px;font-weight:800;margin-bottom:4px}
  h2{font-size:14px;font-weight:700;margin:24px 0 10px;padding:8px 14px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;display:flex;align-items:center;gap:8px}
  p.sub{font-size:12px;color:#64748b;margin-bottom:20px}
  .topbar{display:flex;flex-wrap:wrap;gap:12px;margin-bottom:20px;padding:14px 18px;background:#fff;border:1px solid #e2e8f0;border-radius:10px;align-items:center}
  .topbar .kpi{text-align:center;min-width:80px}
  .topbar .kpi .val{font-size:20px;font-weight:800}
  .topbar .kpi .lbl{font-size:10px;color:#64748b;margin-top:2px}
  .node-card{background:#fff;border-radius:10px;padding:14px 18px;margin-bottom:12px;border:1px solid #e2e8f0}
  .node-header{display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
  .badge{font-size:11px;font-weight:700;padding:2px 8px;border-radius:5px}
  table{border-collapse:collapse;width:100%;margin-bottom:4px}
  th{background:#f1f5f9;font-size:11px;font-weight:700;padding:6px 10px;text-align:left;border:1px solid #e2e8f0}
  td{font-size:12px;padding:6px 10px;border:1px solid #e2e8f0;vertical-align:top}
  .section{background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:16px 18px;margin-bottom:16px}
  .meta-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px;margin-bottom:16px}
  .meta-item{background:#f8fafc;border:1px solid #e2e8f0;border-radius:7px;padding:10px 14px}
  .meta-item .label{font-size:10px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}
  .meta-item .value{font-size:13px;font-weight:600;word-break:break-all}
  .print-btn{margin-bottom:20px;padding:8px 18px;background:#3b82f6;color:#fff;border:none;border-radius:7px;font-size:13px;cursor:pointer;font-weight:600}
  .kpi-row{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:4px}
  .kpi{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:12px 16px;min-width:100px;text-align:center}
  .kv{font-size:24px;font-weight:800;line-height:1}
  .kl{font-size:11px;color:#64748b;margin-top:4px}
  .toc{margin-bottom:20px;padding:12px 16px;background:#fff;border:1px solid #e2e8f0;border-radius:10px}
  .toc a{color:#3b82f6;font-size:12px;margin-right:16px;text-decoration:none}
  .toc a:hover{text-decoration:underline}
  @media print{.print-btn{display:none}.no-print{display:none}.node-card>details{display:none}}
  details summary{list-style:none} details summary::-webkit-details-marker{display:none}
  .section-cp{border-left:3px solid #6366f1}
  .section-wk{border-left:3px solid #10b981}
  .section-wl{border-left:3px solid #f59e0b}
  .section-st{border-left:3px solid #0ea5e9}
  .section-rt{border-left:3px solid #ec4899}
  .section-ev{border-left:3px solid #ef4444}
  .warn-row td{background:#fef2f218}
</style></head>
<body>
  <button class="print-btn" onclick="window.print()">??? Print / Save as PDF</button>
  <h1>??? Cluster Topology — ${clName}</h1>
  <p class="sub">API: ${clAPI} &nbsp;|&nbsp; Generated: ${exported}</p>

  <div class="toc no-print">
    <strong style="font-size:11px;color:#64748b;text-transform:uppercase;letter-spacing:.5px">Jump to: </strong>
    <a href="#sec-cluster">Cluster Info</a>
    <a href="#sec-cp">Control Plane</a>
    <a href="#sec-wk">Workers</a>
    <a href="#sec-wl">Workloads</a>
    <a href="#sec-st">Storage</a>
    <a href="#sec-rt">Routes</a>
    <a href="#sec-ns">Namespaces</a>
    <a href="#sec-ops">Operators</a>
    <a href="#sec-ev">Events</a>
  </div>

  <div class="topbar">
    <div class="kpi"><div class="val" style="color:#6366f1">${tnodes.length}</div><div class="lbl">Total Nodes</div></div>
    <div style="width:1px;background:#e2e8f0;height:36px"></div>
    <div class="kpi"><div class="val" style="color:#6366f1">${cpNodes.length}</div><div class="lbl">Control Plane</div></div>
    <div class="kpi"><div class="val" style="color:#10b981">${wkNodes.length}</div><div class="lbl">Workers</div></div>
    <div style="width:1px;background:#e2e8f0;height:36px"></div>
    <div class="kpi"><div class="val" style="color:${failPods>0?"#ef4444":"#10b981"}">${runPods}/${totalPods}</div><div class="lbl">Pods Running</div></div>
    <div style="width:1px;background:#e2e8f0;height:36px"></div>
    <div class="kpi"><div class="val" style="color:#f59e0b">${deps.length+dcs.length}</div><div class="lbl">Deployments</div></div>
    <div class="kpi"><div class="val" style="color:#f59e0b">${ssets.length}</div><div class="lbl">StatefulSets</div></div>
    <div class="kpi"><div class="val" style="color:#f59e0b">${dsets.length}</div><div class="lbl">DaemonSets</div></div>
    <div style="width:1px;background:#e2e8f0;height:36px"></div>
    <div class="kpi"><div class="val" style="color:#0ea5e9">${tpvcs.length}</div><div class="lbl">PVCs</div></div>
    <div class="kpi"><div class="val" style="color:#0ea5e9">${boundPVCs}</div><div class="lbl">PVCs Bound</div></div>
    <div style="width:1px;background:#e2e8f0;height:36px"></div>
    <div class="kpi"><div class="val" style="color:#ec4899">${troutes.length}</div><div class="lbl">Routes</div></div>
    <div style="width:1px;background:#e2e8f0;height:36px"></div>
    <div class="kpi"><div class="val" style="color:#0ea5e9">${tns.length}</div><div class="lbl">Namespaces</div></div>
    <div class="kpi"><div class="val" style="color:${degOps>0?"#ef4444":"#10b981"}">${availOps}/${tops.length}</div><div class="lbl">Operators OK</div></div>
    <div style="width:1px;background:#e2e8f0;height:36px"></div>
    <div class="kpi"><div class="val" style="color:${warnEvts.length>0?"#ef4444":"#10b981"}">${warnEvts.length}</div><div class="lbl">Warnings</div></div>
    ${version?`<div style="width:1px;background:#e2e8f0;height:36px"></div><div class="kpi"><div class="val" style="color:#64748b;font-size:13px">${version}</div><div class="lbl">OCP Version</div></div>`:""}
    ${channel?`<div class="kpi"><div class="val" style="color:#f59e0b;font-size:12px">${channel}</div><div class="lbl">Channel</div></div>`:""}
  </div>

  <h2 id="sec-cluster">?? Cluster Information</h2>
  <div class="section">
    <div class="meta-grid">
      <div class="meta-item"><div class="label">Cluster Name</div><div class="value">${clName}</div></div>
      <div class="meta-item"><div class="label">API URL</div><div class="value" style="word-break:break-all;font-size:12px">${clAPI}</div></div>
      ${clConsole?`<div class="meta-item"><div class="label">Console URL</div><div class="value" style="word-break:break-all;font-size:12px"><a href="${clConsole}" target="_blank">${clConsole}</a></div></div>`:""}
      ${version?`<div class="meta-item"><div class="label">OCP Version</div><div class="value" style="color:#0ea5e9">${version}</div></div>`:""}
      ${channel?`<div class="meta-item"><div class="label">Channel</div><div class="value" style="color:#f59e0b">${channel}</div></div>`:""}
      ${clusterId?`<div class="meta-item" style="grid-column:1/-1"><div class="label">Cluster ID</div><div class="value" style="font-family:monospace;font-size:12px">${clusterId}</div></div>`:""}
    </div>
  </div>

  <h2 id="sec-cp" class="section-cp">?? Control Plane Nodes (${cpNodes.length})</h2>
  <div class="section section-cp">
    ${cpNodes.length?cpNodes.map(n=>nodeCard(n)).join(""):"<p style='color:#64748b'>No control plane nodes found</p>"}
  </div>

  <h2 id="sec-wk" class="section-wk">?? Worker Nodes (${wkNodes.length})</h2>
  <div class="section section-wk">
    ${wkNodes.length?wkNodes.map(n=>nodeCard(n)).join(""):"<p style='color:#64748b'>No worker nodes found</p>"}
  </div>

  <h2 id="sec-wl" class="section-wl">?? Workloads Summary</h2>
  <div class="section section-wl">
    <div class="kpi-row" style="margin-bottom:16px">
      ${wlCard("Deployments","??",deps.length,"#3b82f6")}
      ${wlCard("Deploy Configs","??",dcs.length,"#6366f1")}
      ${wlCard("StatefulSets","??",ssets.length,"#8b5cf6")}
      ${wlCard("DaemonSets","??",dsets.length,"#f59e0b")}
      ${wlCard("ReplicaSets","??",rsets.length,"#10b981")}
      ${wlCard("Secrets","??",secrets.length,"#ef4444")}
      ${wlCard("ConfigMaps","???",cms.length,"#0ea5e9")}
    </div>
    ${deps.length>0?`<details><summary style="cursor:pointer;font-size:12px;color:#3b82f6;padding:4px 0;margin-bottom:8px">? Show Deployments (${deps.length})</summary>
    <div style="overflow-x:auto"><table><thead><tr><th>Name</th><th>Namespace</th><th>Ready</th><th>Updated</th><th>Available</th></tr></thead><tbody>
    ${deps.map(d=>`<tr><td style="font-weight:600;color:#334155">${d.name}</td><td style="color:#0ea5e9">${d.namespace}</td>
      <td><span style="font-size:10px;font-weight:700;color:${d.ready_replicas>0?"#10b981":"#ef4444"};background:${d.ready_replicas>0?"#10b98118":"#ef444418"};padding:1px 6px;border-radius:4px">${d.ready_replicas||0}/${d.replicas||0}</span></td>
      <td style="color:#64748b">${d.updated_replicas||0}</td><td style="color:#64748b">${d.available_replicas||0}</td></tr>`).join("")}
    </tbody></table></div></details>`:""}
    ${ssets.length>0?`<details style="margin-top:8px"><summary style="cursor:pointer;font-size:12px;color:#8b5cf6;padding:4px 0;margin-bottom:8px">? Show StatefulSets (${ssets.length})</summary>
    <div style="overflow-x:auto"><table><thead><tr><th>Name</th><th>Namespace</th><th>Ready</th><th>Replicas</th></tr></thead><tbody>
    ${ssets.map(s=>`<tr><td style="font-weight:600;color:#334155">${s.name}</td><td style="color:#0ea5e9">${s.namespace}</td>
      <td><span style="font-size:10px;font-weight:700;color:${s.ready_replicas>0?"#10b981":"#ef4444"};background:${s.ready_replicas>0?"#10b98118":"#ef444418"};padding:1px 6px;border-radius:4px">${s.ready_replicas||0}/${s.replicas||0}</span></td>
      <td style="color:#64748b">${s.replicas||0}</td></tr>`).join("")}
    </tbody></table></div></details>`:""}
    ${dsets.length>0?`<details style="margin-top:8px"><summary style="cursor:pointer;font-size:12px;color:#f59e0b;padding:4px 0;margin-bottom:8px">? Show DaemonSets (${dsets.length})</summary>
    <div style="overflow-x:auto"><table><thead><tr><th>Name</th><th>Namespace</th><th>Desired</th><th>Ready</th></tr></thead><tbody>
    ${dsets.map(d=>`<tr><td style="font-weight:600;color:#334155">${d.name}</td><td style="color:#0ea5e9">${d.namespace}</td>
      <td>${d.desired_number||0}</td>
      <td><span style="font-size:10px;font-weight:700;color:${(d.number_ready||0)>=(d.desired_number||0)?"#10b981":"#f59e0b"};background:${(d.number_ready||0)>=(d.desired_number||0)?"#10b98118":"#f59e0b18"};padding:1px 6px;border-radius:4px">${d.number_ready||0}</span></td></tr>`).join("")}
    </tbody></table></div></details>`:""}
  </div>

  <h2 id="sec-st" class="section-st">?? Storage (${tscs.length} classes · ${tpvs.length} PVs · ${tpvcs.length} PVCs)</h2>
  <div class="section section-st">
    <div class="kpi-row" style="margin-bottom:16px">
      ${wlCard("Storage Classes","??",tscs.length,"#0ea5e9")}
      ${wlCard("PersistentVolumes","??",tpvs.length,"#6366f1")}
      ${wlCard("PVCs Total","???",tpvcs.length,"#10b981")}
      ${wlCard("PVCs Bound","?",boundPVCs,"#10b981")}
      ${wlCard("PVCs Pending","?",tpvcs.filter(v=>v.status==="Pending").length,"#f59e0b")}
    </div>
    ${tscs.length>0?`<details><summary style="cursor:pointer;font-size:12px;color:#0ea5e9;padding:4px 0;margin-bottom:8px">? Show Storage Classes (${tscs.length})</summary>
    <div style="overflow-x:auto"><table><thead><tr><th>Name</th><th>Provisioner</th><th>Binding Mode</th><th>Default</th></tr></thead><tbody>
    ${tscs.map(sc=>`<tr><td style="font-weight:600;color:#334155">${sc.name}</td><td style="font-size:11px;color:#64748b">${sc.provisioner||"—"}</td>
      <td style="font-size:11px">${sc.binding_mode||"—"}</td>
      <td>${sc.is_default?'<span style="font-size:10px;font-weight:700;color:#10b981;background:#10b98118;padding:1px 6px;border-radius:4px">DEFAULT</span>':"—"}</td></tr>`).join("")}
    </tbody></table></div></details>`:""}
    ${tpvcs.length>0?`<details style="margin-top:8px"><summary style="cursor:pointer;font-size:12px;color:#6366f1;padding:4px 0;margin-bottom:8px">? Show PersistentVolumeClaims (${tpvcs.length})</summary>
    <div style="overflow-x:auto"><table><thead><tr><th>Name</th><th>Namespace</th><th>Status</th><th>Storage Class</th><th>Capacity</th><th>Access Mode</th></tr></thead><tbody>
    ${tpvcs.map(v=>pvcRow(v)).join("")}
    </tbody></table></div></details>`:""}
  </div>

  <h2 id="sec-rt" class="section-rt">?? Routes / Applications (${troutes.length})</h2>
  <div class="section section-rt">
    ${troutes.length>0?`<div style="overflow-x:auto"><table>
    <thead><tr><th>Name</th><th>Namespace</th><th>Host</th><th>Service</th><th>TLS</th><th>Status</th></tr></thead>
    <tbody>${troutes.map(r=>routeRow(r)).join("")}</tbody></table></div>`
    :"<p style='color:#64748b'>No routes found</p>"}
  </div>

  <h2 id="sec-ns">?? Namespaces / Projects (${tns.length})</h2>
  <div class="section"><div style="overflow-x:auto">
    <table><thead><tr><th>Name</th><th>Display Name</th><th>Phase</th><th>Requester</th><th>Created</th></tr></thead>
    <tbody>${tns.map(ns=>nsRow(ns)).join("")}</tbody></table></div></div>

  <h2 id="sec-ops">?? Cluster Operators (${tops.length})</h2>
  <div class="section"><div style="overflow-x:auto">
    <table><thead><tr><th>Operator</th><th>Health</th><th>Available</th><th>Degraded</th><th>Message</th></tr></thead>
    <tbody>${tops.map(op=>opRow(op)).join("")}</tbody></table></div></div>

  <h2 id="sec-ev" class="section-ev">?? Events (${(tevts||[]).length} total · ${warnEvts.length} warnings)</h2>
  <div class="section section-ev">
    ${(tevts||[]).length>0?`<div style="overflow-x:auto"><table>
    <thead><tr><th>Type</th><th>Namespace</th><th>Object</th><th>Reason</th><th>Message</th><th>Count</th><th>Last Seen</th></tr></thead>
    <tbody>${[...(tevts||[])].sort((a,b)=>(b.count||1)-(a.count||1)).slice(0,50).map(e=>evtRow(e)).join("")}</tbody></table></div>`
    :"<p style='color:#64748b'>No events found</p>"}
  </div>

</body></html>`;
    const w=window.open("","_blank"); w.document.write(html); w.document.close();
  }

  const TABS=[
    {id:"overview",  label:"Overview",   icon:"??"},
    {id:"topology",  label:"Topology",   icon:"???"},
    {id:"nodes",     label:"Nodes",      icon:"???"},
    {id:"pods",      label:"Pods",       icon:"??"},
    {id:"ns",        label:"Namespaces",   icon:"??"},
    {id:"apps",      label:"Applications", icon:"??"},
    {id:"ops",       label:"Operators",    icon:"??"},
    {id:"workloads", label:"Workloads",    icon:"??"},
    {id:"storage",  label:"Storage",   icon:"??"},
    {id:"events",    label:"Events",     icon:"??"},
  ];

  const filteredPods=pods.filter(p2=>
    (!podNs||p2.namespace===podNs)&&
    (!podQ||[p2.name,p2.namespace,p2.node,p2.phase].some(s=>s?.toLowerCase().includes(podQ.toLowerCase())))
  );
  const filteredNs=namespaces.filter(n=>!nsQ||n.name.toLowerCase().includes(nsQ.toLowerCase()));
  const filteredNodes=nodes.filter(n=>!nodeQ||[n.name,n.role,n.ip,n.status].some(s=>s?.toLowerCase().includes(nodeQ.toLowerCase())));
  const filteredEvts=events.filter(e=>(evtTypeFilter==="all"||e.type===evtTypeFilter));

  const podNamespaces=[...new Set(pods.map(p2=>p2.namespace))].sort();

  return(
    <div className="g-gap">
      {/* -- Header -- */}
      <div style={{display:"flex",alignItems:"center",gap:12,flexWrap:"wrap"}}>
        <div style={{display:"flex",alignItems:"center",gap:10}}>
          <div style={{width:38,height:38,borderRadius:10,background:"linear-gradient(135deg,#ee0000,#cc0000)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,flexShrink:0}}>??</div>
          <div>
            <div style={{fontWeight:700,fontSize:17}}>Red Hat OpenShift</div>
            <div style={{fontSize:12,color:p.textMute}}>Container Platform — live cluster management</div>
          </div>
        </div>
        <div style={{flex:1}}/>
        <button className="btn btn-sm" onClick={exportAllClustersPDF} disabled={exportAllBusy||clusters.length===0}
          style={{background:`${p.orange||"#f97316"}15`,border:`1px solid ${p.orange||"#f97316"}40`,color:p.orange||"#f97316",fontWeight:600,fontSize:12}}>
          {exportAllBusy?"? Exporting…":"?? Export All Clusters"}
        </button>
        {(canAct||true)&&(
          <button className="btn btn-sm" onClick={()=>{setVmReqStep(0);setVmReqForm({...OCP_DEFAULTS});setVmReqErr(null);setShowVMReq(true);}}
            style={{display:"flex",alignItems:"center",gap:5,background:"linear-gradient(135deg,#6366f118,#8b5cf618)",border:"1.5px solid #6366f150",color:"#a78bfa",fontWeight:700,fontSize:12}}>
            ??? + Request VM
          </button>
        )}
        {(isAdmin||role==="operator")&&vmReqPendingCount>0&&(
          <button className="btn btn-sm" onClick={()=>{ loadVMRequests(); setShowVMRequests(true); }}
            style={{display:"flex",alignItems:"center",gap:5,background:"linear-gradient(135deg,#f59e0b18,#f9731618)",border:"1.5px solid #f59e0b50",color:"#f59e0b",fontWeight:700,fontSize:12,position:"relative"}}>
            ?? VM Requests
            <span style={{background:"#ef4444",color:"#fff",borderRadius:"50%",width:18,height:18,display:"flex",alignItems:"center",justifyContent:"center",fontSize:10,fontWeight:800}}>{vmReqPendingCount}</span>
          </button>
        )}
        {(isAdmin||role==="operator")&&vmReqPendingCount===0&&(
          <button className="btn btn-sm" onClick={()=>{ loadVMRequests(); setShowVMRequests(true); }}
            style={{display:"flex",alignItems:"center",gap:5,background:`${p.surface}`,border:`1px solid ${p.border}`,color:p.textMute,fontWeight:600,fontSize:12}}>
            ?? VM Requests
          </button>
        )}
        {isAdmin&&<button className="btn btn-primary btn-sm" onClick={()=>setShowAdd(true)}>+ Add Cluster</button>}
      </div>

      {err&&<div style={{padding:"10px 14px",borderRadius:8,background:`${p.red}12`,border:`1px solid ${p.red}30`,color:p.red,fontSize:13}}>{err}</div>}

      {/* -- Cluster selector chips -- */}
      {clusters.length>0&&(
        <div style={{display:"flex",gap:8,flexWrap:"wrap",alignItems:"center"}}>
          {clusters.map(c=>{
            const isSel=selCluster?.id===c.id;
            const stColor=c.status==="connected"?p.green:c.status==="error"?p.red:"#64748b";
            return(
              <div key={c.id} onClick={()=>{ setSelCluster(c); setTab("overview"); }}
                style={{display:"flex",alignItems:"center",gap:8,padding:"7px 14px",borderRadius:10,cursor:"pointer",
                  background:isSel?"linear-gradient(135deg,#ee000018,#cc000012)":p.surface,
                  border:`1.5px solid ${isSel?"#ee000060":p.border}`,transition:"all .15s"}}>
                <div style={{width:8,height:8,borderRadius:"50%",background:stColor,boxShadow:`0 0 6px ${stColor}80`}}/>
                <span style={{fontWeight:600,fontSize:13,color:isSel?"#ee4444":p.text}}>{c.name}</span>
                <span style={{fontSize:10,color:stColor,fontWeight:600}}>{c.status||"unknown"}</span>
                {isAdmin&&<button title="Delete cluster" onClick={e=>{e.stopPropagation();doDelCluster(c);}}
                  style={{background:`${p.red}15`,border:`1px solid ${p.red}30`,borderRadius:4,padding:"0px 4px",cursor:"pointer",fontSize:10,color:p.red,marginLeft:2}}>?</button>}
              </div>
            );
          })}
        </div>
      )}

      {clusters.length===0&&!loading&&(
        <div className="card" style={{textAlign:"center",padding:48}}>
          <div style={{fontSize:48,marginBottom:12}}>??</div>
          <div style={{fontWeight:700,fontSize:16,marginBottom:6}}>No OpenShift Clusters Configured</div>
          <div style={{fontSize:13,color:p.textMute,marginBottom:16}}>Add a cluster to start monitoring nodes, pods and operators.</div>
          {isAdmin&&<button className="btn btn-primary" onClick={()=>setShowAdd(true)}>+ Add Cluster</button>}
        </div>
      )}

      {selCluster&&(
        <div>
          {/* -- Cluster info bar -- */}
          <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap",padding:"8px 14px",borderRadius:10,background:p.surface,border:`1px solid ${p.border}`}}>
            <span style={{fontSize:12,color:p.textMute}}>API:</span>
            <code style={{fontSize:11,color:p.cyan,background:`${p.cyan}10`,padding:"1px 6px",borderRadius:4}}>{selCluster.api_url}</code>
            {selCluster.console_url&&<a href={selCluster.console_url} target="_blank" rel="noreferrer"
              style={{fontSize:11,color:p.accent,textDecoration:"none",marginLeft:4}}>?? Console</a>}
            {selCluster.ai_url&&<a href={selCluster.ai_url} target="_blank" rel="noreferrer"
              style={{fontSize:11,color:"#8b5cf6",textDecoration:"none",marginLeft:4,display:"flex",alignItems:"center",gap:3,
                      padding:"2px 7px",borderRadius:5,background:"#8b5cf612",border:"1px solid #8b5cf630",fontWeight:600}}>
              ?? Red Hat OpenShift AI</a>}
            <div style={{flex:1}}/>
            {isAdmin&&<button className="btn btn-sm" onClick={()=>{
              setEditForm({
                name:       selCluster.name||"",
                api_url:    selCluster.api_url||"",
                console_url:selCluster.console_url||"",
                ai_url:     selCluster.ai_url||"",
                description:selCluster.description||"",
                username:   selCluster.username||"",
                password:   "",
              });
              setEditErr(null);
              setShowEdit(true);
            }}
              style={{background:`${p.orange||"#f97316"}15`,border:`1px solid ${p.orange||"#f97316"}40`,color:p.orange||"#f97316",fontSize:11}}>
              ?? Edit Cluster
            </button>}
            <button className="btn btn-sm" onClick={doTest} disabled={testBusy}
              style={{background:`${p.cyan}15`,border:`1px solid ${p.cyan}30`,color:p.cyan,fontSize:11}}>
              {testBusy?"? Testing…":"?? Test Connection"}
            </button>
            <button className="btn btn-sm" onClick={()=>loadTab(tab)} disabled={tabLoading}
              style={{background:`${p.green}15`,border:`1px solid ${p.green}30`,color:p.green,fontSize:11}}>
              {tabLoading?"?":"?"} Refresh
            </button>
          </div>

          {testResult&&(
            <div style={{padding:"8px 14px",borderRadius:8,background:testResult.reachable?`${p.green}12`:`${p.red}12`,
              border:`1px solid ${testResult.reachable?p.green:p.red}30`,color:testResult.reachable?p.green:p.red,fontSize:13}}>
              {testResult.reachable?"?":"?"} {testResult.message}
            </div>
          )}

          {/* -- Tabs -- */}
          <div style={{display:"flex",gap:2,flexWrap:"wrap",borderBottom:`1px solid ${p.border}`,paddingBottom:2}}>
            {TABS.map(t=>{
              const act=tab===t.id;
              return(
                <button key={t.id} onClick={()=>setTab(t.id)}
                  style={{display:"flex",alignItems:"center",gap:6,padding:"8px 14px",borderRadius:"8px 8px 0 0",border:`1px solid ${act?p.accent+"60":p.border}`,borderBottom:act?"none":"",
                    background:act?`${p.accent}15`:p.surface,color:act?p.accent:p.textSub,fontWeight:act?700:500,fontSize:13,cursor:"pointer",marginBottom:act?-1:0}}>
                  {t.icon} {t.label}
                </button>
              );
            })}
          </div>

          {tabErr&&<div style={{padding:"10px 14px",borderRadius:8,background:`${p.red}12`,border:`1px solid ${p.red}30`,color:p.red,fontSize:13}}>?? {tabErr}</div>}
          {tabLoading&&<LoadState msg="Fetching live data…"/>}

          {!tabLoading&&(
            <div>
              {/* -- OVERVIEW TAB -- */}
              {tab==="overview"&&overview&&(
                <div className="g-gap">
                  {/* Version bar */}
                  {overview.version&&!overview.version.error&&(
                    <div style={{display:"flex",gap:24,flexWrap:"wrap",alignItems:"flex-start",padding:"12px 16px",borderRadius:10,background:p.surface,border:`1px solid ${p.border}`}}>
                      <div>
                        <div style={{fontSize:11,color:p.textMute,marginBottom:4}}>Version</div>
                        <div style={{fontSize:15,fontWeight:700,color:p.cyan}}>{overview.version.version||"—"}</div>
                      </div>
                      <div>
                        <div style={{fontSize:11,color:p.textMute,marginBottom:4}}>Channel</div>
                        <div style={{fontSize:14,fontWeight:700,color:p.accent}}>{overview.version.channel||"—"}</div>
                      </div>
                      <div style={{flex:1,minWidth:280}}>
                        <div style={{fontSize:11,color:p.textMute,marginBottom:4}}>Cluster ID</div>
                        <div style={{display:"flex",alignItems:"center",gap:6}}>
                          <code style={{fontSize:12,color:p.text,background:`${p.bg}`,border:`1px solid ${p.border}`,borderRadius:5,padding:"3px 10px",flex:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>
                            {overview.version.cluster_id||"—"}
                          </code>
                          {overview.version.cluster_id&&(
                            <button title="Copy Cluster ID" onClick={()=>{ navigator.clipboard.writeText(overview.version.cluster_id); setCopiedId(true); setTimeout(()=>setCopiedId(false),2000); }}
                              style={{background:`${p.cyan}15`,border:`1px solid ${p.cyan}30`,borderRadius:5,padding:"3px 10px",cursor:"pointer",fontSize:11,color:p.cyan,flexShrink:0,fontWeight:600}}>
                              {copiedId?"? Copied":"?? Copy"}
                            </button>
                          )}
                        </div>
                      </div>
                      {overview.version.available_updates>0&&(
                        <div style={{display:"flex",alignItems:"center"}}>
                          <span style={{fontSize:12,fontWeight:700,color:p.yellow,background:`${p.yellow}15`,border:`1px solid ${p.yellow}30`,borderRadius:6,padding:"4px 12px"}}>
                            ?? {overview.version.available_updates} update{overview.version.available_updates!==1?"s":""} available
                          </span>
                        </div>
                      )}
                    </div>
                  )}
                  {/* KPI cards */}
                  <div className="g4">
                    {[
                      {icon:"???",label:"Nodes",val:`${overview.nodes_summary.ready}/${overview.nodes_summary.total}`,
                        sub:`${overview.nodes_summary.not_ready} not ready`,color:overview.nodes_summary.not_ready>0?p.red:p.green},
                      {icon:"??",label:"Pods",val:`${overview.pods_summary.running}/${overview.pods_summary.total}`,
                        sub:`${overview.pods_summary.failed} failed · ${overview.pods_summary.pending} pending`,
                        color:overview.pods_summary.failed>0?p.red:p.green},
                      {icon:"??",label:"Operators",val:`${overview.operators_summary.available}/${overview.operators_summary.total}`,
                        sub:`${overview.operators_summary.degraded} degraded`,
                        color:overview.operators_summary.degraded>0?p.red:p.green},
                      {icon:"??",label:"Warnings",val:overview.warnings,sub:"cluster events",
                        color:overview.warnings>0?p.yellow:p.green},
                    ].map((k,i)=>(
                      <div key={i} className="card" style={{padding:"16px 18px"}}>
                        <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:6}}>
                          <span style={{fontSize:22}}>{k.icon}</span>
                          <span style={{fontSize:12,color:p.textMute,fontWeight:600}}>{k.label}</span>
                        </div>
                        <div style={{fontSize:28,fontWeight:800,color:k.color,lineHeight:1}}>{k.val}</div>
                        <div style={{fontSize:11,color:p.textMute,marginTop:4}}>{k.sub}</div>
                      </div>
                    ))}
                  </div>
                  {/* quick-view node table */}
                  {overview.nodes_summary.total===0&&(
                    <div style={{padding:24,textAlign:"center",color:p.textMute,fontSize:13}}>
                      No node data — click Nodes tab or Refresh to fetch live info.
                    </div>
                  )}
                </div>
              )}

              {/* -- TOPOLOGY TAB -- */}
              {tab==="topology"&&(
                <div className="g-gap">
                  {/* -- KPI Summary Bar -- */}
                  {topoData&&(()=>{
                    const td=topoData;
                    const cpN=td.nodes.filter(n=>n.role.includes("master")||n.role.includes("control")).length;
                    const wkN=td.nodes.length-cpN;
                    const runP=td.pods.filter(p2=>p2.phase==="Running").length;
                    const failP=td.pods.filter(p2=>p2.phase==="Failed").length;
                    const boundPVC=(td.pvcs||[]).filter(v=>v.status==="Bound").length;
                    const wl=td.workloads||{};
                    const warnE=(td.events||[]).filter(e=>e.type==="Warning").length;
                    const degOps=td.operators.filter(o=>o.health==="Degraded").length;
                    const kpiStyle=(color)=>({textAlign:"center",padding:"10px 14px",borderRadius:8,background:p.panel,border:`1px solid ${color}28`,minWidth:80,flex:1});
                    return(
                      <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(80px,1fr))",gap:8}}>
                        {[
                          {v:td.nodes.length,    l:"Nodes",       c:p.purple},
                          {v:cpN,                l:"Ctrl Plane",  c:"#6366f1"},
                          {v:wkN,                l:"Workers",     c:p.green},
                          {v:`${runP}/${td.pods.length}`,l:"Pods Running",c:failP>0?p.red:p.green},
                          {v:(wl.deployments?.length||0)+(wl.deploymentconfigs?.length||0),l:"Deployments",c:"#f59e0b"},
                          {v:wl.statefulsets?.length||0,l:"StatefulSets",c:"#8b5cf6"},
                          {v:wl.daemonsets?.length||0,  l:"DaemonSets",  c:"#f97316"},
                          {v:td.pvcs?.length||0, l:"PVCs",        c:p.cyan},
                          {v:boundPVC,           l:"PVCs Bound",  c:p.green},
                          {v:td.storageClasses?.length||0,l:"Storage SCs",c:"#0ea5e9"},
                          {v:td.routes?.length||0,l:"Routes",     c:"#ec4899"},
                          {v:td.namespaces.length,l:"Namespaces", c:p.cyan},
                          {v:`${td.operators.filter(o=>o.health==="Available").length}/${td.operators.length}`,l:"Operators",c:degOps>0?p.red:p.green},
                          {v:warnE,              l:"Warnings",    c:warnE>0?p.red:p.green},
                        ].map((k,i)=>(
                          <div key={i} style={kpiStyle(k.c)}>
                            <div style={{fontSize:18,fontWeight:800,color:k.c,lineHeight:1}}>{k.v}</div>
                            <div style={{fontSize:10,color:p.textMute,marginTop:3}}>{k.l}</div>
                          </div>
                        ))}
                      </div>
                    );
                  })()}

                  {/* Export button */}
                  <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",flexWrap:"wrap",gap:8}}>
                    <div style={{fontSize:12,color:p.textMute}}>
                      {topoData
                        ?<span style={{color:p.text}}>Full cluster view — {topoData.nodes.length} nodes · {topoData.pods.length} pods · {(topoData.routes||[]).length} routes · {(topoData.pvcs||[]).length} PVCs · {(topoData.events||[]).filter(e=>e.type==="Warning").length} warnings</span>
                        :<span>Load topology to view cluster map</span>
                      }
                    </div>
                    {topoData&&(
                      <button onClick={openTopologyPage}
                        style={{display:"flex",alignItems:"center",gap:6,padding:"7px 16px",borderRadius:8,cursor:"pointer",
                          background:"linear-gradient(135deg,#ee000018,#cc000012)",border:"1.5px solid #ee000060",
                          color:"#ee4444",fontWeight:700,fontSize:13}}>
                        ??? Open Full Topology ?
                      </button>
                    )}
                  </div>

                  {topoData&&(()=>{
                    const cpNodes=topoData.nodes.filter(n=>n.role.includes("master")||n.role.includes("control"));
                    const wkNodes=topoData.nodes.filter(n=>!n.role.includes("master")&&!n.role.includes("control"));
                    const podsByNode={};
                    topoData.pods.forEach(pod=>{const nd=pod.node||"(unscheduled)"; if(!podsByNode[nd]) podsByNode[nd]=[]; podsByNode[nd].push(pod);});
                    const wl=topoData.workloads||{};
                    const warnEvts=(topoData.events||[]).filter(e=>e.type==="Warning").slice(0,20);

                    function NodeCard({n}){
                      const sc=n.status==="Ready"?p.green:p.red;
                      const isExpanded=topoExpandNode[n.name];
                      const nodePods=podsByNode[n.name]||[];
                      const running=nodePods.filter(pp=>pp.phase==="Running").length;
                      const failed=nodePods.filter(pp=>pp.phase==="Failed").length;
                      return(
                        <div style={{background:p.surface,border:`1.5px solid ${sc}30`,borderRadius:10,padding:"12px 16px",borderLeft:`3px solid ${sc}`}}>
                          <div style={{display:"flex",alignItems:"center",gap:10,flexWrap:"wrap"}}>
                            <div style={{width:10,height:10,borderRadius:"50%",background:sc,boxShadow:`0 0 6px ${sc}80`,flexShrink:0}}/>
                            <div style={{flex:1,minWidth:0}}>
                              <div style={{fontWeight:700,fontSize:13,color:p.accent,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap"}}>{n.name}</div>
                              <div style={{fontSize:11,color:p.textMute}}>{n.ip||"—"} · {n.os_image||"—"} · {n.container_runtime||"—"}</div>
                            </div>
                            <div style={{display:"flex",gap:6,flexWrap:"wrap",alignItems:"center"}}>
                              <span style={{fontSize:10,fontWeight:700,padding:"2px 7px",borderRadius:5,background:`${p.purple}18`,color:p.purple}}>{n.role}</span>
                              <span style={{fontSize:10,fontWeight:700,padding:"2px 7px",borderRadius:5,background:`${sc}18`,color:sc}}>{n.status}</span>
                              {n.unschedulable&&<span style={{fontSize:10,fontWeight:700,padding:"2px 7px",borderRadius:5,background:`${p.yellow}18`,color:p.yellow}}>Cordoned</span>}
                            </div>
                          </div>
                          <div style={{display:"flex",gap:16,marginTop:8,flexWrap:"wrap"}}>
                            <div style={{fontSize:11,color:p.textMute}}>CPU: <span style={{color:p.text,fontWeight:600}}>{n.cpu_allocatable||"—"}</span></div>
                            <div style={{fontSize:11,color:p.textMute}}>Mem: <span style={{color:p.text,fontWeight:600}}>{n.mem_allocatable_gi?n.mem_allocatable_gi.toFixed(1)+" GiB":"—"}</span></div>
                            {n.cpu_usage_pct>0&&<OcpBar pct={n.cpu_usage_pct}/>}
                            {n.mem_usage_pct>0&&<OcpBar pct={n.mem_usage_pct} color="#8b5cf6"/>}
                            <div style={{fontSize:11,color:p.textMute}}>Pods: <span style={{color:running>0?p.green:p.textMute,fontWeight:600}}>{running} running</span>{failed>0&&<span style={{color:p.red,fontWeight:600}}> · {failed} failed</span>} / {nodePods.length} total</div>
                          </div>
                          {nodePods.length>0&&(
                            <button onClick={()=>setTopoExpandNode(s=>({...s,[n.name]:!s[n.name]}))}
                              style={{marginTop:8,fontSize:11,color:p.accent,background:`${p.accent}10`,border:`1px solid ${p.accent}30`,borderRadius:5,padding:"2px 10px",cursor:"pointer"}}>
                              {isExpanded?"? Hide":"? Show"} {nodePods.length} pod{nodePods.length!==1?"s":""}
                            </button>
                          )}
                          {isExpanded&&(
                            <div style={{marginTop:8,overflowX:"auto"}}>
                              <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                                <thead><tr style={{background:p.bg}}>
                                  {["POD","NAMESPACE","PHASE","POD IP"].map(h=><th key={h} style={{padding:"4px 8px",textAlign:"left",fontWeight:700,color:p.textMute,borderBottom:`1px solid ${p.border}`}}>{h}</th>)}
                                </tr></thead>
                                <tbody>{nodePods.map((pod,pi)=>{
                                  const pc=pod.phase==="Running"?p.green:pod.phase==="Failed"?p.red:pod.phase==="Pending"?p.yellow:"#64748b";
                                  return(<tr key={pi} style={{borderBottom:`1px solid ${p.border}30`}}>
                                    <td style={{padding:"4px 8px",color:p.accent,wordBreak:"break-all",fontSize:11}}>{pod.name}</td>
                                    <td style={{padding:"4px 8px",color:p.cyan,fontSize:11}}>{pod.namespace}</td>
                                    <td style={{padding:"4px 8px"}}><span style={{fontWeight:700,color:pc,background:`${pc}12`,padding:"1px 5px",borderRadius:4,fontSize:10}}>{pod.phase}</span></td>
                                    <td style={{padding:"4px 8px",color:p.textMute,fontFamily:"monospace",fontSize:11}}>{pod.pod_ip||"—"}</td>
                                  </tr>);
                                })}</tbody>
                              </table>
                            </div>
                          )}
                        </div>
                      );
                    }

                    function SectionHeader({icon,label,count,color}){
                      return(
                        <div style={{fontSize:12,fontWeight:700,color:color||p.textMute,marginBottom:8,display:"flex",alignItems:"center",gap:6,padding:"6px 10px",background:`${color||p.accent}10`,borderRadius:6,borderLeft:`3px solid ${color||p.accent}`}}>
                          <span>{icon}</span><span>{label}</span><span style={{marginLeft:"auto",fontSize:11,fontWeight:600,background:`${color||p.accent}18`,padding:"1px 8px",borderRadius:4}}>{count}</span>
                        </div>
                      );
                    }

                    return(
                      <>
                        {/* -- Control Plane -- */}
                        {cpNodes.length>0&&(
                          <div>
                            <SectionHeader icon="??" label="CONTROL PLANE" count={cpNodes.length} color={p.purple}/>
                            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(400px,1fr))",gap:10}}>
                              {cpNodes.map((n,i)=><NodeCard key={i} n={n}/>)}
                            </div>
                          </div>
                        )}

                        {/* -- Workers -- */}
                        {wkNodes.length>0&&(
                          <div>
                            <SectionHeader icon="??" label="WORKER NODES" count={wkNodes.length} color={p.green}/>
                            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(400px,1fr))",gap:10}}>
                              {wkNodes.map((n,i)=><NodeCard key={i} n={n}/>)}
                            </div>
                          </div>
                        )}

                        {/* -- Workloads Summary -- */}
                        {(wl.deployments?.length||0)+(wl.statefulsets?.length||0)+(wl.daemonsets?.length||0)>0&&(
                          <div>
                            <SectionHeader icon="??" label="WORKLOADS" count={(wl.deployments?.length||0)+(wl.deploymentconfigs?.length||0)+(wl.statefulsets?.length||0)+(wl.daemonsets?.length||0)} color="#f59e0b"/>
                            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(220px,1fr))",gap:8,marginBottom:10}}>
                              {[
                                {l:"Deployments",       c:"#3b82f6",  items:wl.deployments||[]},
                                {l:"Deploy Configs",    c:"#6366f1",  items:wl.deploymentconfigs||[]},
                                {l:"StatefulSets",      c:"#8b5cf6",  items:wl.statefulsets||[]},
                                {l:"DaemonSets",        c:"#f97316",  items:wl.daemonsets||[]},
                                {l:"ReplicaSets",       c:"#10b981",  items:wl.replicasets||[]},
                                {l:"Secrets",           c:"#ef4444",  items:wl.secrets||[]},
                                {l:"ConfigMaps",        c:"#0ea5e9",  items:wl.configmaps||[]},
                              ].map((wc,i)=>(
                                <div key={i} style={{background:p.panel,border:`1px solid ${wc.c}28`,borderRadius:8,padding:"10px 14px",textAlign:"center"}}>
                                  <div style={{fontSize:22,fontWeight:800,color:wc.c}}>{wc.items.length}</div>
                                  <div style={{fontSize:11,color:p.textMute,marginTop:3}}>{wc.l}</div>
                                </div>
                              ))}
                            </div>
                            {/* Deployments table */}
                            {(wl.deployments||[]).length>0&&(
                              <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:8,overflow:"hidden",marginBottom:8}}>
                                <div style={{padding:"8px 12px",background:`${p.bg}`,borderBottom:`1px solid ${p.border}`,fontSize:11,fontWeight:700,color:"#3b82f6"}}>?? Deployments ({wl.deployments.length})</div>
                                <div style={{overflowX:"auto",maxHeight:200}}>
                                  <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                                    <thead><tr style={{background:p.bg}}>{["Name","Namespace","Ready","Available","Updated"].map(h=><th key={h} style={{padding:"5px 10px",textAlign:"left",color:p.textMute,fontWeight:700,borderBottom:`1px solid ${p.border}`,whiteSpace:"nowrap"}}>{h}</th>)}</tr></thead>
                                    <tbody>{wl.deployments.map((d,i)=>{
                                      const ok=(d.ready_replicas||0)>0&&(d.ready_replicas||0)>=(d.replicas||0);
                                      return(<tr key={i} style={{borderBottom:`1px solid ${p.border}30`}}>
                                        <td style={{padding:"4px 10px",fontWeight:600,color:p.accent}}>{d.name}</td>
                                        <td style={{padding:"4px 10px",color:p.cyan}}>{d.namespace}</td>
                                        <td style={{padding:"4px 10px"}}><span style={{fontSize:10,fontWeight:700,color:ok?p.green:p.red,background:ok?`${p.green}12`:`${p.red}12`,padding:"1px 5px",borderRadius:4}}>{d.ready_replicas||0}/{d.replicas||0}</span></td>
                                        <td style={{padding:"4px 10px",color:p.textMute}}>{d.available_replicas||0}</td>
                                        <td style={{padding:"4px 10px",color:p.textMute}}>{d.updated_replicas||0}</td>
                                      </tr>);
                                    })}</tbody>
                                  </table>
                                </div>
                              </div>
                            )}
                            {/* StatefulSets table */}
                            {(wl.statefulsets||[]).length>0&&(
                              <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:8,overflow:"hidden",marginBottom:8}}>
                                <div style={{padding:"8px 12px",background:p.bg,borderBottom:`1px solid ${p.border}`,fontSize:11,fontWeight:700,color:"#8b5cf6"}}>?? StatefulSets ({wl.statefulsets.length})</div>
                                <div style={{overflowX:"auto",maxHeight:180}}>
                                  <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                                    <thead><tr style={{background:p.bg}}>{["Name","Namespace","Ready","Replicas"].map(h=><th key={h} style={{padding:"5px 10px",textAlign:"left",color:p.textMute,fontWeight:700,borderBottom:`1px solid ${p.border}`}}>{h}</th>)}</tr></thead>
                                    <tbody>{wl.statefulsets.map((s,i)=>{
                                      const ok=(s.ready_replicas||0)>=(s.replicas||0);
                                      return(<tr key={i} style={{borderBottom:`1px solid ${p.border}30`}}>
                                        <td style={{padding:"4px 10px",fontWeight:600,color:p.accent}}>{s.name}</td>
                                        <td style={{padding:"4px 10px",color:p.cyan}}>{s.namespace}</td>
                                        <td style={{padding:"4px 10px"}}><span style={{fontSize:10,fontWeight:700,color:ok?p.green:p.red,background:ok?`${p.green}12`:`${p.red}12`,padding:"1px 5px",borderRadius:4}}>{s.ready_replicas||0}/{s.replicas||0}</span></td>
                                        <td style={{padding:"4px 10px",color:p.textMute}}>{s.replicas||0}</td>
                                      </tr>);
                                    })}</tbody>
                                  </table>
                                </div>
                              </div>
                            )}
                            {/* DaemonSets */}
                            {(wl.daemonsets||[]).length>0&&(
                              <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:8,overflow:"hidden"}}>
                                <div style={{padding:"8px 12px",background:p.bg,borderBottom:`1px solid ${p.border}`,fontSize:11,fontWeight:700,color:"#f97316"}}>?? DaemonSets ({wl.daemonsets.length})</div>
                                <div style={{overflowX:"auto",maxHeight:180}}>
                                  <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                                    <thead><tr style={{background:p.bg}}>{["Name","Namespace","Desired","Ready","Available"].map(h=><th key={h} style={{padding:"5px 10px",textAlign:"left",color:p.textMute,fontWeight:700,borderBottom:`1px solid ${p.border}`}}>{h}</th>)}</tr></thead>
                                    <tbody>{wl.daemonsets.map((d,i)=>{
                                      const ok=(d.number_ready||0)>=(d.desired_number||0);
                                      return(<tr key={i} style={{borderBottom:`1px solid ${p.border}30`}}>
                                        <td style={{padding:"4px 10px",fontWeight:600,color:p.accent}}>{d.name}</td>
                                        <td style={{padding:"4px 10px",color:p.cyan}}>{d.namespace}</td>
                                        <td style={{padding:"4px 10px",color:p.textMute}}>{d.desired_number||0}</td>
                                        <td style={{padding:"4px 10px"}}><span style={{fontSize:10,fontWeight:700,color:ok?p.green:p.yellow,background:ok?`${p.green}12`:`${p.yellow}12`,padding:"1px 5px",borderRadius:4}}>{d.number_ready||0}</span></td>
                                        <td style={{padding:"4px 10px",color:p.textMute}}>{d.number_available||0}</td>
                                      </tr>);
                                    })}</tbody>
                                  </table>
                                </div>
                              </div>
                            )}
                          </div>
                        )}

                        {/* -- Storage -- */}
                        {((topoData.storageClasses||[]).length>0||(topoData.pvcs||[]).length>0)&&(
                          <div>
                            <SectionHeader icon="??" label="STORAGE" count={`${topoData.storageClasses?.length||0} classes · ${topoData.pvs?.length||0} PVs · ${topoData.pvcs?.length||0} PVCs`} color="#0ea5e9"/>
                            <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(160px,1fr))",gap:8,marginBottom:10}}>
                              {[
                                {l:"Storage Classes",c:"#0ea5e9", v:topoData.storageClasses?.length||0},
                                {l:"PersistentVolumes",c:"#6366f1",v:topoData.pvs?.length||0},
                                {l:"PVCs Total",      c:p.cyan,   v:topoData.pvcs?.length||0},
                                {l:"PVCs Bound",      c:p.green,  v:(topoData.pvcs||[]).filter(v=>v.status==="Bound").length},
                                {l:"PVCs Pending",    c:p.yellow, v:(topoData.pvcs||[]).filter(v=>v.status==="Pending").length},
                                {l:"Default SC",      c:"#10b981",v:(topoData.storageClasses||[]).filter(s=>s.is_default).length},
                              ].map((sc,i)=>(
                                <div key={i} style={{background:p.panel,border:`1px solid ${sc.c}28`,borderRadius:8,padding:"10px 14px",textAlign:"center"}}>
                                  <div style={{fontSize:20,fontWeight:800,color:sc.c}}>{sc.v}</div>
                                  <div style={{fontSize:10,color:p.textMute,marginTop:3}}>{sc.l}</div>
                                </div>
                              ))}
                            </div>
                            {(topoData.pvcs||[]).length>0&&(
                              <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:8,overflow:"hidden"}}>
                                <div style={{padding:"8px 12px",background:p.bg,borderBottom:`1px solid ${p.border}`,fontSize:11,fontWeight:700,color:"#0ea5e9"}}>??? PersistentVolumeClaims ({topoData.pvcs.length})</div>
                                <div style={{overflowX:"auto",maxHeight:220}}>
                                  <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                                    <thead><tr style={{background:p.bg}}>{["Name","Namespace","Status","Storage Class","Capacity","Access Mode"].map(h=><th key={h} style={{padding:"5px 10px",textAlign:"left",color:p.textMute,fontWeight:700,borderBottom:`1px solid ${p.border}`,whiteSpace:"nowrap"}}>{h}</th>)}</tr></thead>
                                    <tbody>{topoData.pvcs.map((v,i)=>{
                                      const sc=v.status==="Bound"?p.green:v.status==="Pending"?p.yellow:p.red;
                                      return(<tr key={i} style={{borderBottom:`1px solid ${p.border}30`}}>
                                        <td style={{padding:"4px 10px",fontWeight:600,color:p.accent,wordBreak:"break-all"}}>{v.name}</td>
                                        <td style={{padding:"4px 10px",color:p.cyan}}>{v.namespace||"—"}</td>
                                        <td style={{padding:"4px 10px"}}><span style={{fontSize:10,fontWeight:700,color:sc,background:`${sc}12`,padding:"1px 5px",borderRadius:4}}>{v.status||"—"}</span></td>
                                        <td style={{padding:"4px 10px",color:p.textMute}}>{v.storage_class||"—"}</td>
                                        <td style={{padding:"4px 10px",color:p.textMute,fontFamily:"monospace"}}>{v.capacity||"—"}</td>
                                        <td style={{padding:"4px 10px",color:p.textMute}}>{v.access_mode||"—"}</td>
                                      </tr>);
                                    })}</tbody>
                                  </table>
                                </div>
                              </div>
                            )}
                          </div>
                        )}

                        {/* -- Routes / Applications -- */}
                        {(topoData.routes||[]).length>0&&(
                          <div>
                            <SectionHeader icon="??" label="ROUTES / APPLICATIONS" count={topoData.routes.length} color="#ec4899"/>
                            <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:8,overflow:"hidden"}}>
                              <div style={{overflowX:"auto",maxHeight:240}}>
                                <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                                  <thead><tr style={{background:p.bg}}>{["Name","Namespace","Host","Service","TLS","Status"].map(h=><th key={h} style={{padding:"5px 10px",textAlign:"left",color:p.textMute,fontWeight:700,borderBottom:`1px solid ${p.border}`,whiteSpace:"nowrap"}}>{h}</th>)}</tr></thead>
                                  <tbody>{topoData.routes.map((r,i)=>{
                                    const ac=r.admitted;
                                    return(<tr key={i} style={{borderBottom:`1px solid ${p.border}30`}}>
                                      <td style={{padding:"4px 10px",fontWeight:600,color:p.accent}}>{r.name}</td>
                                      <td style={{padding:"4px 10px",color:p.cyan}}>{r.namespace}</td>
                                      <td style={{padding:"4px 10px"}}>
                                        {r.url?<a href={r.url} target="_blank" rel="noopener noreferrer" style={{color:"#3b82f6",wordBreak:"break-all"}}>{r.host||"—"}</a>:<span style={{color:p.textMute}}>{r.host||"—"}</span>}
                                      </td>
                                      <td style={{padding:"4px 10px",color:p.textMute}}>{r.service||"—"}</td>
                                      <td style={{padding:"4px 10px",color:p.textMute}}>{r.tls_termination?`?? ${r.tls_termination}`:"?? none"}</td>
                                      <td style={{padding:"4px 10px"}}><span style={{fontSize:10,fontWeight:700,color:ac?p.green:p.red,background:ac?`${p.green}12`:`${p.red}12`,padding:"1px 5px",borderRadius:4}}>{ac?"Admitted":"Rejected"}</span></td>
                                    </tr>);
                                  })}</tbody>
                                </table>
                              </div>
                            </div>
                          </div>
                        )}

                        {/* -- Namespaces + Operators 2-col -- */}
                        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
                          <div>
                            <SectionHeader icon="??" label="NAMESPACES" count={topoData.namespaces.length} color={p.cyan}/>
                            <div className="card" style={{padding:"12px 14px"}}>
                              <div style={{display:"flex",flexWrap:"wrap",gap:5,maxHeight:180,overflowY:"auto"}}>
                                {topoData.namespaces.map((ns,i)=>{
                                  const ac=ns.phase==="Active";
                                  return(<span key={i} style={{fontSize:11,padding:"2px 8px",borderRadius:5,fontWeight:500,
                                    background:ac?`${p.green}12`:`${p.red}12`,color:ac?p.green:p.red,border:`1px solid ${ac?p.green:p.red}25`}}>{ns.name}</span>);
                                })}
                              </div>
                            </div>
                          </div>
                          <div>
                            <SectionHeader icon="??" label="CLUSTER OPERATORS" count={topoData.operators.length} color={p.yellow}/>
                            <div className="card" style={{padding:"12px 14px"}}>
                              <div style={{display:"flex",flexDirection:"column",gap:4,maxHeight:180,overflowY:"auto"}}>
                                {topoData.operators.map((op,i)=>{
                                  const hc=op.health==="Available"?p.green:op.health==="Degraded"?p.red:p.yellow;
                                  return(<div key={i} style={{display:"flex",alignItems:"center",gap:8}}>
                                    <div style={{width:7,height:7,borderRadius:"50%",background:hc,flexShrink:0}}/>
                                    <span style={{fontSize:11,flex:1,overflow:"hidden",textOverflow:"ellipsis",whiteSpace:"nowrap",color:p.text}}>{op.name}</span>
                                    <span style={{fontSize:10,fontWeight:700,color:hc,background:`${hc}12`,padding:"1px 6px",borderRadius:4,flexShrink:0}}>{op.health}</span>
                                  </div>);
                                })}
                              </div>
                            </div>
                          </div>
                        </div>

                        {/* -- Warning Events -- */}
                        {warnEvts.length>0&&(
                          <div>
                            <SectionHeader icon="??" label="WARNING EVENTS" count={warnEvts.length} color={p.red}/>
                            <div style={{background:p.panel,border:`1px solid ${p.red}25`,borderRadius:8,overflow:"hidden"}}>
                              <div style={{overflowX:"auto",maxHeight:240}}>
                                <table style={{width:"100%",borderCollapse:"collapse",fontSize:11}}>
                                  <thead><tr style={{background:p.bg}}>{["Namespace","Object","Reason","Message","Count","Last Seen"].map(h=><th key={h} style={{padding:"5px 10px",textAlign:"left",color:p.textMute,fontWeight:700,borderBottom:`1px solid ${p.border}`,whiteSpace:"nowrap"}}>{h}</th>)}</tr></thead>
                                  <tbody>{warnEvts.map((e,i)=>(
                                    <tr key={i} style={{borderBottom:`1px solid ${p.border}30`,background:i%2===0?`${p.red}05`:"transparent"}}>
                                      <td style={{padding:"4px 10px",color:p.cyan}}>{e.namespace||"—"}</td>
                                      <td style={{padding:"4px 10px",fontWeight:600,color:p.accent,wordBreak:"break-all"}}>{e.name||"—"}</td>
                                      <td style={{padding:"4px 10px",color:p.yellow,fontWeight:600}}>{e.reason||"—"}</td>
                                      <td style={{padding:"4px 10px",color:p.text,maxWidth:260,wordBreak:"break-word"}}>{e.message||"—"}</td>
                                      <td style={{padding:"4px 10px",color:p.red,fontWeight:700}}>{e.count||1}×</td>
                                      <td style={{padding:"4px 10px",color:p.textMute,whiteSpace:"nowrap"}}>{e.last_time?new Date(e.last_time).toLocaleString("en-GB",{dateStyle:"short",timeStyle:"short"}):"—"}</td>
                                    </tr>
                                  ))}</tbody>
                                </table>
                              </div>
                            </div>
                          </div>
                        )}
                      </>
                    );
                  })()}
                </div>
              )}

              {/* -- NODES TAB -- */}
              {tab==="nodes"&&(
                <div className="g-gap">
                  {nodeActMsg&&<div style={{padding:"8px 14px",borderRadius:8,fontSize:13,fontWeight:500,
                    background:nodeActMsg.ok?`${p.green}15`:`${p.red}15`,border:`1px solid ${nodeActMsg.ok?p.green:p.red}40`,
                    color:nodeActMsg.ok?p.green:p.red}}>{nodeActMsg.ok?"?":"?"} {nodeActMsg.text}</div>}
                  <div style={{display:"flex",gap:8,alignItems:"center"}}>
                    <input style={{maxWidth:280,flex:1}} placeholder="Search nodes…" value={nodeQ} onChange={e=>setNodeQ(e.target.value)}/>
                    <span style={{fontSize:12,color:p.textMute}}>{filteredNodes.length} node{filteredNodes.length!==1?"s":""}</span>
                  </div>
                  <div className="card" style={{overflow:"hidden"}}>
                    <div className="tbl-wrap" style={{maxHeight:500}}>
                      <table><thead><tr>
                        <th style={{width:16}}></th>
                        <th style={{minWidth:160}}>NODE</th>
                        <th style={{width:120}}>ROLE</th>
                        <th style={{width:90}}>STATUS</th>
                        <th style={{width:100}}>IP</th>
                        <th style={{width:100}}>CPU ALLOC</th>
                        <th style={{width:130}}>CPU USAGE</th>
                        <th style={{width:100}}>MEM ALLOC</th>
                        <th style={{width:130}}>MEM USAGE</th>
                        <th style={{width:60}}>MAX PODS</th>
                        <th style={{width:80}}>AGE</th>
                        <th style={{minWidth:160}}>OS</th>
                        {canAct&&<th style={{width:220,textAlign:"center"}}>ACTIONS</th>}
                      </tr></thead>
                      <tbody>{filteredNodes.length===0?
                        <tr><td colSpan={canAct?13:12} style={{textAlign:"center",color:p.textMute,padding:20}}>No nodes found</td></tr>:
                        filteredNodes.map((n,i)=>{
                          const as=nodeActState[n.name];
                          const statusColor=n.ready?p.green:p.red;
                          return(
                            <tr key={i} style={{background:n.unschedulable?`${p.yellow}08`:""}}>
                              <td><div style={{width:8,height:8,borderRadius:"50%",background:statusColor,margin:"auto",boxShadow:`0 0 5px ${statusColor}80`}}/></td>
                              <td>
                                <div>
                                  <div style={{fontWeight:600,fontSize:12,color:p.accent}}>{n.name}</div>
                                  {n.unschedulable&&<span style={{fontSize:10,color:p.yellow,background:`${p.yellow}15`,borderRadius:4,padding:"0px 4px"}}>cordoned</span>}
                                  {n.pressures.length>0&&<span style={{fontSize:10,color:p.red}}> ?? {n.pressures.join(", ")}</span>}
                                </div>
                              </td>
                              <td><span style={{fontSize:11,fontWeight:600,color:n.role.includes("master")||n.role.includes("control")?p.cyan:p.textSub,background:n.role.includes("master")||n.role.includes("control")?`${p.cyan}12`:p.surface,padding:"2px 6px",borderRadius:5}}>{n.role}</span></td>
                              <td><OcpHealthBadge health={n.status}/></td>
                              <td><code style={{fontSize:11,color:p.textMute}}>{n.ip||"—"}</code></td>
                              <td><span style={{fontSize:12}}>{n.cpu_allocatable||n.cpu_capacity||"—"}</span></td>
                              <td><OcpBar pct={n.cpu_usage_pct}/></td>
                              <td><span style={{fontSize:12}}>{_ocpMem(n.mem_allocatable_gi)}</span></td>
                              <td><OcpBar pct={n.mem_usage_pct}/></td>
                              <td><span style={{fontSize:12,color:p.textMute}}>{n.pods_capacity||"—"}</span></td>
                              <td><span style={{fontSize:11,color:p.textMute}}>{_ocpAge(n.created_at)}</span></td>
                              <td><span style={{fontSize:11,color:p.textMute}}>{n.os_image||"—"}</span></td>
                              {canAct&&<td style={{textAlign:"center",padding:"3px 4px"}}>
                                {as?.status==="loading"
                                  ?<span style={{fontSize:11,color:p.textMute}}>? {as.action}…</span>
                                  :as?.status==="ok"
                                  ?<span style={{fontSize:11,color:p.green}}>? Done</span>
                                  :<div style={{display:"flex",gap:2,justifyContent:"center"}}>
                                    <button title="Cordon — mark unschedulable" onClick={()=>doNodeAction(n.name,"cordon")}
                                      style={{background:`${p.yellow}18`,border:`1px solid ${p.yellow}44`,borderRadius:5,padding:"2px 6px",cursor:"pointer",fontSize:10,color:p.yellow}}>?? Cordon</button>
                                    <button title="Uncordon — allow scheduling" onClick={()=>doNodeAction(n.name,"uncordon")}
                                      style={{background:`${p.green}18`,border:`1px solid ${p.green}44`,borderRadius:5,padding:"2px 6px",cursor:"pointer",fontSize:10,color:p.green}}>? Uncordon</button>
                                    <button title="Drain — evict all pods" onClick={()=>{ if(window.confirm(`Drain node ${n.name}? All pods will be evicted.`)) doNodeAction(n.name,"drain"); }}
                                      style={{background:`${p.red}18`,border:`1px solid ${p.red}44`,borderRadius:5,padding:"2px 6px",cursor:"pointer",fontSize:10,color:p.red}}>?? Drain</button>
                                  </div>}
                              </td>}
                            </tr>
                          );
                        })
                      }</tbody>
                    </table>
                  </div>
                </div>
              </div>
              )}

              {/* -- PODS TAB -- */}
              {tab==="pods"&&(
                <div className="g-gap">
                  <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"}}>
                    <select value={podNs} onChange={e=>setPodNs(e.target.value)} style={{maxWidth:220}}>
                      <option value="">All Namespaces ({pods.length} pods)</option>
                      {podNamespaces.map(ns=><option key={ns} value={ns}>{ns}</option>)}
                    </select>
                    <input style={{maxWidth:280,flex:1}} placeholder="Search pod name, phase…" value={podQ} onChange={e=>setPodQ(e.target.value)}/>
                    <span style={{fontSize:12,color:p.textMute}}>{filteredPods.length} pods</span>
                  </div>
                  <div className="card" style={{overflow:"hidden"}}>
                    <div className="tbl-wrap" style={{maxHeight:480}}>
                      <table><thead><tr>
                        <th style={{width:16}}></th>
                        <th style={{minWidth:200}}>POD NAME</th>
                        <th style={{minWidth:140}}>NAMESPACE</th>
                        <th style={{width:90}}>STATUS</th>
                        <th style={{width:70}}>READY</th>
                        <th style={{width:70}}>RESTARTS</th>
                        <th style={{minWidth:160}}>NODE</th>
                        <th style={{width:90}}>POD IP</th>
                        <th style={{width:80}}>AGE</th>
                      </tr></thead>
                      <tbody>{filteredPods.length===0?
                        <tr><td colSpan={9} style={{textAlign:"center",color:p.textMute,padding:20}}>No pods found</td></tr>:
                        filteredPods.map((pod,i)=>{
                          const pc=pod.phase==="Running"?p.green:pod.phase==="Failed"?p.red:pod.phase==="Pending"?p.yellow:"#64748b";
                          return(
                            <tr key={i} style={{cursor:"pointer"}} onClick={()=>{
                                setSelPod(pod);
                                setPodDetail(null);
                                setPodDetailLoading(true);
                                setPodModalTab("detail");
                                setPodLogs(null);
                                setPodLogsContainer("");
                                fetchOCPPodDetail(selCluster.id, pod.namespace, pod.name)
                                  .then(d=>setPodDetail(d)).catch(()=>setPodDetail({}))
                                  .finally(()=>setPodDetailLoading(false));
                              }}
                              title="Click for full details">
                              <td><div style={{width:7,height:7,borderRadius:"50%",background:pc,margin:"auto"}}/></td>
                              <td><span style={{fontSize:12,fontWeight:600,color:p.accent,wordBreak:"break-all",textDecoration:"underline",textDecorationStyle:"dotted"}}>{pod.name}</span></td>
                              <td><span style={{fontSize:11,color:p.cyan,background:`${p.cyan}10`,padding:"1px 5px",borderRadius:4}}>{pod.namespace}</span></td>
                              <td><span style={{fontSize:11,fontWeight:700,color:pc,background:`${pc}12`,padding:"2px 7px",borderRadius:5}}>{pod.phase}</span></td>
                              <td><span style={{fontSize:12}}>{pod.ready}</span></td>
                              <td><span style={{fontSize:12,color:pod.restarts>0?p.orange:p.textMute,fontWeight:pod.restarts>0?700:400}}>{pod.restarts}</span></td>
                              <td><span style={{fontSize:11,color:p.textMute}}>{pod.node||"—"}</span></td>
                              <td><code style={{fontSize:11,color:p.textMute}}>{pod.pod_ip||"—"}</code></td>
                              <td><span style={{fontSize:11,color:p.textMute}}>{_ocpAge(pod.start_time)}</span></td>
                            </tr>
                          );
                        })
                      }</tbody>
                    </table>
                  </div>
                </div>
              </div>
              )}

              {/* -- NAMESPACES TAB -- */}
              {tab==="ns"&&(
                <div className="g-gap">
                  <div style={{display:"flex",gap:8,alignItems:"center"}}>
                    <input style={{maxWidth:280}} placeholder="Search namespaces…" value={nsQ} onChange={e=>setNsQ(e.target.value)}/>
                    <span style={{fontSize:12,color:p.textMute}}>{filteredNs.length} namespace{filteredNs.length!==1?"s":""}</span>
                  </div>
                  <div className="card" style={{overflow:"hidden"}}>
                    <div className="tbl-wrap" style={{maxHeight:480}}>
                      <table><thead><tr>
                        <th style={{width:16}}></th>
                        <th style={{minWidth:200}}>NAMESPACE</th>
                        <th style={{minWidth:200}}>DISPLAY NAME</th>
                        <th style={{width:90}}>STATUS</th>
                        <th style={{minWidth:160}}>REQUESTER</th>
                        <th style={{width:80}}>AGE</th>
                        <th style={{minWidth:240}}>DESCRIPTION</th>
                      </tr></thead>
                      <tbody>{filteredNs.length===0?
                        <tr><td colSpan={7} style={{textAlign:"center",color:p.textMute,padding:20}}>No namespaces found</td></tr>:
                        filteredNs.map((ns,i)=>{
                          const ac=ns.phase==="Active";
                          return(
                            <tr key={i} style={{cursor:"pointer"}} onClick={()=>{
                                setSelNsDetail(ns);
                                setNsDetail(null);
                                setNsDetailLoading(true);
                                fetchOCPNamespaceDetail(selCluster.id, ns.name)
                                  .then(d=>setNsDetail(d)).catch(()=>setNsDetail({}))
                                  .finally(()=>setNsDetailLoading(false));
                              }}
                              title="Click for full details">
                              <td><div style={{width:7,height:7,borderRadius:"50%",background:ac?p.green:"#64748b",margin:"auto"}}/></td>
                              <td><span style={{fontSize:12,fontWeight:600,color:p.accent,textDecoration:"underline",textDecorationStyle:"dotted"}}>{ns.name}</span></td>
                              <td><span style={{fontSize:12}}>{ns.display_name||ns.name}</span></td>
                              <td><OcpHealthBadge health={ns.phase||"Active"}/></td>
                              <td><span style={{fontSize:11,color:p.textMute}}>{ns.requester||"—"}</span></td>
                              <td><span style={{fontSize:11,color:p.textMute}}>{_ocpAge(ns.created_at)}</span></td>
                              <td><span style={{fontSize:11,color:p.textMute}}>{ns.description||"—"}</span></td>
                            </tr>
                          );
                        })
                      }</tbody>
                    </table>
                  </div>
                </div>
              </div>
              )}

              {/* -- APPLICATIONS TAB (OpenShift Routes) -- */}
              {tab==="apps"&&(
                <div className="g-gap">
                  {/* Filters */}
                  <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"}}>
                    <input style={{maxWidth:260}} placeholder="Search applications…" value={routeQ}
                      onChange={e=>{setRouteQ(e.target.value);}}/>
                    <select value={routeNsF} onChange={e=>setRouteNsF(e.target.value)}
                      style={{padding:"5px 8px",borderRadius:7,fontSize:12,
                              background:p.surface,border:`1px solid ${p.border}`,color:p.text}}>
                      <option value="all">All Namespaces</option>
                      {[...new Set(routes.map(r=>r.namespace))].sort().map(ns=>(
                        <option key={ns} value={ns}>{ns}</option>
                      ))}
                    </select>
                    <span style={{fontSize:12,color:p.textMute}}>
                      {routes.filter(r=>{
                        const nok=routeNsF==="all"||r.namespace===routeNsF;
                        const qok=!routeQ||[r.name,r.namespace,r.host,r.service].some(s=>s?.toLowerCase().includes(routeQ.toLowerCase()));
                        return nok&&qok;
                      }).length} / {routes.length} route{routes.length!==1?"s":""}
                    </span>
                  </div>

                  {/* Table */}
                  <div className="card" style={{overflow:"hidden"}}>
                    <div className="tbl-wrap" style={{maxHeight:520}}>
                      <table><thead><tr>
                        <th style={{width:16}}></th>
                        <th style={{minWidth:200}}>APPLICATION / ROUTE</th>
                        <th style={{minWidth:160}}>NAMESPACE</th>
                        <th style={{minWidth:300}}>URL</th>
                        <th style={{width:90}}>TLS</th>
                        <th style={{minWidth:140}}>SERVICE</th>
                        <th style={{width:90}}>PORT</th>
                        <th style={{width:80}}>STATUS</th>
                      </tr></thead>
                      <tbody>
                        {(()=>{
                          const filtered=routes.filter(r=>{
                            const nok=routeNsF==="all"||r.namespace===routeNsF;
                            const qok=!routeQ||[r.name,r.namespace,r.host,r.service].some(s=>s?.toLowerCase().includes(routeQ.toLowerCase()));
                            return nok&&qok;
                          });
                          if(filtered.length===0) return(
                            <tr><td colSpan={8} style={{textAlign:"center",color:p.textMute,padding:24}}>
                              {routes.length===0?"No routes found — no OpenShift Routes configured in this cluster":"No routes match your filter"}
                            </td></tr>
                          );
                          return filtered.map((r,i)=>(
                            <tr key={i} style={{borderBottom:`1px solid ${p.border}10`}}>
                              <td>
                                <div style={{width:7,height:7,borderRadius:"50%",
                                  background:r.admitted?p.green:"#64748b",margin:"auto"}}/>
                              </td>
                              <td>
                                <span style={{fontSize:12,fontWeight:600,color:p.text}}>{r.name}</span>
                              </td>
                              <td>
                                <span style={{fontSize:11,padding:"1px 6px",borderRadius:4,
                                  background:`${p.accent||"#3b82f6"}18`,color:p.accent||"#3b82f6",
                                  fontWeight:600}}>{r.namespace}</span>
                              </td>
                              <td>
                                {r.url?(
                                  <a href={r.url} target="_blank" rel="noopener noreferrer"
                                    style={{fontSize:12,color:r.scheme==="https"?"#10b981":"#3b82f6",
                                            textDecoration:"none",wordBreak:"break-all",
                                            display:"flex",alignItems:"center",gap:4}}
                                    title={`Open ${r.url}`}>
                                    <span style={{fontSize:14}}>{r.scheme==="https"?"??":"??"}</span>
                                    <span style={{textDecoration:"underline",textDecorationStyle:"dotted"}}>
                                      {r.host}{r.path||""}
                                    </span>
                                    <span style={{fontSize:10,opacity:.6}}>?</span>
                                  </a>
                                ):(
                                  <span style={{fontSize:11,color:p.textMute}}>—</span>
                                )}
                              </td>
                              <td>
                                {r.tls?(
                                  <span style={{fontSize:10,fontWeight:700,padding:"2px 6px",borderRadius:4,
                                    background:"#10b98118",color:"#10b981"}}>{r.tls}</span>
                                ):(
                                  <span style={{fontSize:10,color:p.textMute}}>None</span>
                                )}
                              </td>
                              <td>
                                <code style={{fontSize:11,color:p.cyan||"#06b6d4"}}>{r.service||"—"}</code>
                              </td>
                              <td>
                                <span style={{fontSize:11,color:p.textMute}}>{r.target_port||"—"}</span>
                              </td>
                              <td>
                                <span style={{fontSize:10,fontWeight:700,padding:"2px 6px",borderRadius:4,
                                  background:r.admitted?"#10b98118":"#64748b18",
                                  color:r.admitted?"#10b981":"#64748b"}}>
                                  {r.admitted?"Admitted":"Pending"}
                                </span>
                              </td>
                            </tr>
                          ));
                        })()}
                      </tbody>
                    </table>
                  </div>
                </div>
              </div>
              )}

              {/* -- OPERATORS TAB -- */}
              {tab==="ops"&&(
                <div className="g-gap">
                  <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                    <span style={{fontSize:12,color:p.textMute}}>{operators.length} cluster operator{operators.length!==1?"s":""}</span>
                    <div style={{display:"flex",gap:6}}>
                      {["all","Available","Degraded","Progressing"].map(f=>{
                        const cnt=f==="all"?operators.length:operators.filter(o=>o.health===f).length;
                        const color=f==="Degraded"?p.red:f==="Progressing"?p.yellow:f==="Available"?p.green:p.textMute;
                        return(<button key={f} style={{fontSize:11,padding:"2px 8px",borderRadius:5,border:`1px solid ${color}40`,background:`${color}12`,color,cursor:"pointer"}}>{f} ({cnt})</button>);
                      })}
                    </div>
                  </div>
                  <div className="card" style={{overflow:"hidden"}}>
                    <div className="tbl-wrap" style={{maxHeight:500}}>
                      <table><thead><tr>
                        <th style={{minWidth:220}}>OPERATOR</th>
                        <th style={{width:110}}>HEALTH</th>
                        <th style={{width:90}}>AVAILABLE</th>
                        <th style={{width:100}}>PROGRESSING</th>
                        <th style={{width:90}}>DEGRADED</th>
                        <th style={{minWidth:200}}>VERSION</th>
                        <th style={{minWidth:260}}>MESSAGE</th>
                      </tr></thead>
                      <tbody>{operators.length===0?
                        <tr><td colSpan={7} style={{textAlign:"center",color:p.textMute,padding:20}}>No operators found</td></tr>:
                        operators.map((op,i)=>(
                          <tr key={i}>
                            <td><span style={{fontSize:12,fontWeight:600,color:p.text}}>{op.name}</span></td>
                            <td><OcpHealthBadge health={op.health}/></td>
                            <td><span style={{fontSize:11,color:op.available==="True"?p.green:p.red}}>{op.available}</span></td>
                            <td><span style={{fontSize:11,color:op.progressing==="True"?p.yellow:p.textMute}}>{op.progressing}</span></td>
                            <td><span style={{fontSize:11,color:op.degraded==="True"?p.red:p.textMute}}>{op.degraded}</span></td>
                            <td><code style={{fontSize:11,color:p.cyan}}>{op.version||"—"}</code></td>
                            <td><span style={{fontSize:11,color:p.textMute,wordBreak:"break-word"}}>{op.degraded_msg||"—"}</span></td>
                          </tr>
                        ))
                      }</tbody>
                    </table>
                  </div>
                </div>
              </div>
              )}

              {/* -- EVENTS TAB -- */}
              {tab==="events"&&(
                <div className="g-gap">
                  <div style={{display:"flex",gap:8,alignItems:"center",flexWrap:"wrap"}}>
                    {["all","Warning","Normal"].map(f=>{
                      const cnt=f==="all"?events.length:events.filter(e=>e.type===f).length;
                      const color=f==="Warning"?p.yellow:f==="Normal"?p.green:p.textMute;
                      return(<button key={f} onClick={()=>setEvtTypeFilter(f)}
                        style={{fontSize:11,padding:"3px 10px",borderRadius:5,border:`1px solid ${color}40`,
                          background:evtTypeFilter===f?`${color}20`:`${color}08`,color,cursor:"pointer",fontWeight:evtTypeFilter===f?700:400}}>
                        {f} ({cnt})</button>);
                    })}
                    <span style={{fontSize:12,color:p.textMute,marginLeft:4}}>{filteredEvts.length} events</span>
                  </div>
                  <div className="card" style={{overflow:"hidden"}}>
                    <div className="tbl-wrap" style={{maxHeight:480}}>
                      <table><thead><tr>
                        <th style={{width:80}}>TYPE</th>
                        <th style={{width:120}}>REASON</th>
                        <th style={{width:80}}>KIND</th>
                        <th style={{minWidth:160}}>OBJECT</th>
                        <th style={{width:100}}>NAMESPACE</th>
                        <th style={{width:50}}>COUNT</th>
                        <th style={{width:130}}>LAST SEEN</th>
                        <th style={{minWidth:260}}>MESSAGE</th>
                      </tr></thead>
                      <tbody>{filteredEvts.length===0?
                        <tr><td colSpan={8} style={{textAlign:"center",color:p.textMute,padding:20}}>No events found</td></tr>:
                        filteredEvts.map((ev,i)=>{
                          const wc=ev.type==="Warning"?p.yellow:p.green;
                          return(
                            <tr key={i}>
                              <td><span style={{fontSize:11,fontWeight:700,color:wc,background:`${wc}12`,padding:"2px 7px",borderRadius:5}}>{ev.type}</span></td>
                              <td><span style={{fontSize:11,fontWeight:600,color:p.text}}>{ev.reason}</span></td>
                              <td><span style={{fontSize:11,color:p.textMute}}>{ev.obj_kind}</span></td>
                              <td><span style={{fontSize:11,color:p.accent}}>{ev.obj_name}</span></td>
                              <td><span style={{fontSize:11,color:p.cyan}}>{ev.namespace||"—"}</span></td>
                              <td><span style={{fontSize:12,fontWeight:ev.count>1?700:400,color:ev.count>5?p.red:p.textMute}}>{ev.count}</span></td>
                              <td><span style={{fontSize:11,color:p.textMute}}>{ev.last_time?ev.last_time.slice(0,16).replace("T"," "):"—"}</span></td>
                              <td><span style={{fontSize:11,color:p.textMute,wordBreak:"break-word"}}>{ev.message}</span></td>
                            </tr>
                          );
                        })
                      }</tbody>
                    </table>
                  </div>
                </div>
              </div>
              )}

              {/* -- WORKLOADS TAB -- */}
              {tab==="workloads"&&(()=>{
                const WL_SUBTABS=[
                  {id:"deployments",      label:"Deployments",       icon:"??"},
                  {id:"deploymentconfigs",label:"DeploymentConfigs",  icon:"??"},
                  {id:"statefulsets",     label:"StatefulSets",       icon:"???"},
                  {id:"daemonsets",       label:"DaemonSets",         icon:"??"},
                  {id:"replicasets",      label:"ReplicaSets",        icon:"??"},
                  {id:"secrets",          label:"Secrets",            icon:"??"},
                  {id:"configmaps",       label:"ConfigMaps",         icon:"??"},
                  {id:"pods",             label:"Pods",               icon:"??"},
                ];
                const HAS_LOGS=new Set(["deployments","deploymentconfigs","statefulsets","daemonsets","replicasets","pods"]);
                const items=(wlData[wlSubTab]||[]);
                const allNs=[...new Set(items.map(r=>r.namespace||r.ns||""))].filter(Boolean).sort();
                const filtered=items.filter(r=>{
                  const ns=r.namespace||r.ns||"";
                  const nsOk=wlNsFilter==="all"||ns===wlNsFilter;
                  const q=wlQ.toLowerCase();
                  const qOk=!q||r.name?.toLowerCase().includes(q)||ns.toLowerCase().includes(q);
                  return nsOk&&qOk;
                });

                const badgeStyle=(color,bg)=>({display:"inline-block",padding:"2px 8px",borderRadius:99,fontSize:11,fontWeight:600,color,background:bg,border:`1px solid ${color}22`});
                const NsBadge=({ns})=><span style={badgeStyle("#6366f1","#6366f115")}>{ns||"-"}</span>;
                const ReplicaBadge=({ready,total})=>{
                  const ok=ready>=total&&total>0;
                  return <span style={badgeStyle(ok?"#10b981":"#f59e0b", ok?"#10b98115":"#f59e0b15")}>{ready}/{total}</span>;
                };
                const TypeBadge=({type})=>{
                  const short=type?.split("/").pop()||type||"Opaque";
                  return <span style={badgeStyle("#8b5cf6","#8b5cf615")}>{short}</span>;
                };

                function openDescribe(item){
                  setWlDescLoading(true); setWlDesc({title:`${wlSubTab} / ${item.name}`,data:null});
                  fetchOCPWorkloadDescribe(selCluster.id,wlSubTab,item.namespace,item.name)
                    .then(d=>setWlDesc({title:`${wlSubTab} / ${item.name}`,data:d}))
                    .catch(e=>setWlDesc({title:"Error",data:{error:e.message}}))
                    .finally(()=>setWlDescLoading(false));
                }
                function openLogs(item){
                  const kind=wlSubTab==="pods"?"pods":wlSubTab;
                  if(wlSubTab==="pods"){
                    setWlLogs({title:`Logs — ${item.name}`,pod:item.name,containers:[],logs:{"fetching...":""}});
                    setWlLogsContainer("");
                    setWlLogsLoading(true);
                    fetchOCPWorkloadLogs(selCluster.id,"pods",item.namespace,item.name)
                      .then(d=>{setWlLogs({title:`Logs — ${item.name}`,pod:item.name,containers:d.containers||[],logs:d.logs||{}});setWlLogsContainer("");})
                      .catch(e=>setWlLogs({title:"Error",pod:"",containers:[],logs:{error:e.message}}))
                      .finally(()=>setWlLogsLoading(false));
                  } else {
                    setWlLogs({title:`Logs — ${item.name}`,pod:"",containers:[],logs:{"fetching...":""}});
                    setWlLogsContainer("");
                    setWlLogsLoading(true);
                    fetchOCPWorkloadLogs(selCluster.id,kind,item.namespace,item.name)
                      .then(d=>{setWlLogs({title:`Logs — ${item.name} (pod: ${d.pod||"?"})`,pod:d.pod||"",containers:d.containers||[],logs:d.logs||{}});setWlLogsContainer("");})
                      .catch(e=>setWlLogs({title:"Error",pod:"",containers:[],logs:{error:e.message}}))
                      .finally(()=>setWlLogsLoading(false));
                  }
                }

                const renderRow=(item)=>{
                  const ns=item.namespace||item.ns||"";
                  const age=_ocpAge(item.created);
                  let statusCell=null;
                  if(wlSubTab==="deployments"||wlSubTab==="deploymentconfigs"||wlSubTab==="statefulsets"||wlSubTab==="replicasets"){
                    statusCell=<ReplicaBadge ready={item.ready_replicas??0} total={item.replicas??0}/>;
                  } else if(wlSubTab==="daemonsets"){
                    statusCell=<ReplicaBadge ready={item.ready??0} total={item.desired??0}/>;
                  } else if(wlSubTab==="secrets"){
                    statusCell=<TypeBadge type={item.type}/>;
                  } else if(wlSubTab==="configmaps"){
                    statusCell=<span style={{fontSize:12,color:"#64748b"}}>{item.data_keys??0} keys</span>;
                  } else if(wlSubTab==="pods"){
                    const phase=item.phase||item.status||"Unknown";
                    const c=phase==="Running"?"#10b981":phase==="Pending"?"#f59e0b":phase==="Succeeded"?"#6366f1":"#ef4444";
                    statusCell=<span style={badgeStyle(c,c+"15")}>{phase}</span>;
                  }
                  return(
                    <tr key={item.name+ns} style={{borderBottom:"1px solid #f1f5f9"}}>
                      <td style={{padding:"9px 12px",fontWeight:600,fontSize:13,color:"#1e293b",maxWidth:260,wordBreak:"break-all"}}>{item.name}</td>
                      <td style={{padding:"9px 12px"}}><NsBadge ns={ns}/></td>
                      <td style={{padding:"9px 12px"}}>{statusCell}</td>
                      <td style={{padding:"9px 12px",fontSize:12,color:"#64748b"}}>{age}</td>
                      <td style={{padding:"9px 8px",whiteSpace:"nowrap"}}>
                        <button title="Describe" style={{background:"#f1f5f9",border:"none",borderRadius:6,padding:"4px 9px",cursor:"pointer",fontSize:12,color:"#475569",marginRight:4}} onClick={()=>openDescribe(item)}>?? Describe</button>
                        {HAS_LOGS.has(wlSubTab)&&<button title="Logs" style={{background:"#f0fdf4",border:"none",borderRadius:6,padding:"4px 9px",cursor:"pointer",fontSize:12,color:"#16a34a",marginRight:4}} onClick={()=>openLogs(item)}>?? Logs</button>}
                        {canAct&&<button title="Delete" style={{background:"#fff1f2",border:"none",borderRadius:6,padding:"4px 9px",cursor:"pointer",fontSize:12,color:"#ef4444"}} onClick={()=>{setWlDelTarget({kind:wlSubTab,namespace:ns,name:item.name});setWlDelErr(null);}}>???</button>}
                      </td>
                    </tr>
                  );
                };

                return(
                  <div style={{padding:"20px 24px"}}>
                    {/* Header */}
                    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:18}}>
                      <div>
                        <h2 style={{margin:0,fontSize:20,fontWeight:700,color:"#0f172a"}}>?? Workloads</h2>
                        <p style={{margin:"4px 0 0",fontSize:13,color:"#64748b"}}>Manage Kubernetes workload resources across all namespaces</p>
                      </div>
                      <button className="btn btn-primary" onClick={()=>loadTab("workloads")} style={{fontSize:12}}>? Refresh</button>
                    </div>

                    {/* Sub-tab pills */}
                    <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:18}}>
                      {WL_SUBTABS.map(st=>(
                        <button key={st.id} onClick={()=>{setWlSubTab(st.id);setWlNsFilter("all");setWlQ("");}}
                          style={{padding:"6px 14px",borderRadius:20,border:"none",cursor:"pointer",fontSize:12,fontWeight:600,
                            background:wlSubTab===st.id?"#ee0000":"#f1f5f9",
                            color:wlSubTab===st.id?"#fff":"#475569",
                            boxShadow:wlSubTab===st.id?"0 2px 8px #ee000033":"none",
                            transition:"all .15s"}}>
                          {st.icon} {st.label}
                          <span style={{marginLeft:6,background:wlSubTab===st.id?"#ffffff33":"#e2e8f0",borderRadius:10,padding:"1px 7px",fontSize:11}}>
                            {(wlData[st.id]||[]).length}
                          </span>
                        </button>
                      ))}
                    </div>

                    {/* Filters row */}
                    <div style={{display:"flex",gap:10,alignItems:"center",marginBottom:14,flexWrap:"wrap"}}>
                      <select value={wlNsFilter} onChange={e=>setWlNsFilter(e.target.value)}
                        style={{padding:"6px 10px",borderRadius:7,border:"1px solid #e2e8f0",fontSize:12,color:"#374151",background:"#fff",minWidth:140}}>
                        <option value="all">All Namespaces</option>
                        {allNs.map(n=><option key={n} value={n}>{n}</option>)}
                      </select>
                      <input value={wlQ} onChange={e=>setWlQ(e.target.value)} placeholder="Search name…"
                        style={{padding:"6px 10px",borderRadius:7,border:"1px solid #e2e8f0",fontSize:12,flex:1,maxWidth:260}}/>
                      <span style={{fontSize:12,color:"#94a3b8",marginLeft:"auto"}}>
                        {filtered.length} of {items.length} items
                      </span>
                    </div>

                    {/* Loading / Error */}
                    {(wlLoading||tabLoading)&&<LoadState msg={`Loading ${WL_SUBTABS.find(s=>s.id===wlSubTab)?.label||""}…`}/>}
                    {!wlLoading&&!tabLoading&&(
                      filtered.length===0
                        ?<div style={{textAlign:"center",padding:48,color:"#94a3b8",fontSize:13}}>No {wlSubTab} found{wlNsFilter!=="all"?` in namespace "${wlNsFilter}"`:""}.</div>
                        :<div style={{background:"#fff",borderRadius:12,border:"1px solid #e2e8f0",overflow:"hidden",boxShadow:"0 1px 4px #0000000a"}}>
                          <table style={{width:"100%",borderCollapse:"collapse"}}>
                            <thead>
                              <tr style={{background:"#f8fafc",borderBottom:"2px solid #e2e8f0"}}>
                                <th style={{padding:"10px 12px",textAlign:"left",fontSize:12,fontWeight:700,color:"#475569",letterSpacing:.5}}>NAME</th>
                                <th style={{padding:"10px 12px",textAlign:"left",fontSize:12,fontWeight:700,color:"#475569",letterSpacing:.5}}>NAMESPACE</th>
                                <th style={{padding:"10px 12px",textAlign:"left",fontSize:12,fontWeight:700,color:"#475569",letterSpacing:.5}}>
                                  {wlSubTab==="daemonsets"?"READY/DESIRED":
                                   wlSubTab==="secrets"?"TYPE":
                                   wlSubTab==="configmaps"?"DATA":
                                   wlSubTab==="pods"?"PHASE":"READY/REPLICAS"}
                                </th>
                                <th style={{padding:"10px 12px",textAlign:"left",fontSize:12,fontWeight:700,color:"#475569",letterSpacing:.5}}>AGE</th>
                                <th style={{padding:"10px 12px",textAlign:"left",fontSize:12,fontWeight:700,color:"#475569",letterSpacing:.5}}>ACTIONS</th>
                              </tr>
                            </thead>
                            <tbody>
                              {filtered.map(item=>renderRow(item))}
                            </tbody>
                          </table>
                        </div>
                    )}
                  </div>
                );
              })()}

              {/* -- STORAGE TAB -- */}
              {tab==="storage"&&(()=>{
                const filteredPvs=pvs.filter(pv=>!pvQ||pv.name.toLowerCase().includes(pvQ.toLowerCase()));
                const allPvcNs=[...new Set(pvcs.map(p=>p.namespace))].sort();
                const filteredPvcs=pvcs.filter(pvc=>{
                  const nsOk=pvcNsFilter==="all"||pvc.namespace===pvcNsFilter;
                  const qOk=!pvcQ||pvc.name.toLowerCase().includes(pvcQ.toLowerCase())||pvc.namespace.toLowerCase().includes(pvcQ.toLowerCase());
                  return nsOk&&qOk;
                });
                const StatusDot=({phase})=>{
                  const c=phase==="Bound"?"#10b981":phase==="Available"?"#10b981":phase==="Released"?"#f59e0b":phase==="Failed"?"#ef4444":"#6b7280";
                  const bg=phase==="Bound"?"#10b98118":phase==="Available"?"#10b98118":phase==="Released"?"#f59e0b18":phase==="Failed"?"#ef444418":"#6b728018";
                  return <span style={{fontSize:11,fontWeight:700,padding:"2px 9px",borderRadius:20,background:bg,color:c,border:`1px solid ${c}30`}}>{phase||"—"}</span>;
                };
                const actionBtn=(label,icon,color,onClick,title)=>(
                  <button onClick={onClick} title={title||label}
                    style={{fontSize:11,padding:"3px 7px",borderRadius:5,fontWeight:600,cursor:"pointer",
                            background:`${color}15`,border:`1px solid ${color}30`,color,display:"inline-flex",alignItems:"center",gap:3,whiteSpace:"nowrap"}}>
                    {icon} {label}
                  </button>
                );
                const openDescribe=async(fetcher,title)=>{
                  setStoreDescLoading(true); setStoreDesc({title,data:null});
                  try{ setStoreDesc({title,data:await fetcher()}); }catch(e){ setStoreDesc({title,data:{error:e.message}}); }
                  setStoreDescLoading(false);
                };
                const openEvents=async(fetcher,title)=>{
                  setStoreEvtsLoading(true); setStoreEvts({title,events:null});
                  try{ setStoreEvts({title,events:await fetcher()}); }catch(e){ setStoreEvts({title,events:[]}); }
                  setStoreEvtsLoading(false);
                };

                return(
                <div className="g-gap">
                  {/* Sub-tab bar */}
                  <div style={{display:"flex",gap:0,borderBottom:`1px solid ${p.border}`,marginBottom:2}}>
                    {[{id:"sc",label:"Storage Classes",icon:"??",count:storageClasses.length},
                      {id:"pv",label:"PersistentVolumes",icon:"??",count:pvs.length},
                      {id:"pvc",label:"PersistentVolumeClaims",icon:"???",count:pvcs.length},
                    ].map(st=>(
                      <button key={st.id} onClick={()=>setStorageSubTab(st.id)}
                        style={{padding:"8px 18px",border:"none",cursor:"pointer",fontSize:12,fontWeight:storageSubTab===st.id?700:500,
                                background:"transparent",borderBottom:`2px solid ${storageSubTab===st.id?p.accent:"transparent"}`,
                                color:storageSubTab===st.id?p.accent:p.textMute,transition:"all .15s",display:"flex",alignItems:"center",gap:6}}>
                        {st.icon} {st.label}
                        <span style={{fontSize:10,padding:"1px 7px",borderRadius:10,background:`${p.accent}18`,color:p.accent,fontWeight:700}}>{st.count}</span>
                      </button>
                    ))}
                    <div style={{flex:1}}/>
                    {canAct&&storageSubTab==="pvc"&&(
                      <button className="btn btn-primary btn-sm" style={{fontSize:11,padding:"5px 12px",alignSelf:"center",marginRight:4}}
                        onClick={()=>{setCreatePVCErr(null);setCreatePVCForm({name:"",namespace:allPvcNs[0]||"default",storage:"1Gi",access_mode:"ReadWriteOnce",storage_class:storageClasses[0]?.name||"",volume_mode:"Filesystem"});setShowCreatePVC(true);}}>
                        + Create PVC
                      </button>
                    )}
                  </div>

                  {/* - Storage Classes - */}
                  {storageSubTab==="sc"&&(
                    storageClasses.length===0
                      ?<div style={{textAlign:"center",padding:40,color:p.textMute,fontSize:13}}>No storage classes found</div>
                      :<div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(340px,1fr))",gap:12}}>
                        {storageClasses.map((sc,i)=>{
                          const isDefault=sc.is_default;
                          const accentC=isDefault?p.green:p.accent;
                          return(
                            <div key={i} style={{background:p.panel,border:`1px solid ${isDefault?p.green+"50":p.border}`,borderRadius:12,padding:"14px 18px",position:"relative"}}>
                              {isDefault&&(
                                <span style={{position:"absolute",top:10,right:12,fontSize:10,fontWeight:700,
                                             color:p.green,background:`${p.green}18`,border:`1px solid ${p.green}40`,
                                             borderRadius:4,padding:"2px 7px"}}>DEFAULT</span>
                              )}
                              <div style={{fontWeight:700,fontSize:14,color:accentC,marginBottom:6,paddingRight:64,wordBreak:"break-all"}}>{sc.name}</div>
                              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:6,marginBottom:8}}>
                                {[
                                  {label:"Provisioner",  val:sc.provisioner},
                                  {label:"Reclaim",      val:sc.reclaim_policy},
                                  {label:"Binding Mode", val:sc.binding_mode},
                                  {label:"Expansion",    val:sc.allow_expansion?"? Allowed":"? Not Allowed"},
                                  {label:"Created",      val:sc.created_at?sc.created_at.slice(0,10):"—"},
                                ].map((row,ri)=>(
                                  <div key={ri} style={{background:p.surface,borderRadius:6,padding:"5px 10px",border:`1px solid ${p.border}`}}>
                                    <div style={{fontSize:9,color:p.textMute,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",marginBottom:2}}>{row.label}</div>
                                    <div style={{fontSize:12,fontWeight:500,wordBreak:"break-all",fontFamily:row.label==="Provisioner"?"monospace":"inherit"}}>{row.val||"—"}</div>
                                  </div>
                                ))}
                              </div>
                              {sc.parameters&&Object.keys(sc.parameters).length>0&&(
                                <div style={{borderTop:`1px solid ${p.border}`,paddingTop:8,marginTop:4,marginBottom:8}}>
                                  <div style={{fontSize:10,color:p.textMute,fontWeight:700,textTransform:"uppercase",letterSpacing:".5px",marginBottom:5}}>Parameters</div>
                                  <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
                                    {Object.entries(sc.parameters).map(([k,v],pi)=>(
                                      <span key={pi} style={{fontSize:10,padding:"2px 7px",borderRadius:10,
                                                             background:`${p.cyan}12`,border:`1px solid ${p.cyan}25`,
                                                             color:p.cyan,fontFamily:"monospace"}}>
                                        {k}={v}
                                      </span>
                                    ))}
                                  </div>
                                </div>
                              )}
                              {/* Actions */}
                              <div style={{display:"flex",gap:6,marginTop:8,flexWrap:"wrap",borderTop:`1px solid ${p.border}`,paddingTop:8}}>
                                {actionBtn("Describe","??",p.accent,()=>openDescribe(()=>fetchOCPDescribeSC(selCluster.id,sc.name),`StorageClass: ${sc.name}`))}
                                {canAct&&actionBtn("Delete","???","#ef4444",()=>{setStoreDelErr(null);setStoreDelTarget({type:"sc",name:sc.name});},"Delete StorageClass")}
                              </div>
                            </div>
                          );
                        })}
                      </div>
                  )}

                  {/* - PersistentVolumes - */}
                  {storageSubTab==="pv"&&(
                    <div>
                      <div style={{display:"flex",gap:8,marginBottom:10,alignItems:"center",flexWrap:"wrap"}}>
                        <input placeholder="Search PVs…" value={pvQ} onChange={e=>setPvQ(e.target.value)}
                          style={{fontSize:12,padding:"5px 10px",borderRadius:6,border:`1px solid ${p.border}`,background:p.surface,color:p.text,width:220}}/>
                        <span style={{fontSize:12,color:p.textMute,marginLeft:4}}>{filteredPvs.length} volume{filteredPvs.length!==1?"s":""}</span>
                      </div>
                      {filteredPvs.length===0
                        ?<div style={{textAlign:"center",padding:40,color:p.textMute,fontSize:13}}>No PersistentVolumes found</div>
                        :<div style={{overflowX:"auto"}}>
                          <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
                            <thead>
                              <tr style={{background:p.surface}}>
                                {["NAME","CAPACITY","ACCESS MODES","RECLAIM","STATUS","CLAIM","STORAGE CLASS","AGE","ACTIONS"].map(h=>(
                                  <th key={h} style={{padding:"7px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:p.textMute,
                                                      letterSpacing:".5px",borderBottom:`1px solid ${p.border}`,whiteSpace:"nowrap"}}>{h}</th>
                                ))}
                              </tr>
                            </thead>
                            <tbody>
                              {filteredPvs.map((pv,i)=>(
                                <tr key={i} style={{borderBottom:`1px solid ${p.border}40`,transition:"background .1s"}}
                                  onMouseEnter={e=>e.currentTarget.style.background=p.surface}
                                  onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                                  <td style={{padding:"8px 10px",fontWeight:600,color:p.accent,wordBreak:"break-all",maxWidth:200}}>{pv.name}</td>
                                  <td style={{padding:"8px 10px",fontFamily:"monospace",fontWeight:700,color:p.text}}>{pv.capacity}</td>
                                  <td style={{padding:"8px 10px",color:p.text}}>{pv.access_modes.join(", ")||"—"}</td>
                                  <td style={{padding:"8px 10px"}}><span style={{fontSize:10,padding:"2px 7px",borderRadius:4,background:`${p.cyan}18`,color:p.cyan,fontWeight:700}}>{pv.reclaim_policy}</span></td>
                                  <td style={{padding:"8px 10px"}}><StatusDot phase={pv.status}/></td>
                                  <td style={{padding:"8px 10px",fontSize:11,color:p.textSub,maxWidth:180,wordBreak:"break-all"}}>{pv.claim_namespace&&pv.claim_name?`${pv.claim_namespace}/${pv.claim_name}`:"—"}</td>
                                  <td style={{padding:"8px 10px",fontFamily:"monospace",fontSize:11,color:p.textMute}}>{pv.storage_class}</td>
                                  <td style={{padding:"8px 10px",color:p.textMute,fontSize:11,whiteSpace:"nowrap"}}>{_ocpAge(pv.created_at)}</td>
                                  <td style={{padding:"8px 10px"}}>
                                    <div style={{display:"flex",gap:4,flexWrap:"wrap"}}>
                                      {actionBtn("Describe","??",p.accent,()=>openDescribe(()=>fetchOCPDescribePV(selCluster.id,pv.name),`PV: ${pv.name}`))}
                                      {actionBtn("Events","??","#f59e0b",()=>openEvents(()=>fetchOCPPVEvents(selCluster.id,pv.name),`Events: PV / ${pv.name}`))}
                                      {canAct&&actionBtn("Delete","???","#ef4444",()=>{setStoreDelErr(null);setStoreDelTarget({type:"pv",name:pv.name});})}
                                    </div>
                                  </td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      }
                    </div>
                  )}

                  {/* - PersistentVolumeClaims - */}
                  {storageSubTab==="pvc"&&(
                    <div>
                      <div style={{display:"flex",gap:8,marginBottom:10,alignItems:"center",flexWrap:"wrap"}}>
                        <input placeholder="Search PVCs…" value={pvcQ} onChange={e=>setPvcQ(e.target.value)}
                          style={{fontSize:12,padding:"5px 10px",borderRadius:6,border:`1px solid ${p.border}`,background:p.surface,color:p.text,width:220}}/>
                        <select value={pvcNsFilter} onChange={e=>setPvcNsFilter(e.target.value)}
                          style={{fontSize:12,padding:"5px 8px",borderRadius:6,border:`1px solid ${p.border}`,background:p.surface,color:p.text}}>
                          <option value="all">All Namespaces</option>
                          {allPvcNs.map(ns=><option key={ns} value={ns}>{ns}</option>)}
                        </select>
                        <span style={{fontSize:12,color:p.textMute}}>{filteredPvcs.length} claim{filteredPvcs.length!==1?"s":""}</span>
                      </div>
                      {filteredPvcs.length===0
                        ?<div style={{textAlign:"center",padding:40,color:p.textMute,fontSize:13}}>No PersistentVolumeClaims found</div>
                        :<div style={{overflowX:"auto"}}>
                          <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
                            <thead>
                              <tr style={{background:p.surface}}>
                                {["NAME","NAMESPACE","STATUS","VOLUME","CAPACITY","ACCESS MODES","STORAGE CLASS","AGE","ACTIONS"].map(h=>(
                                  <th key={h} style={{padding:"7px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:p.textMute,
                                                      letterSpacing:".5px",borderBottom:`1px solid ${p.border}`,whiteSpace:"nowrap"}}>{h}</th>
                                ))}
                              </tr>
                            </thead>
                            <tbody>
                              {filteredPvcs.map((pvc,i)=>(
                                <tr key={i} style={{borderBottom:`1px solid ${p.border}40`,transition:"background .1s"}}
                                  onMouseEnter={e=>e.currentTarget.style.background=p.surface}
                                  onMouseLeave={e=>e.currentTarget.style.background="transparent"}>
                                  <td style={{padding:"8px 10px",fontWeight:600,color:p.accent,wordBreak:"break-all",maxWidth:200}}>{pvc.name}</td>
                                  <td style={{padding:"8px 10px"}}>
                                    <span style={{fontSize:11,padding:"2px 8px",borderRadius:20,background:`${p.accent}12`,color:p.accent,border:`1px solid ${p.accent}25`,fontWeight:600}}>{pvc.namespace}</span>
                                  </td>
                                  <td style={{padding:"8px 10px"}}><StatusDot phase={pvc.status}/></td>
                                  <td style={{padding:"8px 10px",fontFamily:"monospace",fontSize:11,color:p.textSub,maxWidth:180,wordBreak:"break-all"}}>{pvc.volume||"—"}</td>
                                  <td style={{padding:"8px 10px",fontFamily:"monospace",fontWeight:700,color:p.text}}>{pvc.capacity||"—"}</td>
                                  <td style={{padding:"8px 10px",fontSize:11,color:p.text}}>{pvc.access_modes.join(", ")||"—"}</td>
                                  <td style={{padding:"8px 10px",fontFamily:"monospace",fontSize:11,color:p.textMute}}>{pvc.storage_class||"—"}</td>
                                  <td style={{padding:"8px 10px",color:p.textMute,fontSize:11,whiteSpace:"nowrap"}}>{_ocpAge(pvc.created_at)}</td>
                                  <td style={{padding:"8px 10px"}}>
                                    <div style={{display:"flex",gap:4,flexWrap:"wrap"}}>
                                      {actionBtn("Describe","??",p.accent,()=>openDescribe(()=>fetchOCPDescribePVC(selCluster.id,pvc.namespace,pvc.name),`PVC: ${pvc.namespace}/${pvc.name}`))}
                                      {actionBtn("Events","??","#f59e0b",()=>openEvents(()=>fetchOCPPVCEvents(selCluster.id,pvc.namespace,pvc.name),`Events: PVC / ${pvc.name}`))}
                                      {canAct&&actionBtn("Delete","???","#ef4444",()=>{setStoreDelErr(null);setStoreDelTarget({type:"pvc",name:pvc.name,namespace:pvc.namespace});})}
                                    </div>
                                  </td>
                                </tr>
                              ))}
                            </tbody>
                          </table>
                        </div>
                      }
                    </div>
                  )}

                </div>
                );
              })()}
            </div>
          )}
        </div>
      )}

      {/* -- Storage Describe Modal -- */}
      {storeDesc&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2500,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}
          onClick={e=>e.target===e.currentTarget&&setStoreDesc(null)}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:14,padding:24,width:"100%",maxWidth:820,boxShadow:"0 20px 60px #00000080",maxHeight:"88vh",display:"flex",flexDirection:"column"}}>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:16}}>
              <span style={{fontSize:22}}>??</span>
              <div style={{fontWeight:700,fontSize:14,color:p.accent,flex:1,wordBreak:"break-all"}}>{storeDesc.title}</div>
              <button onClick={()=>setStoreDesc(null)} style={{background:`${p.red}12`,border:`1px solid ${p.red}30`,color:p.red,borderRadius:6,padding:"3px 10px",cursor:"pointer",fontWeight:700}}>?</button>
            </div>
            <div style={{overflowY:"auto",flex:1}}>
              {storeDescLoading
                ?<div style={{textAlign:"center",padding:40,color:p.textMute}}>Loading…</div>
                :storeDesc.data?.error
                  ?<div style={{color:"#ef4444",fontSize:13}}>{storeDesc.data.error}</div>
                  :<pre style={{fontSize:11,lineHeight:1.7,color:p.text,background:p.surface,border:`1px solid ${p.border}`,
                                borderRadius:8,padding:16,overflowX:"auto",whiteSpace:"pre-wrap",wordBreak:"break-all",fontFamily:"monospace"}}>
                    {JSON.stringify(storeDesc.data,null,2)}
                  </pre>
              }
            </div>
          </div>
        </div>
      )}

      {/* -- Storage Events Modal -- */}
      {storeEvts&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2500,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}
          onClick={e=>e.target===e.currentTarget&&setStoreEvts(null)}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:14,padding:24,width:"100%",maxWidth:760,boxShadow:"0 20px 60px #00000080",maxHeight:"88vh",display:"flex",flexDirection:"column"}}>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:16}}>
              <span style={{fontSize:22}}>??</span>
              <div style={{fontWeight:700,fontSize:14,color:"#f59e0b",flex:1,wordBreak:"break-all"}}>{storeEvts.title}</div>
              <button onClick={()=>setStoreEvts(null)} style={{background:`${p.red}12`,border:`1px solid ${p.red}30`,color:p.red,borderRadius:6,padding:"3px 10px",cursor:"pointer",fontWeight:700}}>?</button>
            </div>
            {storeEvtsLoading
              ?<div style={{textAlign:"center",padding:40,color:p.textMute}}>Loading events…</div>
              :!storeEvts.events||storeEvts.events.length===0
                ?<div style={{textAlign:"center",padding:40,color:p.textMute,fontSize:13}}>No events found</div>
                :<div style={{overflowY:"auto",flex:1}}>
                  <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
                    <thead>
                      <tr style={{background:p.surface}}>
                        {["TYPE","REASON","MESSAGE","COUNT","LAST SEEN"].map(h=>(
                          <th key={h} style={{padding:"6px 10px",textAlign:"left",fontSize:10,fontWeight:700,color:p.textMute,letterSpacing:".5px",borderBottom:`1px solid ${p.border}`}}>{h}</th>
                        ))}
                      </tr>
                    </thead>
                    <tbody>
                      {storeEvts.events.map((ev,i)=>(
                        <tr key={i} style={{borderBottom:`1px solid ${p.border}40`}}>
                          <td style={{padding:"6px 10px"}}>
                            <span style={{fontSize:11,fontWeight:700,padding:"1px 7px",borderRadius:4,
                                         background:ev.type==="Warning"?"#ef444420":"#10b98120",
                                         color:ev.type==="Warning"?"#ef4444":"#10b981"}}>{ev.type}</span>
                          </td>
                          <td style={{padding:"6px 10px",fontWeight:600,color:p.text,fontSize:11}}>{ev.reason}</td>
                          <td style={{padding:"6px 10px",color:p.textSub,maxWidth:320,wordBreak:"break-word"}}>{ev.message}</td>
                          <td style={{padding:"6px 10px",textAlign:"center",color:p.textMute}}>{ev.count}</td>
                          <td style={{padding:"6px 10px",color:p.textMute,fontSize:11,whiteSpace:"nowrap"}}>{ev.last_seen?ev.last_seen.slice(0,19).replace("T"," "):"—"}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
            }
          </div>
        </div>
      )}

      {/* -- Storage Delete Confirm -- */}
      {storeDelTarget&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2600,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}>
          <div style={{background:p.panel,border:`1px solid #ef444440`,borderRadius:14,padding:28,width:"100%",maxWidth:420,boxShadow:"0 20px 60px #00000080"}}>
            <div style={{fontSize:20,marginBottom:10,textAlign:"center"}}>???</div>
            <div style={{fontWeight:700,fontSize:15,color:"#ef4444",textAlign:"center",marginBottom:8}}>Delete {storeDelTarget.type.toUpperCase()}</div>
            <div style={{fontSize:13,color:p.text,textAlign:"center",marginBottom:6}}>
              <span style={{fontFamily:"monospace",background:p.surface,padding:"2px 8px",borderRadius:4,fontWeight:700,wordBreak:"break-all"}}>
                {storeDelTarget.namespace?`${storeDelTarget.namespace}/`:""}{storeDelTarget.name}
              </span>
            </div>
            <div style={{fontSize:12,color:p.textMute,textAlign:"center",marginBottom:20}}>This action is irreversible.</div>
            {storeDelErr&&<div style={{fontSize:12,color:"#ef4444",marginBottom:10,textAlign:"center"}}>{storeDelErr}</div>}
            <div style={{display:"flex",gap:10,justifyContent:"center"}}>
              <button onClick={()=>{setStoreDelTarget(null);setStoreDelErr(null);}} disabled={storeDelBusy}
                style={{padding:"8px 24px",borderRadius:7,border:`1px solid ${p.border}`,background:p.surface,color:p.text,fontSize:13,cursor:"pointer",fontWeight:600}}>Cancel</button>
              <button disabled={storeDelBusy} onClick={async()=>{
                setStoreDelBusy(true); setStoreDelErr(null);
                try{
                  const t=storeDelTarget;
                  if(t.type==="sc") await deleteOCPSC(selCluster.id,t.name);
                  else if(t.type==="pv") await deleteOCPPV(selCluster.id,t.name);
                  else if(t.type==="pvc") await deleteOCPPVC(selCluster.id,t.namespace,t.name);
                  setStoreDelTarget(null);
                  // Reload storage
                  const [sc,pv_,pvc_]=await Promise.all([fetchOCPStorageClasses(selCluster.id),fetchOCPPVs(selCluster.id),fetchOCPPVCs(selCluster.id)]);
                  setStorageClasses(sc||[]); setPvs(pv_||[]); setPvcs(pvc_||[]);
                }catch(e){ setStoreDelErr(e.message); }
                setStoreDelBusy(false);
              }} style={{padding:"8px 24px",borderRadius:7,border:"none",background:"#ef4444",color:"#fff",fontSize:13,cursor:"pointer",fontWeight:700}}>
                {storeDelBusy?"Deleting…":"Delete"}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* -- Create PVC Modal -- */}
      {showCreatePVC&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2600,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:14,padding:28,width:"100%",maxWidth:440,boxShadow:"0 20px 60px #00000080"}}>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:18}}>
              <span style={{fontSize:22}}>???</span>
              <div style={{fontWeight:700,fontSize:15,color:p.accent,flex:1}}>Create PersistentVolumeClaim</div>
              <button onClick={()=>setShowCreatePVC(false)} style={{background:`${p.red}12`,border:`1px solid ${p.red}30`,color:p.red,borderRadius:6,padding:"3px 10px",cursor:"pointer",fontWeight:700}}>?</button>
            </div>
            <div style={{display:"flex",flexDirection:"column",gap:12}}>
              {[
                {label:"Name",         key:"name",    placeholder:"my-pvc"},
                {label:"Storage Size", key:"storage", placeholder:"1Gi"},
              ].map(f=>(
                <div key={f.key}>
                  <label style={{fontSize:11,fontWeight:700,color:p.textMute,display:"block",marginBottom:4,textTransform:"uppercase",letterSpacing:".5px"}}>{f.label}</label>
                  <input value={createPVCForm[f.key]} onChange={e=>setCreatePVCForm(v=>({...v,[f.key]:e.target.value}))}
                    placeholder={f.placeholder}
                    style={{width:"100%",padding:"7px 10px",borderRadius:7,border:`1px solid ${p.border}`,background:p.surface,color:p.text,fontSize:13,boxSizing:"border-box"}}/>
                </div>
              ))}
              <div>
                <label style={{fontSize:11,fontWeight:700,color:p.textMute,display:"block",marginBottom:4,textTransform:"uppercase",letterSpacing:".5px"}}>Namespace</label>
                {namespaces.length>0
                  ? <select value={createPVCForm.namespace} onChange={e=>setCreatePVCForm(v=>({...v,namespace:e.target.value}))}
                      style={{width:"100%",padding:"7px 10px",borderRadius:7,border:`1px solid ${p.border}`,background:p.surface,color:p.text,fontSize:13}}>
                      {namespaces.map(ns=><option key={ns.name} value={ns.name}>{ns.name}</option>)}
                    </select>
                  : <input value={createPVCForm.namespace} onChange={e=>setCreatePVCForm(v=>({...v,namespace:e.target.value}))}
                      placeholder="default"
                      style={{width:"100%",padding:"7px 10px",borderRadius:7,border:`1px solid ${p.border}`,background:p.surface,color:p.text,fontSize:13,boxSizing:"border-box"}}/>
                }
              </div>
              <div>
                <label style={{fontSize:11,fontWeight:700,color:p.textMute,display:"block",marginBottom:4,textTransform:"uppercase",letterSpacing:".5px"}}>Access Mode</label>
                <select value={createPVCForm.access_mode} onChange={e=>setCreatePVCForm(v=>({...v,access_mode:e.target.value}))}
                  style={{width:"100%",padding:"7px 10px",borderRadius:7,border:`1px solid ${p.border}`,background:p.surface,color:p.text,fontSize:13}}>
                  {["ReadWriteOnce","ReadOnlyMany","ReadWriteMany","ReadWriteOncePod"].map(m=><option key={m} value={m}>{m}</option>)}
                </select>
              </div>
              <div>
                <label style={{fontSize:11,fontWeight:700,color:p.textMute,display:"block",marginBottom:4,textTransform:"uppercase",letterSpacing:".5px"}}>Storage Class</label>
                <select value={createPVCForm.storage_class} onChange={e=>setCreatePVCForm(v=>({...v,storage_class:e.target.value}))}
                  style={{width:"100%",padding:"7px 10px",borderRadius:7,border:`1px solid ${p.border}`,background:p.surface,color:p.text,fontSize:13}}>
                  <option value="">(cluster default)</option>
                  {storageClasses.map(sc=><option key={sc.name} value={sc.name}>{sc.name}{sc.is_default?" (default)":""}</option>)}
                </select>
              </div>
              <div>
                <label style={{fontSize:11,fontWeight:700,color:p.textMute,display:"block",marginBottom:4,textTransform:"uppercase",letterSpacing:".5px"}}>Volume Mode</label>
                <select value={createPVCForm.volume_mode} onChange={e=>setCreatePVCForm(v=>({...v,volume_mode:e.target.value}))}
                  style={{width:"100%",padding:"7px 10px",borderRadius:7,border:`1px solid ${p.border}`,background:p.surface,color:p.text,fontSize:13}}>
                  <option value="Filesystem">Filesystem</option>
                  <option value="Block">Block</option>
                </select>
              </div>
              {createPVCErr&&<div style={{fontSize:12,color:"#ef4444"}}>{createPVCErr}</div>}
              <div style={{display:"flex",gap:10,justifyContent:"flex-end",marginTop:4}}>
                <button onClick={()=>setShowCreatePVC(false)} style={{padding:"8px 20px",borderRadius:7,border:`1px solid ${p.border}`,background:p.surface,color:p.text,fontSize:13,cursor:"pointer"}}>Cancel</button>
                <button disabled={createPVCBusy||!createPVCForm.name||!createPVCForm.namespace} onClick={async()=>{
                  setCreatePVCBusy(true); setCreatePVCErr(null);
                  try{
                    await createOCPPVC(selCluster.id,createPVCForm);
                    setShowCreatePVC(false);
                    const pvc_=await fetchOCPPVCs(selCluster.id); setPvcs(pvc_||[]);
                    setStorageSubTab("pvc");
                  }catch(e){ setCreatePVCErr(e.message); }
                  setCreatePVCBusy(false);
                }} style={{padding:"8px 20px",borderRadius:7,border:"none",background:p.accent,color:"#fff",fontSize:13,cursor:"pointer",fontWeight:700}}>
                  {createPVCBusy?"Creating…":"Create PVC"}
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* -- Workload Describe Modal -- */}
      {wlDesc&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2600,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}
          onClick={e=>e.target===e.currentTarget&&setWlDesc(null)}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:14,padding:24,width:"100%",maxWidth:860,boxShadow:"0 20px 60px #00000080",maxHeight:"90vh",display:"flex",flexDirection:"column"}}>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:16,flexShrink:0}}>
              <span style={{fontSize:22}}>??</span>
              <div style={{fontWeight:700,fontSize:14,color:"#6366f1",flex:1,wordBreak:"break-all"}}>{wlDesc.title}</div>
              <button onClick={()=>setWlDesc(null)} style={{background:"#ef444412",border:"1px solid #ef444430",color:"#ef4444",borderRadius:6,padding:"3px 10px",cursor:"pointer",fontWeight:700}}>?</button>
            </div>
            <div style={{overflowY:"auto",flex:1}}>
              {wlDescLoading
                ?<LoadState msg="Fetching resource…"/>
                :wlDesc.data?.error
                  ?<div style={{color:"#ef4444",fontSize:13}}>{wlDesc.data.error}</div>
                  :<pre style={{fontSize:11,lineHeight:1.7,color:p.text,background:p.surface,border:`1px solid ${p.border}`,
                                borderRadius:8,padding:16,overflowX:"auto",whiteSpace:"pre-wrap",wordBreak:"break-all",fontFamily:"monospace",margin:0}}>
                    {JSON.stringify(wlDesc.data,null,2)}
                  </pre>
              }
            </div>
          </div>
        </div>
      )}

      {/* -- Workload Logs Modal -- */}
      {wlLogs&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2600,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}
          onClick={e=>e.target===e.currentTarget&&setWlLogs(null)}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:14,padding:24,width:"100%",maxWidth:940,boxShadow:"0 20px 60px #00000080",maxHeight:"90vh",display:"flex",flexDirection:"column"}}>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:14,flexShrink:0}}>
              <span style={{fontSize:22}}>??</span>
              <div style={{fontWeight:700,fontSize:14,color:"#10b981",flex:1,wordBreak:"break-all"}}>{wlLogs.title}</div>
              <button onClick={()=>setWlLogs(null)} style={{background:"#ef444412",border:"1px solid #ef444430",color:"#ef4444",borderRadius:6,padding:"3px 10px",cursor:"pointer",fontWeight:700}}>?</button>
            </div>
            {(wlLogs.containers||[]).length>1&&(
              <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:12,flexShrink:0}}>
                {(wlLogs.containers||[]).map(c=>(
                  <button key={c} onClick={()=>setWlLogsContainer(c)}
                    style={{padding:"4px 12px",borderRadius:20,border:"none",cursor:"pointer",fontSize:11,fontWeight:600,
                      background:wlLogsContainer===c?"#10b981":"#f1f5f9",
                      color:wlLogsContainer===c?"#fff":"#475569"}}>
                    {c}
                  </button>
                ))}
              </div>
            )}
            <div style={{overflowY:"auto",flex:1}}>
              {wlLogsLoading
                ?<LoadState msg="Fetching logs…"/>
                :(()=>{
                  const logMap=wlLogs.logs||{};
                  const keys=Object.keys(logMap);
                  const activeKey=wlLogsContainer&&logMap[wlLogsContainer]?wlLogsContainer:(keys[0]||"");
                  const content=logMap[activeKey]||"(no logs)";
                  return(
                    <pre style={{fontSize:11,lineHeight:1.6,color:"#e2e8f0",background:"#0f172a",
                                 borderRadius:8,padding:16,overflowX:"auto",whiteSpace:"pre-wrap",wordBreak:"break-all",fontFamily:"monospace",margin:0,minHeight:300}}>
                      {content}
                    </pre>
                  );
                })()
              }
            </div>
          </div>
        </div>
      )}

      {/* -- Workload Delete Confirm -- */}
      {wlDelTarget&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2700,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}
          onClick={e=>e.target===e.currentTarget&&setWlDelTarget(null)}>
          <div style={{background:p.panel,border:"1px solid #ef444430",borderRadius:14,padding:28,width:"100%",maxWidth:420,boxShadow:"0 20px 60px #00000080"}}>
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:16}}>
              <span style={{fontSize:24}}>??</span>
              <div style={{fontWeight:700,fontSize:16,color:"#ef4444"}}>Delete Workload Resource</div>
            </div>
            <div style={{fontSize:13,color:p.textMute,marginBottom:6}}>Are you sure you want to delete:</div>
            <div style={{background:"#ef444410",borderRadius:8,padding:"10px 14px",marginBottom:16,fontFamily:"monospace",fontSize:12,wordBreak:"break-all"}}>
              <div><b>Kind:</b> {wlDelTarget.kind}</div>
              <div><b>Name:</b> {wlDelTarget.name}</div>
              <div><b>Namespace:</b> {wlDelTarget.namespace}</div>
            </div>
            {wlDelErr&&<div style={{fontSize:12,color:"#ef4444",marginBottom:10,background:"#ef444410",padding:"8px 12px",borderRadius:6}}>{wlDelErr}</div>}
            <div style={{display:"flex",gap:10,justifyContent:"flex-end"}}>
              <button onClick={()=>setWlDelTarget(null)} style={{padding:"8px 18px",borderRadius:7,border:`1px solid ${p.border}`,background:"transparent",color:p.text,cursor:"pointer",fontSize:13}}>Cancel</button>
              <button disabled={wlDelBusy} onClick={async()=>{
                setWlDelBusy(true); setWlDelErr(null);
                try{
                  await deleteOCPWorkload(selCluster.id,wlDelTarget.kind,wlDelTarget.namespace,wlDelTarget.name);
                  setWlDelTarget(null);
                  setWlData(prev=>({...prev,[wlDelTarget.kind]:(prev[wlDelTarget.kind]||[]).filter(x=>!(x.name===wlDelTarget.name&&(x.namespace||x.ns)===wlDelTarget.namespace))}));
                }catch(e){ setWlDelErr(e.message); }
                setWlDelBusy(false);
              }} style={{padding:"8px 20px",borderRadius:7,border:"none",background:"#ef4444",color:"#fff",fontSize:13,cursor:"pointer",fontWeight:700,opacity:wlDelBusy?0.6:1}}>
                {wlDelBusy?"Deleting…":"Delete"}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* -- Pod Detail Modal -- */}
      {selPod&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2100,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}
          onClick={e=>e.target===e.currentTarget&&setSelPod(null)}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:16,padding:28,width:"100%",maxWidth:860,boxShadow:"0 20px 60px #00000080",maxHeight:"90vh",overflowY:"auto"}}>
            {/* Header */}
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:20}}>
              <span style={{fontSize:24}}>??</span>
              <div style={{flex:1,minWidth:0}}>
                <div style={{fontWeight:700,fontSize:15,wordBreak:"break-all",color:p.accent}}>{selPod.name}</div>
                <div style={{fontSize:11,color:p.textMute}}>Pod  ·  {selPod.namespace}  ·  {selCluster?.name}</div>
              </div>
              <div style={{display:"flex",gap:6,flexShrink:0}}>
                <button className="btn btn-sm" onClick={()=>exportPodCSV(podDetail||selPod)}
                  style={{background:`${p.green}15`,border:`1px solid ${p.green}30`,color:p.green,fontSize:11}}>? CSV</button>
                <button className="btn btn-sm" onClick={()=>exportPodPDF(podDetail||selPod)}
                  style={{background:`${p.cyan}15`,border:`1px solid ${p.cyan}30`,color:p.cyan,fontSize:11}}>?? PDF</button>
                <button className="btn btn-sm" onClick={()=>{setSelPod(null);setPodDetail(null);setPodLogs(null);setPodModalTab("detail");}}
                  style={{background:`${p.red}12`,border:`1px solid ${p.red}30`,color:p.red}}>?</button>
              </div>
            </div>

            {/* Tab Bar */}
            <div style={{display:"flex",gap:3,marginBottom:16,background:p.surface,borderRadius:9,padding:4}}>
              {[{id:"detail",icon:"??",label:"Details"},{id:"pvcs",icon:"??",label:"PVCs"},{id:"logs",icon:"??",label:"Logs"}].map(tb=>(
                <button key={tb.id}
                  onClick={()=>{
                    setPodModalTab(tb.id);
                    if(tb.id==="logs"&&!podLogs){
                      setPodLogsLoading(true);
                      fetchOCPPodLogs(selCluster.id, selPod.namespace, selPod.name, podLogsContainer)
                        .then(d=>setPodLogs(d)).catch(()=>setPodLogs({error:"Failed to fetch logs"}))
                        .finally(()=>setPodLogsLoading(false));
                    }
                  }}
                  style={{flex:1,padding:"7px 10px",borderRadius:6,border:"none",cursor:"pointer",
                          fontSize:12,fontWeight:600,
                          background:podModalTab===tb.id?p.accent:"transparent",
                          color:podModalTab===tb.id?"#fff":p.textMute,transition:"all .15s"}}>
                  {tb.icon} {tb.label}
                </button>
              ))}
            </div>

            {(podModalTab==="detail"||podModalTab==="pvcs")&&podDetailLoading&&
              <div style={{textAlign:"center",padding:32,color:p.textMute,fontSize:13}}>? Loading full details…</div>}

            {podModalTab==="detail"&&!podDetailLoading&&(()=>{
              const d = podDetail||{};
              const pc = (d.phase||selPod.phase)==="Running"?p.green:(d.phase||selPod.phase)==="Failed"?p.red:(d.phase||selPod.phase)==="Pending"?p.yellow:"#64748b";
              const SectionTitle = ({icon,title})=>(
                <div style={{fontSize:12,fontWeight:700,color:p.textMute,textTransform:"uppercase",letterSpacing:".7px",marginTop:20,marginBottom:8,display:"flex",alignItems:"center",gap:6}}>
                  <span>{icon}</span>{title}
                </div>
              );
              const Chip = ({label,color})=>(
                <span style={{display:"inline-block",fontSize:11,padding:"2px 8px",borderRadius:12,background:`${color||p.cyan}15`,border:`1px solid ${color||p.cyan}30`,color:color||p.cyan,marginRight:4,marginBottom:4}}>{label}</span>
              );
              const KVRow = ({label,val,mono})=>(
                <div style={{display:"flex",gap:8,padding:"5px 0",borderBottom:`1px solid ${p.border}`,fontSize:12}}>
                  <span style={{minWidth:160,color:p.textMute,fontWeight:600}}>{label}</span>
                  <span style={{flex:1,wordBreak:"break-all",fontFamily:mono?"monospace":"inherit",fontSize:mono?11:12}}>{val||"—"}</span>
                </div>
              );
              const owners = d.owner_refs||[];
              const containers = d.containers||[];
              const initContainers = d.init_containers||[];
              const conditions = d.conditions||[];
              const volumes = d.volumes||[];
              const labels = d.labels||{};
              const annotations = d.annotations||{};
              return <>
                {/* Overview */}
                <SectionTitle icon="??" title="Overview"/>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                  {[
                    {label:"Phase",    val:<span style={{fontWeight:700,color:pc}}>{d.phase||selPod.phase||"?"}</span>},
                    {label:"Ready",    val:d.ready_str||selPod.ready||"—"},
                    {label:"Node",     val:<span style={{color:p.accent}}>{d.node||selPod.node||"—"}</span>},
                    {label:"Pod IP",   val:<code style={{fontSize:11}}>{d.pod_ip||selPod.pod_ip||"—"}</code>},
                    {label:"Host IP",  val:<code style={{fontSize:11}}>{d.host_ip||selPod.host_ip||"—"}</code>},
                    {label:"QoS",      val:d.qos_class||selPod.qos_class||"—"},
                    {label:"SA",       val:d.service_account||"—"},
                    {label:"Restart Policy",val:d.restart_policy||"—"},
                    {label:"DNS Policy",val:d.dns_policy||"—"},
                    {label:"Scheduler",val:d.scheduler_name||"—"},
                    {label:"Started",  val:(d.start_time||selPod.start_time||"").slice(0,19).replace("T"," ")},
                    {label:"Age",      val:_ocpAge(d.start_time||selPod.start_time)},
                    {label:"UID",      val:<code style={{fontSize:10}}>{d.uid||"—"}</code>},
                    ...(owners.length?[{label:"Owner", val:`${owners[0].kind}/${owners[0].name}`}]:[]),
                  ].map((row,i)=>(
                    <div key={i} style={{background:p.surface,borderRadius:7,padding:"8px 12px",border:`1px solid ${p.border}`}}>
                      <div style={{fontSize:10,color:p.textMute,fontWeight:700,marginBottom:3,textTransform:"uppercase",letterSpacing:".5px"}}>{row.label}</div>
                      <div style={{fontSize:12,fontWeight:500}}>{row.val}</div>
                    </div>
                  ))}
                </div>

                {/* Labels */}
                {Object.keys(labels).length>0&&<>
                  <SectionTitle icon="???" title="Labels"/>
                  <div>{Object.entries(labels).map(([k,v],i)=><Chip key={i} label={`${k}=${v}`}/>)}</div>
                </>}

                {/* Annotations */}
                {Object.keys(annotations).length>0&&<>
                  <SectionTitle icon="??" title="Annotations"/>
                  <div style={{maxHeight:140,overflowY:"auto",background:p.surface,borderRadius:8,padding:"8px 12px",border:`1px solid ${p.border}`}}>
                    {Object.entries(annotations).map(([k,v],i)=>(
                      <div key={i} style={{fontSize:11,padding:"3px 0",borderBottom:`1px solid ${p.border}`,display:"flex",gap:8,lineHeight:1.4}}>
                        <span style={{minWidth:240,color:p.textMute,fontFamily:"monospace",wordBreak:"break-all"}}>{k}</span>
                        <span style={{flex:1,wordBreak:"break-all",fontFamily:"monospace",fontSize:10,color:p.text}}>{v}</span>
                      </div>
                    ))}
                  </div>
                </>}

                {/* Containers */}
                {containers.length>0&&<>
                  <SectionTitle icon="??" title={`Containers (${containers.length})`}/>
                  {containers.map((c2,ci)=>{
                    const stColor = c2.state==="running"?p.green:c2.state==="waiting"?p.yellow:c2.state==="terminated"?p.red:"#64748b";
                    return(
                      <div key={ci} style={{border:`1px solid ${p.border}`,borderRadius:10,marginBottom:12,overflow:"hidden"}}>
                        <div style={{background:p.surface,padding:"10px 14px",display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}}>
                          <span style={{fontWeight:700,fontSize:13,color:p.accent}}>{c2.name}</span>
                          <span style={{fontSize:11,fontWeight:700,color:stColor,background:`${stColor}18`,padding:"2px 8px",borderRadius:5}}>{c2.state}</span>
                          {c2.ready&&<span style={{fontSize:10,color:p.green,background:`${p.green}15`,padding:"2px 6px",borderRadius:4}}>Ready</span>}
                          <span style={{fontSize:11,color:p.textMute,marginLeft:"auto"}}>Restarts: <b style={{color:c2.restarts>0?p.orange:p.text}}>{c2.restarts}</b></span>
                        </div>
                        <div style={{padding:"10px 14px"}}>
                          <KVRow label="Image" val={c2.image} mono/>
                          {c2.image_pull_policy&&<KVRow label="Pull Policy" val={c2.image_pull_policy}/>}
                          {c2.state_reason&&<KVRow label="State Reason" val={c2.state_reason}/>}
                          {c2.started_at&&<KVRow label="Started At"   val={c2.started_at}/>}
                          {c2.ports&&c2.ports.length>0&&<KVRow label="Ports" val={c2.ports.map(pt=>`${pt.container_port}/${pt.protocol}${pt.name?" ("+pt.name+")":""}`).join(", ")}/>}
                          {(c2.resources?.requests&&Object.keys(c2.resources.requests).length>0)&&
                            <KVRow label="Requests" val={Object.entries(c2.resources.requests).map(([k2,v2])=>`${k2}: ${v2}`).join(" · ")}/>}
                          {(c2.resources?.limits&&Object.keys(c2.resources.limits).length>0)&&
                            <KVRow label="Limits" val={Object.entries(c2.resources.limits).map(([k2,v2])=>`${k2}: ${v2}`).join(" · ")}/>}
                          {/* Env vars */}
                          {c2.env&&c2.env.length>0&&<>
                            <div style={{fontSize:11,color:p.textMute,fontWeight:700,margin:"8px 0 4px",textTransform:"uppercase"}}>Environment</div>
                            <div style={{maxHeight:110,overflowY:"auto",background:p.bg,borderRadius:6,padding:6}}>
                              {c2.env.map((e2,ei)=>(
                                <div key={ei} style={{fontSize:11,display:"flex",gap:8,padding:"2px 0",fontFamily:"monospace"}}>
                                  <span style={{color:p.cyan,minWidth:180,wordBreak:"break-all"}}>{e2.name}</span>
                                  <span style={{color:p.textMute,wordBreak:"break-all"}}>{e2.value}</span>
                                </div>
                              ))}
                            </div>
                          </>}
                          {/* Volume mounts */}
                          {c2.volume_mounts&&c2.volume_mounts.length>0&&<>
                            <div style={{fontSize:11,color:p.textMute,fontWeight:700,margin:"8px 0 4px",textTransform:"uppercase"}}>Volume Mounts</div>
                            <div style={{background:p.bg,borderRadius:6,padding:6}}>
                              {c2.volume_mounts.map((vm,vi)=>(
                                <div key={vi} style={{fontSize:11,display:"flex",gap:8,padding:"2px 0",fontFamily:"monospace"}}>
                                  <span style={{color:p.yellow,minWidth:180,wordBreak:"break-all"}}>{vm.name}</span>
                                  <span style={{color:p.textMute,wordBreak:"break-all"}}>{vm.mount_path}{vm.read_only?" (ro)":""}</span>
                                </div>
                              ))}
                            </div>
                          </>}
                        </div>
                      </div>
                    );
                  })}
                </>}

                {/* Init Containers */}
                {initContainers.length>0&&<>
                  <SectionTitle icon="??" title={`Init Containers (${initContainers.length})`}/>
                  {initContainers.map((c2,ci)=>(
                    <div key={ci} style={{border:`1px solid ${p.border}`,borderRadius:8,marginBottom:8,padding:"8px 12px"}}>
                      <div style={{fontWeight:600,fontSize:12,color:p.accent,marginBottom:4}}>{c2.name}</div>
                      <KVRow label="Image" val={c2.image} mono/>
                      <KVRow label="State" val={`${c2.state}${c2.state_reason?" — "+c2.state_reason:""}`}/>
                    </div>
                  ))}
                </>}

                {/* Conditions */}
                {conditions.length>0&&<>
                  <SectionTitle icon="?" title="Conditions"/>
                  <div style={{overflowX:"auto"}}>
                    <table style={{width:"100%",fontSize:12,borderCollapse:"collapse"}}>
                      <thead><tr style={{background:p.surface}}>
                        {["Type","Status","Reason","Message","Last Transition"].map(h=>(
                          <th key={h} style={{padding:"6px 10px",textAlign:"left",fontWeight:700,color:p.textMute,fontSize:11,borderBottom:`1px solid ${p.border}`}}>{h}</th>
                        ))}
                      </tr></thead>
                      <tbody>{conditions.map((cond,ci)=>(
                        <tr key={ci} style={{borderBottom:`1px solid ${p.border}`}}>
                          <td style={{padding:"5px 10px",fontWeight:600,color:cond.status==="True"?p.green:p.red}}>{cond.type}</td>
                          <td style={{padding:"5px 10px"}}><span style={{color:cond.status==="True"?p.green:p.red,fontWeight:700}}>{cond.status}</span></td>
                          <td style={{padding:"5px 10px",color:p.textMute}}>{cond.reason||"—"}</td>
                          <td style={{padding:"5px 10px",color:p.textMute,maxWidth:260,wordBreak:"break-word",fontSize:11}}>{cond.message||"—"}</td>
                          <td style={{padding:"5px 10px",color:p.textMute,fontSize:11,whiteSpace:"nowrap"}}>{(cond.last_transition||"").slice(0,19).replace("T"," ")}</td>
                        </tr>
                      ))}</tbody>
                    </table>
                  </div>
                </>}

                {/* Volumes */}
                {volumes.length>0&&<>
                  <SectionTitle icon="??" title="Volumes"/>
                  <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(200px,1fr))",gap:6}}>
                    {volumes.map((v2,vi)=>(
                      <div key={vi} style={{background:p.surface,borderRadius:6,padding:"6px 10px",border:`1px solid ${p.border}`}}>
                        <div style={{fontSize:11,fontWeight:600,color:p.accent,wordBreak:"break-all"}}>{v2.name}</div>
                        <div style={{fontSize:10,color:p.textMute}}>{v2.type}</div>
                      </div>
                    ))}
                  </div>
                </>}

                {/* Tolerations */}
                {d.tolerations&&d.tolerations.length>0&&<>
                  <SectionTitle icon="??" title="Tolerations"/>
                  <div style={{background:p.surface,borderRadius:8,padding:"8px 12px",border:`1px solid ${p.border}`}}>
                    {d.tolerations.map((t2,ti)=>(
                      <div key={ti} style={{fontSize:11,fontFamily:"monospace",padding:"2px 0",color:p.textMute}}>
                        {t2.key||"*"}{t2.operator?` ${t2.operator}`:""}{t2.value?`=${t2.value}`:""}{t2.effect?` [${t2.effect}]`:""}
                      </div>
                    ))}
                  </div>
                </>}
              </>;
            })()}

            {/* -- Logs Tab -- */}
            {podModalTab==="logs"&&(
              <div>
                <div style={{display:"flex",gap:8,marginBottom:12,alignItems:"center",flexWrap:"wrap"}}>
                  <select value={podLogsContainer} onChange={e=>{setPodLogsContainer(e.target.value);setPodLogs(null);}}
                    style={{background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"5px 10px",
                            color:p.text,fontSize:12,minWidth:160}}>
                    <option value="">All containers</option>
                    {(podDetail?.containers||[]).map(c2=>(<option key={c2.name} value={c2.name}>{c2.name}</option>))}
                    {(podDetail?.init_containers||[]).map(c2=>(<option key={"init_"+c2.name} value={c2.name}>?? {c2.name}</option>))}
                  </select>
                  <button className="btn btn-sm" onClick={()=>{
                    setPodLogsLoading(true);setPodLogs(null);
                    fetchOCPPodLogs(selCluster.id, selPod.namespace, selPod.name, podLogsContainer)
                      .then(d=>setPodLogs(d)).catch(()=>setPodLogs({error:"Failed to fetch logs"}))
                      .finally(()=>setPodLogsLoading(false));
                  }} style={{background:`${p.cyan}15`,border:`1px solid ${p.cyan}30`,color:p.cyan,fontSize:11,fontWeight:600}}>
                    ?? Fetch Logs
                  </button>
                  <span style={{fontSize:11,color:p.textMute}}>Last 200 lines</span>
                  {podLogs?.logs&&(
                    <button className="btn btn-sm" onClick={()=>{
                      const txt=Object.entries(podLogs.logs||{}).map(([n,t])=>`=== ${n} ===\n${t}`).join("\n\n");
                      const a=document.createElement("a");
                      a.href=URL.createObjectURL(new Blob([txt],{type:"text/plain"}));
                      a.download=`${selPod.name}-logs.txt`; a.click();
                    }} style={{background:`${p.green}15`,border:`1px solid ${p.green}30`,color:p.green,fontSize:11}}>? Save .txt</button>
                  )}
                </div>
                {podLogsLoading&&<div style={{textAlign:"center",padding:32,color:p.textMute,fontSize:13}}>? Loading logs…</div>}
                {!podLogsLoading&&podLogs&&Object.entries(podLogs.logs||{}).map(([cname,logText],li)=>(
                  <div key={li} style={{marginBottom:16}}>
                    {Object.keys(podLogs.logs).length>1&&(
                      <div style={{fontSize:11,fontWeight:700,color:p.cyan,marginBottom:4,padding:"3px 10px",
                                   background:`${p.cyan}15`,borderRadius:4,display:"inline-block"}}>?? {cname}</div>
                    )}
                    <pre style={{background:"#0d1117",borderRadius:8,padding:"12px 14px",fontSize:11,
                                 lineHeight:1.6,color:"#e2e8f0",overflow:"auto",maxHeight:440,
                                 border:`1px solid ${p.border}`,margin:0,whiteSpace:"pre-wrap",wordBreak:"break-all"}}>
                      {logText||"(no output)"}
                    </pre>
                  </div>
                ))}
                {!podLogsLoading&&podLogs?.error&&<div style={{color:p.red,fontSize:12,padding:12}}>{podLogs.error}</div>}
                {!podLogsLoading&&!podLogs&&(
                  <div style={{textAlign:"center",padding:40,color:p.textMute,fontSize:13}}>
                    Select a container and click ?? Fetch Logs
                  </div>
                )}
              </div>
            )}

            {/* -- PVCs Tab -- */}
            {podModalTab==="pvcs"&&!podDetailLoading&&(()=>{
              const pvcs=podDetail?.pvcs||[];
              if(!pvcs.length) return(
                <div style={{textAlign:"center",padding:40,color:p.textMute,fontSize:13}}>
                  No PersistentVolumeClaims mounted in this pod
                </div>
              );
              return(
                <div style={{overflowX:"auto"}}>
                  <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
                    <thead><tr style={{background:p.surface}}>
                      {["Volume Name","Claim","Status","Storage Class","Capacity","Requested","Access Modes","Mode","Bound PV","R/O"].map(h=>(
                        <th key={h} style={{padding:"7px 10px",textAlign:"left",fontWeight:700,color:p.textMute,
                                            fontSize:11,borderBottom:`1px solid ${p.border}`,whiteSpace:"nowrap"}}>{h}</th>
                      ))}
                    </tr></thead>
                    <tbody>{pvcs.map((pvc,pi)=>(
                      <tr key={pi} style={{borderBottom:`1px solid ${p.border}`}}>
                        <td style={{padding:"6px 10px",fontFamily:"monospace",fontSize:11,color:p.yellow}}>{pvc.volume_name}</td>
                        <td style={{padding:"6px 10px",fontWeight:600,color:p.accent,whiteSpace:"nowrap"}}>{pvc.claim_name}</td>
                        <td style={{padding:"6px 10px"}}>
                          <span style={{fontWeight:700,fontSize:11,padding:"2px 7px",borderRadius:5,
                            color:pvc.phase==="Bound"?p.green:pvc.phase==="Pending"?p.yellow:p.red,
                            background:pvc.phase==="Bound"?`${p.green}15`:pvc.phase==="Pending"?`${p.yellow}15`:`${p.red}15`}}>
                            {pvc.phase}
                          </span>
                        </td>
                        <td style={{padding:"6px 10px",color:p.cyan,fontFamily:"monospace",fontSize:11,whiteSpace:"nowrap"}}>{pvc.storage_class||"—"}</td>
                        <td style={{padding:"6px 10px",color:p.text,whiteSpace:"nowrap"}}>{pvc.capacity||"—"}</td>
                        <td style={{padding:"6px 10px",color:p.textMute,whiteSpace:"nowrap"}}>{pvc.requested||"—"}</td>
                        <td style={{padding:"6px 10px",fontSize:11,color:p.textMute,whiteSpace:"nowrap"}}>{(pvc.access_modes||[]).join(", ")||"—"}</td>
                        <td style={{padding:"6px 10px",fontSize:11,color:p.textMute,whiteSpace:"nowrap"}}>{pvc.volume_mode||"—"}</td>
                        <td style={{padding:"6px 10px",fontFamily:"monospace",fontSize:10,color:p.textMute}}>{pvc.bound_volume||"—"}</td>
                        <td style={{padding:"6px 10px",textAlign:"center"}}>
                          {pvc.read_only
                            ?<span style={{color:p.orange,fontSize:11,fontWeight:700}}>RO</span>
                            :<span style={{color:p.green,fontSize:11,fontWeight:700}}>RW</span>}
                        </td>
                      </tr>
                    ))}</tbody>
                  </table>
                </div>
              );
            })()}
          </div>
        </div>
      )}

      {/* -- Namespace Detail Modal -- */}
      {selNsDetail&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2100,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}
          onClick={e=>e.target===e.currentTarget&&setSelNsDetail(null)}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:16,padding:28,width:"100%",maxWidth:860,boxShadow:"0 20px 60px #00000080",maxHeight:"90vh",overflowY:"auto"}}>
            {/* Header */}
            <div style={{display:"flex",alignItems:"center",gap:10,marginBottom:20}}>
              <span style={{fontSize:24}}>??</span>
              <div style={{flex:1,minWidth:0}}>
                <div style={{fontWeight:700,fontSize:15,color:p.accent}}>{selNsDetail.name}</div>
                <div style={{fontSize:11,color:p.textMute}}>Namespace / Project  ·  {selCluster?.name}</div>
              </div>
              <div style={{display:"flex",gap:6,flexShrink:0}}>
                <button className="btn btn-sm" onClick={()=>exportNsCSV(nsDetail||selNsDetail)}
                  style={{background:`${p.green}15`,border:`1px solid ${p.green}30`,color:p.green,fontSize:11}}>? CSV</button>
                <button className="btn btn-sm" onClick={()=>exportNsPDF(nsDetail||selNsDetail)}
                  style={{background:`${p.cyan}15`,border:`1px solid ${p.cyan}30`,color:p.cyan,fontSize:11}}>?? PDF</button>
                <button className="btn btn-sm" onClick={()=>{setSelNsDetail(null);setNsDetail(null);}}
                  style={{background:`${p.red}12`,border:`1px solid ${p.red}30`,color:p.red}}>?</button>
              </div>
            </div>

            {nsDetailLoading&&<div style={{textAlign:"center",padding:32,color:p.textMute,fontSize:13}}>? Loading full details…</div>}

            {!nsDetailLoading&&(()=>{
              const d = nsDetail||{};
              const SectionTitle = ({icon,title})=>(
                <div style={{fontSize:12,fontWeight:700,color:p.textMute,textTransform:"uppercase",letterSpacing:".7px",marginTop:20,marginBottom:8,display:"flex",alignItems:"center",gap:6}}>
                  <span>{icon}</span>{title}
                </div>
              );
              const Chip = ({label,color})=>(
                <span style={{display:"inline-block",fontSize:11,padding:"2px 8px",borderRadius:12,background:`${color||p.cyan}15`,border:`1px solid ${color||p.cyan}30`,color:color||p.cyan,marginRight:4,marginBottom:4}}>{label}</span>
              );
              const labels = d.labels||{};
              const annotations = d.annotations||{};
              const quotas = d.quotas||[];
              const limitRanges = d.limit_ranges||[];
              const phase = d.phase||selNsDetail.phase||"Active";
              const ac = phase==="Active";
              return <>
                {/* Metadata */}
                <SectionTitle icon="??" title="Metadata"/>
                <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
                  {[
                    {label:"Phase",         val:<span style={{fontWeight:700,color:ac?p.green:"#64748b"}}>{phase}</span>},
                    {label:"Display Name",  val:d.display_name||selNsDetail.display_name||selNsDetail.name},
                    {label:"Requester",     val:d.requester||selNsDetail.requester||"—"},
                    {label:"Node Selector", val:d.node_selector||"—"},
                    {label:"Created",       val:(d.created_at||selNsDetail.created_at||"").slice(0,10)},
                    {label:"Age",           val:_ocpAge(d.created_at||selNsDetail.created_at)},
                    {label:"UID",           val:<code style={{fontSize:10}}>{d.uid||"—"}</code>},
                  ].map((row,i)=>(
                    <div key={i} style={{background:p.surface,borderRadius:7,padding:"8px 12px",border:`1px solid ${p.border}`}}>
                      <div style={{fontSize:10,color:p.textMute,fontWeight:700,marginBottom:3,textTransform:"uppercase",letterSpacing:".5px"}}>{row.label}</div>
                      <div style={{fontSize:12,fontWeight:500}}>{row.val}</div>
                    </div>
                  ))}
                </div>

                {/* Description */}
                {(d.description||selNsDetail.description)&&(
                  <div style={{marginTop:10,background:p.surface,borderRadius:8,padding:"10px 14px",border:`1px solid ${p.border}`,fontSize:13,lineHeight:1.6}}>
                    {d.description||selNsDetail.description}
                  </div>
                )}

                {/* Labels */}
                {Object.keys(labels).length>0&&<>
                  <SectionTitle icon="???" title="Labels"/>
                  <div>{Object.entries(labels).map(([k,v],i)=><Chip key={i} label={`${k}=${v}`}/>)}</div>
                </>}

                {/* Annotations */}
                {Object.keys(annotations).length>0&&<>
                  <SectionTitle icon="??" title="Annotations"/>
                  <div style={{maxHeight:140,overflowY:"auto",background:p.surface,borderRadius:8,padding:"8px 12px",border:`1px solid ${p.border}`}}>
                    {Object.entries(annotations).map(([k,v],i)=>(
                      <div key={i} style={{fontSize:11,padding:"3px 0",borderBottom:`1px solid ${p.border}`,display:"flex",gap:8,lineHeight:1.4}}>
                        <span style={{minWidth:260,color:p.textMute,fontFamily:"monospace",wordBreak:"break-all"}}>{k}</span>
                        <span style={{flex:1,wordBreak:"break-all",fontFamily:"monospace",fontSize:10,color:p.text}}>{v}</span>
                      </div>
                    ))}
                  </div>
                </>}

                {/* Resource Quotas */}
                {quotas.length>0&&<>
                  <SectionTitle icon="??" title={`Resource Quotas (${quotas.length})`}/>
                  {quotas.map((q,qi)=>(
                    <div key={qi} style={{marginBottom:12}}>
                      <div style={{fontSize:12,fontWeight:600,color:p.text,marginBottom:6}}>{q.name}</div>
                      <div style={{overflowX:"auto"}}>
                        <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
                          <thead><tr style={{background:p.surface}}>
                            {["Resource","Hard Limit","Used"].map(h=>(
                              <th key={h} style={{padding:"6px 10px",textAlign:"left",fontWeight:700,color:p.textMute,fontSize:11,borderBottom:`1px solid ${p.border}`}}>{h}</th>
                            ))}
                          </tr></thead>
                          <tbody>{(q.items||[]).map((item,ii)=>{
                            const pct = item.hard&&item.used?Math.min(100,Math.round((parseFloat(item.used)/parseFloat(item.hard))*100)):null;
                            return(
                              <tr key={ii} style={{borderBottom:`1px solid ${p.border}`}}>
                                <td style={{padding:"5px 10px",fontFamily:"monospace",fontSize:11,color:p.cyan}}>{item.resource}</td>
                                <td style={{padding:"5px 10px",color:p.text}}>{item.hard}</td>
                                <td style={{padding:"5px 10px"}}>
                                  <span style={{color:pct!=null&&pct>=90?p.red:pct!=null&&pct>=70?p.yellow:p.green}}>{item.used}</span>
                                  {pct!=null&&<span style={{fontSize:10,color:p.textMute,marginLeft:6}}>({pct}%)</span>}
                                </td>
                              </tr>
                            );
                          })}</tbody>
                        </table>
                      </div>
                    </div>
                  ))}
                </>}

                {/* Limit Ranges */}
                {limitRanges.length>0&&<>
                  <SectionTitle icon="??" title={`Limit Ranges (${limitRanges.length})`}/>
                  {limitRanges.map((lr,li)=>(
                    <div key={li} style={{marginBottom:12}}>
                      <div style={{fontSize:12,fontWeight:600,color:p.text,marginBottom:6}}>{lr.name}</div>
                      <div style={{overflowX:"auto"}}>
                        <table style={{width:"100%",borderCollapse:"collapse",fontSize:12}}>
                          <thead><tr style={{background:p.surface}}>
                            {["Type","Default Request","Default Limit","Min","Max"].map(h=>(
                              <th key={h} style={{padding:"6px 10px",textAlign:"left",fontWeight:700,color:p.textMute,fontSize:11,borderBottom:`1px solid ${p.border}`}}>{h}</th>
                            ))}
                          </tr></thead>
                          <tbody>{(lr.limits||[]).map((lim,lli)=>(
                            <tr key={lli} style={{borderBottom:`1px solid ${p.border}`}}>
                              <td style={{padding:"5px 10px",color:p.cyan,fontWeight:600}}>{lim.type}</td>
                              <td style={{padding:"5px 10px",fontSize:11,fontFamily:"monospace"}}>{Object.entries(lim.default_request||{}).map(([k,v])=>`${k}: ${v}`).join(", ")||"—"}</td>
                              <td style={{padding:"5px 10px",fontSize:11,fontFamily:"monospace"}}>{Object.entries(lim.default||{}).map(([k,v])=>`${k}: ${v}`).join(", ")||"—"}</td>
                              <td style={{padding:"5px 10px",fontSize:11,fontFamily:"monospace"}}>{Object.entries(lim.min||{}).map(([k,v])=>`${k}: ${v}`).join(", ")||"—"}</td>
                              <td style={{padding:"5px 10px",fontSize:11,fontFamily:"monospace"}}>{Object.entries(lim.max||{}).map(([k,v])=>`${k}: ${v}`).join(", ")||"—"}</td>
                            </tr>
                          ))}</tbody>
                        </table>
                      </div>
                    </div>
                  ))}
                </>}

                {/* Empty state when no extra detail yet */}
                {!d.uid&&!nsDetailLoading&&(
                  <div style={{textAlign:"center",padding:16,color:p.textMute,fontSize:12}}>Basic info only — full detail could not be loaded</div>
                )}
              </>;
            })()}
          </div>
        </div>
      )}

      {/* -- Edit Cluster Modal -- */}
      {showEdit&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2000,display:"flex",alignItems:"center",justifyContent:"center"}}
          onClick={e=>e.target===e.currentTarget&&setShowEdit(false)}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:16,padding:28,width:"100%",maxWidth:520,boxShadow:"0 20px 60px #00000080"}}>
            <div style={{fontWeight:700,fontSize:16,marginBottom:20,display:"flex",alignItems:"center",gap:10}}>
              <span style={{fontSize:22}}>??</span> Edit Cluster — {selCluster?.name}
            </div>
            {editErr&&<div style={{marginBottom:12,padding:"8px 12px",borderRadius:7,background:`${p.red}15`,border:`1px solid ${p.red}30`,color:p.red,fontSize:13}}>{editErr}</div>}
            {[
              {k:"name",          label:"Cluster Name",                      ph:"e.g. OCP-4.18-Production"},
              {k:"api_url",       label:"API Server URL",                    ph:"https://api.ocp.example.com:6443"},
              {k:"username",      label:"Username",                          ph:"kubeadmin"},
              {k:"password",      label:"New Password (leave blank to keep)",ph:"????????????",type:"password"},
              {k:"console_url",   label:"Console URL (optional)",            ph:"https://console-openshift-console.apps…"},
              {k:"ai_url",        label:"Red Hat OpenShift AI URL (optional)",ph:"https://rhods-dashboard-redhat-ods-applications.apps…"},
              {k:"description",   label:"Description (optional)",            ph:""},
            ].map(f=>(
              <div key={f.k} style={{marginBottom:12}}>
                <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>{f.label}</label>
                <input type={f.type||"text"} placeholder={f.ph} value={editForm[f.k]||""}
                  onChange={e=>setEditForm(prev=>({...prev,[f.k]:e.target.value}))}
                  style={{width:"100%",boxSizing:"border-box"}}/>
                {f.k==="ai_url"&&editForm.ai_url&&(
                  <div style={{marginTop:5,display:"flex",alignItems:"center",gap:6}}>
                    <span style={{fontSize:11,color:p.textMute}}>Current:</span>
                    <a href={editForm.ai_url} target="_blank" rel="noreferrer"
                      style={{fontSize:11,color:"#8b5cf6",textDecoration:"underline",textDecorationStyle:"dotted",
                              wordBreak:"break-all",display:"flex",alignItems:"center",gap:3}}>
                      ?? {editForm.ai_url} <span style={{fontSize:10,opacity:.6}}>?</span>
                    </a>
                  </div>
                )}
              </div>
            ))}
            <div style={{display:"flex",gap:8,justifyContent:"flex-end",marginTop:20}}>
              <button className="btn btn-sm" onClick={()=>setShowEdit(false)}>Cancel</button>
              <button className="btn btn-primary btn-sm" onClick={doEditCluster} disabled={editBusy}>
                {editBusy?"? Saving…":"Save Changes"}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* -- VM Request Wizard -- */}
      {showVMReq&&(
        <div style={{position:"fixed",inset:0,background:"#00000095",zIndex:3000,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}
          onClick={e=>e.target===e.currentTarget&&!vmReqBusy&&(setShowVMReq(false),setVmReqStep(0))}>
          <div style={{background:p.panel,border:`1px solid #6366f140`,borderRadius:18,width:"100%",maxWidth:720,maxHeight:"90vh",overflowY:"auto",boxShadow:"0 24px 80px #00000090",display:"flex",flexDirection:"column"}}>
            {/* Wizard header */}
            <div style={{padding:"20px 28px 0",flexShrink:0}}>
              <div style={{display:"flex",alignItems:"center",gap:12,marginBottom:16}}>
                <div style={{width:40,height:40,borderRadius:10,background:"linear-gradient(135deg,#6366f1,#8b5cf6)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:22,flexShrink:0}}>???</div>
                <div>
                  <div style={{fontWeight:800,fontSize:17,color:p.text}}>Request Virtual Machine</div>
                  <div style={{fontSize:12,color:p.textMute}}>OpenShift Virtualization — self-service VM provisioning request</div>
                </div>
                <button onClick={()=>{setShowVMReq(false);setVmReqStep(0);}} style={{marginLeft:"auto",background:"transparent",border:"none",color:p.textMute,fontSize:20,cursor:"pointer",lineHeight:1}}>?</button>
              </div>
              {/* Step indicator */}
              {(()=>{
                const steps=["Cluster","OS Template","Resources","Networking","Cloud-Init","Review & Submit"];
                return(
                  <div style={{display:"flex",gap:0,marginBottom:20}}>
                    {steps.map((s,i)=>{
                      const done=i<vmReqStep; const active=i===vmReqStep;
                      const c2=active?"#8b5cf6":done?p.green:"#334155";
                      return(
                        <div key={i} style={{flex:1,display:"flex",flexDirection:"column",alignItems:"center",gap:4}}>
                          <div style={{display:"flex",alignItems:"center",width:"100%"}}>
                            {i>0&&<div style={{flex:1,height:2,background:done?p.green:"#334155",marginTop:0}}/>}
                            <div style={{width:26,height:26,borderRadius:"50%",background:active?"#6366f1":done?p.green:"#1e293b",
                              border:`2px solid ${c2}`,display:"flex",alignItems:"center",justifyContent:"center",
                              fontSize:11,fontWeight:700,color:active||done?"#fff":p.textMute,flexShrink:0}}>
                              {done?"?":i+1}
                            </div>
                            {i<steps.length-1&&<div style={{flex:1,height:2,background:done?p.green:"#334155"}}/>}
                          </div>
                          <div style={{fontSize:9,fontWeight:active?700:400,color:c2,textAlign:"center",whiteSpace:"nowrap"}}>{s}</div>
                        </div>
                      );
                    })}
                  </div>
                );
              })()}
            </div>

            {/* Wizard body */}
            <div style={{padding:"0 28px 20px",flex:1,overflowY:"auto"}}>
              {vmReqErr&&<div style={{marginBottom:12,padding:"8px 12px",borderRadius:7,background:`${p.red}15`,border:`1px solid ${p.red}30`,color:p.red,fontSize:13}}>{vmReqErr}</div>}

              {/* -- STEP 0 — Cluster -- */}
              {vmReqStep===0&&(
                <div>
                  <div style={{fontSize:13,fontWeight:700,color:p.textMute,marginBottom:12,textTransform:"uppercase",letterSpacing:1}}>Select Cluster</div>
                  {clusters.length===0?(
                    <div style={{padding:24,textAlign:"center",color:p.textMute,fontSize:13}}>No OpenShift clusters configured. Ask an admin to add one.</div>
                  ):(
                    <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(200px,1fr))",gap:10}}>
                      {clusters.map(cl=>{
                        const sel=vmReqForm.cluster_id===cl.id;
                        const sc=cl.status==="connected"?p.green:cl.status==="error"?p.red:"#64748b";
                        return(
                          <div key={cl.id} onClick={()=>{
                              setVmReqForm(f=>({...f,cluster_id:cl.id,cluster_name:cl.name}));
                              loadWizardClusterData(cl.id);
                            }}
                            style={{padding:"14px 16px",borderRadius:12,cursor:"pointer",border:`2px solid ${sel?"#6366f1":p.border}`,
                              background:sel?"linear-gradient(135deg,#6366f115,#8b5cf615)":p.surface,transition:"all .15s"}}>
                            <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:6}}>
                              <div style={{width:10,height:10,borderRadius:"50%",background:sc,boxShadow:`0 0 6px ${sc}80`}}/>
                              <span style={{fontWeight:700,fontSize:13,color:sel?"#a78bfa":p.text}}>{cl.name}</span>
                            </div>
                            <div style={{fontSize:10,color:p.textMute,wordBreak:"break-all"}}>{cl.api_url}</div>
                            <div style={{marginTop:4}}>
                              <span style={{fontSize:10,fontWeight:700,padding:"2px 6px",borderRadius:4,background:`${sc}15`,color:sc}}>{cl.status||"unknown"}</span>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  )}
                  {vmReqForm.cluster_id&&(
                    <div style={{marginTop:14}}>
                      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:12}}>
                        <div>
                          <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>Namespace {vmReqNsLoading&&<span style={{color:"#f59e0b"}}>?</span>}</label>
                          <select value={vmReqForm.namespace} onChange={e=>setVmReqForm(f=>({...f,namespace:e.target.value}))}
                            style={{width:"100%",background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"6px 10px",color:p.text,fontSize:12}}>
                            {vmReqNs.length>0?vmReqNs.map(ns=><option key={ns.name} value={ns.name}>{ns.name}</option>):<option value="default">default</option>}
                          </select>
                        </div>
                        <div>
                          <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>VM Name <span style={{color:p.red}}>*</span></label>
                          <input value={vmReqForm.vm_name} onChange={e=>setVmReqForm(f=>({...f,vm_name:_vmNameClean(e.target.value.toLowerCase())}))}
                            placeholder="e.g. my-vm-01" style={{width:"100%",boxSizing:"border-box",fontSize:12}}/>
                          <div style={{fontSize:10,color:p.textMute,marginTop:2}}>lowercase letters, numbers, hyphens</div>
                        </div>
                      </div>
                      <div style={{marginTop:10}}>
                        <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>Description (optional)</label>
                        <input value={vmReqForm.description} onChange={e=>setVmReqForm(f=>({...f,description:e.target.value}))}
                          placeholder="What is this VM for?" style={{width:"100%",boxSizing:"border-box",fontSize:12}}/>
                      </div>
                    </div>
                  )}
                </div>
              )}

              {/* -- STEP 1 — OS Template -- */}
              {vmReqStep===1&&(
                <div>
                  <div style={{fontSize:13,fontWeight:700,color:p.textMute,marginBottom:12,textTransform:"uppercase",letterSpacing:1}}>Operating System Template</div>
                  <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(200px,1fr))",gap:10}}>
                    {OCP_OS_TEMPLATES.map(t=>{
                      const sel=vmReqForm.os_template===t.id;
                      return(
                        <div key={t.id} onClick={()=>{
                            const tpl=OCP_OS_TEMPLATES.find(x=>x.id===t.id);
                            setVmReqForm(f=>({...f,os_template:t.id,cpu_cores:tpl.cpu_cores,memory_gi:tpl.memory_gi,boot_disk_size:tpl.boot}));
                          }}
                          style={{display:"flex",flexDirection:"column",gap:6,padding:"12px 14px",borderRadius:12,cursor:"pointer",
                            border:`2px solid ${sel?t.color:p.border}`,background:sel?`${t.color}12`:p.surface,transition:"all .15s"}}>
                          <div style={{display:"flex",alignItems:"center",gap:8}}>
                            <span style={{fontSize:20}}>{t.icon}</span>
                            <span style={{fontWeight:700,fontSize:12,color:sel?t.color:p.text}}>{t.label}</span>
                          </div>
                          <div style={{fontSize:10,color:p.textMute}}>{t.desc}</div>
                          <div style={{fontSize:10,color:p.textMute}}>Default: {t.cpu_cores}vCPU · {t.memory_gi}GiB · {t.boot}</div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}

              {/* -- STEP 2 — Resources -- */}
              {vmReqStep===2&&(
                <div>
                  <div style={{fontSize:13,fontWeight:700,color:p.textMute,marginBottom:14,textTransform:"uppercase",letterSpacing:1}}>CPU, Memory & Storage</div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:12,marginBottom:14}}>
                    <div>
                      <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>CPU Sockets</label>
                      <select value={vmReqForm.cpu_sockets} onChange={e=>setVmReqForm(f=>({...f,cpu_sockets:+e.target.value}))}
                        style={{width:"100%",background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"6px 10px",color:p.text,fontSize:12}}>
                        {[1,2,4].map(v=><option key={v} value={v}>{v}</option>)}
                      </select>
                    </div>
                    <div>
                      <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>Cores per Socket</label>
                      <select value={vmReqForm.cpu_cores} onChange={e=>setVmReqForm(f=>({...f,cpu_cores:+e.target.value}))}
                        style={{width:"100%",background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"6px 10px",color:p.text,fontSize:12}}>
                        {[1,2,4,6,8,12,16].map(v=><option key={v} value={v}>{v}</option>)}
                      </select>
                    </div>
                    <div>
                      <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>CPU Threads</label>
                      <select value={vmReqForm.cpu_threads} onChange={e=>setVmReqForm(f=>({...f,cpu_threads:+e.target.value}))}
                        style={{width:"100%",background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"6px 10px",color:p.text,fontSize:12}}>
                        {[1,2].map(v=><option key={v} value={v}>{v}</option>)}
                      </select>
                    </div>
                  </div>
                  <div style={{padding:"10px 14px",borderRadius:8,background:`${p.purple}10`,border:`1px solid ${p.purple}25`,marginBottom:14,fontSize:12,color:p.textMute}}>
                    Total vCPU: <strong style={{color:p.text}}>{vmReqForm.cpu_sockets * vmReqForm.cpu_cores * vmReqForm.cpu_threads}</strong>
                  </div>
                  <div style={{marginBottom:14}}>
                    <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:8}}>Memory (GiB)</label>
                    <div style={{display:"flex",flexWrap:"wrap",gap:8}}>
                      {OCP_MEM_OPTIONS.map(v=>(
                        <button key={v} onClick={()=>setVmReqForm(f=>({...f,memory_gi:v}))}
                          style={{padding:"6px 16px",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:12,
                            border:`2px solid ${vmReqForm.memory_gi===v?"#8b5cf6":p.border}`,
                            background:vmReqForm.memory_gi===v?"#8b5cf620":p.surface,
                            color:vmReqForm.memory_gi===v?"#a78bfa":p.textMute}}>
                          {v} GiB
                        </button>
                      ))}
                    </div>
                  </div>
                  {/* Boot disk */}
                  <div style={{background:p.surface,border:`1px solid ${p.border}`,borderRadius:10,padding:"12px 14px",marginBottom:10}}>
                    <div style={{fontWeight:700,fontSize:12,color:p.cyan,marginBottom:10}}>?? Boot Disk</div>
                    <div style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:10}}>
                      <div>
                        <label style={{fontSize:11,color:p.textMute,display:"block",marginBottom:3}}>Size</label>
                        <select value={vmReqForm.boot_disk_size} onChange={e=>setVmReqForm(f=>({...f,boot_disk_size:e.target.value}))}
                          style={{width:"100%",background:p.panel,border:`1px solid ${p.border}`,borderRadius:6,padding:"5px 8px",color:p.text,fontSize:11}}>
                          {OCP_DISK_SIZES.map(s=><option key={s} value={s}>{s}</option>)}
                        </select>
                      </div>
                      <div>
                        <label style={{fontSize:11,color:p.textMute,display:"block",marginBottom:3}}>Storage Class {vmReqNsLoading&&"?"}</label>
                        <select value={vmReqForm.boot_disk_sc} onChange={e=>setVmReqForm(f=>({...f,boot_disk_sc:e.target.value}))}
                          style={{width:"100%",background:p.panel,border:`1px solid ${p.border}`,borderRadius:6,padding:"5px 8px",color:p.text,fontSize:11}}>
                          {vmReqScs.length>0?vmReqScs.map(sc=><option key={sc.name} value={sc.name}>{sc.name}{sc.is_default?" (default)":""}</option>):<option value="">cluster default</option>}
                        </select>
                      </div>
                      <div>
                        <label style={{fontSize:11,color:p.textMute,display:"block",marginBottom:3}}>Interface</label>
                        <select value={vmReqForm.boot_disk_interface} onChange={e=>setVmReqForm(f=>({...f,boot_disk_interface:e.target.value}))}
                          style={{width:"100%",background:p.panel,border:`1px solid ${p.border}`,borderRadius:6,padding:"5px 8px",color:p.text,fontSize:11}}>
                          {["virtio","sata","scsi"].map(v=><option key={v} value={v}>{v}</option>)}
                        </select>
                      </div>
                    </div>
                  </div>
                  {/* Additional disks */}
                  <div style={{background:p.surface,border:`1px solid ${p.border}`,borderRadius:10,padding:"12px 14px"}}>
                    <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:8}}>
                      <div style={{fontWeight:700,fontSize:12,color:"#f59e0b"}}>? Additional Disks (optional)</div>
                      <button onClick={()=>setVmReqForm(f=>({...f,additional_disks:[...f.additional_disks,{size:"20Gi",sc:vmReqScs[0]?.name||"",interface:"virtio"}]}))}
                        style={{fontSize:11,padding:"3px 10px",borderRadius:6,cursor:"pointer",background:`${p.green}10`,border:`1px solid ${p.green}40`,color:p.green}}>
                        + Add Disk
                      </button>
                    </div>
                    {vmReqForm.additional_disks.length===0&&<div style={{fontSize:11,color:p.textMute}}>No additional disks</div>}
                    {vmReqForm.additional_disks.map((d,i)=>(
                      <div key={i} style={{display:"grid",gridTemplateColumns:"1fr 1fr 1fr auto",gap:8,marginBottom:6,alignItems:"center"}}>
                        <select value={d.size} onChange={e=>{const a=[...vmReqForm.additional_disks];a[i]={...a[i],size:e.target.value};setVmReqForm(f=>({...f,additional_disks:a}));}}
                          style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:5,padding:"4px 6px",color:p.text,fontSize:11}}>
                          {OCP_DISK_SIZES.map(s=><option key={s} value={s}>{s}</option>)}
                        </select>
                        <select value={d.sc} onChange={e=>{const a=[...vmReqForm.additional_disks];a[i]={...a[i],sc:e.target.value};setVmReqForm(f=>({...f,additional_disks:a}));}}
                          style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:5,padding:"4px 6px",color:p.text,fontSize:11}}>
                          {vmReqScs.length>0?vmReqScs.map(sc=><option key={sc.name} value={sc.name}>{sc.name}</option>):<option value="">default</option>}
                        </select>
                        <select value={d.interface} onChange={e=>{const a=[...vmReqForm.additional_disks];a[i]={...a[i],interface:e.target.value};setVmReqForm(f=>({...f,additional_disks:a}));}}
                          style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:5,padding:"4px 6px",color:p.text,fontSize:11}}>
                          {["virtio","sata","scsi"].map(v=><option key={v} value={v}>{v}</option>)}
                        </select>
                        <button onClick={()=>setVmReqForm(f=>({...f,additional_disks:f.additional_disks.filter((_,j)=>j!==i)}))}
                          style={{background:`${p.red}12`,border:`1px solid ${p.red}30`,borderRadius:5,padding:"4px 8px",cursor:"pointer",color:p.red,fontSize:11}}>?</button>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* -- STEP 3 — Networking -- */}
              {vmReqStep===3&&(
                <div>
                  <div style={{fontSize:13,fontWeight:700,color:p.textMute,marginBottom:14,textTransform:"uppercase",letterSpacing:1}}>Network Configuration</div>
                  <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:14}}>
                    <div>
                      <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>Network Type</label>
                      <select value={vmReqForm.network_type} onChange={e=>setVmReqForm(f=>({...f,network_type:e.target.value}))}
                        style={{width:"100%",background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"7px 10px",color:p.text,fontSize:12}}>
                        <option value="masquerade">Masquerade (NAT — default)</option>
                        <option value="bridge">Bridge</option>
                        <option value="slirp">Slirp</option>
                        <option value="sriov">SR-IOV</option>
                      </select>
                      <div style={{fontSize:10,color:p.textMute,marginTop:3}}>
                        {vmReqForm.network_type==="masquerade"?"Recommended: VM uses cluster NAT with pod IP":vmReqForm.network_type==="bridge"?"VM gets direct L2 bridge access to network attachment":"Network passthrough for high-performance workloads"}
                      </div>
                    </div>
                    <div>
                      <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>NIC Interface</label>
                      <select value={vmReqForm.network_interface} onChange={e=>setVmReqForm(f=>({...f,network_interface:e.target.value}))}
                        style={{width:"100%",background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"7px 10px",color:p.text,fontSize:12}}>
                        <option value="virtio">virtio (recommended)</option>
                        <option value="e1000e">e1000e</option>
                        <option value="rtl8139">rtl8139</option>
                      </select>
                    </div>
                    <div style={{gridColumn:"1/-1"}}>
                      <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>Network Attachment / Name</label>
                      <input value={vmReqForm.network_name} onChange={e=>setVmReqForm(f=>({...f,network_name:e.target.value}))}
                        placeholder="Pod Networking" style={{width:"100%",boxSizing:"border-box",fontSize:12}}/>
                      <div style={{fontSize:10,color:p.textMute,marginTop:3}}>Leave as "Pod Networking" for default pod network, or specify a NetworkAttachmentDefinition name</div>
                    </div>
                  </div>
                  <div style={{marginTop:14,padding:"10px 14px",borderRadius:8,background:`${p.cyan}10`,border:`1px solid ${p.cyan}25`,fontSize:11,color:p.textMute}}>
                    <strong style={{color:p.cyan}}>?? OpenShift Virt Network:</strong> Masquerade is recommended for most workloads. Use Bridge or SR-IOV for VMs requiring direct network access or high throughput.
                  </div>
                  <div style={{marginTop:14}}>
                    <label style={{display:"flex",alignItems:"center",gap:8,cursor:"pointer",fontSize:13,color:p.text}}>
                      <input type="checkbox" checked={vmReqForm.start_on_create} onChange={e=>setVmReqForm(f=>({...f,start_on_create:e.target.checked}))}/>
                      <span>Start VM immediately after provisioning</span>
                    </label>
                  </div>
                </div>
              )}

              {/* -- STEP 4 — Cloud-Init -- */}
              {vmReqStep===4&&(
                <div>
                  <div style={{fontSize:13,fontWeight:700,color:p.textMute,marginBottom:14,textTransform:"uppercase",letterSpacing:1}}>Cloud-Init &amp; Access</div>
                  <label style={{display:"flex",alignItems:"center",gap:8,cursor:"pointer",fontSize:13,color:p.text,marginBottom:14}}>
                    <input type="checkbox" checked={vmReqForm.cloud_init_enabled} onChange={e=>setVmReqForm(f=>({...f,cloud_init_enabled:e.target.checked}))}/>
                    <span>Enable cloud-init (recommended for Linux VMs)</span>
                  </label>
                  {vmReqForm.cloud_init_enabled&&(
                    <div style={{display:"flex",flexDirection:"column",gap:12}}>
                      <div>
                        <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>SSH Public Key (optional)</label>
                        <textarea value={vmReqForm.ssh_public_key} onChange={e=>setVmReqForm(f=>({...f,ssh_public_key:e.target.value}))}
                          placeholder="ssh-rsa AAAA... user@host"
                          rows={3} style={{width:"100%",boxSizing:"border-box",fontFamily:"monospace",fontSize:11,resize:"vertical",background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"8px 10px",color:p.text}}/>
                        <div style={{fontSize:10,color:p.textMute,marginTop:2}}>Injected into authorized_keys for default cloud user (ec2-user / cloud-user / ubuntu)</div>
                      </div>
                      <div>
                        <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>Root Password (optional)</label>
                        <input type="password" value={vmReqForm.root_password} onChange={e=>setVmReqForm(f=>({...f,root_password:e.target.value}))}
                          placeholder="Leave blank to disable password login"
                          style={{width:"100%",boxSizing:"border-box",fontSize:12}}/>
                      </div>
                      <div style={{padding:"10px 14px",borderRadius:8,background:`${p.yellow}10`,border:`1px solid ${p.yellow}30`,fontSize:11,color:p.textMute}}>
                        ?? <strong style={{color:p.yellow}}>Security Note:</strong> SSH key auth is strongly recommended over password auth. Passwords are stored securely and only used for initial provisioning.
                      </div>
                    </div>
                  )}
                  <div style={{marginTop:14}}>
                    <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>Additional Notes / Justification</label>
                    <textarea value={vmReqForm.notes} onChange={e=>setVmReqForm(f=>({...f,notes:e.target.value}))}
                      placeholder="Describe the purpose of this VM, any special requirements, project/team…"
                      rows={4} style={{width:"100%",boxSizing:"border-box",fontSize:12,resize:"vertical",background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"8px 10px",color:p.text}}/>
                  </div>
                </div>
              )}

              {/* -- STEP 5 — Review & Submit -- */}
              {vmReqStep===5&&(()=>{
                const tpl=OCP_OS_TEMPLATES.find(t=>t.id===vmReqForm.os_template)||OCP_OS_TEMPLATES[0];
                const cl=clusters.find(c=>c.id===vmReqForm.cluster_id);
                const totalCpu=vmReqForm.cpu_sockets*vmReqForm.cpu_cores*vmReqForm.cpu_threads;
                function Row({label,value,accent}){
                  return(<div style={{display:"flex",padding:"6px 0",borderBottom:`1px solid ${p.border}20`}}>
                    <div style={{width:180,fontSize:12,color:p.textMute,flexShrink:0}}>{label}</div>
                    <div style={{fontSize:12,fontWeight:600,color:accent||p.text,wordBreak:"break-all"}}>{value||"—"}</div>
                  </div>);
                }
                return(
                  <div>
                    <div style={{fontSize:13,fontWeight:700,color:p.textMute,marginBottom:14,textTransform:"uppercase",letterSpacing:1}}>Review Your Request</div>
                    <div style={{background:p.surface,border:`1px solid ${p.border}`,borderRadius:12,padding:"14px 18px",marginBottom:14}}>
                      <div style={{fontWeight:700,fontSize:12,color:"#a78bfa",marginBottom:10}}>?? Identity</div>
                      <Row label="Cluster" value={cl?.name} accent="#a78bfa"/>
                      <Row label="Namespace" value={vmReqForm.namespace} accent={p.cyan}/>
                      <Row label="VM Name" value={vmReqForm.vm_name} accent={p.accent}/>
                      {vmReqForm.description&&<Row label="Description" value={vmReqForm.description}/>}
                    </div>
                    <div style={{background:p.surface,border:`1px solid ${p.border}`,borderRadius:12,padding:"14px 18px",marginBottom:14}}>
                      <div style={{fontWeight:700,fontSize:12,color:tpl.color,marginBottom:10}}>{tpl.icon} OS &amp; Resources</div>
                      <Row label="OS Template" value={tpl.label} accent={tpl.color}/>
                      <Row label="Total vCPU" value={`${totalCpu} (${vmReqForm.cpu_sockets}S × ${vmReqForm.cpu_cores}C × ${vmReqForm.cpu_threads}T)`}/>
                      <Row label="Memory" value={`${vmReqForm.memory_gi} GiB`}/>
                      <Row label="Boot Disk" value={`${vmReqForm.boot_disk_size} · ${vmReqForm.boot_disk_interface}${vmReqForm.boot_disk_sc?" · "+vmReqForm.boot_disk_sc:""}`}/>
                      {vmReqForm.additional_disks.length>0&&<Row label="Extra Disks" value={vmReqForm.additional_disks.map(d=>`${d.size}`).join(" + ")}/>}
                    </div>
                    <div style={{background:p.surface,border:`1px solid ${p.border}`,borderRadius:12,padding:"14px 18px",marginBottom:14}}>
                      <div style={{fontWeight:700,fontSize:12,color:"#ec4899",marginBottom:10}}>?? Networking</div>
                      <Row label="Network Type" value={vmReqForm.network_type}/>
                      <Row label="NIC Interface" value={vmReqForm.network_interface}/>
                      <Row label="Network" value={vmReqForm.network_name}/>
                      <Row label="Start on Create" value={vmReqForm.start_on_create?"Yes":"No"} accent={vmReqForm.start_on_create?p.green:p.textMute}/>
                    </div>
                    {vmReqForm.cloud_init_enabled&&(
                      <div style={{background:p.surface,border:`1px solid ${p.border}`,borderRadius:12,padding:"14px 18px",marginBottom:14}}>
                        <div style={{fontWeight:700,fontSize:12,color:p.green,marginBottom:10}}>?? Cloud-Init</div>
                        <Row label="Cloud-Init" value="Enabled" accent={p.green}/>
                        <Row label="SSH Key" value={vmReqForm.ssh_public_key?`? Provided (${vmReqForm.ssh_public_key.slice(0,40)}…)`:"Not provided"}/>
                        <Row label="Root Password" value={vmReqForm.root_password?"? Set (hidden)":"Not set"}/>
                      </div>
                    )}
                    {vmReqForm.notes&&(
                      <div style={{background:`${p.yellow}10`,border:`1px solid ${p.yellow}30`,borderRadius:10,padding:"10px 14px",marginBottom:14}}>
                        <div style={{fontSize:11,fontWeight:700,color:p.yellow,marginBottom:4}}>?? Notes / Justification</div>
                        <div style={{fontSize:12,color:p.text}}>{vmReqForm.notes}</div>
                      </div>
                    )}
                    <div style={{padding:"10px 14px",borderRadius:8,background:`${p.green}10`,border:`1px solid ${p.green}25`,fontSize:12,color:p.textMute}}>
                      ? Your request will be reviewed by an admin/operator before the VM is provisioned.
                    </div>
                  </div>
                );
              })()}
            </div>

            {/* Wizard footer */}
            <div style={{padding:"12px 28px 20px",borderTop:`1px solid ${p.border}`,display:"flex",gap:10,justifyContent:"space-between",alignItems:"center",flexShrink:0}}>
              <button className="btn btn-sm" onClick={()=>vmReqStep===0?(setShowVMReq(false),setVmReqStep(0)):setVmReqStep(s=>s-1)} disabled={vmReqBusy}
                style={{fontWeight:600,minWidth:80}}>
                {vmReqStep===0?"Cancel":"? Back"}
              </button>
              <div style={{fontSize:11,color:p.textMute}}>Step {vmReqStep+1}{" / "}6</div>
              {vmReqStep<5?(
                <button className="btn btn-primary btn-sm" onClick={()=>{
                    if(vmReqStep===0&&!vmReqForm.cluster_id){setVmReqErr("Please select a cluster first");return;}
                    if(vmReqStep===0&&!vmReqForm.vm_name.trim()){setVmReqErr("VM name is required");return;}
                    setVmReqErr(null); setVmReqStep(s=>s+1);
                  }} style={{fontWeight:700,minWidth:80}}>
                  Next ?
                </button>
              ):(
                <button className="btn btn-primary btn-sm" onClick={submitVMRequest} disabled={vmReqBusy}
                  style={{background:"linear-gradient(135deg,#6366f1,#8b5cf6)",border:"none",fontWeight:700,minWidth:120}}>
                  {vmReqBusy?"? Submitting…":"?? Submit Request"}
                </button>
              )}
            </div>
          </div>
        </div>
      )}

      {/* -- VM Requests Queue (Admin/Operator) -- */}
      {showVMRequests&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:3000,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}
          onClick={e=>e.target===e.currentTarget&&setShowVMRequests(false)}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:18,width:"100%",maxWidth:900,maxHeight:"88vh",overflowY:"auto",boxShadow:"0 24px 80px #00000090",display:"flex",flexDirection:"column"}}>
            <div style={{padding:"20px 24px",borderBottom:`1px solid ${p.border}`,display:"flex",alignItems:"center",gap:12,flexShrink:0}}>
              <span style={{fontSize:22}}>??</span>
              <div>
                <div style={{fontWeight:800,fontSize:16,color:p.text}}>OpenShift VM Requests</div>
                <div style={{fontSize:12,color:p.textMute}}>{vmRequests.length} total · {vmRequests.filter(r=>r.status==="pending").length} pending approval</div>
              </div>
              <div style={{marginLeft:"auto",display:"flex",gap:8}}>
                <button className="btn btn-sm" onClick={loadVMRequests} disabled={vmReqsLoading}>{vmReqsLoading?"?":"?"} Refresh</button>
                <button onClick={()=>setShowVMRequests(false)} style={{background:"transparent",border:"none",color:p.textMute,fontSize:20,cursor:"pointer"}}>?</button>
              </div>
            </div>
            <div style={{padding:"16px 24px",flex:1,overflowY:"auto"}}>
              {vmRequests.length===0&&!vmReqsLoading&&(
                <div style={{textAlign:"center",padding:40,color:p.textMute,fontSize:13}}>No VM requests yet.</div>
              )}
              {vmRequests.map(req=>{
                const sc=req.status==="pending"?p.yellow:req.status==="approved"?p.green:req.status==="declined"?p.red:"#64748b";
                const tpl=OCP_OS_TEMPLATES.find(t=>t.id===req.os_template)||{icon:"???",label:req.os_template};
                return(
                  <div key={req.id} style={{background:p.surface,border:`1px solid ${sc}25`,borderRadius:12,padding:"14px 18px",marginBottom:10,borderLeft:`3px solid ${sc}`}}>
                    <div style={{display:"flex",alignItems:"center",gap:10,flexWrap:"wrap",marginBottom:8}}>
                      <span style={{fontSize:16}}>{tpl.icon}</span>
                      <div style={{flex:1,minWidth:0}}>
                        <div style={{fontWeight:700,fontSize:14,color:p.accent}}>{req.vm_name}</div>
                        <div style={{fontSize:11,color:p.textMute}}>{req.req_number} · {req.cluster_name}{" / "}{req.namespace} · by <strong style={{color:p.text}}>{req.requester}</strong></div>
                      </div>
                      <span style={{fontSize:11,fontWeight:700,padding:"3px 10px",borderRadius:6,background:`${sc}15`,color:sc,textTransform:"capitalize"}}>{req.status}</span>
                      <div style={{fontSize:10,color:p.textMute,whiteSpace:"nowrap"}}>{req.created_at?.slice(0,16)}</div>
                    </div>
                    <div style={{display:"flex",flexWrap:"wrap",gap:16,marginBottom:req.notes?8:0}}>
                      <div style={{fontSize:11,color:p.textMute}}>OS: <span style={{color:p.text,fontWeight:600}}>{tpl.label||req.os_template}</span></div>
                      <div style={{fontSize:11,color:p.textMute}}>vCPU: <span style={{color:p.text,fontWeight:600}}>{req.cpu_sockets*req.cpu_cores*req.cpu_threads}</span></div>
                      <div style={{fontSize:11,color:p.textMute}}>RAM: <span style={{color:p.text,fontWeight:600}}>{req.memory_gi} GiB</span></div>
                      <div style={{fontSize:11,color:p.textMute}}>Boot: <span style={{color:p.text,fontWeight:600}}>{req.boot_disk_size}</span></div>
                      <div style={{fontSize:11,color:p.textMute}}>Network: <span style={{color:p.text,fontWeight:600}}>{req.network_type}</span></div>
                      <div style={{fontSize:11,color:p.textMute}}>Start: <span style={{color:req.start_on_create?p.green:p.textMute,fontWeight:600}}>{req.start_on_create?"Yes":"No"}</span></div>
                    </div>
                    {req.notes&&<div style={{fontSize:11,color:p.textMute,fontStyle:"italic",marginBottom:6}}>"{req.notes}"</div>}
                    {req.review_notes&&<div style={{fontSize:11,color:p.textMute,marginBottom:4}}>Admin note: <span style={{color:p.text}}>{req.review_notes}</span></div>}
                    {req.reviewed_by&&<div style={{fontSize:10,color:p.textMute}}>Reviewed by {req.reviewed_by} at {req.reviewed_at?.slice(0,16)}</div>}
                    {(isAdmin||role==="operator")&&req.status==="pending"&&(
                      <div style={{marginTop:10,display:"flex",gap:8}}>
                        <button className="btn btn-sm" onClick={()=>{setVmReqReviewTarget(req);setVmReqReviewForm({decision:"approved",review_notes:""});}}
                          style={{background:`${p.green}15`,border:`1px solid ${p.green}40`,color:p.green,fontWeight:700,fontSize:12}}>
                          ? Approve
                        </button>
                        <button className="btn btn-sm" onClick={()=>{setVmReqReviewTarget(req);setVmReqReviewForm({decision:"declined",review_notes:""});}}
                          style={{background:`${p.red}15`,border:`1px solid ${p.red}40`,color:p.red,fontWeight:700,fontSize:12}}>
                          ? Decline
                        </button>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* -- Review Confirm -- */}
      {vmReqReviewTarget&&(
        <div style={{position:"fixed",inset:0,background:"#00000095",zIndex:4000,display:"flex",alignItems:"center",justifyContent:"center",padding:16}}>
          <div style={{background:p.panel,border:`1px solid ${p.border}`,borderRadius:16,padding:28,width:"100%",maxWidth:480,boxShadow:"0 20px 60px #00000090"}}>
            <div style={{fontWeight:800,fontSize:16,marginBottom:6}}>
              {vmReqReviewForm.decision==="approved"?"? Approve Request":"? Decline Request"}
            </div>
            <div style={{fontSize:13,color:p.textMute,marginBottom:16}}>
              {vmReqReviewTarget.req_number} — <strong style={{color:p.text}}>{vmReqReviewTarget.vm_name}</strong> ({vmReqReviewTarget.cluster_name}{"/"}{vmReqReviewTarget.namespace})
            </div>
            <div style={{display:"flex",gap:10,marginBottom:14}}>
              {["approved","declined"].map(d=>(
                <button key={d} onClick={()=>setVmReqReviewForm(f=>({...f,decision:d}))}
                  style={{flex:1,padding:"8px",borderRadius:8,cursor:"pointer",fontWeight:700,fontSize:13,
                    border:`2px solid ${d==="approved"?p.green:p.red}`,
                    background:vmReqReviewForm.decision===d?d==="approved"?`${p.green}20`:`${p.red}20`:"transparent",
                    color:d==="approved"?p.green:p.red}}>
                  {d==="approved"?"? Approve":"? Decline"}
                </button>
              ))}
            </div>
            <div style={{marginBottom:16}}>
              <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>Admin Notes (optional)</label>
              <textarea value={vmReqReviewForm.review_notes} onChange={e=>setVmReqReviewForm(f=>({...f,review_notes:e.target.value}))}
                placeholder="Reason for approval/decline, any instructions…"
                rows={3} style={{width:"100%",boxSizing:"border-box",fontSize:12,resize:"vertical",background:p.surface,border:`1px solid ${p.border}`,borderRadius:6,padding:"8px 10px",color:p.text}}/>
            </div>
            <div style={{display:"flex",gap:8,justifyContent:"flex-end"}}>
              <button className="btn btn-sm" onClick={()=>setVmReqReviewTarget(null)} disabled={vmReqReviewBusy}>Cancel</button>
              <button className="btn btn-primary btn-sm" onClick={doReviewVMReq} disabled={vmReqReviewBusy}
                style={{background:vmReqReviewForm.decision==="approved"?"linear-gradient(135deg,#22c55e,#16a34a)":"linear-gradient(135deg,#ef4444,#dc2626)",border:"none",fontWeight:700}}>
                {vmReqReviewBusy?"? Saving…":`Confirm ${vmReqReviewForm.decision==="approved"?"Approval":"Decline"}`}
              </button>
            </div>
          </div>
        </div>
      )}

      {/* -- Add Cluster Modal -- */}
      {showAdd&&(
        <div style={{position:"fixed",inset:0,background:"#00000090",zIndex:2000,display:"flex",alignItems:"center",justifyContent:"center"}}
          onClick={e=>e.target===e.currentTarget&&setShowAdd(false)}>
            <div style={{fontWeight:700,fontSize:16,marginBottom:20,display:"flex",alignItems:"center",gap:10}}>
              <span style={{fontSize:22}}>??</span> Add OpenShift Cluster
            </div>
            {addErr&&<div style={{marginBottom:12,padding:"8px 12px",borderRadius:7,background:`${p.red}15`,border:`1px solid ${p.red}30`,color:p.red,fontSize:13}}>{addErr}</div>}
            {[
              {k:"name",label:"Cluster Name",ph:"e.g. OCP-4.18-Production"},
              {k:"api_url",label:"API Server URL",ph:"https://api.ocp.example.com:6443"},
              {k:"username",label:"Username",ph:"kubeadmin"},
              {k:"password",label:"Password",ph:"????????????",type:"password"},
              {k:"console_url",label:"Console URL (optional)",ph:"https://console-openshift-console.apps…"},
              {k:"ai_url",label:"Red Hat OpenShift AI URL (optional)",ph:"https://rhods-dashboard-redhat-ods-applications.apps…"},
              {k:"description",label:"Description (optional)",ph:""},
            ].map(f=>(
              <div key={f.k} style={{marginBottom:12}}>
                <label style={{fontSize:12,color:p.textMute,display:"block",marginBottom:4}}>{f.label}</label>
                <input type={f.type||"text"} placeholder={f.ph} value={addForm[f.k]}
                  onChange={e=>setAddForm(prev=>({...prev,[f.k]:e.target.value}))}
                  style={{width:"100%",boxSizing:"border-box"}}/>
              </div>
            ))}
            <div style={{display:"flex",gap:8,justifyContent:"flex-end",marginTop:20}}>
              <button className="btn btn-sm" onClick={()=>setShowAdd(false)}>Cancel</button>
              <button className="btn btn-primary btn-sm" onClick={doAddCluster} disabled={addBusy}>
                {addBusy?"? Adding…":"Add Cluster"}
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
